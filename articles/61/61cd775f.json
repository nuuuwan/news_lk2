    "ta": {
      "title": "\u0b90\u0bb8\u0bcd \u0b89\u0b9f\u0ba9\u0bcd 03 \u0baa\u0bbf\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb1\u0ba4\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0baa\u0bbf\u0bb0\u0ba4\u0bc7\u0b9a \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (17) \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb2\u0bc8 \u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0bb5\u0bc0\u0bb0\u0bbf\u0baf\u0baa\u0bc1\u0bb0 \u0baa\u0bbf\u0bb0\u0ba4\u0bc7\u0b9a\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0bc7\u0bb1\u0bcd\u0b95\u0bca\u0ba3\u0bcd\u0b9f \u0ba8\u0b9f\u0bb5\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd 13 \u0b95\u0bbf\u0bb0\u0bbe\u0bae\u0bcd 750 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0b95\u0bbf\u0bb0\u0bbe\u0bae\u0bcd \u0b90\u0bb8\u0bcd \u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bc1\u0b9f\u0ba9\u0bcd \u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1 \u0b9a\u0ba8\u0bcd\u0ba4\u0bc7\u0b95 \u0ba8\u0baa\u0bb0\u0bcd\u0b95\u0bb3\u0bc8 \u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0b9a\u0bbf\u0bb0\u0bc7\u0bb7\u0bcd\u0b9f \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9f\u0bcd\u0b9a\u0b95\u0bb0\u0bcd \u0ba4\u0bbf\u0bb0\u0bc1.\u0b9a\u0bc1\u0b9c\u0bbf\u0ba4\u0bcd \u0bb5\u0bc6\u0ba4\u0bae\u0bc1\u0bb2\u0bcd\u0bb2 \u0b95\u0bc8\u0ba4\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd. .",
        "\u0b9a\u0ba8\u0bcd\u0ba4\u0bc7\u0b95\u0ba8\u0baa\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0baf\u0bbf\u0bb0\u0ba4\u0bcd\u0ba4\u0bc1 \u0b90\u0ba8\u0bc2\u0bb1\u0bc1 \u0bb0\u0bc2\u0baa\u0bbe \u0baa\u0ba3\u0bae\u0bcd, \u0b9f\u0bbf\u0b9c\u0bbf\u0b9f\u0bcd\u0b9f\u0bb2\u0bcd \u0ba4\u0bb0\u0bbe\u0b9a\u0bc1, \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0b95\u0bc8\u0ba4\u0bcd\u0ba4\u0bca\u0bb2\u0bc8\u0baa\u0bc7\u0b9a\u0bbf\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b95\u0b9e\u0bcd\u0b9a\u0bbe \u0b8e\u0ba9\u0bcd\u0baa\u0ba9 \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b95\u0bc8\u0baa\u0bcd\u0baa\u0bb1\u0bcd\u0bb1\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9.",
        "\u0b95\u0bc8\u0ba4\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b9a\u0ba8\u0bcd\u0ba4\u0bc7\u0b95\u0ba8\u0baa\u0bb0\u0bcd\u0b95\u0bb3\u0bcd 25, 26 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd 35 \u0bb5\u0baf\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b8e\u0ba9\u0bb5\u0bc1\u0bae\u0bcd, \u0bb9\u0bb2\u0bbf\u0baf\u0bbe\u0bb2, \u0b95\u0bc8\u0bb2\u0bbe\u0b95\u0bca\u0b9f \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0bc0\u0bb0\u0bbf\u0baf\u0baa\u0bc1\u0bb0 \u0baa\u0bbf\u0b9f\u0bbe\u0b9e\u0bcd\u0b9a\u0bbf\u0b95\u0bb3\u0bc8 \u0b9a\u0bc7\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b8e\u0ba9\u0bb5\u0bc1\u0bae\u0bcd \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bbe\u0bb0\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0b9a\u0bbf\u0bb0\u0bc7\u0bb7\u0bcd\u0b9f \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0b85\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9f\u0bcd\u0b9a\u0b95\u0bb0\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0bc1\u0b9c\u0bbf\u0ba4\u0bcd \u0bb5\u0bc7\u0ba4\u0bae\u0bc1\u0bb2\u0bcd\u0bb2",
            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "CARDINAL"
          },
          {
            "text": "13 \u0b95\u0bbf\u0bb0\u0bbe\u0bae\u0bcd",
            "label": "QUANTITY"
          },
          {
            "text": "750",
            "label": "CARDINAL"
          },
          {
            "text": "\u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0baa\u0bbf\u0bb0\u0ba4\u0bc7\u0b9a \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1",
            "label": "FAC"
          },
          {
            "text": "\u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0bb5\u0bc0\u0bb0\u0bbf\u0baf\u0baa\u0bc1\u0bb0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0bae\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0baf\u0bbf\u0bb0\u0ba4\u0bcd\u0ba4\u0bc1 \u0b90\u0ba8\u0bc2\u0bb1\u0bc1",
            "label": "CARDINAL"
          },
