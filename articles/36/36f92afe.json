  "original_title": "\u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db8\u0dc4\u0da2\u0db1 \u0dc3\u0dda\u0dc0\u0dcf \u0db4\u0db1\u0dad \u0dbd\u0db6\u0db1 \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0db8\u0dd0\u0dad\u0dd2\u0dc3\u0db6\u0dba\u0dda \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba\u0da7",
