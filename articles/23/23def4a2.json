    "si": {
      "title": "\u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0d9a\u0ddd\u0da7\u0dd2 100\u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0dc3\u0ddc\u0dbb\u0dcf\u0d9c\u0dad\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1 \u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0ddc\u0dbb\u0da7\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0ddc\u0dbb\u0dcf\u0d9c\u0dad\u0dca \u0da2\u0d82\u0d9c\u0db8 \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 08\u0d9a\u0dca, \u0dbd\u0dd0\u0db4\u0dca\u0da7\u0ddc\u0db4\u0dca \u0db4\u0dbb\u0dd2\u0d9c\u0dab\u0d9a\u0dba\u0d9a\u0dca \u0dc3\u0dc4 \u0dad\u0dc0\u0dad\u0dca \u0dc0\u0da7\u0dd2\u0db1\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0dbb\u0dd0\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d8a\u0dba\u0dda (18) \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0d9a\u0ddd\u0da7\u0dd2 100\u0d9a \u0db4\u0db8\u0dab \u0dc0\u0da7\u0dd2\u0db1\u0dcf \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7\u0dba\u0dd2 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda. \u0db8\u0ddc\u0dbb\u0da7\u0dd4\u0dc0 \u0dc3\u0dc4 \u0d92 \u0d85\u0dc0\u0da7 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc4\u0dcf \u0d9a\u0da9 \u0dc3\u0dcf\u0db4\u0dca\u0db4\u0dd4\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1\u0dba\u0d9a\u0dca.",
        "\u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db8\u0ddc\u0dbb\u0da7\u0dd4\u0dc0, \u0db8\u0dd4\u0dbb\u0dc0\u0dad\u0dca\u0dad, \u0db4\u0dcf\u0db1\u0daf\u0dd4\u0dbb \u0dc3\u0dc4 \u0d9a\u0dd9\u0dc3\u0dd9\u0dbd\u0dca\u0dc0\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 21 \u0dc3\u0dc4 26 \u0dba\u0db1 \u0dc0\u0dba\u0dc3\u0dca\u0dc0\u0dbd \u0db4\u0dc3\u0dd4\u0dc0\u0db1\u0dca\u0db1\u0db1\u0dca \u0db6\u0dc0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda."
      ],
