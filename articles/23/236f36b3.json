  "text_idx": {
    "en": {
      "title": "35,000 metric tons of gasoline will arrive today",
      "author": "unknown",
      "body_lines": [
        "A senior officer of the Ceylon Petroleum Corporation told 'Lankadeepa' that a ship carrying a cargo of 35,000 metric tons of petrol is scheduled to arrive in Colombo tonight (18).",
        "The officer further said that the unloading of the vehicles will start as soon as the inspection of the petrol stock is received and after that the distribution will start as soon as possible."
      ],
