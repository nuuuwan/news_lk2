    "si": {
      "title": "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0ddc\u0db1\u0dca 35,000\u0d9a\u0dca \u0d85\u0daf \u0d91\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0ddc\u0db1\u0dca 35,000 \u0d9a \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0d9a\u0ddc\u0dc5\u0db9\u0da7 \u0d85\u0daf (18) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc5\u0d9c\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0 \u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dd4 \u2018\u0dbd\u0d82\u0d9a\u0dcf\u0daf\u0dd3\u0db4\u2019\u0dba\u0da7 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d91\u0db8 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dad\u0ddc\u0d9c \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0dc0\u0dcf\u0dc4\u0dcf\u0db8 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u200d\u0dc2\u0dab \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd6 \u0dc0\u0dcf\u0dc4\u0dcf\u0db8 \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d89\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0dc4\u0dd0\u0d9a\u0dd2 \u0d89\u0d9a\u0dca\u0db8\u0dab\u0dd2\u0db1\u0dca \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
