          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "Saad Sherida Al-Kaabi",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dbd\u0dca.\u0db4\u0dd3.\u0da2\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dbd\u0dca\u0d91\u0db1\u0dca\u0da2\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0da7\u0dcf\u0dbb\u0dca \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db6\u0dd2\u0db1\u0dca \u0dc4\u0db8\u0dcf\u0da9\u0dca \u0db6\u0dd2\u0db1\u0dca \u0d9a\u0dcf\u0dc3\u0dd2\u0db8\u0dca \u0d85\u0dbd\u0dca-\u0d85\u0db6\u0dca\u0daf\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0d85\u0dbd\u0dca-\u0dad\u0dcf\u0db1\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0dc3\u0dc4 \u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca",
