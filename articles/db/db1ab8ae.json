          {
            "text": "\u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dc3\u0db1\u0dca\u0dad \u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dc3\u0db1\u0dca\u0dad \u0da2\u0dd3\u0dc0\u0db1\u0dca\u0dad \u0d9c\u0dd4\u0dab\u0dad\u0dd2\u0dbd\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dbd\u0dca\u0dc0\u0dda\u0dc0\u0dcf \u0dc3\u0dd2\u0dbb\u0dd2\u0dad\u0db8\u0dca\u0db8\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dad\u0dca\u200d\u0dbb\u0dc3\u0dca\u0dad\u0dc0\u0dcf\u0daf\u0dba \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0db4\u0db1\u0dad",
