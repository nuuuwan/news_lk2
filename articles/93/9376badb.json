          },
          {
            "text": "\u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca (\u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 \u0dc3\u0dc4 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba",
