          },
          {
            "text": "\u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a",
            "label": "DATE"
          },
          {
            "text": "\u0dc0\u0dc3\u0dbb 2023",
            "label": "DATE"
          },
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 9 \u0dba\u0dd2",
