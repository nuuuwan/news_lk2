  "original_title": "\u2019\u2019\u0db6\u0dbd\u0dbd\u0ddd\u0db7\u0dd3\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0d86\u0dba\u0dd4\u0dc2 \u0db1\u0dd1\u2019\u2019",
  "text_idx": {
    "en": {
      "title": "\"There is no life for greed\"",
      "author": "unknown",
      "body_lines": [
        "Former President Maithripala Sirisena has issued a statement saying that the President and the Prime Minister should bow down to the people's demand and resign from their positions in order to immediately stop the country from turning into an anarchy and turning it into a lake of blood.",
        "The former President mentions that a tragedy that has never happened in the history of Sri Lanka is taking place and that a small group of people who have gone crazy in the face of power are working to completely destroy this country."
      ],
      "title_ents": [],
      "body_line_ents_list": [
