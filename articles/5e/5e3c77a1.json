            "label": "NORP"
          },
          {
            "text": "\u0b9e\u0bbe\u0baf\u0bbf\u0bb1\u0bcd\u0bb1\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0bae\u0bc7\u0bb1\u0bcd\u0b95\u0bc1 \u0b9f\u0bc6\u0bb2\u0bcd\u0bb2\u0bbf",
            "label": "GPE"
          },
          {
            "text": "\u0bae\u0bcc\u0bb2\u0bbe\u0ba9\u0bbe \u0b86\u0b9a\u0bbe\u0ba4\u0bcd \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0b95\u0bcd \u0b95\u0bb2\u0bcd\u0bb2\u0bc2\u0bb0\u0bbf \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0ba9\u0bc8",
            "label": "ORG"
