    "si": {
      "title": "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc2\u0dd9\u0da9\u0dca\u0dc0\u0dbd \u0db1\u0dd2\u0db8\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf\u0da7\u0dad\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0d85\u0dc3\u0dbd \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2 \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0d9c\u0dd0\u0dc3\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dd4 \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dda. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db1\u0dd2\u0db8\u0dbd\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0d91\u0daf\u0dd2\u0dbb\u0dd2\u0dc3\u0dd2\u0d82\u0dc4"
      ],
