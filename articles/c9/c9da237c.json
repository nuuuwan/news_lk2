          {
            "text": "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
