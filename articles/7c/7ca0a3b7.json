          "label": "GPE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0d86\u0dbb\u0ddd\u0d9c\u0dca\u200d\u0dba\u0dcf \u0db1\u0d9c\u0dbb\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db4\u0dc5\u0db8\u0dd4 \u0daf\u0dd2\u0db1, \u0dc3\u0db3\u0dd4\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dd9.\u0dc0. 7",
