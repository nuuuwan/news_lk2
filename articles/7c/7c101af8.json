  "text_idx": {
    "en": {
      "title": "Curfew illegal: Bar Association",
      "author": "unknown",
      "body_lines": [
        "The Sri Lankan Bar Association has stated that the current curfew in the country is illegal.",
        "The association also said that there is no provision in the Police Ordinance to issue a curfew.",
        "The Sri Lankan Bar Association also stated that the curfew has been issued as a violation of the fundamental rights of the people. (a)"
      ],
