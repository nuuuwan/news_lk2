            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bbf\u0bb0\u0bbf\u0baf\u0ba8\u0bcd\u0ba4 \u0b9c\u0baf\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9",
            "label": "PERSON"
          },
          {
            "text": "\u0baf\u0b9a\u0ba8\u0bcd\u0ba4 \u0b95\u0bcb\u0ba4\u0bbe\u0b95\u0bca\u0b9f",
            "label": "PERSON"
