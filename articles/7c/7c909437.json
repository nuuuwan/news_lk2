    "si": {
      "title": "\u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0dd9\u0daf\u0db1 \u0dc4\u0dd0\u0da7\u0dd2 \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d9a\u0dd2\u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d9c\u0dd1\u0dc3\u0dca \u0d9c\u0ddc\u0da9 \u0db6\u0dd1\u0db8 \u0dc3\u0dc4 \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d85\u0daf (10) \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba.",
        "\u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3700\u0d9a\u0dca \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0db4\u0dc5\u0db8\u0dd4 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0d8a\u0dba\u0dda (10) \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dc5\u0d9f\u0dcf\u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3740 \u0d9a\u0dca \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0daf\u0dd9\u0dc0\u0dd9\u0db1\u0dd2 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0d85\u0daf (10)\u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3200\u0d9a\u0dca \u0dad\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0dbd\u0db6\u0db1 15 \u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dcf \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0\u0daf \u0d91\u0db8 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db8\u0dda \u0db8\u0dcf\u0dc3\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d87\u0dab\u0dc0\u0dd4\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba 33,000\u0d9a\u0dd2.",
        "\u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dbd\u0db6\u0db1 12 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dc3\u0dc4 \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dcf\u0db1\u0dd4\u0d9a\u0dd6\u0dbd\u0dc0 \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d9c\u0dd1\u0dc3\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0d9c\u0dd0\u0da7\u0dc5\u0dd4\u0dc0 \u0db8\u0dda \u0db8\u0dc3 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0db8\u0d9c \u0dc4\u0dd0\u0dbb\u0dd9\u0db1 \u0db6\u0dc0 \u0dbd\u0dd2\u0da7\u0dca\u0dbb\u0ddd \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db8\u0dd4\u0daf\u0dd2\u0dad \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [],
