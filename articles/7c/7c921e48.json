    "si": {
      "title": "\u0d9c\u0ddd\u0da8\u0dcf\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4 \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dc3\u0db4\u0dd4\u0dbb\u0dcf \u0d85\u0dc0\u0dc3\u0db1\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4 \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dd2\u0dc5\u0dd2\u0dba\u0dd9\u0dc5 \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dbd\u0dda\u0d9a\u0db8\u0dca, \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc3\u0dcf\u0d9c\u0dbb \u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dc0\u0dc3\u0db8\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db1\u0dd4\u0daf\u0dd4\u0dbb\u0dd4 \u0daf\u0dd2\u0db1\u0dd9\u0d9a \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1\u0dd4 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba. \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dd4 \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dd9 \u0d8a\u0dba\u0dda (29\u0daf\u0dcf) \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0d9a\u0daf\u0dd3 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dda\u0daf\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dc3\u0dbd \u0dbd\u0daf \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1 \u0dc0\u0dbd\u0da7 \u0db4\u0dd2\u0dc5\u0dd2\u0dad\u0dd4\u0dbb\u0dd4 \u0daf\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0dc4\u0dda \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.",
        "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dd9\u0dbb\u0da7\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dc0 \u0d9c\u0dd2\u0dba\u0dda \u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb \u0db4\u0dbb\u0dd2\u0dc3\u0dbb\u0dba\u0d9a\u0dca \u0dba\u0da7\u0dad\u0dda \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba. \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d92 \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0dc4\u0dcf \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4\u0da7 \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4 \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0daf \u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dc0\u0dc3\u0db8\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0d9c\u0ddd\u0da8\u0dcf",
          "label": "LOC"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dcf\u0d9c\u0dbb \u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dc0\u0dc3\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          },
          {
            "text": "29 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "LOC"
          },
          {
            "text": "\u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "PERSON"
