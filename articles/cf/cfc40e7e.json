            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bb2\u0bb2\u0b9a\u0bc7\u0b95\u0bb0 \u0bae\u0bbe\u0bb5\u0b9f\u0bcd\u0b9f\u0bbf",
            "label": "PERSON"
