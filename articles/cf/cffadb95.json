  "original_title": "\u0dc4\u0dad\u0dca \u0dc3\u0dd2\u0dba \u0dc4\u0dd0\u0da7\u0d9a\u0da7 \u0daf\u0dca\u0dc0\u0dd2\u0dad\u0dca\u0dc0 \u0db4\u0dd4\u0dbb\u0dc0\u0dd0\u0dc3\u0dd2\u0db7\u0dcf\u0dc0\u0dba",
  "text_idx": {
    "en": {
      "title": "Seven hundred and sixty dual citizenship",
      "author": "unknown",
      "body_lines": [
        "Dual citizenship has been issued to 760 people who had applied for dual citizenship in Sri Lanka.",
        "Investment Promotion Minister Dhammika Perera said that a special policy decision was reached to carry out the process of issuing dual citizenship in this country without delay.",
        "Accordingly, dual citizenship will be issued every week on Monday to the people who have received security clearance. This will avoid long delays in issuing dual citizenship to a person who has received the clearance from the Ministry of Defense and it can only take a maximum of 6 days for a person who has received the clearance to receive dual citizenship."
      ],
      "title_ents": [
        {
          "text": "Seven hundred and sixty",
          "label": "CARDINAL"
        }
      ],
      "body_line_ents_list": [
        [
          {
