    "si": {
      "title": "\u0db8\u0dd3\u0db8\u0dd4\u0dbb\u0dda \u0d9c\u0db8\u0db1 \u0daf\u0db8\u0dca\u0db6\u0da9\u0dd9\u0db1\u0dca \u0db1\u0dad\u0dbb \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dcf\u0dbb\u0dd2\u0dba\u0db4\u0ddc\u0dc5\u00a0 \u0db8\u0dd3\u0db8\u0dd4\u0dbb\u0dda \u0d9c\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dba\u0d9a\u0dca \u0dc4\u0dd4\u0db1\u0dca\u0db1\u0dc3\u0dca\u0d9c\u0dd2\u0dbb\u0dd2\u0dba - \u0db8\u0dd3\u0db8\u0dd4\u0dbb\u0dda \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0daf\u0db8\u0dca\u0db6\u0da9\u0dda \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0db4\u0dcf\u0dad\u0dba\u0d9a\u0da7 \u0db4\u0dd9\u0dbb\u0dc5\u0dd3\u0db8\u0dd9\u0db1\u0dca 19 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd2\u0dc0\u0dcf\u0dc4\u0d9a \u0d9a\u0dad\u0d9a\u0dca \u0db8\u0dd2\u0dba \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dc0\u0dad\u0dca 6 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db8\u0dd0\u0daf\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc4\u0dcf \u0dad\u0dd9\u0dbd\u0dca\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dbb\u0ddd\u0dc4\u0dbd\u0dca\u0dc0\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dbd\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d8b\u0da9\u0daf\u0dd4\u0db8\u0dca\u0db6\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
