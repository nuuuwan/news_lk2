    "si": {
      "title": "''\u0d85\u0db4\u0ddd \u0daf\u0dd0\u0d9a\u0dca\u0d9a\u0dcf...\u0daf\u0dd0\u0d9a\u0dca\u0d9a\u0dcf. \u0dbd\u0ddc\u0d9a\u0dca\u0d9a\u0dcf \u0d9c\u0dad\u0dca\u0dad \u0dc3\u0dd0\u0db4 \u0dc4\u0ddc\u0db3\u0da7\u0db8 \u0daf\u0dd0\u0d9a\u0dca\u0d9a\u0dcf.''",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0dbb\u0d9c\u0dbd\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0d85\u0dad\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0d9c\u0dad\u0dca \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0db1\u0dca\u0daf\u0dd2\u0dbb\u0dba, \u0d85\u0dbb\u0dbd\u0dd2\u0dba\u0d9c\u0dc4 \u0db8\u0db1\u0dca\u0daf\u0dd2\u0dbb\u0dba \u0dc3\u0dc4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0daf\u0dd0\u0d9a\u0db6\u0dbd\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0daf \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf (\u0da2\u0dd6\u0dbd\u0dd2 11) \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dc4.",
        "\u0d94\u0dc0\u0dd4\u0db1\u0dca \u0db6\u0ddc\u0dc4\u0ddd \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dad\u0db8\u0db1\u0dca \u0d9a\u0dd2\u0dc3\u0dd2 \u0daf\u0dd2\u0db1\u0dd9\u0d9a \u0daf\u0dd0\u0d9a \u0db1\u0dd4\u0daf\u0dd4\u0da7\u0dd4 \u0db8\u0dd9\u0db8 \u0db8\u0db1\u0dca\u0daf\u0dd2\u0dbb \u0daf\u0dd0\u0d9a\u0db6\u0dbd\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dbd\u0dd0\u0db6\u0dd3\u0db8 \u0d9c\u0dd0\u0db1 \u0dc3\u0dad\u0dd4\u0da7\u0dd4 \u0dc0\u0db1 \u0db6\u0dc0\u0dba\u0dd2. \u0d9a\u0ddc\u0dc5\u0db9\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd4\u0dc0 \u0daf \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0db8\u0db1\u0dca\u0daf\u0dd2\u0dbb \u0db1\u0dbb\u0db9\u0db1 \u0dbd\u0daf \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0daf \u0db6\u0dd3\u0db6\u0dd3\u0dc3\u0dd3\u0dba\u0da7 \u0d85\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0dc5 \u0d9a\u0dc5\u0dc4.",
        "''\u0dbd\u0ddc\u0d9a\u0dca\u0d9a\u0dcf \u0d9c\u0dad\u0dca\u0dad \u0dc3\u0dd0\u0db4 \u0dc4\u0ddc\u0db3\u0da7\u0db8 \u0daf\u0dd0\u0d9a\u0dca\u0d9a\u0dcf. \u0d85\u0db4\u0dd2 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0daf\u0dd4\u0d9a\u0dca \u0dc0\u0dd2\u0db3\u0dd2\u0db1\u0dc0\u0dcf.'' ''\u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba\u0da7 \u0db6\u0dbd\u0db1\u0dca\u0db1 \u0dbd\u0dd0\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dc4\u0dd0. \u0d91\u0d9a\u0dba\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0ddd \u0d91\u0d9a\u0dca\u0d9a \u0d86\u0dc0\u0dda.'' \u0d86\u0daf\u0dd3 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0d94\u0dc0\u0dd4\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dc4."
      ],
