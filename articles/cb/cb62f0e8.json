  "original_title": "22 \u0d85\u0daf \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0d9a\u0dbb\u0db1\u0dc0\u0dcf",
  "text_idx": {
    "en": {
      "title": "22 will be gazetted today",
      "author": "unknown",
      "body_lines": [
        "Minister Wijayadasa Rajapaksa said that the 22nd Constitutional Amendment will be gazetted today and will be presented to Parliament after 7 days.",
        "He said that the government has removed the 22nd constitutional amendment that he personally submitted and introduced a new constitutional amendment.",
        "However, he said that after presenting this to Parliament, it will be named as the 21st Constitutional Amendment.",
        "He said that in this amendment, the bad things mentioned in the 19th amendment have been removed and the good things in the 20th amendment have been presented."
      ],
