            "label": "GPE"
          },
          {
            "text": "\u0baa\u0bbf\u0b9f\u0bbf\u0baa\u0bbf",
            "label": "ORG"
          },
          {
            "text": "TNA",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bbf\u0bb0\u0baa\u0bb2\u0bae\u0bbe\u0ba9 \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0b9f\u0bcd\u0b9a\u0bbf",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0ba3\u0bcd\u0b9f\u0bc7 \u0b9f\u0bc8\u0bae\u0bcd\u0bb8\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1",
            "label": "ORG"
