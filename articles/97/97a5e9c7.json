    "en": {
      "title": "Parliamentary sessions are limited to 3 days",
      "author": "unknown",
      "body_lines": [
        "The Committee on Parliamentary Business has decided to limit the sitting of Parliament to three days.",
        "Accordingly, Parliament is scheduled to convene on the 4th, 5th and 6th of next week.",
        "The Committee on Parliamentary Business convened under the chairmanship of Speaker Mahinda Yapa Abeywardena at the Parliament Complex this morning (30)."
      ],
      "title_ents": [
        {
          "text": "3 days",
          "label": "DATE"
        }
      ],
