          }
        ],
        [
          {
            "text": "14",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc1\u0dcf\u0db1\u0dca\u0dad\u0dd2\u0db1\u0db1\u0dca\u0daf\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd4\u0db8\u0dda\u0db0\u0dcf \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db1\u0dca.\u0da2\u0dd3. \u0dc3\u0dd4\u0da2\u0dd3\u0dc0 \u0db4\u0dab\u0dca\u0da9\u0dd2\u0dad\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dbb\u0db1\u0dca\u0daf \u0db1\u0dc0\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dd0\u0db1\u0dd2 \u0dc0\u0dd1\u0dc0\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc0\u0dd4\u0dbd\u0dc0\u0dd2 \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca",
            "label": "PERSON"
          },
