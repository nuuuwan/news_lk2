        ],
        [
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "\u0daf\u0dba\u0dcf\u0db1\u0db1\u0dca\u0daf \u0db6\u0dab\u0dca\u0da9\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0d89\u0db1\u0dca\u0dad\u0dd2\u0d9a\u0dcf\u0db6\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dad\u0dd4\u0db1\u0dca",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dbb\u0dcf\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0db8\u0dca \u0da0\u0d9a\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dca\u0dad\u0dd2 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0d9a\u0dbb\u0db1\u0dca",
