        ],
        [
          {
            "text": "\u0dc3\u0db8\u0dcf\u0da2\u0dc0\u0dcf\u0daf\u0dd3 \u0da2\u0db1\u0dad\u0dcf \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab \u0d9a\u0ddc\u0dc5\u0db9\u0daf\u0dd3",
