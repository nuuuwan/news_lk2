    "si": {
      "title": "\u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d87\u0db8\u0dad\u0dd2 \u0dc0\u0dd2\u0daf\u0dd2\u0dba\u0da7 \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d8b\u0dad\u0dca\u0dad\u0dbb \u0daf\u0dd9\u0db1\u0dca\u0db1",
      "author": "\u0da9\u0dd2\u0da2\u0dd2\u0da7\u0dbd\u0dca \u0db8\u0dda\u0dc3\u0dba 5",
      "body_lines": [
        "\u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1, \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc4\u0dcf \u0da2\u0db1\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc3\u0dd4\u0dc3\u0dd2\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0da2\u0dba\u0db1\u0dca\u0dad \u0db8\u0dc4\u0dad\u0dcf \u0db1\u0dd2\u0dbd \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad\u0dc0\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1, \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc4\u0dcf \u0da2\u0db1\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf 2005 \u0dc3\u0dd2\u0da7 2010 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5\u0dda\u0dba."
      ],
