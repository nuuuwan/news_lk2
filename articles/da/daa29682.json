    "si": {
      "title": "\u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1\u0dba \u0dc1\u0dd6\u0dbb\u0dba\u0db1\u0dca \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0dd0\u0dc0\u0dca\u0dbd\u0ddc\u0d9a\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0d9a\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d8a\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dad\u0dd3\u0dbb\u0dab\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba 2022 \u0da9\u0dba\u0dbd\u0ddc\u0d9c\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0d9c\u0dca\u0db6\u0dd2 \u0dbd\u0dd3\u0d9c\u0dca \u0dc1\u0dd6\u0dbb\u0dba\u0db1\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd6\u0dba\u0dda \u0dc0\u0dad\u0dca\u0db8\u0db1\u0dca \u0dc3\u0dc4 \u0dad\u0dd4\u0db1\u0dca \u0dc0\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0dc1\u0dd6\u0dbb\u0dba\u0db1\u0dca \u0dc0\u0dd6 \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 21\u0da7 15\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dd2. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0d9a\u0dd4\u0dc2\u0dcf\u0db1\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dcf\u0da2"
      ],
