    "si": {
      "title": "\u0d9a\u0dd9\u0dcf\u0dbb\u0ddd\u0db1\u0dcf \u0d9c\u0dd0\u0db1 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0d9c\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0dc1\u0dd9\u0dca\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8 \u0dba\u0dc5\u0dd2 \u0d89\u0dc4\u0dc5 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dd2\u0db1\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca\u0d9a\u0dbb\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dba\u0ddc\u0db8\u0dd4 \u0dc0\u0db1 \u0dbd\u0dd9\u0dc3 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (02) \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db8\u0dda \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d85\u0dc0\u0db0\u0dcf\u0db1\u0dba\u0d9a\u0dca \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0ddd\u0db4\u0daf\u0dda\u0dc1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d91\u0db8 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0db1\u0dd2\u0dba\u0db8\u0dcf\u0d9a\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db4\u0daf\u0dd2\u0db1 \u0dbd\u0dd9\u0dc3 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba\u0dda \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dca\u0dad\u0dd2\u0dba\u0da7 \u0d89\u0da9 \u0db1\u0ddc\u0dad\u0dd0\u0db6\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0dc0\u0db0\u0dcf\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dc3\u0dc4 \u0db8\u0db1\u0dca\u0d9a\u0dd2 \u0dc6\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0dc0\u0dc3\u0d82\u0d9c\u0dad \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0\u00a0 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca\u00a0 \u0db8\u0dd9\u0dc3\u0dda\u0daf \u0d9a\u0dd3\u0dba.",
        "\u201c\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca -19 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc4\u0dcf \u0db8\u0dbb\u0dab \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 1731\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd4\u0dab\u0dcf. \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0db8\u0dbb\u0dab 26\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd4\u0dab\u0dcf. \u0d91\u0db8 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0daf\u0dd3 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 472\u0d9a\u0da7 \u0d85\u0da9\u0dd4 \u0dc0\u0dd4\u0dab\u0dcf. \u0db8\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd4\u0dab\u0dda 13\u0dba\u0dd2. \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 283\u0dba\u0dd2. \u0db8\u0dbb\u0dab 3\u0dba\u0dd2. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 1616\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. \u0db8\u0dbb\u0dab \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 35\u0d9a\u0dca. \u0db8\u0dda \u0db8\u0dbb\u0dab 35\u0db1\u0dca 28 \u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd4\u0dab\u0dda \u0da2\u0dd6\u0dbd\u0dd2 18 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf\u0dba\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0\u0dba\u0dd2. \u0db8\u0dda \u0daf\u0dd9\u0dc3 \u0db6\u0dd0\u0dbd\u0dd6 \u0dc0\u0dd2\u0da7 \u0dad\u0dc0\u0dad\u0dca \u0d91\u0d9a \u0d9a\u0dbb\u0dd4\u0dab\u0d9a\u0dca \u0db4\u0dd9\u0db1\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db4\u0dc5\u0db8\u0dd4 \u0dc0\u0da7\u0dba\u0dda \u0daf\u0dd3 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 17\u0d9a\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca\u0dad\u0dcf. \u0daf\u0dd9\u0dc0\u0db1 \u0dc0\u0da7\u0dba\u0dda \u0daf\u0dd3 \u0d91\u0dba \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 14\u0d9a\u0da7 \u0d85\u0da9\u0dd4 \u0dc0\u0dd4\u0dab\u0dcf. \u0dad\u0dd4\u0db1\u0dca\u0dc0\u0dd9\u0db1\u0dd2 \u0dc0\u0da7\u0dba\u0dda \u0daf\u0dd3 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 8\u0dba\u0dd2. 4\u0dc0\u0db1 \u0dc0\u0da7\u0dba\u0dda \u0daf\u0dd3\u00a0 \u0d91\u0db1\u0dca\u0db1\u0dad \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca 22,623 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db4\u0db8\u0dab\u0dba\u0dd2. \u0dad\u0dd4\u0db1\u0dca\u0dc0\u0dd9\u0db1\u0dd2 \u0dc0\u0dad\u0dcf\u0dc0\u0dd9\u0dad\u0dca, 4\u0dc0\u0db1 \u0dc0\u0dad\u0dcf\u0dc0\u0dd9\u0dad\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad \u0d9c\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0d85\u0da9\u0dd4\u0dc0\u0dd9\u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0db1\u0dd2\u0dc3\u0dcf \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca\u0d9a\u0dbb\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db1\u0dd0\u0dc0\u0dad \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4\u0dba\u0dd2.",
        "\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0daf\u0dd0\u0db1\u0da7 \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 8\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. \u0d91\u0dba \u0d94\u0d9a\u0dca\u0dad\u0ddd\u0db8\u0dca\u0db6\u0dbb\u0dca \u0db8\u0dcf\u0dc3\u0dba \u0dc0\u0dd9\u0db1\u0d9a\u0db8\u0dca \u0db4\u0dcf\u0dc0\u0dd2\u0da0\u0dca\u0da0\u0dd2 \u0d9a\u0dbb\u0db1\u0dca\u0db1 \u0db4\u0dd4\u0dc5\u0dd4\u0dc0\u0db1\u0dca. \u0d92 \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 8 \u0d94\u0d9a\u0dca\u0dad\u0ddd\u0db6\u0dbb\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0daf\u0dd3 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dbb\u0db1\u0dca\u0db1 \u0db6\u0dd0\u0dbb\u0dd2 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0db1\u0dd2\u0dc3\u0dcf \u0d9a\u0ddc\u0da7\u0dc3\u0d9a\u0dca \u0dc0\u0dd9\u0db1 \u0dbb\u0da7\u0d9a\u0da7 \u0daf\u0dd9\u0db1\u0dca\u0db1 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0d91\u0db1\u0dca\u0db1\u0dad \u0d9c\u0dd9\u0db1\u0dcf\u0dc0\u0dda \u0d94\u0db6 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca. \u0d92 \u0db1\u0dd2\u0dc3\u0dcf \u0d91\u0db1\u0dca\u0db1\u0dad \u0dbd\u0db6\u0dcf\u0db1\u0ddc\u0d9c\u0dad\u0dca \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0daf\u0dd9\u0db1\u0dcf\u0d9c\u0dd9\u0db1\u0dca \u0db8\u0db8 \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0d9a\u0dbb\u0db1\u0dc0\u0dcf, \u0d89\u0d9a\u0dca\u0db8\u0dab\u0dd2\u0db1\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1 \u0d9a\u0dd2\u0dba\u0dbd\u0dcf.",
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db8\u0dda \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0daf\u0dd9\u0db1\u0dc0\u0dcf. \u0d92 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0daf\u0dd9\u0db1\u0dcf\u0db8 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4\u0dba\u0dd2. \u0d8a\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u201c\u0db8\u0db1\u0dca\u0d9a\u0dd2 \u0dc6\u0ddc\u0d9a\u0dca\u0dc3\u0dca\u201d \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0\u0dad\u0dca \u0d85\u0dc0\u0db0\u0dcf\u0db1\u0dba \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dbb\u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. \u0daf\u0dd0\u0db1\u0da7 \u0d91\u0dba \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7\u00a0 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dcf \u0db1\u0dd0\u0dc4\u0dd0. \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7\u00a0 \u0d91\u0db8 \u0dbb\u0ddd\u0d9c\u0dba \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8 \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0db1 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc0\u0dd4\u0dab\u0ddc\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0db1\u0dca\u0db1 \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca \u0dc3\u0d9a\u0dc3\u0dca \u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0db1\u0dc0\u0dcf. \u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0daf\u0dd3 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9c\u0dd0\u0db1 \u0dc4\u0dd2\u0dad\u0dbd\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf \u0d9a\u0dbb\u0db1\u0dca\u0db1. \u0db8\u0dda \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba\u0da7 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0d9a\u0dca \u0daf\u0dd9\u0db1\u0dca\u0db1 \u0d91\u0db4\u0dcf \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dca\u0dc0\u0dba\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0db8\u0db8 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dc0\u0dcf\u201d."
      ],
