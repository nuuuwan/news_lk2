      "body_line_ents_list": [
        [
          {
            "text": "\u0bae\u0bb9\u0bc7\u0bb2 \u0b9c\u0baf\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9",
            "label": "PERSON"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
