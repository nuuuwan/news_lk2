  "original_title": "\u0d85\u0dbd\u0dd2 \u0dc0\u0db1\u0dca\u0daf\u0dd2\u0dba \u2019\u2019  \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dba\u0dba\u0dd2",
  "text_idx": {
    "en": {
      "title": "Ali is going to increase compensation",
      "author": "unknown",
      "body_lines": [
        "State Minister for Wildlife Mr. Wimalaweera Dissanayake told Lankadeepa that a proposal has been submitted to the cabinet to increase the compensation amount of five lakh rupees to ten lakh rupees for a person who dies due to an attack by a wild elephant.",
        "In addition to this, he mentioned that the cabinet has also proposed to increase the amount of compensation from one lakh rupees to two lakh fifty thousand rupees to a person whose property is damaged by wild elephant attacks.",
        "It is said that this proposal has been submitted to the cabinet after considering the requests made by many parties."
      ],
      "title_ents": [
        {
          "text": "Ali",
          "label": "PERSON"
        }
      ],
