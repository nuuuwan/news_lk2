        ],
        [
          {
            "text": "\u0d85\u0db4\u0dca\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "\u0dbb\u0ddd\u0d9c \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0dc3\u0dc4 \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1",
            "label": "ORG"
