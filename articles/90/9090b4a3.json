            "text": "\u0ba4\u0bbf\u0bb0\u0bc1\u0b95\u0bcb\u0ba3\u0bae\u0bb2\u0bc8 \u0b8f\u0bb1\u0b95\u0bcd\u0b95\u0ba3\u0bcd\u0b9f\u0bbf",
