    "si": {
      "title": "\u0db6\u0dc4\u0dcf\u0dbd\u0dd4\u0db8\u0dca \u0db1\u0dd0\u0dc0\u0dca\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db4\u0dd2\u0dbb\u0dd2\u0dc0\u0dd0\u0dba \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0da9\u0dd2\u0da2\u0dd2\u0da7\u0dbd\u0dca \u0db8\u0dda\u0dc3\u0dba 5",
      "body_lines": [
        "\u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0db6\u0dc4\u0dcf\u0dbd\u0dd4\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dc3\u0db1\u0dad\u0dca \u0db8\u0d82\u0da2\u0dd4\u0dbd \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db6\u0dc4\u0dcf\u0dbd\u0dd4\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0daf \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d9a\u0db1\u0dca\u0da7\u0dda\u0db1\u0dbb\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dc3\u0dd2\u0dba\u0dba\u0da7 10 \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0db1 \u0db6\u0dc0\u0dba\u0dd2 \u0d91\u0db8 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dba\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db6\u0dc4\u0dcf\u0dbd\u0dd6\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dc3\u0db1\u0dad\u0dca \u0db8\u0d82\u0da2\u0dd4\u0dbd \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9c\u0dad\u0dca \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd6 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0db6\u0dc4\u0dcf\u0dbd\u0dd4\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0dd2\u0dba\u0dba\u0da7 35 \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd4\u0dc0\u0dad\u0dca \u0db1\u0dd0\u0dc0\u0dad\u0dad\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 10 \u0d9a\u0dd2\u0db1\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba\u0dd2."
      ],
