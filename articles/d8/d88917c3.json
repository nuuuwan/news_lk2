    "si": {
      "title": "\u0db1\u0dd2\u0daf\u0dc4\u0dc3 \u0dbd\u0dd0\u0db6\u0dd6 \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0d9c\u0d82\u0d9c\u0dcf\u0dbb\u0dcf\u0db8\u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0db8\u0dcf\u0dc0 \u0dbd\u0dd0\u0db6 \u0db1\u0dd2\u0daf\u0dc4\u0dc3 \u0dbd\u0dd0\u0db6\u0dd6 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0da9 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d9a\u0ddc\u0dc5\u0db9, \u0dc4\u0dd4\u0dab\u0dd4\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0d9c\u0d82\u0d9c\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d86\u0dc1\u0dd3\u0dbb\u0dca\u0dc0\u0dcf\u0daf \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba.",
        "\u0d9c\u0d82\u0d9c\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0d9a\u0dd2\u0dbb\u0dd2\u0db1\u0dca\u0daf\u0dda \u0d85\u0dc3\u0dca\u0dc3\u0da2\u0dd2 \u0dc4\u0dd2\u0db8\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dd4\u0d9b \u0db8\u0dc4\u0dcf \u0dc3\u0d82\u0d9d\u0dbb\u0dad\u0dca\u0db1\u0dba \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0dc0\u0dd3 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0dc3\u0dd9\u0dad\u0dca \u0db4\u0dad\u0dcf \u0d86\u0dc1\u0dd3\u0dbb\u0dca\u0dc0\u0dcf\u0daf \u0d9a\u0dc5\u0dc4.",
        "\u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0db8\u0dc4\u0dad\u0dcf \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0daf \u0db8\u0dd9\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0d91\u0d9a\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dc4."
      ],
      "title_ents": [],
      "body_line_ents_list": [
