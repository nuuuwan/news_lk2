    "si": {
      "title": "\u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0db4\u0dcf\u0dbd\u0dd4\u0dc0\u0da7 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd1\u0dbd\u0dd2\u0dba\u0d9c\u0ddc\u0da9 \u0db8\u0dd0\u0db1\u0dd2\u0d82 \u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0ddc\u0dbd, \u0daf\u0db9\u0dd4\u0dbd\u0dca\u0dbd, \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0db8\u0dd3\u0d9c\u0ddc\u0da9 \u0dc3\u0dc4 \u0db6\u0ddd\u0d9a\u0dd4\u0db1\u0dca\u0daf\u0dbb \u0d87\u0dad\u0dd4\u0dbd\u0dd4 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0d85\u0daf (7) \u0daf\u0dd2\u0db1\u0dba\u0dda \u0db4\u0dcf\u0dbd\u0dd4 \u0dc3\u0db6\u0dcf\u0dc0\u0dba\u0d9a\u0dca \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd2\u0dab.",
        "\u0db7\u0dcf\u0db1\u0dca\u0da9 \u0dbd\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0dc4 \u0db6\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0dc5\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0db1 \u0daf\u0dd9\u0d9a\u0db8 \u0db4\u0dc4\u0dc5 \u0dc0\u0dd0\u0da7\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd9\u0dc5\u0db3\u0dcf\u0db8\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0db6\u0ddc\u0dc4\u0ddd \u0daf\u0dd4\u0dc3\u0dca\u0d9a\u0dbb \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc3\u0db8\u0dc3\u0dca\u0dae \u0dbd\u0d82\u0d9a\u0dcf \u0d92\u0d9a\u0dcf\u0db6\u0daf\u0dca\u0db0 \u0d86\u0dbb\u0dca\u0dad\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0dc3\u0dc4 \u0db8\u0dd0\u0db1\u0dd2\u0d82 \u0dc0\u0dd9\u0dc5\u0db3 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0db7\u0dcf\u0dab\u0dca\u0da9\u0dcf\u0d9c\u0dcf\u0dbb\u0dd2\u0d9a \u0db1\u0dd2\u0db8\u0dbd\u0dca \u0d85\u0dad\u0dca\u0dad\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0db0\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9c \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf\u0d9c\u0dd9\u0db1 \u0dba\u0dcf\u0db8 \u0db6\u0ddc\u0dc4\u0ddd \u0d9c\u0dd0\u0da7\u0dbd\u0dd4 \u0dc3\u0dc4\u0d9c\u0dad \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2\u0daf \u0d94\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db8\u0dda \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d87\u0dad\u0dd0\u0db8\u0dca \u0d86\u0dbb\u0dca\u0dad\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd\u00a0 \u0db6\u0ddc\u0dc4\u0ddd \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca \u0dc0\u0dc3\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dd4\u0daf \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0db6\u0dc0 \u0d85\u0db4 \u0dc0\u0dcf\u0dbb\u0dca\u0dae\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0ddd \u0db4\u0dc0\u0dc3\u0dad\u0dd2.",
        "\u0d91\u0dc5\u0dc0\u0dbd\u0dd4 \u0dc3\u0dc4 \u0db4\u0dc5\u0dad\u0dd4\u0dbb\u0dd4 \u0db8\u0dd2\u0dc5 \u0d9c\u0dab\u0db1\u0dca\u0daf \u0dc0\u0dd9\u0db1\u0daf\u0dcf\u0da7 \u0dc0\u0da9\u0dcf \u0dc3\u0dcf\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dc0 \u0db8\u0dd2\u0dc5 \u0db4\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0dd1\u0dbd\u0dd2\u0dba\u0d9c\u0ddc\u0da9 \u0db8\u0dd0\u0db1\u0dd2\u0d82 \u0dc0\u0dd9`\u0dc5\u0db3\u0db4\u0ddc\u0dbd\u0dda \u0d9a\u0dd0\u0dbb\u0da7\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 250\u0d9a\u0dca, \u0db6\u0ddc\u0d82\u0da0\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 300 \u0d9a\u0dca, \u0d9c\u0ddd\u0dc0\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 200\u0d9a\u0dca, \u0dc0\u0db8\u0dca\u0db6\u0da7\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 300\u0d9a\u0dca, \u0dbd\u0dd3\u0d9a\u0dca\u0dc3\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 150\u0d9a\u0dca, \u0dc0\u0da7\u0dca\u0da7\u0d9a\u0dca\u0d9a\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 220 \u0d9a\u0dca \u0d85\u0db8\u0dd4 \u0db8\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 500\u0d9a\u0dca, \u0daf\u0dd9\u0dc4\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 200 \u0d9a\u0dca \u0dad\u0d9a\u0dca\u0d9a\u0dcf\u0dbd\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 150\u0d9a\u0dca, \u0dbd\u0dd9\u0dc3\u00a0 \u0d85\u0dc5\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd6 \u0db6\u0dc0 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0ddd \u0d9a\u0dd2\u0dba\u0dad\u0dd2.",
        "\u0db8\u0dd9\u0dba\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d86\u0dbb\u0dca\u0dad\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0d9a\u0dd0\u0dbb\u0da7\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 320\u0d9a\u0dca, \u0db6\u0ddc\u0d82\u0da0\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 360 \u0d9a\u0dca, \u0d9c\u0ddd\u0dc0\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 280\u0d9a\u0dca, \u0dc0\u0db8\u0dca\u0db6\u0da7\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 400\u0d9a\u0dca, \u0dc0\u0da7\u0dca\u0da7\u0d9a\u0dca\u0d9a\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 200 \u0d9a\u0dca, \u0d85\u0db8\u0dd4 \u0db8\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 800\u0d9a\u0dca, \u0daf\u0dd9\u0dc4\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 700 \u0d9a\u0dca \u0dad\u0d9a\u0dca\u0d9a\u0dcf\u0dbd\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 360 \u0d9a\u0dca, \u0dbb\u0da7 \u0d85\u0dbd \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 240\u0d9a\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0d85\u0dbd \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 420\u0d9a\u0dca \u0db6\u0dd3 \u0dbd\u0dd6\u0dab\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u00a0 200\u0d9a\u0dca \u0dbd\u0dd9\u0dc3\u00a0 \u0d85\u0dc5\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd6 \u0db6\u0dc0 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0ddd \u0d9a\u0dd2\u0dba\u0dad\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0db4\u0dd1\u0dbd\u0dd2\u0dba\u0d9c\u0ddc\u0da9 \u0db8\u0dcf\u0dbd\u0dd4 \u0dc0\u0dd9\u0dbd\u0daf\u0db4\u0ddc\u0dbd\u0dda\u00a0 \u0dad\u0dbd\u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1550\u0d9a\u0dca, \u0db6\u0dbd\u0dba\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1000 \u0d9a\u0dca,\u00a0 \u0dc3\u0dcf\u0dbd\u0dba\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 800\u0d9a\u0dca, \u0dc4\u0dd4\u0dbb\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1000\u0d9a\u0dca,\u00a0 \u0dbd\u0dd2\u0db1\u0dca\u0db1\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 950\u0d9a\u0dca\u00a0 \u0d86\u0daf\u0dd3 \u0dbd\u0dd9\u0dc3 \u0d85\u0dc5\u0dd9\u0dc0\u0dd2 \u0dc0\u0dda."
      ],
