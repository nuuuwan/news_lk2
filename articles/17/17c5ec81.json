          {
            "text": "\u0d9a\u0dc5\u0dd4\u0db6\u0ddd\u0dc0\u0dd2\u0dbd \u0db4\u0daf\u0dd4\u0db8 \u0dc4\u0dd2\u0db8\u0dd2",
