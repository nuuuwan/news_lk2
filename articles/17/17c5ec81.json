          {
            "text": "\u0dc3\u0dd4\u0db8\u0d82\u0d9c\u0dbd \u0dc4\u0dcf\u0db8\u0dd4\u0daf\u0dd4\u0dbb\u0dd4\u0dc0\u0ddd",
