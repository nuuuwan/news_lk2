    "si": {
      "title": "\u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dba\u0ddd\u0d9c\u0dd2\u0d9a \u0db4\u0dbb\u0dd2\u0d9a\u0dca\u0dc2\u0dab \u0dc4\u0dd9\u0da7 \u0dc3\u0dd2\u0da7 \u0daf\u0dd2\u0db1 \u0dad\u0dd4\u0db1\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0db4\u0dad\u0dca\u200d\u0dbb \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 - 2021 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda\u00a0 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dba\u0ddd\u0d9c\u0dd2\u0d9a \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dc0\u0dbd\u0da7 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd6 \u0d85\u0db4\u0dd9\u0d9a\u0dca\u0dc2\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0dc4\u0dd9\u0da7 (19) \u0dc3\u0dd2\u0da7 21 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db6\u0da7\u0dc4\u0dd2\u0dbb \u0dc3\u0d82\u0d9c\u0dd3\u0dad\u0dba \u0dc0\u0dd2\u0dc2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dba\u0ddd\u0d9c\u0dd2\u0d9a \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0dc4\u0dd9\u0da7 \u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dda.",
        "\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db1\u0dbb\u0dca\u0dad\u0db1\u0dba,\u0db7\u0dcf\u0dbb\u0dad \u0db1\u0dbb\u0dca\u0dad\u0db1\u0dba,\u0d9c\u0dd8\u0dc4 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dc0, \u0db4\u0dd9\u0dbb\u0daf\u0dd2\u0d9c \u0dc3\u0d82\u0d9c\u0dd3\u0dad\u0dba, \u0d9a\u0dbb\u0dca\u0dab\u0dcf\u0da7\u0d9a \u0dc3\u0d82\u0d9c\u0dd3\u0dad\u0dba, \u0db1\u0dcf\u0da7\u0dca\u200d\u0dba \u0dc4\u0dcf \u0dbb\u0d82\u0d9c \u0d9a\u0dbd\u0dcf\u0dc0 (\u0dc3\u0dd2\u0d82\u0dc4\u0dbd) \u0db1\u0dcf\u0da7\u0dca\u200d\u0dba \u0dc4\u0dcf \u0dbb\u0d82\u0d9c \u0d9a\u0dbd\u0dcf\u0dc0 (\u0daf\u0dd9\u0db8\u0dc5) \u0dba\u0db1 \u0dc0\u0dd2\u0dc2\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dba\u0ddd\u0d9c\u0dd2\u0d9a \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0db1 \u0d85\u0db1\u0dd2\u0daf\u0dca\u0daf\u0dcf (20) \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dda.",
        "\u0d89\u0d82\u0da2\u0dd2\u0db1\u0dda\u0dbb\u0dd4\u00a0 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dc0\u0dda\u0daf\u0dba \u0dc3\u0dc4 \u0da2\u0ddb\u0dc0 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dc0\u0dda\u0daf\u0dba \u0dba\u0db1 \u0dc0\u0dd2\u0dc2\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dba\u0ddd\u0d9c\u0dd2\u0d9a \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0db1 \u0d85\u0db1\u0dd2\u0daf\u0dca\u0daf\u0dcf (21) \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dda."
      ],
      "title_ents": [
        {
