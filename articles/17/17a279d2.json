          {
            "text": "\u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "FAC"
          }
        ],
        [
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0db1\u0dbb\u0dca\u0dad\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dd8\u0dc4 \u0d85\u0dcf\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dca\u0dba\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd9\u0dbb\u0daf\u0dd2\u0d9c \u0dc3\u0d82\u0d9c\u0dd3\u0dad\u0dba",
