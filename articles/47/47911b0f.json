    "si": {
      "title": "\u0db4\u0dc5\u0db8\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba\u0da7 \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0db4\u0dad\u0dca \u0db7\u0dcf\u0dbb\u0d9c\u0dd0\u0db1\u0dd3\u0db8 1 \u0dad\u0dd9\u0d9a\u0dca \u0daf\u0dd2\u0d9c\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0db6\u0db1 2023 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dbd \u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba\u0da7 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0dd3\u0db8\u0dda \u0daf\u0dd2\u0db1\u0dba \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 1 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dbb\u0da7\u0dd9\u0dc4\u0dd2 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dc0\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca 2023 \u0dc0\u0dc3\u0dbb\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0dc1\u0dda\u0dab\u0dd2\u0dba\u0da7 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0db6\u0db3\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0db4\u0dad\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0daf\u0dd2\u0db1\u0dba \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0d9a\u0dbb \u0daf\u0dd9\u0db1 \u0db8\u0dd9\u0db1\u0dca \u0daf\u0dd9\u0db8\u0dcf\u0db4\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0dca \u0dc3\u0dc5\u0d9a\u0dcf \u0db8\u0dd9\u0db8 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
