    "si": {
      "title": "\u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0d9a \u0db4\u0dd2\u0dba\u0dad\u0dca \u0db1\u0dd2\u0d9a\u0dda\u0dc2\u0dbd\u0dcf \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0db4\u0dd2\u0dba\u0dad\u0dca \u0db1\u0dd2\u0d9a\u0dda\u0dc2\u0dbd \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 26 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb \u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0ddc\u0dc5\u0db9 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0da2\u0dd4\u0dbd\u0dd2 14 \u0dc0\u0db1\u0daf\u0dcf \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0da7 \u0db6\u0dbd\u0dc4\u0dad\u0dca\u0d9a\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4\u0dc0\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d94\u0dc4\u0dd4\u0da7 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0d91\u0dbd\u0dca\u0dbd \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0d85\u0daf \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0da7 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dcf."
      ],
