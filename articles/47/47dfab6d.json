        ],
        [
          {
            "text": "\u0b8f.\u0b8e\u0bb2\u0bcd.\u0b8e\u0bae\u0bcd.\u0b85\u0ba4\u0bbe\u0b89\u0bb2\u0bcd\u0bb2\u0bbe",
