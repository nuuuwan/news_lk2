    "si": {
      "title": "\u0db4\u0dd9\u0dbb\u0dd0\u0dc5\u0dd4\u0dab\u0dd4 \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0dad\u0dd9\u0dbd\u0dca \u0d9c\u0db1\u0dca\u0db1 \u0db4\u0ddc\u0dbb\u0d9a\u0dad\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba \u0d85\u0dba\u0dd2 \u0d95 \u0dc3\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d9c\u0db6\u0da9\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0dc4\u0db4\u0dd4\u0dad\u0dbd\u0dda \u0dad\u0dd9\u0dbd\u0dca \u0d9c\u0db6\u0da9\u0dcf\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0da9\u0dd3\u0dc3\u0dbd\u0dca\u00a0 \u0dbd\u0dd3\u0da7\u0dbb\u0dca\u00a0 33000 \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0dad\u0dd9\u0dbd\u0dca \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0d9a\u0dca \u0d85\u0daf (11) \u0d8b\u0daf\u0dda\u00a0 \u0dc4\u0db4\u0dd4\u0dad\u0dbd\u0dda\u00a0 \u0db4\u0d82\u0d9a\u0dd0\u0da7\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0daf\u0dd3 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0dc4\u0dbb\u0dc4\u0dcf \u0db4\u0dd9\u0dbb\u0dc5\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0d89\u0db1\u0dca\u00a0 \u0dc0\u0dd1\u0dc4\u0dd9\u0db1 \u0dad\u0dd9\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dcf\u0dc3\u0dd3\u0db1\u0dca \u0db4\u0ddc\u0dbb\u0d9a\u0db8\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0\u0daf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0d9c\u0ddc\u0dc3\u0dca \u0dbd\u0ddc\u0dbb\u0dd2\u0dba \u0db4\u0dd9\u0dbb\u0dc5\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0db8\u0dd2\u0db1\u0dca \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0dd9\u0d9a\u0dd4\u0da7\u0dad\u0dca\u00a0 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u00a0 \u0db6\u0dc0\u0daf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0db6 \u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0d9a\u0da7 \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dba\u0ddc\u0daf\u0db8\u0dd2\u0db1\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2\u0daf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0d89\u0dc0\u0dad\u0da7 \u0dba\u0db1 \u0dad\u0dd9\u0dbd\u0dca \u0d9a\u0dd1\u0db1\u0dca \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0dc0\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dcf\u0dc3\u0dd3\u0db1\u0dca\u00a0 \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dcf\u00a0 \u0db6\u0dc0\u0daf \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2."
      ],
