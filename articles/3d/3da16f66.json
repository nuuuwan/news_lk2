  "original_title": "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4 \u0da7\u0dd2\u0d9a\u0da7\u0dca \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0dc0\u0dd9\u0dad\u0dd2",
  "text_idx": {
    "en": {
      "title": "Station masters withdraw from ticket sales",
      "author": "unknown",
      "body_lines": [
        "The station masters have decided to refrain from issuing railway tickets for a period of 48 hours from 6.00 pm today.",
        "They have started this professional action by protesting against the unfair increase of railway fares in a time of crisis and not taking steps to increase the fares under a prescribed system."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
