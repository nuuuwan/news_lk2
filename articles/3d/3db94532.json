          }
        ],
        [
          {
            "text": "\u0d85\u0db4\u0db1\u0dba\u0db1 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda",
            "label": "DATE"
          },
          {
            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 30 \u0dba\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8, \u0d86\u0dc1\u0dca\u0dc0\u0dcf\u0daf\u0dba\u0d9a\u0dca \u0dc3\u0dc4 \u0dc1\u0d9a\u0dca\u0dad\u0dd2\u0db8\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8",
            "label": "WORK_OF_ART"
          },
          {
            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 30 \u0dba\u0dd2",
