          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d85\u0db4\u0db1\u0dba\u0db1\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd4\u0da7\u0dd2\u0dba",
            "label": "ORG"
