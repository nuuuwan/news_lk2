          {
            "text": "\u0dc0\u0dcf\u0dbd\u0da0\u0dca\u0da0\u0dda\u0db1 \u0dc0\u0dd0\u0da9\u0db6\u0dbd\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0d8b\u0db4 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a",
