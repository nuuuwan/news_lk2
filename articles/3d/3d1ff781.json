    "si": {
      "title": "\u0dc0\u0dcf\u0dc4\u0db1 \u0dbd\u0d9a\u0dca\u0dc2 5\u0d9a\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dcf.",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc4\u0dbb\u0dc4\u0dcf \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba (21\u0daf\u0dcf) \u0dc3\u0dd2\u0da7 \u0d8a\u0dba\u0dda (28\u0daf\u0dcf) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dcf\u0dc4\u0db1 536,055\u0d9a\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0d85\u0dad\u0dbb QR \u0dc4\u0dd2 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca 536\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad. \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da2\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d8a\u0dba\u0dda \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc3\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0d89\u0db1\u0dca\u0db0\u0db1 187,005\u0d9a\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dad\u0dca \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca 826\u0d9a\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0d9a\u0dd6\u0dbd \u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d8a\u0dba\u0dda \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc0\u0dcf\u0dc4\u0db1 4,479,376\u0d9a\u0dca \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
