  "time_ut": 1661696972,
  "original_lang": "ta",
  "original_title": "\u0b85\u0bb0\u0b9a \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bcd \u0b95\u0bbe\u0bb2\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bc1",
  "text_idx": {
    "en": {
      "title": "Deadline for government agencies",
      "author": "unknown",
      "body_lines": [
        "The National Water Supply and Drainage Board has decided to levy a 2.5 percent fee from government agencies that do not pay their water bills for more than three months.",
        "No dues have been collected earlier from government agencies that are overdue for payment of dues. Meanwhile, it will be decided in the near future to cut off the water supply operations of the official residences of mayors who have not paid their water bills for more than two months.",
        "The Speaker has been informed that the Members of Parliament who have failed to pay the water charges must pay the water charges.",
        "The National Water Supply and Drainage Board has informed that some members of Parliament have not yet paid the water bill of 13 million rupees."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "The National Water Supply and Drainage Board",
            "label": "ORG"
          },
          {
            "text": "2.5 percent",
            "label": "PERCENT"
          },
          {
            "text": "more than three months",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "more than two months",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "Parliament",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "The National Water Supply and Drainage Board",
            "label": "ORG"
          },
          {
            "text": "Parliament",
            "label": "ORG"
          },
          {
            "text": "13 million",
            "label": "CARDINAL"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dbb\u0dcf\u0da2\u0dca\u0dba \u0d86\u0dba\u0dad\u0db1 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0daf\u0dd2\u0db1\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dcf\u0dc3 \u0dad\u0dd4\u0db1\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0da2\u0dbd \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0db1 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 2.5\u0d9a \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0d9a\u0dca \u0d85\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d9c\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd9\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0dd6 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0dba \u0d9a\u0dbb \u0db1\u0ddc\u0db8\u0dd0\u0dad. \u0db8\u0dda \u0d85\u0dad\u0dbb \u0db8\u0dcf\u0dc3 \u0daf\u0dd9\u0d9a\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0da2\u0dbd \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dd6 \u0db1\u0d9c\u0dbb\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db1\u0dd2\u0dbd \u0db1\u0dd2\u0dc0\u0dcf\u0dc3\u0dc0\u0dbd \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0db4\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0da7 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba\u0dd2.",
        "\u0da2\u0dbd \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d9c\u0dd9\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0db4\u0ddc\u0dc4\u0ddc\u0dc3\u0dad\u0dca \u0dc0\u0dd6 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d85\u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0da2\u0dbd \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d9c\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d87\u0dad\u0dd0\u0db8\u0dca \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 13\u0d9a \u0da2\u0dbd \u0db6\u0dd2\u0dbd \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0d9c\u0dd9\u0dc0\u0dcf \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd3 \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 2.5 \u0d9a\u0dd2",
            "label": "PERCENT"
          },
          {
            "text": "\u0db8\u0dcf\u0dc3 \u0dad\u0dd4\u0db1\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db8\u0dcf\u0dc3 \u0daf\u0dd9\u0d9a\u0d9a\u0da7 \u0dc0\u0da9\u0dcf",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 13 \u0d9a\u0dd2",
            "label": "CARDINAL"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b85\u0bb0\u0b9a \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bcd \u0b95\u0bbe\u0bb2\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bc1",
      "author": "unknown",
      "body_lines": [
        "\u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bbe\u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd \u0ba8\u0bc0\u0bb0\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0ba4\u0bcd\u0ba4\u0bc8 \u0b9a\u0bc6\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0ba4 \u0b85\u0bb0\u0b9a \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 2.5 \u0b9a\u0ba4\u0bb5\u0bc0\u0ba4 \u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0ba4\u0bcd\u0ba4\u0bc8 \u0b85\u0bb1\u0bb5\u0bbf\u0b9f\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0ba8\u0bc0\u0bb0\u0bcd\u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bb2\u0bcd \u0bb5\u0b9f\u0bbf\u0b95\u0bbe\u0bb2\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1\u0b9a\u0bcd \u0b9a\u0baa\u0bc8 \u0ba4\u0bc0\u0bb0\u0bcd\u0bae\u0bbe\u0ba9\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bc8 \u0b9a\u0bc6\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0b95\u0bbe\u0bb2\u0ba8\u0bcd\u0ba4\u0bbe\u0bb4\u0bcd\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bcd \u0b85\u0bb0\u0b9a \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b87\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bb0\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b8e\u0ba4\u0bc1\u0bb5\u0bc1\u0bae\u0bcd \u0b85\u0bb1\u0bb5\u0bbf\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8. \u0b87\u0ba4\u0bc7\u0bb5\u0bc7\u0bb3\u0bc8 \u0ba8\u0bc0\u0bb0\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0ba4\u0bcd\u0ba4\u0bc8 \u0b87\u0bb0\u0bc1 \u0bae\u0bbe\u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd \u0b9a\u0bc6\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0ba4 \u0bae\u0bc7\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bcb\u0b95\u0baa\u0bc2\u0bb0\u0bcd\u0bb5 \u0b87\u0bb2\u0bcd\u0bb2\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0ba8\u0bc0\u0bb0\u0bcd \u0bb5\u0bbf\u0ba8\u0bbf\u0baf\u0bcb\u0b95\u0b9a\u0bcd \u0b9a\u0bc6\u0baf\u0bb1\u0bcd\u0baa\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bc8 \u0ba4\u0bc1\u0ba3\u0bcd\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0b95\u0bbe\u0bb2\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba4\u0bc0\u0bb0\u0bcd\u0bae\u0bbe\u0ba9\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f \u0b89\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0ba8\u0bc0\u0bb0\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bc8 \u0b9a\u0bc6\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4\u0ba4\u0bcd \u0ba4\u0bb5\u0bb1\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3 \u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0ba8\u0bc0\u0bb0\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bc8 \u0b9a\u0bc6\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4 \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bc6\u0ba9 \u0b9a\u0baa\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "13 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0ba9\u0bcd \u0bb0\u0bc2\u0baa\u0bbe\u0baf\u0bcd \u0ba8\u0bc0\u0bb0\u0bcd\u0b95\u0b9f\u0bcd\u0b9f\u0ba3\u0ba4\u0bcd\u0ba4\u0bc8 \u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0bbf\u0bb2\u0bb0\u0bcd \u0b87\u0ba4\u0bc1\u0bb5\u0bb0\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0bc6\u0bb2\u0bc1\u0ba4\u0bcd\u0ba4\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8 \u0b8e\u0ba9 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0ba8\u0bc0\u0bb0\u0bcd\u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bb2\u0bcd \u0bb5\u0b9f\u0bbf\u0b95\u0bbe\u0bb2\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1\u0b9a\u0bcd \u0b9a\u0baa\u0bc8 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0ba8\u0bc0\u0bb0\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bb2\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0b9f\u0bbf\u0b95\u0bbe\u0bb2\u0bcd \u0bb5\u0bbe\u0bb0\u0bbf\u0baf\u0bae\u0bcd",
            "label": "ORG"
