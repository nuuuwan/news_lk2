    "si": {
      "title": "\u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1, \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4, \u0d86\u0dba\u0dad\u0db1 \u0dba\u0da7\u0dad\u0dda \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2\u0dc0\u0dbd \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dad\u0dd2\u0dba \u0dc3\u0db8\u0dcf\u0dbd\u0ddd\u0da0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dc5 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbb\u0da2\u0dba\u0dda \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0dc3\u0dc4 \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0ddd \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dc3\u0dd0\u0dbd\u0dc3\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd (POs) \u0dc3\u0dc4 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0d92\u0d9a\u0d9a (PMUs) \u0dc3\u0db8\u0dcf\u0dbd\u0ddd\u0da0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0\u0d9a\u0dca \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dda.\u0da7\u0dd3. \u0d9a\u0db8\u0dbd\u0dca \u0db4\u0daf\u0dca\u0db8\u0dc3\u0dd2\u0dbb\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0db1\u0dca.\u0d9a\u0dda.\u0da2\u0dd3.\u0d9a\u0dda. \u0db8\u0dd9\u0db8 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0\u0dda \u0dc3\u0dd9\u0dc3\u0dd4 \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0db1\u0dd9\u0db8\u0dca\u0db8\u0dcf\u0dc0\u0dad\u0dca\u0dad \u0dc3\u0dc4 \u0d86\u0dbb\u0dca.\u0d91\u0da0\u0dca.\u0dbb\u0dd4\u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dca \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "2022 \u0d85\u0dad\u0dd4\u0dbb\u0dd4 \u0d85\u0dba\u0dc0\u0dd0\u0dba \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd/\u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0d92\u0d9a\u0d9a \u0dc4\u0dbb\u0dc4\u0dcf \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0db1\u0dca \u0d85\u0daf\u0dcf\u0dc5 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba/\u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4/\u0d86\u0dba\u0dad\u0db1\u0dba \u0dba\u0da7\u0dad\u0dda\u0db8 \u0d89\u0da7\u0dd4 \u0d9a\u0dc5 \u0dc4\u0dd0\u0d9a\u0dd2\u0daf \u0dba\u0db1\u0dca\u0db1.",
        "POs \u0dc3\u0dc4 PMUs \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0dc0\u0dbb\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0daf\u0dcf\u0dc5 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0db1\u0dca \u0d89\u0da7\u0dd4 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda\u0daf \u0dba\u0db1\u0dca\u0db1.",
        "POs/PMU \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0dda \u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0daf\u0dd2\u0d9c\u0da7\u0db8 \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4\u0daf \u0dba\u0db1\u0dca\u0db1.",
        "\u0d91\u0db8 PO \u0dc3\u0dc4 PMU \u0dc0\u0dbd \u0daf\u0dd0\u0db1\u0da7 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0d85\u0dad\u0dd2\u0dbb\u0dd2\u0d9a\u0dca\u0dad\u0dba\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dda\u0daf \u0dba\u0db1\u0dca\u0db1.",
        "\u0d91\u0db8 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0\u0dda \u0db1\u0dd2\u0dbb\u0dca\u0daf\u0dda\u0dc1 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0 2022 \u0db1\u0ddc\u0dc0\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca 15 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0da7 \u0db4\u0dd9\u0dbb \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc0\u0dca\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dca\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0d92\u0d9a\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dcf\u0db0\u0dca\u0dba \u0d85\u0d82\u0dc1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dda.\u0da7\u0dd3. \u0d9a\u0db8\u0dbd\u0dca \u0db4\u0daf\u0dca\u0db8\u0dc3\u0dd2\u0dbb\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db1\u0dca.\u0d9a\u0dda.\u0da2\u0dd3.\u0d9a\u0dda. \u0db1\u0dd0\u0db8\u0dca\u0db8\u0dcf\u0dc0\u0dad\u0dca\u0dad",
            "label": "PERSON"
          },
          {
            "text": "\u0d86\u0dbb\u0dca.\u0d91\u0da0\u0dca.\u0dbb\u0dd4\u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dca",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "2022",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd/\u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0d92\u0d9a\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba/\u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4/\u0d86\u0dba\u0dad\u0db1\u0dba",
            "label": "ORG"
          }
        ],
