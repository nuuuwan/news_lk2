        [
          {
            "text": "\u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0baa\u0b9f\u0bc8\u0b95\u0bb3\u0bcd \u0b9c\u0bc6\u0ba9\u0bb0\u0bb2\u0bcd",
