  "text_idx": {
    "en": {
      "title": "8th Executive President takes oath",
      "author": "unknown",
      "body_lines": [
        "Mr. Ranil Wickramasinghe was sworn in as the 8th Executive President of Sri Lanka at the Kotte Parliament premises.",
        "Mr. Ranil Wickramasinghe, who has held the office of Prime Minister six times, will be sworn in as the Executive President for the first time.",
        "Mr. Ranil Wickramasinghe requested to be given the opportunity to take oath at the Parliament premises after becoming the Executive President by parliamentary vote.",
        "Mr. Ranil Wickramasinghe is known as a leader who highly valued parliamentary democracy in his political career."
      ],
