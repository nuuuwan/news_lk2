      "title": "Bus fares up from tonight",
      "author": "unknown",
      "body_lines": [
        "A senior official of the National Transport Commission told Lankadeepa that bus fares will be increased by 22 percent from midnight today (30).",
        "The official added that the minimum bus fare will be increased from 32 rupees to 40 rupees along with the increase in fares."
      ],
      "title_ents": [
        {
          "text": "tonight",
          "label": "TIME"
        }
      ],
      "body_line_ents_list": [
        [
          {
