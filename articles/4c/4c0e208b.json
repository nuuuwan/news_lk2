            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf\u0daf\u0dd3\u0db4",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 22 \u0d9a\u0dd2",
