    "ta": {
      "title": "\u0baa\u0bb3\u0bcd\u0bb3\u0bbf\u0b95\u0bb3\u0bcd \u0bb0\u0b95\u0bcd\u0baa\u0bbf \u0bb2\u0bc0\u0b95\u0bcd 2022 \u0b87\u0bb2\u0bcd \u0b87\u0b9a\u0bbf\u0baa\u0ba4\u0ba9 \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf\u0baf\u0bc0\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0ba4\u0bc1",
