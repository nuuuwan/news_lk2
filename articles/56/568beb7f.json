    "si": {
      "title": "2022 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0d9c\u0dca\u0db6\u0dd2 \u0dbd\u0dd3\u0d9c\u0dba\u0dda \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0dc4\u0d9a\u0dba\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd4\u0dc5 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0dbb \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0d9a\u0ddc\u0dc5\u0db9 \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0db4\u0dcf\u0dc3\u0dbd 2022 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0d9c\u0dca\u0db6\u0dd2 \u0dbd\u0dd3\u0d9c\u0dca \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0dc4\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0d85\u0daf (14) \u0d9a\u0dd2\u0dbb\u0dd4\u0dc5\u0dd4 \u0db4\u0dd0\u0dc5\u0db3\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb, \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dad\u0dca\u0db8\u0db1\u0dca \u0dc1\u0dd6\u0dbb\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0d9c\u0dca\u0db6\u0dd2 \u0dbd\u0dd3\u0d9c\u0dca \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc1\u0dd6\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dda\u0dbb\u0dd3\u0db8\u0dda \u0dad\u0dd3\u0dbb\u0dab\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc0\u0da7\u0dba\u0dda \u0dad\u0dbb\u0d9c\u0dba \u0d89\u0dbb\u0dd2\u0daf\u0dcf (14) \u0d9a\u0ddc\u0dc5\u0db9 \u0dc4\u0dd0\u0dc0\u0dca\u0dbd\u0ddc\u0d9a\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dc0\u0da7\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dad\u0dbb\u0d9c 6\u0db8 \u0da2\u0dba\u0d9c\u0dad\u0dca \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0db4\u0dd2\u0dbd \u0d85\u0db4\u0dbb\u0dcf\u0da2\u0dd2\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0dba. \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0dc0\u0dd6\u0dba\u0dda \u0d91\u0d9a\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0d9a\u0dca \u0db4\u0db8\u0dab\u0dd2.",
        "\u0dad\u0dbb\u0d9c\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0db7\u0dcf\u0d9c\u0dba\u0dda\u0daf\u0dd3 \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 10-6\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d85\u0dbb\u0dca\u0db0\u0dba \u0db1\u0dd2\u0db8\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0db4\u0dc3\u0dd4\u0dc0\u0dd2\u0dba. \u0daf\u0dd9\u0dc0\u0db1 \u0d85\u0dbb\u0dca\u0db0\u0dba\u0dda \u0daf\u0dd3 \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 15\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca \u0d85\u0dad\u0dbb \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0da7 \u0daf\u0dd9\u0dc0\u0db1 \u0d85\u0dbb\u0dca\u0db0\u0dba\u0dda\u0daf\u0dd3 \u0dbd\u0db6\u0dcf \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd6\u0dba\u0dda \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 5\u0d9a\u0dca \u0db4\u0db8\u0dab\u0dd2.",
        "\u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba\u0dda \u0d85\u0db4\u0dbb\u0dcf\u0da2\u0dd2\u0dad \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0db4\u0dd2\u0dbd \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 21\u0da7 15\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dad\u0dbb\u0d9c\u0dba \u0da2\u0dba\u0d9c\u0dad\u0dca \u0d85\u0dad\u0dbb \u0db8\u0dda\u0da2\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dca\u0dbb\u0ddd\u0dba\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 \u0d85\u0db1\u0dd4\u0dc3\u0dca\u0db8\u0dbb\u0dab \u0db4\u0dc5\u0dd2\u0dc4 \u0dba\u0dc5\u0dd2 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0dbb \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba.",
        "\u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba 2017 \u0dc0\u0dc3\u0dbb\u0dda \u0dc3\u0dd2\u0da7 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0da2\u0dba\u0d9c\u0dd9\u0db1 \u0db1\u0dd0\u0dad. \u0d92 \u0d85\u0dad\u0dbb 2019 \u0dc0\u0dc3\u0dbb\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba \u0dc1\u0dd6\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
        "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dad\u0dd8\u0db4\u0dca\u0dad\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0db1 \u0dad\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0dc3\u0dc4\u0dba \u0daf\u0dd9\u0db1\u0dc0\u0dcf: \u0dc3\u0dd3.\u0dc0\u0dd3. \u0dc0\u0dd2\u0d9c\u0dca\u0db1\u0dda\u0dc2\u0dca\u0dc0\u0dbb\u0db1\u0dca"
      ],
