      "body_line_ents_list": [
        [
          {
            "text": "13",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "9.30 \u0db4\u0dd9.\u0dc0.",
            "label": "TIME"
          },
          {
            "text": "\u0db8\u0dda \u0d8b\u0daf\u0dd1\u0dc3\u0db1",
            "label": "TIME"
          }
        ],
        [
          {
            "text": "\u0da2\u0dd3.\u0d91\u0dbd\u0dca \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8",
            "label": "PERSON"
          },
          {
            "text": "\u0da0\u0db1\u0dca\u0db1 \u0da2\u0dba\u0dc3\u0dd4\u0db8\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0da0\u0dbb\u0dd2\u0dad \u0dc4\u0dda\u0dbb\u0dad\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dcf\u0dbd\u0d9a \u0d9c\u0ddc\u0da9\u0dc4\u0dda\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0dd4\u0dab\u0db4\u0dcf\u0dbd \u0dbb\u0dad\u0dca\u0db1\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dd2\u0dbd\u0dcf\u0db1\u0dca \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0d8b\u0daf\u0dba\u0db1 \u0d9a\u0dd2\u0dbb\u0dd2\u0db3\u0dd2\u0d9c\u0ddc\u0da9",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dc3\u0db1\u0dca\u0dad \u0dba\u0dcf\u0db4\u0dcf \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
