  "original_title": "\u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bbe \u0b85\u0ba4\u0bbf\u0bb0\u0b9f\u0bbf \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0baa\u0bcd\u0baa\u0bc1",
  "text_idx": {
    "en": {
      "title": "President Quota Action Announcement",
      "author": "unknown",
      "body_lines": [
        "\"President Gotabaya Rajapaksa said that steps have been taken to distribute gas, fuel, essential items and medicines. He also said that the current situation will be resolved in a couple of days."
      ],
      "title_ents": [
        {
          "text": "Quota Action",
