    "si": {
      "title": "\u0d85\u0daf \u0daf\u0dd2\u0db1 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0db1 \u0dc3\u0dd3\u0db8\u0dd2\u0dad \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0dc3\u0dda\u0dc0\u0dba\u0da7 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d85\u0daf (\u0da2\u0dd4\u0dbd\u0dd2 06) \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba 48 \u0db1\u0dca 22 \u0d9a\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db6\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dda\u0dc0\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
