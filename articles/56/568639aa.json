    "si": {
      "title": "\u0d9a\u0ddc\u0dc5\u0db9 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0dc0\u0dd0\u0daf\u0d9c\u0dad\u0dca \u0db4\u0dab\u0dd2\u0dc0\u0dd2\u0da9\u0dba\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0dc4\u0dd9\u0da7 (3) \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 8 \u0dc3\u0dd2\u0da7 \u0d89\u0dbb\u0dd2\u0daf\u0dcf \u0d85\u0dbd\u0dd4\u0dba\u0db8 2 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0dbb\u0dd0\u0dc3\u0d9a\u0da7 \u0db4\u0dd0\u0dba 18\u0d9a \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8\u0dca \u0dad\u0dc4\u0db1\u0db8\u0d9a\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dda.",
        "\u0d85\u0db9\u0dad\u0dbd \u0da2\u0dbd \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0db6\u0dbd\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dba\u0da7\u0dd2\u0dad\u0dbd \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca\u0dc0\u0dbd \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d85\u0dbd\u0dd4\u0dad\u0dca\u0dc0\u0dd0\u0da9\u0dd2\u0dba\u0dcf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db1 \u0db6\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0daf\u0db1\u0dca\u0dc0\u0dcf \u0d87\u0dad.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0ddc\u0dc5\u0db9, \u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd - \u0d9a\u0dbd\u0dca\u0d9a\u0dd2\u0dc3\u0dcf\u0dba\u0dd2, \u0d9a\u0ddc\u0da7\u0dcf, \u0d9a\u0da9\u0dd4\u0dc0\u0dd9\u0dbd \u0db8\u0dc4 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0dbd\u0da7 \u0d85\u0dba\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0dc3\u0dc4 \u0db8\u0dc4\u0dbb\u0d9c\u0db8, \u0db6\u0ddc\u0dbb\u0dbd\u0dc3\u0dca\u0d9c\u0db8\u0dd4\u0dc0, \u0d9a\u0ddc\u0dc5\u0db1\u0dca\u0db1\u0dcf\u0dc0\u0dda \u0dba\u0db1 \u0db8\u0dc4 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0dbd\u0da7 \u0d85\u0dba\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0db8\u0dd9\u0db8 \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0dc3\u0dd3\u0db8\u0dcf \u0d9a\u0dd9\u0dbb\u0dd9\u0db1\u0dd4 \u0d87\u0dad\u0dd2.",
        "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8, \u0d9a\u0ddc\u0da7\u0dca\u0da7\u0dd2\u0d9a\u0dcf\u0dc0\u0dad\u0dba\u0dd2 - \u0db8\u0dd4\u0dbd\u0dca\u0dbd\u0dda\u0dbb\u0dd2\u0dba\u0dcf\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0, \u0dbb\u0dad\u0dca\u0db8\u0dbd\u0dcf\u0db1\u0dba\u0dd2 \u0dc3\u0dc4 \u0d9a\u0da7\u0dd4\u0db4\u0dd9\u0dad\u0dd2 \u0dba\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba\u0dd2. (\u0d86)"
      ],
      "title_ents": [
        {
          "text": "\u0d9a\u0ddc\u0dc5\u0db9",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "18-\u0db4\u0dd0\u0dba",
            "label": "TIME"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dd9\u0da7 \u0d8b\u0daf\u0dda 8",
            "label": "TIME"
          },
          {
            "text": "2",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d89\u0dbb\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db9\u0dad\u0dbd \u0da2\u0dbd \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0db6\u0dbd\u0dcf\u0d9c\u0dcf\u0dbb\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd-\u0d9a\u0dbd\u0dca\u0d9a\u0dd2\u0dc3\u0dcf\u0dba\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4\u0dbb\u0d9c\u0db8, \u0db6\u0ddc\u0dbb\u0dbd\u0dc3\u0dca\u0d9c\u0db8\u0dd4\u0dc0, \u0d9a\u0ddc\u0dbd\u0db1\u0dca\u0db1\u0dcf\u0dc0\u0dda \u0db8\u0dc4 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0da7\u0dca\u0da7\u0dd2\u0d9a\u0dcf\u0dc0\u0dad\u0dba\u0dd2",
