          },
          {
            "text": "\u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dad\u0db4\u0dd4\u0dbb\u0db8\u0dca \u0dbb\u0da2\u0dba\u0dda \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dbb\u0ddd\u0dc4\u0dbd",
