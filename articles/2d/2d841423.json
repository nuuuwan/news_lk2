      ],
      "body_line_ents_list": [
        [
          {
            "text": "The Ministry of Finance",
            "label": "ORG"
          },
          {
            "text": "more than 300",
            "label": "CARDINAL"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0db7\u0dcf\u0dab\u0dca\u0da9 300\u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0d86\u0db1\u0dba\u0db1\u0dba \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7\u0dd2 , \u0dba\u0ddd\u0d9c\u0da7\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd2 \u0d86\u0dc4\u0dcf\u0dbb , \u0db4\u0dbd\u0dad\u0dd4\u0dbb\u0dd4, \u0da0\u0ddc\u0d9a\u0dbd\u0da7\u0dca, \u0dc3\u0dd4\u0dc0\u0db3 \u0dc0\u0dd2\u0dbd\u0dc0\u0dd4\u0db1\u0dca, \u0dbb\u0dd6\u0db4\u0dbd\u0dcf\u0dc0\u0db1\u0dca\u200d\u0dba \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0d87\u0db3\u0dd4\u0db8\u0dca, \u0dc0\u0dcf\u0dba\u0dd4\u0dc3\u0db8\u0dd3\u0d9a\u0dbb\u0dab, \u0dc1\u0dd3\u0dad\u0d9a\u0dbb\u0dab, \u0d9c\u0dd8\u0dc4 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab, \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db7\u0dcf\u0dab\u0dca\u0da9 300 \u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dad\u0dcf\u0dc0\u0d9a\u0dcf\u0dbd\u0dd2\u0d9a\u0dc0 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [
        {
          "text": "300 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2",
