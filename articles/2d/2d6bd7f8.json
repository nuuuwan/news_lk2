          }
        ],
        [
          {
            "text": "\u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dad\u0dd2\u0dbd\u0d9a",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dba\u0db1\u0dca\u0dad \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dad\u0dd2\u0dbd\u0d9a",
            "label": "PERSON"
