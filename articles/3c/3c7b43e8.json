          },
          {
            "text": "\u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dba",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dd0\u0db4\u0dca\u0dad\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca \u0db8\u0dcf\u0dc3 \u0dc4\u0dad\u0dbb",
            "label": "DATE"
          },
