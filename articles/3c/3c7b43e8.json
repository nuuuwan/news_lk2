      "body_line_ents_list": [
        [
          {
            "text": "\u0db8\u0dd6\u0dbd\u0dca\u0dba \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc3\u0dca\u0dae\u0dcf\u0dba\u0dd3\u0d9a\u0dbb\u0dab \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dda.\u0d91\u0db8\u0dca.",
