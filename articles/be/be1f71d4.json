            "label": "DATE"
          }
        ],
        [],
        [
          {
            "text": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "LOC"
          }
        ],
        [
          {
            "text": "\u0d92 \u0d9a\u0ddc\u0dc5\u0db9 \u0da9\u0dcf\u0dbb\u0dca\u0dbd\u0dd2 \u0db4\u0dcf\u0dbb\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4 \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda\u0daf\u0dd3\u0dba\u0dd2",
