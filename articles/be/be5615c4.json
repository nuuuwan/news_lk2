    "si": {
      "title": "\u0dc3\u0dad\u0dd2\u0dba\u0d9a\u0daf\u0dd3 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0dc4\u0dd4  1590\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 1590\u0d9a\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0dda\u0daf\u0dd3\u00a0 \u00a0\u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d91\u0db8 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca\u00a0 \u0dc3\u0dd2\u0dba\u0dba\u0da7 50.8 \u0d9a\u0dca\u0db8 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad\u0dd9\u0db1\u0dd2",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb\u00a0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3 \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc3 56 \u0d9a\u0dca \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0d85\u0db0\u0dd2\u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0dca \u0d9a\u0dbd\u0dcf\u0db4 \u0dbd\u0dd9\u0dc3 \u0db1\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0d92\u0d9a\u0d9a\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
