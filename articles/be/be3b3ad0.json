  "time_ut": 1661847398,
  "original_lang": "si",
  "original_title": "\u0dbb\u0da2\u0dba\u0da7 \u0db8\u0dd2\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc0\u0dcf\u0dc4\u0db1 \u0db4\u0db8\u0dab\u0dba\u0dd2",
  "text_idx": {
    "en": {
      "title": "The government will only have electric vehicles from now on",
      "author": "unknown",
      "body_lines": [
        "In his budget speech, the President said that as a government policy, the purchase of fossil fuel-based vehicles will be suspended from now on.",
        "He said that in the future, electric vehicles will be purchased for public service and the private sector will also be encouraged to use such vehicles."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [],
        []
      ]
    },
    "si": {
      "title": "\u0dbb\u0da2\u0dba\u0da7 \u0db8\u0dd2\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc0\u0dcf\u0dc4\u0db1 \u0db4\u0db8\u0dab\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db4\u0dad\u0dca\u0dad\u0dd2\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dbb\u0da2\u0dba\u0dda \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd2\u0db1\u0dca \u0db8\u0dad\u0dd4 \u0db4\u0ddc\u0dc3\u0dd2\u0dbd \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dcf\u0daf\u0d9a \u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dc0\u0dcf\u0dc4\u0db1 \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db1 \u0db6\u0dc0 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0dd2\u0dba \u0d85\u0dba\u0dc0\u0dd0\u0dba \u0d9a\u0dae\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0db1 \u0dc0\u0dcf\u0dc4\u0db1 \u0db8\u0dd2\u0dbd\u0daf\u0dd2 \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0\u0dad\u0dca \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0d85\u0d82\u0dc1\u0dba\u0da7\u0daf \u0db8\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc0\u0dcf\u0dc4\u0db1 \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d8b\u0db1\u0db1\u0dca\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [],
        []
      ]
    },
    "ta": {
      "title": "\u0b87\u0ba9\u0bbf \u0bae\u0bbf\u0ba9\u0bcd\u0b9a\u0bbe\u0bb0 \u0bb5\u0bbe\u0b95\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0b9f\u0bcd\u0b9f\u0bc1\u0bae\u0bc7 \u0b85\u0bb0\u0b9a\u0bbf\u0b9f\u0bae\u0bcd \u0b87\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b85\u0bb0\u0b9a\u0bbe\u0b99\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0b95\u0bca\u0bb3\u0bcd\u0b95\u0bc8\u0baf\u0bca\u0ba9\u0bcd\u0bb1\u0bbf\u0ba9\u0bcd \u0baa\u0b9f\u0bbf, \u0baa\u0bc1\u0ba4\u0bc8\u0baa\u0b9f\u0bbf\u0bb5 \u0b8e\u0bb0\u0bbf\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bc8\u0b95\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f \u0bb5\u0bbe\u0b95\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bc8 \u0b95\u0bca\u0bb3\u0bcd\u0bb5\u0ba9\u0bb5\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0bb5\u0ba4\u0bc1 \u0b87\u0ba9\u0bbf \u0b87\u0b9f\u0bc8\u0ba8\u0bbf\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0ba9 \u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0ba4\u0ba9\u0ba4\u0bc1 \u0bb5\u0bb0\u0bb5\u0bc1 \u0b9a\u0bc6\u0bb2\u0bb5\u0bc1\u0ba4\u0bcd \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f \u0b89\u0bb0\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0b95\u0bbe\u0bb2\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0bca\u0ba4\u0bc1 \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0b95 \u0bae\u0bbf\u0ba9\u0bcd\u0b9a\u0bbe\u0bb0 \u0bb5\u0bbe\u0b95\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bca\u0bb3\u0bcd\u0bb5\u0ba9\u0bb5\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0ba9\u0bb5\u0bc1\u0bae\u0bcd, \u0ba4\u0ba9\u0bbf\u0baf\u0bbe\u0bb0\u0bcd \u0ba4\u0bc1\u0bb1\u0bc8\u0baf\u0bbf\u0ba9\u0bb0\u0bc1\u0bae\u0bcd \u0b85\u0bb5\u0bcd\u0bb5\u0bbe\u0bb1\u0bbe\u0ba9 \u0bb5\u0bbe\u0b95\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bc8 \u0baa\u0baf\u0ba9\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0b8a\u0b95\u0bcd\u0b95\u0bc1\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0ba9\u0bb5\u0bc1\u0bae\u0bcd \u0b85\u0bb5\u0bb0\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ],
