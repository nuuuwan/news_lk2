    "si": {
      "title": "\u0dc4\u0dd9\u0da7 \u0dc0\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dd2\u0da7\u0dad\u0da7 \u0db1\u0ddc\u0dba\u0db1 \u0db6\u0dc0\u0da7 \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dc3\u0dc4 \u0db6\u0dd0\u0dc3\u0dd2\u0dbd\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dc2\u0dca\u0da8\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0da5\u0dcf \u0daf\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2, \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db6\u0dd0\u0dc3\u0dd2\u0dbd\u0dca \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0dc3\u0dc4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d91\u0dc3\u0dca.\u0d86\u0dbb\u0dca. \u0d86\u0da7\u0dd2\u0d9c\u0dbd \u0db8\u0dc4\u0dad\u0dcf \u0dc4\u0dd9\u0da7 (\u0da2\u0dd4\u0dbd\u0dd2 14) \u0dc0\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0dbb\u0da7\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dc0 \u0db1\u0ddc\u0dba\u0db1 \u0db6\u0dc0\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dc2\u0dca\u0da8\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0da5\u0dcf \u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d85\u0daf \u0daf\u0dd9\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9a\u0dbb\u0dd4 \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
