        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc3\u0dd4\u0dc3\u0dd9\u0dba\u0dd2 \u0d87\u0dbd\u0dd9\u0d9a\u0dca\u0dc3\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca'",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddc\u0d82\u0d9c\u0dca\u0dbb\u0dc3\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "ECJ \u0da2\u0dd3\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0dab\u0dca\u0da9\u0db8\u0db1\u0dca",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba\u0dda \u0d89\u0dc4\u0dc5 \u0db4\u0dd9\u0dc5\u0dda \u0dc0\u0dd2\u0db1\u0dba \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "WORK_OF_ART"
          },
          {
            "text": "21 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0db6\u0dca\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0",
