    "si": {
      "title": "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0dba\u0dd0\u0dc0\u0dd3\u0db8 \u0dba\u0dc5\u0dd2 \u0d87\u0dbb\u0db9\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0dba\u0dc0\u0db1 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0dc4\u0dd9\u0da7 (25) \u0dc3\u0dd2\u0da7 \u0db1\u0dd0\u0dc0\u0dad \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0db7\u0dcf\u0dbb\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca\u0db4\u0dad\u0dd2 \u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0d86\u0dbb\u0dd2\u0dba\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
