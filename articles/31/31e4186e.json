    "si": {
      "title": "\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0d9a\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0d86\u0db4\u0dc3\u0dd4 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8 \u0d86\u0daf\u0dcf\u0dbb\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dc3\u0dd2\u0da7 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd\u0da7, \u0db8\u0dc4\u0dbb\u0d9c\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0d9a\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d9c\u0dd2\u0dbd\u0db1\u0dca \u0dbb\u0dae\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1\u0dba\u0d9a\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db1\u0dd0\u0dc0\u0dad \u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8 \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba\u0dcf.",
        "\u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8 \u0d86\u0daf\u0dcf\u0dbb\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0da9\u0dd2\u0dbd\u0dcf\u0da9\u0dd2\u0dba\u0dcf \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dda\u0daf\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dbb\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0dba\u0db1 \u0d9c\u0dd2\u0dbd\u0db1\u0dca \u0dbb\u0dae\u0dba\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0db1\u0ddc\u0daf\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0daf\u0dd0\u0da9\u0dd2 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u0dc0\u0dbd\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0db4\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2."
      ],
      "title_ents": [],
