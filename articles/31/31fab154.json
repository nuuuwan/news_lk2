    "si": {
      "title": "\u0dc0\u0db3\u0dd4\u0dbb\u0dd4 \u0d8b\u0dab, \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19, \u0d91\u0da0\u0dca.\u0d85\u0dba\u0dd2.\u0dc0\u0dd3.  \u0dad\u0dd4\u0db1\u0db8 \u0d91\u0d9a\u0dc0\u0dbb \u0dc4\u0dd0\u0daf\u0dd2\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0dad\u0dcf\u0dbd\u0dd2\u0dba\u0dda 36 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dc3\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0d9a\u0dd4\u0da7 \u0dc0\u0db3\u0dd4\u0dbb\u0dd4 \u0d8b\u0dab, \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19 \u0dc3\u0dc4 \u0d91\u0da0\u0dca.\u0d85\u0dba\u0dd2.\u0dc0\u0dd3. \u00a0\u200d\u0dad\u0dd4\u0db1\u0db8 \u0d91\u0d9a\u0dc0\u0dbb \u0d86\u0dc3\u0dcf\u0daf\u0db1\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d91\u0dbb\u0da7 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc0\u0db3\u0dd4\u0dbb\u0dd4 \u0d8b\u0dab, \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19 \u0dc3\u0dc4 \u0d91\u0da0\u0dca.\u0d85\u0dba\u0dd2.\u0dc0\u0dd3. \u0dba\u0db1\u0dd4 \u0dc0\u0dba\u0dd2\u0dbb\u0dc3 \u0dbb\u0ddd\u0d9c \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0dbb\u0ddd\u0d9c \u0dad\u0dd4\u0db1\u0db8 \u0d91\u0d9a\u0db8 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0d9a\u0dd4\u0d9c\u0dd9\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0dc0\u0dd4\u0dab\u0dd4 \u0db4\u0dc5\u0db8\u0dd4 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0db8\u0dd9\u0dba \u0dba\u0dd0\u0dba\u0dd2 \u0daf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd9\u0dba\u0dd2.",
        "\u0dc3\u0dca\u0db4\u0dcf\u0da4\u0dca\u0da4\u0dba\u0dda \u0daf\u0dd2\u0db1 \u0db4\u0dc4\u0d9a \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0db8\u0dcf \u0d9a\u0dbb \u0d86\u0db4\u0dc3\u0dd4 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db8\u0dd9\u0db8 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0da7 \u0daf\u0dd2\u0db1 \u0db1\u0dc0\u0dba\u0d9a\u0da7 \u0db4\u0db8\u0dab \u0db4\u0dc3\u0dd4 \u0d8b\u0dab, \u0d8b\u0d9c\u0dd4\u0dbb\u0dda \u0d85\u0db8\u0dcf\u0dbb\u0dd4\u0dc0, \u0dad\u0dd9\u0dc4\u0dd9\u0da7\u0dca\u0da7\u0dd4\u0dc0, \u0dc4\u0dd2\u0dc3\u0dbb\u0daf\u0dba \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4 \u0db4\u0dc0\u0dc3\u0dad\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0dd6\u0dbb\u0dca\u0dab \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf\u0dc0\u0d9a\u0da7 \u0dbd\u0d9a\u0dca \u0d9a\u0dbb\u0daf\u0dca\u0daf\u0dd3 \u0d94\u0dc4\u0dd4 \u0dc0\u0db3\u0dd4\u0dbb\u0dd4 \u0d8b\u0dab, \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19 \u0dc3\u0dc4 \u0d91\u0da0\u0dca.\u0d85\u0dba\u0dd2.\u0dc0\u0dd3. \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0d9a\u0dd4 \u0db6\u0dc0 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd2\u0dba. \u0db8\u0dd9\u0db8 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0da7 \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19\u2019 \u0d86\u0dc3\u0dcf\u0daf\u0db1\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd9\u0dba\u0dd2."
      ],
