    "si": {
      "title": "\u0d87\u0db6\u0ddc\u0da7\u0dca\u0dc3\u0dca\u0dbd\u0dd3 \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba \u0dad\u0dc0\u0dad\u0dca \u0dc3\u0dbb\u0dca\u0dc0\u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9c\u0dad \u0db8\u0dd2\u0dbd\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d9a\u0dbb \u0d9c\u0db1\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d87\u0db6\u0ddc\u0da7\u0dca\u0dc3\u0dca\u0dbd\u0dd2 \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba \u0dbb\u0dd4. \u0da2\u0dd4\u0dbd\u0dd2 27 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dad\u0dda \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda\u0daf\u0dd3 \"\u0dc6\u0dca\u0dbd\u0ddd\u0dbb\u0db1\u0dca\u0dc3\u0dca\" \u0dbd\u0d9a\u0dd4\u0dab \u0dba\u0da7\u0dad\u0dda CTC High Grown PF1 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0da7 \u0dbb\u0dd4. \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0dbd\u0daf \u0dad\u0dda \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0d91\u0db8 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca \u0d91\u0d9a\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1,460 \u0d9a\u0dd2.",
        "\u0d87\u0db6\u0ddc\u0da7\u0dca\u0dc3\u0dca\u0dbd\u0dd3 \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba \u0dc4\u0dd0\u0da7\u0db1\u0dca \u0d9a\u0dbd\u0dcf\u0db4\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0dc4\u0dd0\u0da7\u0db1\u0dca \u0dc0\u0dad\u0dd4\u0d9a\u0dbb\u0dba\u0dda \u0dc0\u0dd2\u0dc2\u0dba \u0db4\u0dae\u0dba\u0da7 \u0d85\u0dba\u0dad\u0dca \u0dc0\u0dda. \u0db8\u0dd9\u0db8 \u0dad\u0dda \u0db4\u0dda\u0dbd\u0dd2\u0dba Sun Shine Tea Ltd \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0d9a\u0dbb \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dca\u0daf\u0dda \u0dad\u0dda \u0dad\u0dd0\u0dbb\u0dd0\u0dc0\u0dca\u0d9a\u0dbb\u0dd4 \u0da2\u0ddd\u0db1\u0dca \u0d9a\u0dd3\u0dbd\u0dca\u0dc3\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dd2."
