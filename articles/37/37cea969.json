    "en": {
      "title": "Notification issued by Sri Lanka Electricity Board",
      "author": "unknown",
      "body_lines": [
        "Sri Lanka Electricity Board has announced that electricity consumers can receive their monthly electricity bills via email.",
        "Consumers are requested to visit the official website of Sri Lanka Electricity Board and register for e-Bill service.",
        "Sri Lanka Electricity Board has informed the consumers to type the account number as \u201cEBILL\u201d and send it to 1989. (a)"
      ],
