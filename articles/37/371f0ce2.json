          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0da2\u0db1 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dca\u0da7\u0dd1\u0db1\u0dca\u0da9\u0dbb\u0dca\u0da9\u0dca \u0da0\u0dcf\u0dbb\u0dca\u0da7\u0da9\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba",
            "label": "NORP"
          },
          {
            "text": "\u0dab\u0dba\u0dc0\u0dbb \u0dbd\u0dd2\u0db4\u0dd2\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd2\u0db1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0da7 \u0db4\u0dc3\u0dd4",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba",
