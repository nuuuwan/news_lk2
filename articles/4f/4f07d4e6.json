        [],
        [
          {
            "text": "\u0db8\u0dc4\u0dc0 \u0db4\u0dbd\u0dcf\u0dbd\u0dca\u0dbd \u0db1\u0dc0\u0ddd\u0daf\u0dba \u0db4\u0dcf\u0dc3\u0dbd \u0dc3\u0dc4 \u0dc0\u0dd2\u0da2\u0dba\u0db4\u0dad\u0dd2\u0dba \u0db4\u0dcf\u0dc3\u0dbd",
