      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b95\u0bbe\u0bb2\u0bc8",
            "label": "TIME"
          },
          {
            "text": "\u0b9e\u0bbe\u0baf\u0bbf\u0bb1\u0bcd\u0bb1\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8 31",
            "label": "DATE"
          },
          {
            "text": "\u0b89\u0ba9\u0bcd\u0ba9\u0bbf\u0b9a\u0bcd\u0b9a\u0bc8, \u0ba8\u0bc6\u0b9f\u0bbf\u0baf\u0bae\u0b9f\u0bc1",
            "label": "ORG"
