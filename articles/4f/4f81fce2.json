    },
    "si": {
      "title": "\u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0dc3\u0db8\u0dca\u0db6\u0dcf \u0dc3\u0dc4\u0dbd\u0dca \u0dc4\u0dcf \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0db8\u0dd2\u0dbd \u0dc3\u0dad\u0ddc\u0dc3 \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0dad\u0ddc\u0dc3 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0dc3\u0dd0\u0dbd\u0dca\u0dc0\u0dbd \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0dc3\u0db8\u0dca\u0db6\u0dcf \u0dc3\u0dc4\u0dbd\u0dca \u0dc3\u0dc4 \u0dbb\u0dad\u0dd4 \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dc5\u0dd2\u0db1\u0dca \u0dbb\u0dd4. 21 \u0dc3\u0dc4 25\u00a0 \u0d85\u0da9\u0dd4\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda. \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0dc3\u0db8\u0dca\u0db6\u0dcf \u0dc3\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a \u0db1\u0dc0 \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 194 \u0d9a\u0dca \u0dc0\u0db1 \u0d85\u0dad\u0dbb\u00a0 \u0dbb\u0dad\u0dd4 \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 460\u0d9a\u0dd2\u0dd2."
      ],
      "title_ents": [],
