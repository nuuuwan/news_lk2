    "si": {
      "title": "\u0dc4\u0dbb\u0dca\u0dc2\u0d9c\u0dda \u2019\u2019\u0d9a\u0db4\u0dd4\u0da7\u0dd4\u2019\u2019\u0d9a\u0dad\u0dcf\u0dc0\u0da7 \u0da9\u0dba\u0db1\u0dcf\u0d9c\u0dd9\u0db1\u0dca \u2019\u2019\u0d9a\u0db4\u0dd4\u0da7\u0dd4\u2019\u2019\u0d8b\u0dad\u0dca\u0dad\u0dbb\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d9a\u0db4\u0dd4\u0da7\u0dd4 \u0d9a\u0dd6\u0da9\u0dd4\u0dc0\u0dda \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0daf\u0dd0\u0db8\u0dd3\u0db8 \u0dba\u0dd0\u0dba\u0dd2 \u0db4\u0dad\u0dca\u0d9a\u0dc5 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0db1\u0dd3\u00a0 \u0da9\u0dba\u0db1\u0dcf \u0d9c\u0db8\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dcf\u0dba.",
        "\u0d9a\u0db4\u0dd4\u0da7\u0dd4 \u0d9a\u0dd6\u0da9\u0dd4\u0dc0\u0dda \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0daf\u0dd0\u0db8\u0dd6 \u0d9a\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0dc4\u0dbb\u0dca\u0dc2 \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dc3\u0dd6 \u0db6\u0dc0 \u0d9a\u0dd3 \u0da9\u0dba\u0db1\u0dcf \u0d9c\u0db8\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0d92 \u0d9a\u0dad\u0dcf\u0dc0 \u0d87\u0dc3\u0dd4\u0dab\u0dd4 \u0dc0\u0dd2\u0da7 \u0dad\u0db8\u0dcf\u0da7 \u0dc4\u0dd2\u0db1\u0dcf \u0d9c\u0dd2\u0dba \u0db6\u0dc0 \u0daf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dcf\u0dba.",
        "\u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \"\u0db8\u0d9c\u0dda \u0d9a\u0dd6\u0da9\u0dd4\u0dc0\u0da7\" \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0daf\u0dd0\u0db8\u0dd3\u0db8 \u0dba\u0dd0\u0dba\u0dd2 \u0daf \u0d89\u0dad\u0dd2\u0db1\u0dca \u0d9a\u0db4\u0dd4\u0da7\u0dd4 \u0d9a\u0dd6\u0da9\u0dd4\u0dc0\u0dda \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0daf\u0db8\u0db1\u0dca\u0db1\u0da7 \u0d91\u0db4\u0dcf \u0dba\u0dd0\u0dba\u0dd2 \u0d9a\u0dd2\u0dba\u0db8\u0dd2\u0db1\u0dca \u0d94\u0db6 \u0dad\u0dd4\u0db8\u0dcf\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dba\u0dcf\u0da7 \u0db4\u0dc4\u0dbb \u0d9c\u0dc3\u0db1\u0dca\u0db1\u0da7 \u0d91\u0db4\u0dcf \u0dba\u0dd0\u0dba\u0dd2\u0daf \u0da9\u0dba\u0db1\u0dcf \u0d9c\u0db8\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dcf\u0dba.",
        "\u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba\u0dda \u0d9a\u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dc4\u0dbb\u0dca\u0dc2 \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0db8\u0dad\u0db8\u0dd2\u0db1\u0dca \u0d8a\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda \"\u0dbb\u0db1\u0dd2\u0dbd\u0dca\u0d9c\u0dda \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db4\u0dad\u0dca\u0dad\u0dd2\u0dba \u0d9a\u0dcf\u0d9a\u0dca \u0d9a\u0dd6\u0da9\u0dd4\u0dc0\u0dda \u0dc4\u0daf\u0db4\u0dd4 \u0d9a\u0ddc\u0dc4\u0dcf \u0db4\u0dd0\u0da7\u0dc0\u0d9a\u0dd4 \u0dc0\u0d9c\u0dda\" \u0db6\u0dc0\u0dba\u0dd2."
      ],
