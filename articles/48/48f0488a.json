    "si": {
      "title": "\u0daf\u0dd6\u0dc2\u0dab\u0dba\u0dd9\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dc4\u0dd2\u0db8\u0dd2 \u0dad\u0dd0\u0db1",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da7\u0dca\u200d\u0dbb\u0dcf\u0db1\u0dca\u0dc3\u0dca\u0db4\u0dda\u0dbb\u0db1\u0dca\u0dc3\u0dd2 \u0d89\u0db1\u0dca\u0da7\u0dbb\u0dca\u0db1\u0dd0\u0dc2\u0db1\u0dbd\u0dca (TI) \u0dc4\u0dd2 \u0db1\u0dc0\u0dad\u0db8 \u0daf\u0dd6\u0dc2\u0dab \u0dc3\u0d82\u0da2\u0dcf\u0db1\u0db1 \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba\u0dda (2021 \u0dc0\u0dc3\u0dbb) \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 102 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad.",
        "\u0db8\u0dd9\u0db8 \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba \u0dbd\u0ddc\u0dc0 \u0db4\u0dd4\u0dbb\u0dcf \u0dbb\u0da7\u0dc0\u0dbd\u0dca \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 180\u0d9a \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba\u0dda \u0daf\u0dd6\u0dc2\u0dab \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0d9c\u0dad \u0d9a\u0dbb\u0dba\u0dd2. \u0dc3\u0db8\u0dcf\u0dbd\u0ddd\u0da0\u0db1 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0dda 4 \u0dc0\u0db1 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba \u0db1\u0dd2\u0dbb\u0dca\u0daf\u0dda\u0dc1 \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0dda \"\u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0 \u0dc1\u0d9a\u0dca\u0dad\u0dd2\u0db8\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0dc4 \u0daf\u0dd6\u0dc2\u0dd2\u0dad \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba\u0db1\u0dca \u0d85\u0dc0\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4\u0dba\u0db1\u0dca \u0daf\u0dd2\u0d9c\u0da7\u0db8 \u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dcf \u0dba\u0dd4\u0dad\u0dd4\" \u0db6\u0dc0\u0dba\u0dd2."
      ],
      "title_ents": [
