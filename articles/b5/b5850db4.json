    "si": {
      "title": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dba\u0dcf\u0d9c \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0da7 \u0dc0\u0dc3\u0dbb 86\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab \u0dc0\u0dda.",
        "1936 \u0daf\u0dd3 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0dda \u0daf\u0dd0\u0db1\u0da7 \u0dc3\u0dad\u0dd4\u0db1\u0dca 4000\u0d9a\u0dca \u0db4\u0db8\u0dab \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dad\u0dbb, \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dd4. \u0db8\u0dda \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0d9a\u0dd1\u0db8 \u0daf\u0dd9\u0db1\u0dca\u0db1 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 45\u0d9a\u0dca.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 86 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb\u0dba\u0da7 \u0dc3\u0db8\u0d9c\u0dcf\u0db8\u0dd3\u0dc0 \u0db8\u0dd9\u0dbb\u0da7 \u0dc0\u0dad\u0dca\u0db8\u0db1\u0dca \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dca\u0dbd\u0da7 \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u2018\u0dc3\u0dad\u0dca\u0dc0 \u0dc3\u0dc0\u0dd2\u0dba\u2019 \u0db1\u0db8\u0dd2\u0db1\u0dca \u0db1\u0dc0 \u0db4\u0ddd\u0dc2\u0dab \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0dc3\u0dc4 \u0db4\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dba\u0dcf\u0d9c \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0d85\u0daf (03) \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dcf.",
        "\u0db8\u0dd9\u0db8 \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1 \u0dba\u0da7\u0dad\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d95\u0db1\u0dd1\u0db8 \u0db4\u0dd4\u0dbb\u0dc0\u0dd0\u0dc3\u0dd2\u0dba\u0dd9\u0d9a\u0dd4\u0da7 \u0d91\u0d9a\u0dca \u0dc3\u0dad\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0dc4\u0ddd \u0dc3\u0dad\u0dd4\u0db1\u0dca \u0dc3\u0db8\u0dd6\u0dc4\u0dba\u0d9a \u0dc0\u0d9c\u0d9a\u0dd3\u0db8 \u0db7\u0dcf\u0dbb\u0d9c\u0dd9\u0db1 \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0da7 \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dc4 \u0d85\u0db1\u0dd9\u0d9a\u0dd4\u0dad\u0dca \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dad\u0dcf \u0dbd\u0db6\u0dcf \u0daf\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba."
      ],
