          },
          {
            "text": "\u0d9a\u0dbd\u0dca\u0db8\u0dd4\u0dab\u0dda",
            "label": "ORG"
          },
          {
            "text": "\u0d94\u0da7\u0db8\u0dcf\u0dc0\u0dcf\u0da9\u0dd2",
