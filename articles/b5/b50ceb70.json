          },
          {
            "text": "\u0d9a\u0dbd\u0dca\u0db8\u0dd4\u0dab\u0dda",
            "label": "GPE"
          },
          {
            "text": "\u0d85\u0db8\u0dca\u0db4\u0dcf\u0dbb\u0dba\u0dd2",
