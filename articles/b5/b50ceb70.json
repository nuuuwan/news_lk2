            "label": "QUANTITY"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dbd\u0dca\u0db8\u0dd4\u0dab\u0dda \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dbd\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db8\u0dca\u0db4\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0d89\u0dbb\u0dd2\u0daf\u0dcf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda",
            "label": "TIME"
          },
          {
            "text": "03 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "FAC"
          },
          {
            "text": "\u0db8\u0da9\u0d9a\u0dbd\u0db4\u0dd4\u0dc0 \u0d9a\u0dd9\u0dc3\u0dd9\u0dbd\u0dca \u0d9a\u0da9\u0daf\u0dcf\u0dc3\u0dd2 \u0d9a\u0db8\u0dca\u0dc4\u0dbd \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0d85\u0d82\u0dc1\u0dba",
            "label": "EVENT"
          }
        ],
        [
          {
            "text": "30 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
