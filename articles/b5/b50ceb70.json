          },
          {
            "text": "\u0dc3\u0dda\u0db1\u0dcf\u0db0\u0dd2\u0dbb \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0da2\u0dda.\u0d86\u0dbb\u0dca",
