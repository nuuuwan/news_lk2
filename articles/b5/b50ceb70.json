          {
            "text": "\u0dc0\u0dbb\u0dd4\u0dab \u0da2\u0dba\u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db8\u0dca\u0db4\u0dcf\u0dbb \u0d9a\u0dbd\u0dcf\u0db4\u0dba",
