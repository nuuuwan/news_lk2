        [
          {
            "text": "\u0ba4\u0bc7\u0baf\u0bbf\u0bb2\u0bc8 \u0b9a\u0bbf\u0bb1\u0bc1 \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0baa\u0bbf\u0bb5\u0bbf\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0b9a\u0baa\u0bc8",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0ba4\u0bc7\u0baf\u0bbf\u0bb2\u0bc8 \u0b9a\u0bbf\u0bb1\u0bc1 \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0baa\u0bbf\u0bb5\u0bbf\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0b9a\u0baa\u0bc8",
            "label": "ORG"
          },
