  "original_title": "\u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad \u0dc0\u0dd9\u0dba\u0dd2",
  "text_idx": {
