          },
          {
            "text": "\u0bb5\u0bc6\u0bb3\u0bcd\u0bb3\u0bc8 \u0bae\u0bbe\u0bb3\u0bbf\u0b95\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bbf\u0bb0\u0bbe\u0b99\u0bcd\u0b95\u0bcd\u0bb3\u0bbf\u0ba9\u0bcd \u0b85\u0bb1\u0bc8",
            "label": "FAC"
          },
          {
            "text": "\u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc1\u0bb1\u0bb5\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb1\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0b95\u0ba3\u0bcd \u0b9a\u0bbf\u0bae\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1\u0ba4\u0bb2\u0bcd",
