    "si": {
      "title": "\u0da0\u0dd3\u0db1\u0dba\u0dda \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0: 46\u0d9a\u0dca \u0db8\u0dbb\u0dd4\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da0\u0dd3\u0db1\u0dba\u0dda \u0d9a\u0db3\u0dd4\u0d9a\u0dbb \u0dc3\u0dd2\u0da0\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0dbb\u0dd2\u0da0\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dba\u0dda 6.8\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a\u0dca \u0dc4\u0da7\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d85\u0daf (5) \u0dc3\u0dd2\u0da0\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0dba\u0dcf\u0db1\u0dca \u0db1\u0d9c\u0dbb\u0dba\u0da7 \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 40 \u0dad\u0dd4\u0dc5 \u0daf\u0dd9\u0dc0\u0db1 \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a\u0dca \u0daf\u0dd0\u0db1\u0dd4\u0dab\u0dcf. \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dbb\u0dd2\u0da0\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dba\u0dda 4.2 \u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc3\u0da7\u0dc4\u0db1\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0da0\u0dd3\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0db8\u0dd9\u0db8 \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca 46 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dc0\u0dad\u0dca 16 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dca\u0db1\u0dda."
      ],
