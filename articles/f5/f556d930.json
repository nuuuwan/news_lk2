    "si": {
      "title": "\u0dba\u0dcf\u0dbd\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0d9a\u0dca \u0db6\u0dd2\u0db3 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca, \u0dbb\u0ddd\u0daf \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad",
      "author": "\u0dc0\u0dd2\u0dc2\u0dca\u0dab\u0dd4",
      "body_lines": [
        "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0db1\u0dc0 \u0da0\u0dd9\u0db8\u0dca\u0db8\u0db1\u0dd2 \u0db4\u0dcf\u0dbb\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0d9a\u0dca 06 \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0d85\u0dbd\u0dd4\u0dba\u0db8 \u0d9a\u0da9\u0dcf \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc3\u0dc4 \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0dca \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d8a\u0dba\u0dda \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0dad\u0dd2\u0db6\u0dd6 \u0dbb\u0ddd\u0daf \u0dbb\u0dae\u0dba \u0dc3\u0ddc\u0dba\u0dcf \u0db6\u0dbd\u0daf\u0dca\u0daf\u0dd3 \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0dda \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc3\u0ddc\u0dbb\u0dcf\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc3\u0ddc\u0dba\u0dcf\u0d9c\u0dad\u0dca\u0dad\u0dcf.",
        "\u0d89\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0dc3\u0dc0\u0dd2\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0d9a\u0dd0\u0db8\u0dbb\u0dcf\u0dc0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0db1\u0dd2\u0dc0\u0dc3\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd6 \u0dc3\u0ddc\u0dbb\u0dcf \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0dda \u0dad\u0dd2\u0db6\u0dd6 \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2\u0dba \u0dc3\u0dc4 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc3\u0ddc\u0dbb\u0dcf\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd9\u0dbd\u0dca\u0dc0\u0dad\u0db1\u0dca \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf."
      ],
