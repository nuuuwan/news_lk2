    "si": {
      "title": "\u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1\u0dba \u0db4\u0dbb\u0daf\u0dc0\u0db8\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 4 \u0daf\u0dd9\u0db1\u0dcf\u0d9c\u0dda \u0dc0\u0da7\u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 4 \u0daf\u0dd9\u0db1\u0dcf\u0d9c\u0dda \u0dc0\u0da7\u0dba\u0da7 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd2\u0dba. \u0d92 \u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dad\u0dbb\u0d9c\u0dba \u0d9a\u0da9\u0dd4\u0dbd\u0dd4 2\u0d9a\u0dd2\u0db1\u0dca \u0da2\u0dba \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dd2.",
        "\u0dad\u0dbb\u0d9c\u0dba\u0dda \u0db8\u0dd4\u0dbd\u0dd2\u0db1\u0dca\u0db8 \u0db4\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0da7 \u0db4\u0dc4\u0dbb\u0daf\u0dd4\u0db1\u0dca \u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db4\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0dcf\u0dbb 20 \u0dad\u0dd4\u0dc5\u0daf\u0dd3 \u0d9a\u0da9\u0dd4\u0dbd\u0dd4 7\u0d9a\u0da7 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 183\u0d9a\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd2\u0dba. \u0db4\u0dd2\u0dc5\u0dd2\u0dad\u0dd4\u0dbb\u0dd4 \u0d89\u0db1\u0dd2\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d9a\u0dc5 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0db4\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0dcf\u0dbb 19.2\u0d9a\u0daf\u0dd3 \u0d9a\u0da9\u0dd4\u0dbd\u0dd4 8\u0d9a\u0dca \u0daf\u0dd0\u0dc0\u0dd3 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 184\u0d9a\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dbb\u0d9c\u0dba \u0da2\u0dba \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd2\u0dba.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0da7 \u0dc3\u0dcf\u0dbb\u0dca\u0dae\u0d9a \u0d86\u0dbb\u0db8\u0dca\u0db7\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca (60) \u0dc4\u0dcf \u0db4\u0dd0\u0dad\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dc1\u0dca\u0dc1\u0d82\u0d9a (20) \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd6\u0dc4.\u00a0 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 45\u0d9a\u0dca \u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d89\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 32\u0d9a\u0dca \u0dad\u0dd4\u0dc5 \u0db4\u0dd0\u0dad\u0dd4\u0db8\u0dca, \u0da0\u0dbb\u0dd2\u0dad\u0dca, \u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a \u0dc4\u0dcf \u0db7\u0dcf\u0db1\u0dd4\u0d9a \u0daf\u0dd0\u0dc0\u0dd3 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0db1\u0dcf\u0dba\u0d9a \u0daf\u0dc3\u0dd4\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0d9a (45) \u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0dc3\u0db8\u0d9c \u0d91\u0d9a\u0dca\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d89\u0db1\u0dd2\u0db8 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 133\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba\u0dda\u0dba. \u0db4\u0dc3\u0dd4\u0dc0 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 131\u0daf\u0dd3 \u0db4\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dd2 \u0d9a\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0dbd\u0dd9\u0dc3 \u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca, \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 139\u0daf\u0dd3 \u0dc4\u0dba\u0dc0\u0dd0\u0db1\u0dd2 \u0d9a\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0dbd\u0dd9\u0dc3 \u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0dc4\u0dc3\u0dbb\u0d82\u0d9c, \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 158\u0daf\u0dd3 \u0daf\u0dc3\u0dd4\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0d9a\u0dad\u0dca \u0daf\u0dd0\u0dc0\u0dd3 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0d92 \u0dc0\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0dcf\u0dbb 2.1\u0d9a\u0daf\u0dd3 \u0da2\u0dba\u0d9c\u0dc4\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 26\u0d9a\u0dca \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dc0 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0da0\u0dcf\u0db8\u0dd2\u0d9a \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 (16 (\u0db4\u0db1\u0dca\u0daf\u0dd4 10)) \u0d85\u0dc3\u0dd2\u0dad \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 (10 (\u0db4\u0db1\u0dca\u0daf\u0dd4 3)) \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0dad\u0dbb\u0d9c\u0dba\u0dda \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba \u0d9c\u0dd9\u0db1 \u0d86\u0dc0\u0dda\u0dba."
      ],
