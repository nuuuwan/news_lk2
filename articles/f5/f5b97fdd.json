        ],
        [
          {
            "text": "\u0d91\u0d9a\u0d9a\u0dca \u0db4\u0db8\u0dab\u0dba\u0dd2",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dbd\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2",
            "label": "NORP"
          },
          {
            "text": "\u0dc0\u0dd2\u0db8\u0dbd\u0db0\u0dbb\u0dca\u0db8\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0dbb\u0da2\u0dad\u0dd4\u0db8\u0dcf",
