    "si": {
      "title": "\u0db1\u0dd2\u0dc0\u0dc3\u0da7 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0db6\u0db1 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0db8\u0db8 \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0dad\u0db8 \u0db1\u0dd2\u0dc0\u0dc3 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0db6\u0db1 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0dad\u0db8\u0db1\u0dca \u0d91\u0db8 \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0dbb\u0dd0\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba \u0db6\u0dc0\u0dad\u0dca \u0dad\u0db8\u0db1\u0dca\u0da7 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0d91\u0d9a\u0db8 \u0db1\u0dd2\u0dc0\u0dc3 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0dd0\u0db6\u0dd6 \u0db1\u0dd2\u0dc0\u0dc3 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba. \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db8\u0dda \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.\u0d91\u0dc3\u0dda\u0db8 \u0d9c\u0dd9\u0dc0\u0dbd\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2\u0dc0\u0db1\u0dca\u0db1\u0dda \u0dc4\u0dd2\u0da7\u0dca\u0dbd\u0dbb\u0dca\u0dc0\u0dcf\u0daf\u0dd3 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd2\u0dba.",
        "\"9 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d85\u0dbb\u0d9c\u0dbd\u0dba \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0db8\u0da7 \u0dad\u0dd2\u0db6\u0dd4\u0dab \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0dca \u0d9a\u0dbd\u0dca \u0daf\u0dcf\u0dbd\u0dcf \u0db8\u0db8 \u0d9c\u0dd9\u0daf\u0dbb \u0dc4\u0dd2\u0da7\u0dd2\u0dba\u0dcf. \u0db8\u0da7 \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dab\u0dd2\u0dc0\u0dd2\u0da9\u0dd2\u0dba\u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dcf \u0dc4\u0dc0\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0d85\u0dbb\u0d9c\u0dbd\u0dba \u0db1\u0dd2\u0db8 \u0dc0\u0dd9\u0dbd\u0dcf \u0dba\u0db1 \u0d85\u0dba \u0db8\u0d9c\u0dda \u0d9c\u0dd9\u0daf\u0dbb \u0d85\u0dc3\u0dc5 \u0d9a\u0dd1 \u0d9c\u0dc4\u0db1\u0dca\u0db1 \u0db4\u0dd4\u0dc5\u0dd4\u0dc0\u0db1\u0dca \u0d92\u0d9a \u0db1\u0dd2\u0dc3\u0dcf \u0d9c\u0dd9\u0daf\u0dbb\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dc0\u0dd9\u0dbd\u0dcf \u0dba\u0db1\u0dca\u0db1 \u0d9a\u0dd2\u0dba\u0dbd\u0dcf.",
        "\u0db8\u0db8\u0dad\u0dca \u0db7\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dc0\u0dad\u0dca \u0db4\u0dd2\u0da7\u0dc0\u0dd9\u0dbd\u0dcf \u0d9c\u0dd2\u0dba\u0dcf. \u0db8\u0db8 \u0d91\u0dad\u0db1 \u0d89\u0db1\u0dca\u0db1\u0d9a\u0ddc\u0da7 \u0dad\u0db8\u0dba\u0dd2 \u0db8\u0dda \u0d9c\u0dd9\u0daf\u0dbb \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0dd2\u0db6\u0dca\u0db6\u0dda. \u0db8\u0da7 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda\u0dad\u0dca \u0db4\u0dd2\u0da7\u0dbb\u0da7\u0dad\u0dca \u0dad\u0dd2\u0db6\u0dd4\u0dab \u0d91\u0d9a\u0db8 \u0d9c\u0dd9\u0daf\u0dbb \u0d85\u0daf \u0d9c\u0dd2\u0db1\u0dd2\u0db6\u0dad\u0dca \u0d9a\u0dbb\u0dbd\u0dcf \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda.",
        "\u0db8\u0d9c\u0dda \u0dbd\u0ddc\u0d9a\u0dd4\u0db8 \u0db0\u0db1\u0dba \u0dc0\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd4\u0dab\u0dda \u0db4\u0dd4\u0dc3\u0dca\u0dad\u0d9a\u0dcf\u0dbd\u0dba. \u0db4\u0ddc\u0dad\u0dd4\u0db1\u0dca 2500\u0d9a\u0dca \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dc0\u0dcf. \u0db4\u0dd8\u0dad\u0dd4\u0d9c\u0dca\u200d\u0dbb\u0dd3\u0dc3\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba, \u0d95\u0dbd\u0db1\u0dca\u0daf \u0d9a\u0dcf\u0dbd\u0dba \u0d9c\u0dd0\u0db1 \u0dbd\u0dd2\u0dba\u0db4\u0dd4 \u0db4\u0ddc\u0dad\u0dca \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dc0\u0dcf. \u0db4\u0ddc\u0dad\u0dca \u0d9c\u0dab\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dc0\u0dcf. \u0dc3\u0db8\u0dc4\u0dbb \u0d92\u0dc0\u0dcf \u0d9a\u0dd2\u0dc3\u0dd2\u0d82\u0d9c\u0dbb\u0dca \u0dc0\u0dd0\u0db1\u0dd2 \u0d85\u0dad\u0dca\u0dc3\u0db1\u0dca \u0d9a\u0dbb\u0dbd\u0dcf \u0daf\u0dd2\u0db4\u0dd4 \u0db4\u0ddc\u0dad\u0dca \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db8\u0dda\u0dc0\u0dcf \u0db8\u0da7 \u0dc4\u0dd0\u0db8\u0daf\u0dcf\u0db8 \u0dad\u0dd2\u0dba\u0dcf \u0d9c\u0db1\u0dca\u0db1 \u0db6\u0dd1. \u0db8\u0db8\u0dba\u0dd2 \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dba\u0dd2 \u0d91\u0d9a\u0d9f\u0dc0\u0dd4\u0dab\u0dda \u0d85\u0db4\u0dd2 \u0db8\u0dda\u0dc0\u0dcf \u0db4\u0dd4\u0dc3\u0dca\u0dad\u0d9a\u0dcf\u0dbd\u0dc0\u0dbd\u0da7 \u0daf\u0dd9\u0db1\u0dca\u0db1. \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0da7 \u0daf\u0dd9\u0db1\u0dca\u0db1.\u0db8\u0d9c\u0dda \u0db4\u0dd0\u0dbb\u0dab\u0dd2\u0db8 \u0db4\u0dd8\u0dad\u0dd4\u0d9c\u0dca\u200d\u0dbb\u0dd3\u0dc3\u0dd2 \u0d95\u0dbd\u0db1\u0dca\u0daf \u0db4\u0ddc\u0dad\u0dca \u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0da7 \u0daf\u0dd9\u0db1\u0dca\u0db1. \u0d92 \u0dc0\u0d9c\u0dda\u0db8 \u0daf\u0dd9\u0db1\u0dca\u0db1 \u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf. \u0dc3\u0db8\u0dc4\u0dbb \u0d92\u0dc0\u0dcf \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 200\u0d9a\u0dca \u0dc0\u0dd2\u0dad\u0dbb \u0db4\u0dd0\u0dbb\u0dab\u0dd2 \u0d92\u0dc0\u0dcf.\u0db6\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u200d\u0dba \u0dba\u0dd4\u0d9c\u0dba \u0d86\u0db4\u0dd4 \u0d9c\u0db8\u0db1\u0dca \u0d87\u0db1\u0dca\u0daf \u0d92\u0dc0\u0dcf.",
        "\u0d85\u0daf \u0db8\u0da7 \u0d89\u0dad\u0dd4\u0dbb\u0dd4\u0dc0\u0dd9\u0dbd\u0dcf \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d91\u0d9a\u0d9a\u0dca \u0dc0\u0dd2\u0dad\u0dbb\u0dba\u0dd2. \u0d92 \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d95\u0dbd\u0db1\u0dca\u0daf \u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb\u0dba\u0d9a\u0dca \u0dc0\u0dd2\u0db8\u0dbd\u0db0\u0dbb\u0dca\u0db8\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0dbb\u0da2\u0dad\u0dd4\u0db8\u0dcf \u0d95\u0dbd\u0db1\u0dca\u0daf \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4 \u0dc4\u0db8\u0dd4\u0dc0\u0dd3\u0db8\u0dba\u0dd2.",
        "\u0db8\u0da7 \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd2\u0da7\u0d9a\u0dba \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf. \u0db6\u0dd4\u0daf\u0dd4\u0daf\u0dc4\u0db8 \u0d9c\u0dd0\u0db1 \u0db4\u0ddc\u0dad\u0dca \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf.\u0d92 \u0d91\u0d9a\u0d9a\u0dca\u0dc0\u0dad\u0dca \u0db1\u0dd1. \u0db8\u0da7 \u0dc0\u0da7\u0dd2\u0db1\u0dcf \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dbb\u0dd6\u0db4 15\u0d9a\u0dca 20\u0d9a\u0dca \u0dc0\u0dd2\u0dad\u0dbb \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf. \u0d91\u0d9a\u0d9a\u0dca \u0d89\u0dad\u0dd4\u0dbb\u0dd4\u0dc0\u0dd9\u0dbd\u0dcf \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dc0\u0dcf.\u0db8\u0da7 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf \u0db4\u0dc3\u0dca\u0dc0\u0d9c \u0db8\u0dc4\u0dab\u0dd4\u0db1\u0dca \u0db6\u0dde\u0daf\u0dca\u0db0 \u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb \u0db8\u0dda \u0d91\u0d9a\u0d9a\u0dca\u0dc0\u0dad\u0dca \u0db1\u0dd1. \u0db8\u0d9c\u0dda \u0dc4\u0dd0\u0db8\u0daf\u0dd9\u0dba\u0d9a\u0dca\u0db8 \u0db1\u0dd0\u0dad\u0dd2 \u0dc0\u0dd9\u0dbd\u0dcf \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda. \u0db8\u0dd9\u0dc4\u0dd9\u0db8 \u0d9c\u0dd9\u0dc0\u0dbd\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0dda \u0dc4\u0dd2\u0da7\u0dca\u0dbd\u0dbb\u0dca\u0dc0\u0dcf\u0daf\u0dd3 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dc0\u0dd2\u0dad\u0dbb\u0dba\u0dd2.\""
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "9 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "2500",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0dd8\u0dad\u0dd4\u0d9c\u0dd3\u0dc3\u0dd2",
            "label": "NORP"
          },
          {
            "text": "\u0dbd\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2",
            "label": "NORP"
          },
          {
            "text": "\u0d9a\u0dd2\u0dc3\u0dd2\u0d82\u0d9c\u0dbb\u0dca",
            "label": "PERSON"
