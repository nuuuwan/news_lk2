    "si": {
      "title": "\u0d94\u0db8\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0ddd\u0db1\u0dca \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba \u0dc4\u0dd8\u0daf \u0dc3\u0ddb\u0dbd\u0dc0\u0dbd\u0da7 \u0dc4\u0dcf\u0db1\u0dd2 \u0d9a\u0dbb\u0db1\u0dc0\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19 \u0d94\u0db8\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0ddd\u0db1\u0dca \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2\u0dba\u0dda, \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u2018\u0db6\u0dd3.\u0d92.5\u2019 \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2\u0dba \u0dc0\u0dda\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0db6\u0ddd \u0dc0\u0db1 \u0db6\u0dd2\u0dc4\u0dd2\u0dc3\u0dd4\u0dab\u0dd4 \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2\u0dba\u0d9a\u0dca \u0db6\u0dc0\u0dad\u0dca, \u2018\u0db6\u0dd3.\u0d92.5\u2019 \u0dc4\u0dd8\u0daf \u0dc3\u0ddb\u0dbd\u0dc0\u0dbd\u0da7 \u0dc4\u0dcf\u0db1\u0dd2 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0db4\u0dd8\u0dad\u0dd4\u0d9c\u0dcf\u0dbd \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0db4\u0dbb\u0dca\u0dba\u0dda\u0dc2\u0d9a\u0dba\u0ddd \u0d9a\u0dd2\u0dba\u0dad\u0dd2.",
        "\u2018\u0db6\u0dd3.\u0d92.5\u2019 \u0dc0\u0dba\u0dd2\u0dbb\u0dc3\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca, \u0db4\u0dd8\u0dad\u0dd4\u0d9c\u0dcf\u0dbd \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0db4\u0dbb\u0dca\u0dba\u0dda\u0dc2\u0d9a\u0dba\u0db1\u0dca \u0db4\u0dd4\u0dc5\u0dd4\u0dbd\u0dca \u0db4\u0dbb\u0dca\u0dba\u0dda\u0dc2\u0dab \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0db8\u0dda \u0dc0\u0db1 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dca\u0dad\u0dda \u0d92 \u0d85\u0db1\u0dd4\u0dc0\u0dba. \u0db4\u0dd8\u0dad\u0dd4\u0d9c\u0dcf\u0dbd\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1 \u0dc3\u0db8\u0dc3\u0dca\u0dad \u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19\u2019 \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0d9c\u0dab\u0db1 5,337,121 \u0d9a\u0dd2. \u0db8\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dca\u0db1\u0dda 24,587 \u0d9a\u0dca \u0dbd\u0dd9\u0dc3\u0dba. \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0d9c\u0dab\u0db1 4,237,853 \u0d9a\u0dd2.",
        "\u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19\u2019 \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba\u0dda \u0dc3\u0dd0\u0dbb \u0db6\u0dcf\u0dbd \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7, \u0dbb\u0ddd\u0dc4\u0dbd\u0dca\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1 \u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19\u2019 \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0db8\u0dbb\u0dab \u0d85\u0dc0\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7\u0dad\u0dca \u2018\u0d94\u0db8\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0ddd\u0db1\u0dca\u2019 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd6 \u0db1\u0db8\u0dd4\u0dad\u0dca, \u2018\u0d94\u0db8\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0ddd\u0db1\u0dca\u2019 \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db6\u0dd2\u0dc4\u0dd2\u0dc0\u0dd4\u0dab\u0dd4 \u0d8b\u0db4 \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2 \u0db6\u0dd2\u0dc4\u0dd2\u0dc3\u0dd4\u0dab\u0dd4 \u0dc3\u0dca\u0dc0\u0dbb\u0dd6\u0db4\u0dba\u0d9a\u0dca \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dbd\u0ddc\u0dc0 \u0db1\u0db1\u0dca\u0daf\u0dd9\u0dc3\u0dd2\u0db1\u0dca\u2018 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19 \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0db4\u0dd9\u0db1\u0dca\u0db1\u0dd4\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dca\u0dad\u0dda \u0daf \u2018\u0d94\u0db8\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0ddd\u0db1\u0dca\u2019 \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2\u0dba\u0dda \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dd2. \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf \u0d9a\u0dd3\u0db4\u0dba\u0d9a\u0dca \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0d91\u0dba\u0dd2\u0db1\u0dca \u0db6\u0dd2\u0dc4\u0dd2\u0dc3\u0dd4\u0dab\u0dd4 \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd0\u0dbd\u0d9a\u0dd9\u0db1\u0dca\u0db1\u0dda \u2018\u0db6\u0dd3.\u0d92.5\u2019 \u0dba.",
        "\u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d9c\u0dad \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0d9c\u0dab\u0db1 \u0d89\u0dc4\u0dc5 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dca\u0db1\u0dda\u0dad\u0dca, \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd0\u0da9\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0da7\u0db1\u0dca\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dca\u0dad\u0dda\u0dad\u0dca \u2018\u0db6\u0dd3.\u0d92.5\u2019 \u0d8b\u0db4 \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2\u0dba\u0dda \u0db6\u0dbd\u0db4\u0dd1\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dba\u0dd0\u0dba\u0dd2 \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0daf \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0d85\u0d9f\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.\u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dbd\u0ddc\u0dc0",
        "\u0dc3\u0db8\u0dc3\u0dca\u0dad \u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19\u2019 \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0d9c\u0dab\u0db1 579,780,429 \u0d9a\u0dd2. \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0db8\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dca\u0db1\u0dda 6,414,615 \u0d9a\u0dca \u0dbd\u0dd9\u0dc3\u0dba. \u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca 19\u2019 \u0d86\u0dc3\u0dcf\u0daf\u0db1\u0dba \u0dc0\u0dd3 \u0db4\u0dd6\u0dbb\u0dca\u0dab \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0d9c\u0dab\u0db1 549,638,534 \u0d9a\u0dd2."
      ],
