            "label": "CARDINAL"
          },
          {
            "text": "\u0b9a\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bb5\u0bc7\u0bb2\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bae\u0bbf\u0ba4\u0bbe \u0b85\u0baa\u0bc7\u0bb0\u0ba4\u0bcd\u0ba9",
            "label": "PERSON"
          },
          {
            "text": "\u0baf\u0bc2\u0b9f\u0bbf\u0baf\u0bc2\u0baa\u0bb0\u0bcd \u0bb0\u0ba4\u0bbf\u0ba4\u0bc1 \u0b9a\u0bc7\u0ba9\u0bbe\u0bb0\u0ba4\u0bcd\u0ba9",
            "label": "ORG"
          },
