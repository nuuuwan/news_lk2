          {
            "text": "\u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba - \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0daf\u0dd2\u0dc1\u0dcf\u0dc0",
