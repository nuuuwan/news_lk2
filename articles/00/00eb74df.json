    "si": {
      "title": "\u0dba\u0dcf\u0dbd\u0dd2 \u0dc4\u0dd2 QR. \u0d8b\u0dc3\u0dcf\u0dc0\u0dd2 \u0dc0\u0dd2\u0d9a\u0dd2\u0dab\u0dd3\u0db8",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0db3\u0dc4\u0dcf \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d85\u0dc0\u0dc3\u0dbb \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dd3\u0db8\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d91\u0db8 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc4\u0dd0\u0db3\u0dd4\u0db1\u0dd4\u0db8\u0dca\u0db4\u0dad\u0d9a\u0dca \u0dc3\u0dc4 '\u0d9a\u0dd3 \u0da7\u0dd0\u0d9c\u0dca' \u0d91\u0d9a\u0d9a\u0dca \u0db8\u0dd9\u0db1\u0dca \u0dc3\u0dcf\u0daf\u0dcf \u0d91\u0dba\u0da7 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0dba\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2.",
        "\u0dba\u0dcf\u0dbd\u0dd2 \u0dc4\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4 QR \u0dc0\u0dda. \u0d9a\u0dda\u0dad\u0dba \u0dba\u0dad\u0dd4\u0dbb\u0dd4 \u0da7\u0dd0\u0d9c\u0dca \u0d86\u0d9a\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dcf\u0daf\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0db8\u0d9f\u0dd2\u0db1\u0dca \u0d91\u0dba \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0dda \u0dc0\u0dd2\u0dc0\u0dbb\u0dba\u0db1\u0dca \u0dad\u0dd4\u0dc5 \u0dc3\u0dd2\u0dbb\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0d94\u0dc4\u0dd4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 600\u0d9a\u0dca \u0db4\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dba\u0dcf\u0d9c \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0d91\u0dbd\u0dd9\u0dc3\u0db8 \u0dad\u0dc0\u0dad\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dca \u0dc4\u0dd0\u0db3\u0dd4\u0db1\u0dd4\u0db8\u0dca\u0db4\u0dad\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 QR \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb\u0dba\u0dd2. \u0dbb\u0dda\u0d9b\u0dcf\u0dc0 \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0d92\u0d9a\u0da7 \u0d91\u0dba\u0dcf\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 300\u0d9a\u0dca \u0daf\u0dd9\u0db1\u0dc0\u0dcf. (\u0d92)"
      ],
