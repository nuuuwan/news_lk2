            "text": "2 \u0dc4\u0dbb\u0dcf\u0dbb\u0dda",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda",
            "label": "GPE"
          },
          {
            "text": "\u0daf\u0dc1\u0d9a\u0dba\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 40 \u0d9a\u0dd2",
            "label": "PERCENT"
          },
          {
            "text": "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dc4 \u0d9a\u0db1\u0dca\u0db1\u0dba",
            "label": "DATE"
