    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4\u0dba \u0db4\u0d9a\u0dca\u0dc2 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1 \u0d92\u0d9a\u0db8\u0dad\u0dd2\u0d9a\u0dc0 \u0d85\u0db1\u0dd4\u0db8\u0dad \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda (\u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4) \u0d9a\u0dd8\u0dad\u0dca\u200d\u0dba\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0db4\u0d9a\u0dca\u0dc2 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1 \u0d92\u0d9a\u0db8\u0dad\u0dd2\u0d9a\u0dc0 \u0d85\u0db1\u0dd4\u0db8\u0dad \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4\u0dba\u0dda 71 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb\u0dba \u0d91\u0db8 \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d85\u0daf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0db8\u0dc4\u0dbb\u0d9c\u0db8 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dad\u0dbb\u0dd4\u0dab \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db7\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2.",
        "\u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dd9\u0dbb \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4 \u0d9a\u0dd8\u0dad\u0dca\u200d\u0dba\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0db8\u0dab\u0dca\u0da9\u0dbd \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4 \u0db8\u0dc4\u0dbd\u0dda\u0d9a\u0db8\u0dca \u0daf\u0dba\u0dcf\u0dc3\u0dd2\u0dbb\u0dd2 \u0da2\u0dba\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0db1\u0dd2\u0db4 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0dba\u0ddd\u0da2\u0dd2\u0dad \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
