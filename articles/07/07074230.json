          },
          {
            "text": "29",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0dab\u0dba\u0dda\u0daf\u0dd3",
