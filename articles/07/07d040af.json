            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "ISUF",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dbd\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd0\u0dbb\u0dbd\u0dd2 \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0da7\u0dd9\u0d9a\u0dca\u0db1\u0dd2\u0d9a\u0dbd\u0dca \u0dc4\u0db1\u0dca\u0daf\u0dd2\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dbd\u0dd2\u0db4\u0dca\u0da7\u0db1\u0dca \u0dc0\u0da7\u0dbb\u0dc0\u0dd4\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dbb\u0daf\u0dcf\u0db1",
            "label": "ORG"
