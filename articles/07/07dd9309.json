    "si": {
      "title": "LIOC \u0d89\u0db1\u0dca\u0db0\u0db1\u0dc4\u0dbd\u0dca 116\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0dd0\u0db6\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc3\u0dad\u0dd4 \u0d89\u0db1\u0dca\u0db0\u0db1\u0dc4\u0dbd\u0dca 116\u0d9a\u0dca \u0dc0\u0dd9\u0dad \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db4\u0dbb\u0dca\u0dba\u0db1\u0dca\u0dad\u0dba\u0dd9\u0db1\u0dca \u0da9\u0dd2\u0dc3\u0dbd\u0dca \u0dc4\u0dcf \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0d85\u0daf \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf\u0dd2 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2."
      ],
