            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dab\u0dca\u0da9\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca.\u0d91\u0db8\u0dca.\u0da9\u0dd3.\u0da2\u0dda.",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0da0\u0db8\u0dd2\u0db1\u0dca\u0daf \u0d9a\u0dd4\u0dbd\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          }
        ],
        [],
        [],
        [
          {
            "text": "\u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
