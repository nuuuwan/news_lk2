    "si": {
      "title": "\u0d91\u0da2\u0dcf\u0db4\u0dba \u0d86\u0d9c\u0db8\u0da7 \u0db8\u0dd4\u0dbd\u0dca \u0dad\u0dd0\u0db1 \u0daf\u0dd3 \u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb \u0dc3\u0dd0\u0db8\u0dbb\u0dd4\u0db8 \u0d85\u0dbb\u0db9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda 76 \u0dc0\u0dd9\u0db1\u0dd2 \u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb \u0dc3\u0dd0\u0db8\u0dbb\u0dd4\u0db8 \u0db1\u0dd2\u0db8\u0dd2\u0dad\u0dca\u0dad\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0d86\u0d9c\u0db8\u0dca \u0dc3\u0dd2\u0dc4\u0dd2\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0db4\u0dc4\u0d9a\u0daf\u0dd3 \u0dc4\u0dd9\u0da7(4) \u0dc3\u0dbb\u0dca\u0dc0 \u0d86\u0d9c\u0db8\u0dd2\u0d9a \u0dc0\u0dad\u0dcf\u0dc0\u0dad\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d91\u0da2\u0dcf\u0db4 \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0db1\u0dcf\u0dba\u0d9a \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0da2\u0dca\u200d\u0dba\u0dd9\u0dc2\u0dca\u0da8 \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a \u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc0\u0dd2\u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0dd4\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dc0\u0dcf\u0dbd\u0dd4\u0d9a\u0dcf \u0dbb\u0dcf\u0db8\u0dba,\u0d9a\u0ddc\u0da0\u0dca\u0da0\u0dd2\u0d9a\u0da9\u0dda \u0dc1\u0dd2\u0dc0\u0db8\u0dca \u0d9a\u0ddd\u0dc0\u0dd2\u0dbd ,\u0d9a\u0ddc\u0da0\u0dca\u0da0\u0dd2\u0d9a\u0da9\u0dda \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0d85\u0db1\u0dca\u0dad\u0ddd\u0db1\u0dd2 \u0daf\u0dda\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba,\u0d9a\u0ddc\u0dc5\u0db9 \u0daf\u0dc0\u0da7 \u0d9c\u0dc4 \u0db4\u0dbd\u0dca\u0dbd\u0dd2\u0dba \u0dc3\u0dc4 \u0dc4\u0dd4\u0dab\u0dd4\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0d9c\u0d82\u0d9c\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0d86\u0d9c\u0db8\u0dd2\u0d9a \u0dc0\u0dad\u0dcf\u0dc0\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc0\u0dd2\u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1,\u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dc0\u0da2\u0dd2\u0dbb \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1,\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0dc3\u0dcf\u0d9c\u0dbd \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dba\u0d9a ,\u0db8\u0dc4 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0db4\u0dcf\u0dbd\u0dd2\u0dad \u0dbb\u0d82\u0d9c\u0dda \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb,\u0d8b\u0db4 \u0db1\u0dcf\u0dba\u0d9a \u0d85\u0d9a\u0dd2\u0dbd \u0dc0\u0dd2\u0dbb\u0dcf\u0da2\u0dca \u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dc0\u0dc3\u0db8\u0dca, \u0dbd\u0d9a\u0dca\u0dc0\u0db1\u0dd2\u0dad \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0db1\u0dd3 \u0dc1\u0dcf\u0db1\u0dca\u0dad\u0dd2\u0db1\u0dd2 \u0d9a\u0ddd\u0db1\u0dca\u0d9c\u0dc4\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dca\u0db8 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd3\u0dc4\u0dd4 \u0db8\u0dd9\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd9\u0dad\u0dd2.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda 76 \u0dc0\u0db1 \u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb\u0dba \u0dc3\u0dd0\u0db4\u0dca\u0dad\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca 6 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf\u0da7 \u0dba\u0dd9\u0daf\u0dd3 \u0d87\u0dad."
      ],
