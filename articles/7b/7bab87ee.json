    "si": {
      "title": "\u0db4\u0dcf\u0dc3\u0dca\u0db4\u0ddd\u0da7\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0db1\u0d9a\u0da7 100\u0d9a\u0da7 \u0d91\u0d9a\u0dca\u0daf\u0dd2\u0db1 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0",
      "author": "unknown",
      "body_lines": [
        "\u0d86\u0d9c\u0db8\u0db1 \u0dc4\u0dcf \u0dc0\u0dd2\u0d9c\u0db8\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dba\u0da7\u0dad\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dcf \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dc4\u0dad\u0dbb\u0d9a\u0dca \u0dc4\u0dbb\u0dc4\u0dcf \u0daf\u0dd2\u0db1\u0d9a\u0da7 100 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0dca\u0daf\u0dd2\u0db1 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d91\u0db8 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dcf\u0dad\u0dbb, \u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc4\u0dcf \u0dc0\u0dc0\u0dca\u0db1\u0dd2\u0dba\u0dcf\u0dc0 \u0dba\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d9a\u0dbd\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0db1\u0dba\u0d9a\u0dca \u0dc4\u0dcf \u0dc0\u0dda\u0dbd\u0dcf\u0dc0\u0d9a\u0dca \u0dc0\u0dd9\u0db1\u0dca\u0d9a\u0dbb \u0d9c\u0dad\u0dca \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 100\u0d9a\u0dca \u0dc0\u0dd9\u0dad \u0d89\u0d9a\u0dca\u0daf\u0dd2\u0db1 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0dba\u0dd2. \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0dbd\u0dd0\u0daf\u0dda. www.immigration.gov.lk \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba \u0dc4\u0dbb\u0dc4\u0dcf \u0d89\u0dc4\u0dad \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbd \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dc0\u0dd9\u0dad \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0db4\u0dad\u0dca \u0db7\u0dcf\u0dbb\u0daf\u0dd3 \u0daf\u0dd2\u0db1\u0dba\u0d9a\u0dca \u0dc4\u0dcf \u0dc0\u0dda\u0dbd\u0dcf\u0dc0\u0d9a\u0dca \u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dca\u0dad\u0dcf\u0dc0 \u0dad\u0dd2\u0db6\u0dda."
      ],
