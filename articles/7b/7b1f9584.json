          },
          {
            "text": "\u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dca \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
          },
          {
