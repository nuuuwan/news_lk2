    "si": {
      "title": "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0d9c\u0dd0\u0db1 \u0dc0\u0dd2\u0db8\u0dbd\u0dc0\u0dd3\u0dbb \u0d9a\u0dd2\u0dba\u0db1 \u0d9a\u0dad\u0dcf\u0dc0",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0db1\u0ddc\u0dc0\u0db1 \u0db1\u0dd2\u0dc3\u0dcf\u00a0 \u0d94\u0dc4\u0dd4 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0dc0\u0dd3\u0db8 \u0d9c\u0dd0\u0db1 \u0dc4\u0dd8\u0daf\u0dba\u0dcf\u0d82\u0d9c\u0db8 \u0dc3\u0dad\u0dd4\u0da7\u0dd4 \u0dc0\u0db1 \u0db6\u0dc0 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0db8\u0dbd\u0dc0\u0dd3\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d94\u0dc4\u0dd4 \u0dc4\u0ddc\u0dbb\u0d9a\u0dd4\u00a0 \u0daf\u0dd6\u0dc2\u0dd2\u0dad\u0dba\u0d9a\u0dd4 \u0dc0\u0d82\u0da0\u0db1\u0dd2\u0d9a\u0dba\u0d9a\u0dd4 \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dc3\u0dd6 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbb\u0d82\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a\u00a0 \u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb \u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0d9a\u0dd4 \u0db6\u0dc0\u0daf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d94\u0dc4\u0dd4\u0da7 \u0dad\u0db8\u0dcf \u0dc3\u0dd4\u0db6 \u0db4\u0dad\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0db8\u0dbd\u0dc0\u0dd3\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
