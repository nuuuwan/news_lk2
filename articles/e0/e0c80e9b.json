    "si": {
      "title": "\u0d85\u0da9\u0dd2 15 \u0d9a\u0dca \u0d8b\u0dc3 \u0d9c\u0d82\u0da2\u0dcf \u0d9c\u0dc3\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dc4\u0dcf\u0dbd\u0dd2\u0d87\u0dbd \u0d8c\u0dc0 \u0daf\u0dd3\u0d9c\u0dbd\u0dca\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0d9c\u0dd9\u0dc0\u0dad\u0dca\u0dad\u0dda \u0dc0\u0d9c\u0dcf\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0d85\u0da9\u0dd2 15 \u0d9a\u0dca \u0db4\u0db8\u0dab \u0d8b\u0dc3 \u0d9c\u0d82\u0da2\u0dcf \u0d9c\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0dc4\u0dcf\u0dbd\u0dd2\u0d87\u0dbd \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0d8a\u0dba\u0dda (13) \u0d85\u0dad\u0dca \u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd9\u0dc3\u0dda \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dca\u0dad\u0dda \u0dc4\u0dcf\u0dbd\u0dd2\u0d87\u0dbd \u0d8c\u0dc0 \u0daf\u0dd3\u0d9c\u0dbd\u0dca\u0dbd \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 63 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd2.  \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0dc0\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0daf\u0dd3 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0d9c\u0dda \u0d9c\u0dd9\u0dc0\u0dad\u0dca\u0dad\u0dda \u0db8\u0dcf\u0db1\u0dcf \u0db4\u0db3\u0dd4\u0dbb\u0dd4 \u0d85\u0dad\u0dbb\u0dda \u0d9a\u0dd4\u0da9\u0dcf \u0db6\u0dd0\u0dbb\u0dbd\u0dca \u0db7\u0dcf\u0d9c\u0dba\u0d9a \u0dc0\u0d9c\u0dcf\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0db8\u0dd9\u0db8 \u0d9c\u0d82\u0da2\u0dcf \u0d9c\u0dc3 \u0dc3\u0db8\u0d9f \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad."
      ],
