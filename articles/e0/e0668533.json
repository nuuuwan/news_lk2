    "si": {
      "title": "\u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd \u0dbd\u0dd2\u0d82\u0d9c\u0db1\u0d9c\u200c\u0dbb\u0dca \u0d85\u0dba\u0dd2.\u0d95.\u0dc3\u0dd2.\u0d89\u0db1\u0dca\u0daf\u0db1\u0dc4\u0dbd \u0d85\u0dc3\u0dbd \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0da7 \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0daf \u0d85\u0daf \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0dad\u0dd9\u0d9a\u0dca \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0db4\u0ddc\u0dbd\u0dd2\u0db8\u0dda \u0d91\u0db8 \u0d9a\u0dd4\u0da9\u0dcf\u00a0 \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dba\u0d9a\u0dca \u0db1\u0dc0\u0dad\u0dcf \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0dad\u0db8 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae\u0dba \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d91\u0db1 \u0dad\u0dd9\u0d9a\u0dca\u00a0 \u0db8\u0ddc\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0da7\u00a0 \u0db8\u0dd9\u0db8 \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dba \u0dad\u0db6\u0dcf \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0d9a\u0dd4 \u0db8\u0dd9\u0db8 \u0d89\u0da9 \u0dc0\u0dd9\u0db1\u0dca\u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc3\u0dd9\u0dc3\u0dd4 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc4."
      ],
      "title_ents": [],
