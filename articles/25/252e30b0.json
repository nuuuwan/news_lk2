        ],
        [
          {
            "text": "\u0d85\u0dbb\u0dd4\u0db1\u0dca\u0daf\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4\u0d9c\u0dda",
