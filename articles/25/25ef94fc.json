    "ta": {
      "title": "\u0b95\u0bcb\u0bb5\u0bbf\u0b9f\u0bcd-19 \u0ba8\u0bcb\u0baf\u0bbe\u0bb2\u0bcd \u0b90\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc7\u0bb0\u0bcd \u0b87\u0bb1\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd",
