    "si": {
      "title": "\u0dbb\u0daf\u0d9c\u0dd4\u0dbb\u0dd4\u0dad\u0dd4\u0db8\u0dcf \u0d85\u0dc1\u0dca\u0dc0 \u0dbb\u0dae\u0dba\u0d9a \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "body_lines": [
        "\u0dbb\u0da7\u0db4\u0dd4\u0dbb\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dd2\u0d9f\u0dba\u0d9a\u0dca \u0db8\u0db0\u0dca\u200d\u0dba\u0dba\u0dda \u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda \u0dbb\u0daf\u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbb\u0dae\u0dba\u0d9a \u0db1\u0dd0\u0d9c\u0dd3 \u0dc3\u0dd2\u0dba \u0d9c\u0db8\u0db1 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
