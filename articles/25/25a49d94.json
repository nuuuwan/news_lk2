    "si": {
      "title": "\u0d87\u0db4\u0dca \u0d91\u0d9a\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 21 \u0dc3\u0dd2\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u2018\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0dbd\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba\u2019 \u0d85\u0db1\u0dd4\u0dc0 \u0dbd\u0db6\u0db1 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf (21 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf) \u0dc3\u0dd2\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0dd2\u0db4\u0dd9\u0da7\u0dca\u0d9a\u0ddd \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca\u0dc0\u0dbd \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dc3\u0dd2\u0da7\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc5\u0d9a\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u200d\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (18) \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d9a\u0dd2\u0dc0\u0dca.\u0d86\u0dbb\u0dca. \u0dc3\u0d82\u0d9a\u0dda\u0dad\u0dba \u0dc3\u0dc4 \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0dda \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d85\u0d82\u0d9a\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0db8\u0dab\u0d9a\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d9a\u0dd3 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u200d\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0daf\u0dd0\u0db1\u0da7 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d89\u0dc0\u0dad\u0dca\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0daf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0dda \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d85\u0d82\u0d9a\u0dba\u0dda \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0db8 0, 1 \u0dc3\u0dc4 2 \u0dc0\u0db1 \u0dc0\u0dcf\u0dc4\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dbd\u0db6\u0db1 21 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0daf \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u200d\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
