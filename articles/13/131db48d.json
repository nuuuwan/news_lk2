    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da7\u0dca\u200d\u0dbb\u0dd9\u0dc2\u0dbb\u0dd3\u0dc3\u0dca \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dda",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 55 \u0d9a \u0db7\u0dcf\u0dab\u0dca\u0da9\u0dcf\u0d9c\u0dcf\u0dbb \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0dc0\u0dd2\u0d9a\u0dd4\u0dab\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d9a\u0dbd\u0dca\u0db4\u0dd2\u0dbb\u0dd9\u0db1 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0d85\u0da9\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db6\u0ddc\u0dc4\u0ddd \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0dcf\u0dc3 3 \u0d9a \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dab\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0daf\u0dad\u0dca\u0dad \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dba\u0dd2.",
        "\u0dab\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 25\u0d9a\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0dd0\u0db8\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 45\u0d9a \u0db8\u0dcf\u0dc3 3\u0d9a \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 61\u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 31.5\u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0d9a\u0dd4\u0dab\u0dcf \u0d87\u0dad.",
        "\u0db8\u0dcf\u0dc3 3 \u0d9a \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0 \u0dc3\u0dd2\u0dba\u0dba\u0da7 31.40 \u0da7 \u0db8\u0db3\u0d9a\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dbd\u0dd9\u0dc3 \u0d87\u0dc3\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 15\u0d9a\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0dd0\u0db8\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db8\u0dcf\u0dc3 \u200b\u200b6\u0d9a \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 230\u0d9a\u0dca \u0db4\u0daf\u0db1\u0db8\u0dca \u0d85\u0d82\u0d9a 104\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 29.97\u0d9a\u0da7 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd2\u0dba.",
        "\u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 9.4\u0d9a \u0db8\u0dcf\u0dc3 12\u0d9a \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 15\u0d9a\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0dd0\u0db8\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db4\u0daf\u0db1\u0db8\u0dca \u0d85\u0d82\u0d9a 5\u0d9a\u0dd2\u0db1\u0dca \u0d85\u0da9\u0dd4\u0dc0\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 29.82\u0d9a\u0da7 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd2\u0dba.",
        "\u0dab\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 55 \u0d9a \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d92\u0dc0\u0dcf \u0dc3\u0dd2\u0dba\u0dbd\u0dca\u0dbd\u0db8 \u0dc0\u0dd2\u0d9a\u0dd4\u0dab\u0dd4\u0dc0\u0dcf. (\u0d9a\u0ddc\u0dc5\u0db9/\u0da2\u0dd6\u0dbd\u0dd2 20/2022)"
      ],
