    "si": {
      "title": "\u0dc3\u0da2\u0dd2\u0da9\u0dca\u0d9c\u0dda \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dda \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0d85\u0dc3\u0dca\u0dc0\u0dd4\u0dab\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf \u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db8\u0dba\u0db1\u0dca\u0daf \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dad\u0db8 \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0dad\u0dbb\u0dd4\u0dab \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0dc0\u0db1 \u0dc3\u0dcf\u0db8\u0d9a\u0dd2 \u0dad\u0dbb\u0dd4\u0dab \u0db4\u0dbd\u0dc0\u0dda\u0d9a\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db0\u0dd6\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0d85\u0dc3\u0dca\u0dc0\u0dd6 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
      "title_ents": [
        {
          "text": "\u0d91\u0d9a",
          "label": "CARDINAL"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db8\u0dba\u0db1\u0dca\u0daf \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dcf\u0db8\u0d9a\u0dd2 \u0dad\u0dbb\u0dd4\u0dab \u0db4\u0dbd\u0dc0\u0dda\u0d9a\u0dba",
            "label": "GPE"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b9a\u0b9c\u0bbf\u0ba4\u0bcd \u0b85\u0ba3\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b92\u0bb0\u0bc1\u0bb5\u0bb0\u0bcd \u0b87\u0bb0\u0bbe\u0b9c\u0bbf\u0ba9\u0bbe\u0bae\u0bbe",
      "author": "unknown",
      "body_lines": [
        "\u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0b9f\u0bcd\u0b9a\u0bbf\u0ba4\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0b9a\u0b9c\u0bbf\u0ba4\u0bcd \u0baa\u0bbf\u0bb0\u0bc7\u0bae\u0ba4\u0bbe\u0bb8 \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bbe\u0ba9 \u0b90\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0b95\u0bcd\u0ba4\u0bbf \u00a0\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd \u0bae\u0baf\u0ba8\u0bcd\u0ba4 \u0ba4\u0bbf\u0b9a\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95 \u0ba4\u0ba9\u0ba4\u0bc1 \u0b95\u0b9f\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b87\u0bb3\u0bc8\u0b9e\u0bb0\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbe\u0ba9 \u0b9a\u0bae\u0b95\u0bbf \u0ba4\u0bb0\u0bc1\u0ba3 \u0baa\u0bb2\u0bb5\u0bc7\u0b95\u0baf\u0bb5\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0baa\u0ba4\u0bb5\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b87\u0bb0\u0bbe\u0b9c\u0bbf\u0ba9\u0bbe\u0bae\u0bbe \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd \u0b8e\u0ba9 \u0b85\u0bb5\u0bb0\u0ba4\u0bc1 \u0b85\u0ba8\u0bcd\u0ba4\u0bb0\u0b99\u0bcd\u0b95 \u0b9a\u0bc6\u0baf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ],
      "title_ents": [
        {
          "text": "\u0b92\u0ba9\u0bcd\u0bb1\u0bc1",
          "label": "CARDINAL"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b90\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0bae\u0bbe\u0baf\u0ba8\u0bcd\u0ba4 \u0ba4\u0bbf\u0b9a\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0b9c\u0bbf\u0ba4\u0bcd \u0baa\u0bbf\u0bb0\u0bc7\u0bae\u0ba4\u0bbe\u0b9a",
            "label": "PERSON"
          },
          {
            "text": "\u0b9a\u0bae\u0b95\u0bbf \u0ba4\u0bb0\u0bc1\u0ba3 \u0baa\u0bb2\u0bb5\u0bc7\u0b95\u0baf\u0bbe",
            "label": "GPE"
          }
        ]
      ]
    }
  }
}