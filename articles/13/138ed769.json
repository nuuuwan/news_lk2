          },
          {
            "text": "\u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf \u0b9a\u0bcb\u0b9a\u0bb2\u0bbf\u0bb8\u0bcd\u0b9f\u0bcd \u0b95\u0b9f\u0bcd\u0b9a\u0bbf \u0baa\u0bc1\u0baa\u0bc1\u0ba4\u0bc1 \u0b9c\u0baf\u0b95\u0bca\u0b9f",
