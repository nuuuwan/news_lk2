    "si": {
      "title": "\u0d85\u0daf \u0da0\u0dd3\u0db1 \u0dbb\u0da2\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0da7\u0da7 \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0dc3\u0dc4\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da0\u0dd3\u0db1 \u0dbb\u0da2\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0db1 \u0dad\u0dc0\u0dad\u0dca \u0dc3\u0dc4\u0dbd\u0dca \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0d85\u0daf \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0 \u0da0\u0dd3\u0db1 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dcf.",
        "\u0da0\u0dd3\u0db1 \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dbd\u0db6\u0dcf\u0daf\u0dd4\u0db1\u0dca \u0dc3\u0dc4\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0dc3\u0dc4\u0dbd\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dc3 25 \u0dc0\u0db1\u0daf\u0dcf \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1\u0dc0\u0dd2\u0dad\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0da0\u0dd3\u0db1 \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0db1 \u0dad\u0dc0\u0dad\u0dca \u0dc3\u0dc4\u0dbd\u0dca \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0d85\u0daf \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0 \u0d9a\u0ddc\u0dc5\u0db9 \u0da0\u0dd3\u0db1 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2. (\u0d92)"
      ],
