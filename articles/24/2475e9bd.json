    "si": {
      "title": "\u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0d9a\u0dca: \u0d85\u0dba\u0dd9\u0d9a\u0dca \u0db8\u0dbb\u0dd4\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca\u0dad\u0dda \u0d9a\u0ddc\u0da7\u0db1\u0dca\u0da0\u0dda\u0db1 \u0dc0\u0dd2\u0dc0\u0dda\u0d9a\u0dcf\u0db1\u0db1\u0dca\u0daf \u0db4\u0dcf\u0dbb\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 51 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd2.",
        "\u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0d9c\u0dda \u0db8\u0dd8\u0dad \u0dc1\u0dbb\u0dd3\u0dbb\u0dba \u0d9a\u0ddc\u0dc5\u0db9 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd9\u0dbb\u0dc5\u0db6\u0da9 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dba\u0dd2. (\u0d92)"
      ],
