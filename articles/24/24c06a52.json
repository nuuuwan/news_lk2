    "si": {
      "title": "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dc0\u0dd3\u0dbd\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dad\u0dca \u0d89\u0dc4\u0dc5\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0dd1\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dba \u0d9a\u0dc5 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 80 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 90 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10 \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd6 \u0db6\u0dc0 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0db1\u0dca\u0d9c\u0dda \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dbd\u0dbd\u0dd2\u0dad\u0dca \u0db0\u0dbb\u0dca\u0db8\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u2018\u0dbd\u0d82\u0d9a\u0dcf\u0daf\u0dd3\u0db4\u2019\u0dba\u0da7 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb \u0dc3\u0daf\u0dc4\u0dcf \u0d85\u0dba\u0d9a\u0dc5 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 100 \u0dba\u0dda \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0d89\u0dc4\u0dc5 \u0db1\u0ddc\u0daf\u0dd0\u0db8\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0daf\u0dc4\u0dcf \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d89\u0d9a\u0dca\u0db8\u0dab\u0dd2\u0db1\u0dca \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca \u0dc0\u0dd2\u0dba\u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0db0\u0dbb\u0dca\u0db8\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
