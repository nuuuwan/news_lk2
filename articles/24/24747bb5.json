        [
          {
            "text": "\u0da2\u0dd3.\u0d91\u0da0\u0dca.\u0d85\u0da2\u0dd2\u0dad\u0dca \u0d9a\u0dd4\u0db8\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dd4 \u0d9a\u0ddc\u0da7\u0dd4 \u0db4\u0dc0\u0dd4\u0dbb",
            "label": "FAC"
