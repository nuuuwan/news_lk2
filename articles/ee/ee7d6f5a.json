    },
    "si": {
      "title": "\u0da2\u0dd3\u0dc0\u0db1 \u0dc0\u0dd2\u0dba\u0daf\u0db8 \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0d89\u0dbd\u0dca\u0dbd\u0db8\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf...",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1, \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba, \u0db6\u0dc3\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dc3\u0dc4 \u0da2\u0dd3\u0dc0\u0db1 \u0dc0\u0dd2\u0dba\u0daf\u0db8 \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0dbb\u0da2\u0dba\u0da7 \u0db6\u0dbd\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd9\u0dc5\u0db3 \u0dc3\u0dda\u0dc0\u0dcf \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0dc4\u0dcf \u0db4\u0ddc\u0daf\u0dd4 \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0dc3\u0d82\u0d9c\u0db8\u0dba (CMU) \u0d85\u0daf \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd2\u0dba. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca \u0db1\u0dd2\u0db8\u0dbd\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0d91\u0daf\u0dd2\u0dbb\u0dd2\u0dc3\u0dd2\u0d82\u0dc4."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dbb\u0dca\u0d9a\u0db1\u0dca\u0da7\u0dba\u0dd2\u0dbd\u0dca \u0d89\u0db1\u0dca\u0da9\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dbd\u0dca",
