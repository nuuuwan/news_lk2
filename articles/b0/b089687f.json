    "si": {
      "title": "\u0d9a\u0dc4\u0dad\u0dd4\u0da9\u0dd4\u0dc0 \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0d9c\u0dd2\u0db1\u0dca\u0db1\u0d9a\u0dca \u0d9a\u0db1\u0dca\u0da7\u0dda\u0db1\u0dbb\u0dba\u0dda \u0d9c\u0db6\u0da9\u0dcf \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca ?",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0dc4\u0dad\u0dd4\u0da9\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0d87\u0dad\u0dd2\u0dc0\u0dd6 \u0d9c\u0dd2\u0db1\u0dca\u0db1\u0dd9\u0db1\u0dca \u0db8\u0dc0 \u0dc3\u0dc4 \u0db4\u0dd2\u0dba\u0dcf \u0db8\u0dd2\u0dba \u0d9c\u0ddc\u0dc3\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf\u0da7 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0dda\u0dad\u0dd4\u0dc0 \u0d9a\u0db1\u0dca\u0da7\u0dda\u0db1\u0dbb\u0dba\u0d9a \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0d9c\u0db6\u0da9\u0dcf \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0da7 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dba\u0dd2."
