    "si": {
      "title": "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0\u0dda \u0db4\u0dd2\u0dc4\u0dd2 \u0d87\u0db1\u0dd4\u0db8: 10\u0d9a\u0dca \u0db8\u0dbb\u0dd4\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0\u0dda \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0dc3\u0dc3\u0dca\u0d9a\u0dd0\u0da0\u0dca\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0d8a\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0db4\u0dd2\u0dc4\u0dd2 \u0d87\u0db1\u0dd4\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca 10 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dc0\u0dad\u0dca 15 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db4\u0dc5\u0dcf\u0dad\u0dda \u0dbb\u0dd0\u0da2\u0dd2\u0db1\u0dcf \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0da2\u0dda\u0db8\u0dca\u0dc3\u0dca \u0dc3\u0dca\u0db8\u0dd2\u0dad\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3 \u0db1\u0dda\u0dc2\u0db1\u0dca, \u0dc0\u0dd9\u0dbd\u0dca\u0da9\u0db1\u0dca \u0dc3\u0dc4 \u0dc3\u0dc3\u0dca\u0d9a\u0dd0\u0da7\u0dd6\u0db1\u0dca \u0dba\u0db1 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0db4\u0dd2\u0dc4\u0dd2 \u0d87\u0db1\u0dd4\u0db8\u0dca \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0da2\u0dda\u0db8\u0dca\u0dc3\u0dca \u0dc3\u0dca\u0db8\u0dd2\u0dad\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3 \u0db1\u0dda\u0dc2\u0db1\u0dca \u0dc3\u0dc4 \u0dc0\u0dd9\u0dbd\u0dca\u0da9\u0db1\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1 13 \u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0dad\u0dca \u0db6\u0dc0\u0dba\u0dd2.",
        "Royal Canadian Mounted Police \u0dc3\u0dc4\u0d9a\u0dcf\u0dbb \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca Rhonda Blackmore \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0ddc\u0dba\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dba \u0d91\u0dbd\u0dca\u0dbd \u0d9a\u0dc5 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d9a\u0dd0\u0db1\u0da9\u0dcf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda. 31 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0da9\u0dda\u0db8\u0dd2\u0dba\u0db1\u0dca \u0dc3\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0db1\u0dca \u0dc3\u0dc4 30 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db8\u0dba\u0dd2\u0dbd\u0dca\u0dc3\u0dca \u0dc3\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0db1\u0dca\u0da7 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0d85\u0d9f\u0dc0\u0dcf \u0d87\u0dad. (\u0d92)"
      ],
