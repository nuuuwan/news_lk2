    "en": {
      "title": "Demand for increase in train fares",
      "author": "unknown",
      "body_lines": [
        "It has demanded a 50 per cent increase in train fares. A request has been made to the Cabinet in this regard, said Gamini Seneviratne, spokesperson for the Railway Department and Deputy Transport Officer."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
