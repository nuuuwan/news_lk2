          },
          {
            "text": "15",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0b89\u0baf\u0bb0\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0b95\u0bcd \u0b95\u0bc1\u0bb4\u0bc1",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b85\u0b9f\u0bcd\u0bae\u0bbf\u0bb0\u0bb2\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
            "label": "GPE"
