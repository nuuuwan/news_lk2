    "si": {
      "title": "NTMI \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0dc0\u0dc3\u0dcf \u0dad\u0db6\u0db1\u0dd4 \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1\u0dba (NTMI) \u0db4\u0dc0\u0dc3\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dc0\u0dad \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd9\u0db1 \u0dad\u0dd4\u0dbb\u0dd4 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0d91\u0dc4\u0dd2 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0db1\u0dca \u0dbd\u0db6\u0dcf \u0db1\u0ddc\u0daf\u0dd9\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d91\u0dc4\u0dd2 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb \u0d9c\u0db8\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0da2\u0dd6\u0dbd\u0dd2 01 \u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 NTMI \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0dd3\u0db8\u0dcf \u0d9a\u0dbb\u0db1\u0dd4 \u0d87\u0dad.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 1225 \u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0d87\u0db8\u0dad\u0dd4\u0db8\u0dca \u0d85\u0d82\u0d9a\u0dba \u0d87\u0db8\u0dad\u0dd3\u0db8\u0dd9\u0db1\u0dca, \u0d86\u0dba\u0dad\u0db1\u0dba\u0dda \u0db1\u0dd2\u0dbd \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba\u0da7 (www.ntmi.lk) \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dc4\u0ddd \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dd4\u0dad\u0dca \u0db1\u0dcf\u0dbd\u0dd2\u0d9a\u0dcf \u0dc4\u0dbb\u0dc4\u0dcf \u0dc4\u0db8\u0dd4\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0d8b\u0db4\u0dbd\u0dda\u0d9b\u0db1\u0d9c\u0dad \u0d9a\u0dc5 \u0dc4\u0dd0\u0d9a\u0dd2\u0dba."
      ],
