          },
          {
            "text": "\u0bb5\u0bbe\u0ba9\u0bcd\u0b95\u0bbe\u0bb0\u0bcd\u0b9f\u0bcd \u0b9a\u0bcb\u0b9a\u0bb2\u0bbf\u0bb8\u0bcd\u0b9f\u0bcd \u0b95\u0b9f\u0bcd\u0b9a\u0bbf",
            "label": "ORG"
