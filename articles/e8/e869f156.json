            "text": "\u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 18 \u0d9a\u0dd2",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 217 \u0d9a\u0dd2",
            "label": "CARDINAL"
          }
        ],
        [],
        [
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 70 \u0daf\u0d9a\u0dca\u0dc0\u0dcf",
            "label": "PERCENT"
          },
          {
            "text": "\u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
