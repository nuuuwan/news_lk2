          },
          {
            "text": "\u0dc0\u0dd3\u0dbb\u0dad\u0dba\u0dd2 \u0dc3\u0db1\u0dca\u0dad\u0dd2\u0db4\u0dca\u200d\u0dbb\u0db7\u0ddc\u0db6\u0dca",
            "label": "PERSON"
