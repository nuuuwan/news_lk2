      "title": "SLRC telecasting goes off air",
      "author": "unknown",
      "body_lines": [
        "The Sri Lanka Rupavahini Corporation (SLRC) has suspended their live and recorded telecasts as the corporation premises is being surrounded by protesters."
      ],
      "title_ents": [],
