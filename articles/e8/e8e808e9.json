    "ta": {
      "title": "\u0b87\u0b9a\u0bbf\u0baa\u0ba4\u0ba9 \u0b9a\u0bc6\u0baf\u0bbf\u0ba9\u0bcd\u0b9f\u0bcd \u0baa\u0bc0\u0b9f\u0bcd\u0b9f\u0bb0\u0bcd\u0bb8\u0bc8 \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0ba4\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0bb9\u0bc6\u0bb5\u0bcd\u0bb2\u0bca\u0b95\u0bcd \u0baa\u0bbe\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd \u0b87\u0b9f\u0bae\u0bcd\u0baa\u0bc6\u0bb1\u0bcd\u0bb1 20 \u0bb5\u0baf\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0bbe\u0b9f\u0b9a\u0bbe\u0bb2\u0bc8\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0bb0\u0b95\u0bcd\u0baa\u0bbf \u0bb2\u0bc0\u0b95\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0ba4\u0bcd \u0ba4\u0bca\u0b9f\u0bb0\u0bbf\u0bb2\u0bcd \u0b87\u0b9a\u0bbf\u0baa\u0ba4\u0ba9 \u0b95\u0bb2\u0bcd\u0bb2\u0bc2\u0bb0\u0bbf 29-17 \u0b8e\u0ba9\u0bcd\u0bb1 \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf\u0b95\u0bcd\u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd \u0baa\u0bc1\u0ba9\u0bbf\u0ba4 \u0baa\u0bc0\u0bb1\u0bcd\u0bb1\u0bb0\u0bcd \u0b95\u0bb2\u0bcd\u0bb2\u0bc2\u0bb0\u0bbf\u0baf\u0bc8 \u0ba4\u0bcb\u0bb1\u0bcd\u0b95\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0ba4\u0bc1. \u0b87\u0b9a\u0bbf\u0baa\u0ba4\u0bbe\u0ba9\u0bbf\u0baf\u0ba9\u0bcd\u0b95\u0bb3\u0bcd \u0b90\u0ba8\u0bcd\u0ba4\u0bc1 \u0b9f\u0bcd\u0bb0\u0bc8\u0b95\u0bb3\u0bc8 \u0b85\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd, \u0b85\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1 \u0b9f\u0bcd\u0bb0\u0bc8\u0b95\u0bb3\u0bc8 \u0b95\u0bcb\u0bb2\u0bbe\u0b95 \u0bae\u0bbe\u0bb1\u0bcd\u0bb1\u0bbf\u0baf\u0ba4\u0bc1. \u0b95\u0bc1\u0bb7\u0bbe\u0ba9\u0bcd \u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bbe\u0b9c\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0baa\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bcd"
      ],
