    "si": {
      "title": "\u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1\u0dba \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db4\u0dd3\u0dad\u0dbb \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0d9a\u0dc5\u0dda\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd \u0dc3\u0dc4 \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db4\u0dd3\u0dad\u0dbb \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd \u0d85\u0dad\u0dbb \u0dc4\u0dd0\u0dc0\u0dca\u0dbd\u0ddc\u0d9a\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 20 \u0db1\u0dca \u0db4\u0dc4\u0dc5 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0d9c\u0dca\u0db6\u0dd2 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 29-17 \u0d9a\u0dd2\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 07-12 \u0d9a \u0db4\u0dbb\u0dad\u0dbb\u0dba\u0d9a\u0dca \u0da2\u0dba\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd2\u0dba. \u0d89\u0dc3\u0dd2\u0db4\u0dad\u0db1\u0dd2\u0dba\u0db1\u0dca \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4\u0d9a \u0daf\u0dd2\u0db1\u0dd4\u0db8\u0dca 5\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d89\u0db1\u0dca \u0dad\u0dd4\u0db1\u0d9a\u0dca\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dca\u0dad\u0db1\u0dba \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0db4\u0dd3\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0ddd \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4\u0d9a \u0daf\u0dd2\u0db1\u0dd4\u0db8\u0dca \u0dad\u0dd4\u0db1\u0dd9\u0db1\u0dca \u0d91\u0d9a\u0d9a\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca \u0d86\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dc4. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0d9a\u0dd4\u0dc2\u0dcf\u0db1\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dcf\u0da2"
      ],
