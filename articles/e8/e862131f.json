    "si": {
      "title": "\u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0dca \u0d9c\u0db8\u0db1\u0d9a",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0db7\u0dcf\u0dbb\u0dad\u0dd3 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0db6\u0db1 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db4\u0dcf\u0dc3\u0dbd \u0db1\u0dd2\u0db8\u0dc0\u0dd3 \u0dc3\u0dd2\u0dba \u0db1\u0dd2\u0dc0\u0dd9\u0dc3\u0da7 \u0dba\u0dcf\u0db8\u0da7 \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0db1\u0dd0\u0dad\u0dd2\u0dc0 \u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0dc3\u0dd2\u0da7 \u0d87\u0dbd\u0dca\u0dbd\u0dda\u0d85\u0dbb\u0dcf\u0dc0 \u0db6\u0dbd\u0dcf \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db6\u0dc3\u0dca\u0dbb\u0dae\u0dba\u0d9a \u0dc0\u0dc4\u0dbd\u0dba \u0db8\u0dad \u0db1\u0dd0\u0d9c\u0dd3 \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0dca \u0d9c\u0db8\u0db1\u0d9a \u0d9c\u0dd2\u0dba\u0dda \u0db8\u0dd9\u0dc3\u0dda\u0dba.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9c\u0db8 \u0db6\u0dc3\u0dca\u200d \u0dbb\u0dae \u0daf\u00a0\u0da7\u0dba\u0dbb\u0dca \u0db6\u0dd0\u0da7\u0dbb\u0dd2 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db6\u0dc3\u0dca\u0dbb\u0dae \u0db0\u0dd2\u0dc0\u0db1 \u0db1\u0ddc\u0dc0\u0db1 \u0d85\u0dad\u0dbb\u00a0\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0 \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db6\u0dc3\u0dca\u0dbb\u0dae \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d85\u0da9\u0dcf\u0dbd \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca\u0dc0\u0dbd\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0db4\u0dcf\u0dc3\u0dbd \u0db1\u0dd2\u0db8\u0dc0\u0dd3 \u0dba\u0dc5\u0dd2 \u0db1\u0dd2\u0dc0\u0dd9\u0dc3\u0dca \u0d9a\u0dbb\u0dcf \u0dba\u0dcf\u0db8\u0da7 \u0db6\u0dc3\u0dca\u0dbb\u0dae \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0 \u0daf\u0dd0\u0da9\u0dd2 \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2 ."
      ],
