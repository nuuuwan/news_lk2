    "si": {
      "title": "\u0da2\u0db1\u0db4\u0dad\u0dd2 \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d91\u0dc5\u0dd0\u0db9\u0dd9\u0db1\u00a0 \u0dc3\u0dad\u0dd2\u00a0 \u0d85\u0db1\u0dca\u0dad\u0dba\u0dda\u0daf\u0dd3 \u0db8\u0ddc\u0dab\u0dbb\u0dcf\u0d9c\u0dbd \u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba\u0d9a\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0dd2\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0\u00a0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0db8\u0dd4\u0dd4\u0dbd\u0dd2\u0db1\u0dca\u0db8 \u0d91\u0dc5\u0dd0\u0db9\u0dd9\u0db1 27\u0daf\u0dcf\u00a0 \u0db8\u0ddc\u0dab\u0dbb\u0dcf\u0d9c\u0dbd\u0da7 \u0db4\u0db8\u0dd2\u0dab \u0db8\u0ddc\u0dab\u0dbb\u0dcf\u0d9c\u0dbd\u00a0 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1\u00a0 \u0dc3\u0db7\u0dcf\u0dc0\u0da7\u00a0 \u0db8\u0ddc\u0dab\u0dbb\u0dcf\u0d9c\u0dbd\u00a0 \u0db4\u0dd4\u0dd4\u0dc3\u0dca\u0dad\u0d9a\u0dcf\u0dbd\u00a0\u00a0 \u0dc1\u0dca\u200d\u0dbb\u0dc0\u0dab\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda\u0daf\u0dd3 \u0d91\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d89\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0\u00a0 28 \u0daf\u0dcf \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0d9a\u0dd2\u0dbb\u0dd2\u0dc0\u0dd9\u0dc4\u0dd9\u0dbb \u0dc4\u0dcf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba, \u0dc0\u0dd0\u0da9\u0dc3\u0dd2\u0da7\u0dd2 \u0d9a\u0db1\u0dca\u0daf\u00a0 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dba, \u0dad\u0dd2\u0dc3\u0dca\u0dc3\u0db8\u0dc4\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dba\u0db1 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba \u0d9a\u0dd2\u0dbb\u0dd2\u0dd2\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba."
