      "body_line_ents_list": [
        [
          {
            "text": "\u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
