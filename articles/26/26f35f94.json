          {
            "text": "\u0daf\u0dd0\u0db1\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dda\u0da7\u0dbb\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8",
