          }
        ],
        []
      ]
    },
    "si": {
      "title": "\u0da9\u0dbd\u0dc3\u0dd4\u0dad\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dc3\u0da7\u0db1\u0da7 \u0d91\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0db7\u0dd2\u0db1\u0dc0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db0\u0dd6\u0dbb\u0dba\u0da7 \u0dad\u0db8\u0dcf\u0daf \u0dad\u0dbb\u0d9f \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u00a0 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dd9\u0dca \u0d85\u0dad\u0dbb \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db0\u0dd6\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0dc0\u0dad\u0dca \u0db1\u0db8\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0d86\u0dbb\u0d82\u0da0\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0db4\u0dd0\u0dc0\u0dc3\u0dda"
      ],
      "title_ents": [
        {
          "text": "\u0da9\u0dbd\u0dc3\u0dca",
