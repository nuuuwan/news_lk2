          },
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0d89\u0dad\u0dd2\u0dbb\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0db4\u0dcf\u0dbd\u0d9a \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dda\u0dab\u0dd4\u0d9a\u0dcf \u0da2\u0dba\u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb",
            "label": "PERSON"
          },
          {
