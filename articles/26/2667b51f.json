    "si": {
      "title": "\u0daf\u0dd2\u0dc0\u0dcf \u0d86\u0dc4\u0dcf\u0dbb \u0db4\u0dd0\u0d9a\u0da7\u0dca \u0db8\u0dd2\u0dbd \u0d85\u0daf \u0dc3\u0dd2\u0da7 10% \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d91\u0dc5\u0dc0\u0dc5\u0dd4 \u0db6\u0dad\u0dca \u0db4\u0dd0\u0d9a\u0da7\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d86\u0dc4\u0dcf\u0dbb \u0dc0\u0dbb\u0dca\u0d9c \u0daf\u0dd0\u0db1\u0da7 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db8\u0dd2\u0dbd\u0dd9\u0db1\u0dca 10%\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0d86\u0db4\u0db1\u0dc1\u0dcf\u0dbd\u0dcf \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba (AICOA) \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d91\u0db8 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d85\u0dc3\u0dda\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8 \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dca\u0dbd\u0da7 \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9c\u0dad\u0dca \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d92 \u0db1\u0dd2\u0dc3\u0dcf \u0d91\u0dc5\u0dc0\u0dc5\u0dd4, \u0db8\u0dcf\u0dc5\u0dd4, \u0da0\u0dd2\u0d9a\u0db1\u0dca \u0dbb\u0dba\u0dd2\u0dc3\u0dca \u0db4\u0dd0\u0d9a\u0da7\u0dca, \u0dc6\u0dca\u200d\u0dbb\u0dba\u0dd2\u0da9\u0dca \u0dbb\u0dba\u0dd2\u0dc3\u0dca \u0dc3\u0dc4 \u0d9a\u0ddc\u0dad\u0dca\u0dad\u0dd4\u0dc0\u0dbd \u0db4\u0dc0\u0dcf \u0db8\u0dd2\u0dbd \u0dc3\u0dd2\u0dba\u0dba\u0da7 10\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0dba\u0db1\u0dc0\u0dcf.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0dc0\u0dda\u0daf\u0db1\u0dcf \u0dad\u0dda, \u0d9a\u0dd2\u0dbb\u0dd2 \u0dad\u0dda \u0dc3\u0dc4 \u0d86\u0db4\u0dca\u0db4 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dd2\u0dc3\u0dd2\u0daf\u0dd4 \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.(\u0da0\u0dad\u0dd4\u0dbb\u0d82\u0d9c \u0dc3\u0db8\u0dbb\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8)"
      ],
