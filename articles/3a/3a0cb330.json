  "original_title": "\u0dc3\u0da2\u0dd2\u0dad\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dc3\u0da7\u0db1\u0da7 \u0d91\u0dba\u0dd2",
  "text_idx": {
    "en": {
      "title": "Sajith President will come to fight",
      "author": "unknown",
      "body_lines": [
        "The parliamentary group of the Samagi Jana Balavega has unanimously decided that the opposition leader Sajith Premadasa should contest for the currently vacant position of President. This decision has been taken after a long discussion held by the group of councilors this afternoon."
      ],
      "title_ents": [],
