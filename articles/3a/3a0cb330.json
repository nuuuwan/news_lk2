            "label": "TIME"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dc3\u0da2\u0dd2\u0dad\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dc3\u0da7\u0db1\u0da7 \u0d91\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc4\u0dd2\u0dc3\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db0\u0dd4\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0db8\u0dc4\u0dad\u0dcf \u0dad\u0dbb\u0d9c \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0da7 \u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba\u0dda \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0d92\u0d9a\u0db8\u0dad\u0dd2\u0d9a\u0dc0 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda. \u0d91\u0db8 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0d85\u0daf \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0daf\u0dd2\u0dbb\u0dca\u0d9d \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0dad\u0dd2\u0dbb\u0dab\u0dba \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
