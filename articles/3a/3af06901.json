          },
          {
            "text": "\u0dc3\u0d82\u0da2\u0dba \u0da2\u0dba\u0d9a\u0ddc\u0da9\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db8\u0dcf\u0dba\u0dcf \u0da2\u0dba\u0d9a\u0ddc\u0da9\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba",
            "label": "ORG"
          },
          {
