          },
          {
            "text": "\u0dbb\u0dcf\u0da2\u0dca\u0dba \u0db1\u0ddc\u0dc0\u0db1 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1",
