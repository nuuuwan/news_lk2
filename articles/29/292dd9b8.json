        [
          {
            "text": "\u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dbb\u0dad\u0dca\u0dc0\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0dbb\u0dd4\u0dab\u0dd2 \u0dc0\u0dd2\u0da2\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dd9\u0db1\u0dbb\u0dcf\u0dbd\u0dca (\u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dd2\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0db1\u0dd2\u0dbd\u0dca \u0da2\u0dcf\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dbb\u0dd2\u0dc3\u0dbb \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db1\u0dd6\u0dc2 \u0db4\u0dd0\u0dbd\u0dca\u0db4\u0dd2\u0da7",
