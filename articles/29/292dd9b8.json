            "text": "\u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0d87\u0db8\u0dad\u0dd2\u0dc0\u0dbb\u0dd4",
            "label": "FAC"
          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dab\u0dca\u0da9\u0dbd",
