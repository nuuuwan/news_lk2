          "text": "\u0b9f\u0bbe\u0ba9\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0baf\u0b9a\u0bbe\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd",
