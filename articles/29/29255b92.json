  "original_title": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0db8\u0dd2\u0dbd \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0db6\u0dc3\u0dd2\u0dba\u0dd2",
  "text_idx": {
    "en": {
      "title": "Liter price is coming down again",
      "author": "unknown",
      "body_lines": [
        "The company has decided to lower the price of Litro gas once again. The price will be revised with effect from midnight on the 5th.",
        "Mr. Muditha Peiris, Chairman of Litro Company, stated that according to the price formula introduced last year, they are working to bring down the gas price.",
        "He said that the price of all domestic gas cylinders will be reduced and so far 5 million domestic gas cylinders have been released to the market.",
        "The chairman said that 95 percent of the delegates have gas cylinders and that the home delivery app will be activated in the future."
      ],
      "title_ents": [
        {
          "text": "Liter",
          "label": "PERSON"
        }
      ],
