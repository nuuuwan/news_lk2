    "ta": {
      "title": "\u0b9a\u0bbf\u0baa\u0bbf\u0b8e\u0bb8\u0bcd\u0b8e\u0bb2\u0bcd \u0bb0\u0bc2. \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b95\u0bb0\u0bc1\u0bb5\u0bc2\u0bb2 \u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0 \u0b8f\u0bb2\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd 142 \u0baa\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0ba9\u0bcd",
