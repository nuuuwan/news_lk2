          {
            "text": "\u0ba4\u0bbf \u0b9a\u0ba3\u0bcd\u0b9f\u0bc7 \u0b9f\u0bc8\u0bae\u0bcd\u0bb8\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b89\u0bb2\u0b95 \u0bb5\u0b99\u0bcd\u0b95\u0bbf",
            "label": "ORG"
          },
