            "label": "PERSON"
          }
        ],
        [],
        [
          {
            "text": "\u0d91\u0d9a\u0d9a\u0da7 \u0dc0\u0da9\u0dcf",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc0\u0dca\u0dba\u0dcf\u0db4\u0dcf\u0dbb \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d85\u0d82\u0d9a\u0dba",
            "label": "ORG"
          }
        ],
        [],
        [
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd",
