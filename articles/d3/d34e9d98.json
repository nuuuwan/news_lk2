          {
            "text": "\"\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0bc7\u0bb0\u0bcd\u0bb5\u0bc1 \u0bb5\u0bbf\u0bb0\u0bc1\u0ba4\u0bc1",
