          {
            "text": "\u0db8\u0dd6\u0dbd \u0d9a\u0dda\u0dad \u0dbb\u0dc3\u0dcf\u0dba\u0db1\u0dcf\u0d9c\u0dcf\u0dbb",
            "label": "PERSON"
