          },
          {
            "text": "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0d9a\u0dd0\u0db1\u0dca\u0daf\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dcf\u0dc3\u0dbd",
            "label": "ORG"
