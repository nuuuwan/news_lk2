    "si": {
      "title": "\u0d9a\u0dbd\u0dcf \u0d85\u0d82\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0d91\u0d9a \u0d9a\u0dd0\u0db1\u0dca\u0daf\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0da7",
      "author": "unknown",
      "body_lines": [
        "2021 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0dbd\u0dcf \u0d85\u0d82\u0dc1\u0dba\u0dda \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0dbb\u0d9c\u0dad\u0dca \u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0d9a\u0dd0\u0db1\u0dca\u0daf\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0db8\u0dc4 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dda \u0d89\u0dc1\u0dcf\u0dbb \u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2 \u0d87\u0dad."
      ],
      "title_ents": [
        {
          "text": "\u0d91\u0d9a",
          "label": "CARDINAL"
        },
        {
          "text": "\u0d9a\u0dd0\u0db1\u0dca\u0daf\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
