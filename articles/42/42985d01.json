          {
            "text": "\u0dc3\u0ddd\u0db8\u0dcf\u0dc0\u0dad\u0dd3 \u0d8b\u0daf\u0dca\u0dba\u0dcf\u0db1\u0dba",
            "label": "FAC"
          }
        ],
        [
          {
            "text": "\u0d9a\u0db1\u0dca\u0dad\u0d9a\u0dcf\u0da9\u0dca \u0db4\u0dd4\u0db1\u0dbb\u0dd4\u0dad\u0dca\u0dae\u0dcf\u0db4\u0db1 \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
