          }
        ],
        [
          {
            "text": "\u0dc4\u0dba\u0dc3\u0dd2\u0dba\u0dba\u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dba\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2\u0dba",
            "label": "CARDINAL"
