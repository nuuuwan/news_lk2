      "title": "\u0d9a\u0ddc\u0dbb\u0ddd\u0db1\u0dcf \u0dbb\u0ddd\u0d9c\u0dd3\u0dc4\u0dd4 131\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dbb\u0ddd\u0db1\u0dcf \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 131\u0d9a\u0dca \u0d85\u0daf \u0daf\u0dd2\u0db1\u0dba\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0d85\u0daf \u0daf\u0dd2\u0db1\u0dba\u0dda \u0daf\u0dd3 \u0d9a\u0ddc\u0dbb\u0ddd\u0db1\u0dcf \u0db8\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0db1\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb \u0d87\u0dad."
      ],
