            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 \u0daf\u0dd9\u0d9a\u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0dca",
            "label": "DATE"
          },
          {
            "text": "20 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0dc0\u0dca\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba",
