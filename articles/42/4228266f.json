            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 \u0dc4\u0dad\u0dbb\u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0dca",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 \u0daf\u0dd9\u0d9a\u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0dca",
            "label": "DATE"
          },
          {
