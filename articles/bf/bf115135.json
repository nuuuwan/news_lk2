            "label": "PERSON"
          },
          {
            "text": "49 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc0\u0dc0\u0dd4\u0dc5\u0dd4\u0d9c\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0db8\u0d9c\u0dca\u0d9c\u0ddc\u0db1",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "15 \u0db4\u0db8\u0dab",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "14 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dcf\u0db1\u0daf\u0dd4\u0dbb \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "FAC"
          }
        ],
        [
          {
            "text": "\u0db8\u0d9c\u0dca\u0d9c\u0ddc\u0db1",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0dd2\u0db4\u0dd9\u0da7\u0dca\u0d9a\u0ddd",
            "label": "ORG"
          },
          {
            "text": "20 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "24 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf \u0dbb\u0dd1",
            "label": "TIME"
          },
          {
            "text": "2",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0dba\u0dcf\u0d9c\u0dbd",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "20 \u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0d8a\u0dba\u0dda \u0dc3\u0dc0\u0dc3",
            "label": "TIME"
          },
          {
            "text": "25 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0d9a\u0dc5\u0dd4\u0dad\u0dbb \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0db1\u0daf\u0dd4\u0dbb \u0db8\u0dcf\u0db1\u0dc0 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
