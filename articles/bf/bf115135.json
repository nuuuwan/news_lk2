          {
            "text": "\u0db4\u0dcf\u0db1\u0daf\u0dd4\u0dbb \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
