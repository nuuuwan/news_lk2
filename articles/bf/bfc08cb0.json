    "si": {
      "title": "\u0db6\u0dd0\u0db3\u0dd4\u0db8\u0dca\u0d9a\u0dbb \u0db4\u0ddc\u0dbd\u0dd3 \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0db1\u0ddc\u0dad\u0d9a\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d91\u0dba\u0dcf\u0dbb\u0dca\u0dbd\u0dba\u0dd2\u0db1\u0dca\u0dc3\u0dca \u0db6\u0dd0\u0db3\u0dd4\u0db8\u0dca\u0d9a\u0dbb '\u0dc3\u0dd3' \u0d85\u0d9c\u0dba\u0dba\u0dd2",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT - \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dbb\u0dd2\u0db1 \u0dbd\u0daf \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0ddc\u0dbd\u0dd3 \u0d9a\u0dd6\u0db4\u0db1\u0dba \u0d9c\u0dd9\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3\u0dad\u0dca, \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf\u0d9c\u0dd9\u0db1 \u0dba\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0db6\u0dd0\u0db3\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dba\u0d9a\u0dca \u0dad\u0dc0\u0db8\u0dad\u0dca \u2018C\u2019 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0d9c\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 Fitch Ratings \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\"2024 \u0daf\u0dd3 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db1\u0ddd\u0da7\u0dca\u0da7\u0dd4, \u0db1\u0ddd\u0da7\u0dca\u0da7\u0dd4 \u0db7\u0dcf\u0dbb\u0d9a\u0dcf\u0dbb \u0d94\u0db4\u0dca\u0db4\u0dd4\u0dc0 \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d87\u0db4\u0d9a\u0dbb\u0dd4 - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0da2\u0dba\u0da7 \u0db6\u0dd0\u0db3\u0dd3 \u0d87\u0dad\u0dd2 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda \u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dd2\u0dad \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dca \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0d8b\u0dbd\u0dca\u0dbd\u0d82\u0d9d\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd3,\" \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dcf\u0dba\u0dad\u0db1\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d92\u0dc0\u0dcf \u0db1\u0db8\u0dca (i) 2022 \u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca 12 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d91\u0dc4\u0dd2 \u0db6\u0dcf\u0dc4\u0dd2\u0dbb \u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dc3\u0dc4 \u0db4\u0ddc\u0dbd\u0dd3 \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0dda \u0dad\u0dc4\u0db1\u0db8\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dc4 (ii) 2022 \u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 25 \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0db1 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dab\u0dba \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dc5\u0dd2\u0dba \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dd0\u0dbb\u0dd3\u0db8, \u0dc3\u0dc4 \u0d92 \u0d86\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad \u0dc3\u0dc4\u0db1 \u0d9a\u0dcf\u0dbd\u0dba 2022 \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd3\u0db8.",
        "Fitch Ratings-Singapore-28 July 2022: SriLankan Airlines Limited (SLA) \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0db1 30\u0d9a \u0dc3\u0dc4\u0db1 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0d91\u0dc4\u0dd2 \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0d9a\u0dbb\u0db1 \u0dbd\u0daf USD \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 175\u0d9a \u0d85\u0db1\u0dcf\u0dbb\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0db1\u0ddd\u0da7\u0dca\u0da7\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf USD \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 6.125\u0d9a \u0db4\u0ddc\u0dbd\u0dd2\u0dba\u0d9a\u0dca \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0db1\u0ddd\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0dbd \u0daf\u0dd2\u0d9c\u0dd4\u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d9a\u0dd9\u0dbb\u0dd9\u0dc4\u0dd2 \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db1\u0ddc\u0d9a\u0dbb\u0dba\u0dd2. 'C', Fitch Ratings \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "2024 \u0daf\u0dd3 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db1\u0ddd\u0da7\u0dca\u0da7\u0dd4, \u0db1\u0ddd\u0da7\u0dca\u0da7\u0dd4 \u0db7\u0dcf\u0dbb \u0d94\u0db4\u0dca\u0db4\u0dd4\u0dc0 \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d87\u0db4\u0d9a\u0dbb\u0dd4 - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0da2\u0dba\u0da7 \u0db6\u0dd0\u0db3\u0dd3 \u0d87\u0dad\u0dd2 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda \u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dd2\u0dad \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dca \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0d9a\u0da9 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd3. \u0d92\u0dc0\u0dcf \u0db1\u0db8\u0dca (i) 2022 \u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca 12 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d91\u0dc4\u0dd2 \u0db6\u0dcf\u0dc4\u0dd2\u0dbb \u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dc3\u0dc4 \u0db4\u0ddc\u0dbd\u0dd3 \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0dda \u0dad\u0dc4\u0db1\u0db8\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dc4 (ii) 2022 \u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 25 \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0db1 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dab\u0dba \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dc5\u0dd2\u0dba \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dd0\u0dbb\u0dd3\u0db8, \u0dc3\u0dc4 \u0d86\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad \u0dc3\u0dc4\u0db1 \u0d9a\u0dcf\u0dbd\u0dba 2022 \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd3\u0db8.",
        "\u0db8\u0dd3\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0, \u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dc4 SLA \u0dc0\u0dd0\u0db1\u0dd2 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba\u0dda \u0dab\u0dba \u0d9c\u0dd0\u0dab\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dab\u0dba\u0dc0\u0dbd\u0da7 \u0db6\u0dbd\u0db4\u0dcf\u0db1 \u0dab\u0dba \u0dc3\u0dc4\u0db1 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8 \u0dad\u0dc0\u0db8\u0dad\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0d91\u0dba \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd6 \u0db6\u0dd0\u0db3\u0dd3\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0dc0\u0dd0\u0db1\u0dd2 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0d9a \u0d85\u0d9b\u0dab\u0dca\u0da9 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0db8\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc6\u0dd2\u0da0\u0dca \u0dc3\u0dbd\u0d9a\u0dba\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dca 'C' \u0dc4\u0dd2 \u0daf\u0dd2\u0d9c\u0dd4\u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0dc1\u0dca\u0dbb\u0dda\u0dab\u0dd2\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0db4\u0d9c\u0dda \u0db1\u0dd2\u0dbb\u0dca\u0dc0\u0da0\u0db1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0d9a\u0dd6\u0dbd \u0dc0\u0dda."
      ],
