          }
        ],
        [
          {
            "text": "\u0dc3\u0dcf\u0db0\u0dcf\u0dbb\u0dab \u0dc3\u0db8\u0dcf\u0da2\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd6 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba",
