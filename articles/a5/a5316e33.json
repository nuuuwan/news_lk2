  "original_title": "\u0bb5\u0bbf\u0b9a\u0bc7\u0b9f \u0bb5\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bae\u0bbe\u0ba9\u0bbf \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bb2\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc0\u0b9f\u0bc1",
  "text_idx": {
    "en": {
      "title": "Special Gazette Notification Issue",
      "author": "",
      "body_lines": [
        "A special gazette notification has been issued prohibiting the sale or use of rice or paddy for animal feed production.",
        "This special gazette notification has been issued by the Consumer Affairs Authority. (a)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [],
        [
          {
            "text": "the Consumer Affairs Authority",
