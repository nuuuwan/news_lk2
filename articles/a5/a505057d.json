          {
            "text": "\u0dc4\u0dba\u0dd2\u0db1\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad",
            "label": "GPE"
          },
          {
            "text": "\u0da0\u0dd3\u0db1 \u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0d85\u0db7\u0dca\u200d\u0dba\u0dc0\u0d9a\u0dcf\u0dc1 \u0d92\u0da2\u0db1\u0dca\u0dc3\u0dd2\u0dba",
