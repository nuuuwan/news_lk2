      "title": "Doctors in fuel queues",
      "body_lines": [
        "Doctors are seen in fuel queues in Colombo despite assurance that health staff could refuel their vehicles at identified filling stations on Fridays. Pix by Nimalsiri Edirisinghe"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "Fridays",
            "label": "DATE"
          },
          {
            "text": "Nimalsiri Edirisinghe",
