    "si": {
      "title": "\u0dc3\u0dad\u0dd2\u0dba\u0da7 \u0daf\u0dd2\u0db1 3\u0d9a\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca \u0db4\u0dcf\u0dc3\u0dbd - \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
      "author": "\u0da7\u0dd3 \u0dba\u0dd4\u0dc0\u0dbb\u0dcf\u0da2\u0dca",
      "body_lines": [
        "\u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db1\u0dd0\u0dc0\u0dad \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd9\u0db1 \u0dad\u0dd4\u0dbb\u0dd4 \u0dbd\u0db6\u0db1 \u0dc3\u0db3\u0dd4\u0daf\u0dcf (25) \u0dc3\u0dd2\u0da7 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0daf\u0dd2\u0db1 3\u0d9a\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0db3\u0dd4\u0daf\u0dcf, \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dba\u0db1 \u0daf\u0dd2\u0db1 3 \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc0\u0dd2\u0db0\u0dd2\u0db8\u0dad\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db6\u0dc0 \u0daf\u0db1\u0dca\u0dc0\u0dcf \u0d87\u0dad.",
        "\u0db8\u0dda \u0dc3\u0db8\u0d9f\u0db8 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0db1\u0ddc\u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0dc3\u0dd2\u0da7 \u0d89\u0d9c\u0dd0\u0db1\u0dca\u0dc0\u0dd3\u0db8 \u0dc4\u0ddd \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0da2\u0dcf\u0dbd\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0d89\u0d9c\u0dd0\u0db1\u0dca\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0daf \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb \u0d87\u0dad."
      ],
