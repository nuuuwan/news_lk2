        ],
        [
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0db4\u0ddc\u0dc5\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4\u0dc0 \u0db4\u0dd4\u0dbd\u0dad\u0dd2\u0dc3\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb \u0db8\u0dab\u0dca\u0da9\u0db4\u0dba",
