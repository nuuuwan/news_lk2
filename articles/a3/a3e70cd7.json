          {
            "text": "\u0baa\u0bca\u0bb2\u0ba9\u0bcd\u0ba9\u0bb1\u0bc1\u0bb5\u0bc8",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0ba8\u0bc2\u0bb1\u0bc1",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0baa\u0bca\u0bb2\u0ba9\u0bcd\u0ba9\u0bb1\u0bc1\u0bb5\u0bc8 \u0baa\u0bc1\u0bb2\u0ba4\u0bbf\u0b9a\u0bbf",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0 \u0bae\u0ba3\u0bcd\u0b9f\u0baa\u0bae\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0ba4\u0bae\u0ba9\u0bcd\u0b95\u0b9f\u0bc1\u0bb5",
            "label": "GPE"
          },
          {
            "text": "\u0baa\u0bca\u0bb2\u0ba9\u0bcd\u0ba9\u0bb1\u0bc1\u0bb5\u0bc8 \u0bae\u0bbe\u0bb5\u0b9f\u0bcd\u0b9f\u0bae\u0bcd",
            "label": "LOC"
          }
        ],
