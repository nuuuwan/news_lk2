    "si": {
      "title": "LP \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0dad\u0dc0\u0dad\u0dca \u0d85\u0da9\u0dd4 \u0d9a\u0dd9\u0dbb\u0dda: LITRO \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 12.5 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0dbd\u0db6\u0db1 \u0dc3\u0db3\u0dd4\u0daf\u0dcf (5 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf) \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db8\u0dd4\u0daf\u0dd2\u0dad \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db1\u0dc0 \u0db8\u0dd2\u0dbd \u0dc3\u0dd6\u0dad\u0dca\u200d\u0dbb\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad \u0db8\u0dd2\u0dbd \u0d9a\u0dd4\u0db8\u0d9a\u0dca \u0daf\u0dd0\u0dba\u0dd2 \u0d94\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0db1\u0ddc\u0d9a\u0dc5 \u0db1\u0db8\u0dd4\u0dad\u0dca \u0dbb\u0da7\u0dda \u0d85\u0db1\u0dd9\u0d9a\u0dd4\u0dad\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0d9a\u0dbb\u0db1 \u0db8\u0dd2\u0dbd\u0da7 \u0dc0\u0da9\u0dcf \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbb\u0da7 \u0db4\u0dd4\u0dbb\u0dcf \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 \u0db4\u0dc4\u0d9a\u0dca \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0dc4\u0dd2\u0d9f\u0dba \u0db8\u0db1\u0dcf\u0dc0 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0dad\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0db6\u0dd2\u0d82\u0daf\u0dd4\u0dc0\u0da7 \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba. \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae LITRO \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dc0\u0dbd \u0db8\u0dd2\u0dbd \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 8 \u0dc3\u0dd2\u0da7 \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3. (\u0da0\u0dad\u0dd4\u0dbb\u0d82\u0d9c \u0dc3\u0db8\u0dbb\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8)"
      ],
