    "si": {
      "title": "\u0d85\u0daf \u0db4\u0dd0\u0dba \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0d9a\u0dd0\u0db4\u0dd9\u0db1\u0dc0\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 A, B, C, D, E, F, G, H, I, J, K, L, P, Q, R, S, S, S, T, U, V, W \u0dba\u0db1 \u0d9a\u0dbd\u0dcf\u0db4\u0dc0\u0dbd \u0db4\u0dd0\u0dba\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0d8b\u0daf\u0dd1\u0dc3\u0db1.\u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 40 \u0dba\u0dd2 \u0db4\u0dd0\u0dba \u0d91\u0d9a\u0dba\u0dd2 \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 20 \u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d9a\u0ddc\u0db8\u0dd2\u0dc3\u0db8 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2. (\u0d86)"
      ],
