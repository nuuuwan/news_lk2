    "ta": {
      "title": "\u0b87\u0b9a\u0bc1\u0bb0\u0bc1\u0bb5\u0bbf\u0b9f\u0bae\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0b95\u0bbe\u0bae\u0ba9\u0bcd\u0bb5\u0bc6\u0bb2\u0bcd\u0ba4\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0bae\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0bb3\u0bc1\u0ba4\u0bc2\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0b87\u0b9a\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0b87\u0ba8\u0bcd\u0ba4 \u0b86\u0ba3\u0bcd\u0b9f\u0bc1 \u0baa\u0bca\u0ba4\u0bc1\u0ba8\u0bb2\u0bb5\u0bbe\u0baf \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0b95 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bc8 \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0bc6\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0bae\u0bc1\u0b9f\u0bbf\u0ba8\u0bcd\u0ba4\u0ba4\u0bc1.",
        "\u0baa\u0bb0\u0bcd\u0bae\u0bbf\u0b99\u0bcd\u0b95\u0bbe\u0bae\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b86\u0ba3\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 55 \u0b95\u0bbf\u0bb2\u0bcb \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0ba3\u0bcd\u0b95\u0bb2\u0baa\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bae\u0bb2\u0bc7\u0b9a\u0bbf\u0baf\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0b95\u0bae\u0ba4\u0bc1 \u0b85\u0ba9\u0bbf\u0b95\u0bcd \u0baa\u0bbf\u0ba9\u0bcd \u0b95\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bcd \u0ba4\u0b99\u0bcd\u0b95\u0baa\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bc8\u0baf\u0bc1\u0bae\u0bcd, \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0bcd \u0b9a\u0bb0\u0bcd\u0b95\u0bbe\u0bb0\u0bcd \u0bb5\u0bc6\u0bb3\u0bcd\u0bb3\u0bbf\u0baa\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd.",
        "\u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bcd \u0bb8\u0bcd\u0ba9\u0bbe\u0b9f\u0bcd\u0b9a\u0bcd \u0bae\u0bc1\u0bb1\u0bc8\u0baf\u0bbf\u0bb2\u0bcd 105 \u0b95\u0bbf\u0bb2\u0bcb\u0bb5\u0bc1\u0bae\u0bcd, \u0b95\u0bbf\u0bb3\u0bc0\u0ba9\u0bcd \u0b85\u0ba3\u0bcd\u0b9f\u0bcd \u0b9c\u0bc6\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd 120 \u0b95\u0bbf\u0bb2\u0bcb\u0bb5\u0bc1\u0bae\u0bcd \u0ba4\u0bc2\u0b95\u0bcd\u0b95\u0bbf \u0bae\u0bca\u0ba4\u0bcd\u0ba4\u0bae\u0bcd 225 \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf\u0b95\u0bb3\u0bcd \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd."
      ],
