          {
            "text": "04",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dab\u0dca\u0da9\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dda \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dc4\u0dad",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "RHS \u0dc3\u0db8\u0dbb\u0dad\u0dd4\u0d82\u0d9c",
