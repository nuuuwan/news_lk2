    "si": {
      "title": "\u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba: \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc0\u0dd2\u0dc2\u0dba\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0db1\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc0\u0dd9\u0dad \u0dc0\u0dd2\u0dc2\u0dba\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4, \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf \u0dc3\u0dc4 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db4\u0dd2\u0dad \u0d86\u0dba\u0dad\u0db1 \u0db4\u0dd0\u0dc0\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dc3 22 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7; \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0db3\u0dc4\u0dcf DMT \u0dc3\u0db8\u0d9f \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3\u0db8\u0da7 49CC \u0db6\u0dba\u0dd2\u0d9a\u0dca"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "News 1st",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 22 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4, \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf \u0dc3\u0dc4 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db4\u0dd2\u0dad \u0d86\u0dba\u0dad\u0db1",
            "label": "ORG"
          }
        ],
