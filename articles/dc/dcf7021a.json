    "si": {
      "title": "\u0dbb\u0dd2\u0dc2\u0dcf\u0da9\u0dca\u0d9c\u0dda \u0dc3\u0dc4\u0dba\u0dad\u0dca \u0da9\u0dbd\u0dc3\u0dca\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dd2\u0dc2\u0dcf\u0da9\u0dca \u0db6\u0daf\u0dd4\u0dbb\u0dca\u0daf\u0dd3\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba \u0daf\u0dbb\u0db1 \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba\u0daf \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0d9a \u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0dc3\u0dc4\u0dcf\u0dba \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db6\u0daf\u0dd4\u0dbb\u0dca\u0daf\u0dd3\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0d9a\u0daf\u0dd3 \u0db8\u0dda \u0db6\u0dc0 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0dbb\u0dd2\u0dc2\u0dcf\u0da9\u0dca",
          "label": "ORG"
        },
        {
          "text": "\u0da9\u0dbd\u0dc3\u0dca",
          "label": "GPE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba",
            "label": "LAW"
          },
