    "si": {
      "title": "\u0dad\u0dd6\u0dad\u0dca\u0dad\u0dd4\u0d9a\u0dd4\u0da9\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d92\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0dc0\u0dda\u0daf\u0db1\u0dcf \u0db1\u0dcf\u0dc1\u0d9a \u0db4\u0dd9\u0dad\u0dd2 \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0dd0\u0db1\u0dda.",
      "author": "T. Saranya",
      "body_lines": [
        "\u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db1\u0dcf\u0da9\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dd6 \u0dc0\u0dda\u0daf\u0db1\u0dcf \u0db1\u0dcf\u0dc1\u0d9a \u0db4\u0dd9\u0dad\u0dd2 \u0dad\u0ddc\u0d9c\u0dba \u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db1\u0dcf\u0da9\u0dd4 Q \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc1 \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0db7\u0dcf\u0dbb\u0dba\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0dad\u0dd6\u0dad\u0dd4\u0d9a\u0dd4\u0da9\u0dd2 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0dad\u0dca\u200d\u0dbb\u0dd9\u0dc3\u0dca\u0db4\u0dd4\u0dbb\u0db8\u0dca \u0dc0\u0dd9\u0dbb\u0dc5 \u0dad\u0dd3\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dc0\u0dda\u0daf\u0db1\u0dcf \u0db1\u0dcf\u0dc1\u0d9a \u0db4\u0dd9\u0dad\u0dd2 \u0da2\u0dcf\u0dc0\u0dcf\u0dbb\u0db8\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0da7 Q \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dd9\u0dba\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0dad\u0dca\u200d\u0dbb\u0dd9\u0dc3\u0dca\u0db4\u0dd4\u0dbb\u0db8\u0dca \u0dc0\u0dd9\u0dbb\u0dc5 \u0dad\u0dd3\u0dbb\u0dba\u0dda \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d85\u0d82\u0d9a\u0dba\u0d9a\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0 \u0dc3\u0dd0\u0d9a\u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db1\u0dc0\u0dad\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0dbb\u0da7 \u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0\u0d9a\u0dca Q \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd4\u0dc0\u0dcf.",
        "\u0d89\u0db1\u0dca \u0dc0\u0dda\u0daf\u0db1\u0dcf \u0db1\u0dcf\u0dc1\u0d9a \u0db4\u0dd9\u0dad\u0dd2 4430\u0d9a\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dc4\u0ddc\u0dbb \u0dbb\u0dc4\u0dc3\u0dda \u0d9c\u0dd9\u0db1 \u0d92\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dcf\u0da9\u0dca\u0db4\u0dad\u0dca 443\u0d9a \u0db4\u0db8\u0dab \u0dad\u0dd2\u0db6\u0dd3 \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0dc3\u0ddc\u0dba\u0dcf\u0d9c\u0dad\u0dca \u0dc0\u0dda\u0daf\u0db1\u0dcf \u0db1\u0dcf\u0dc1\u0d9a \u0db4\u0dd9\u0dad\u0dd2 \u0dc3\u0dc4 \u0dbb\u0da7 \u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 Q \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbb\u0dda\u0d9c\u0dd4 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd9\u0dad \u0db7\u0dcf\u0dbb \u0daf\u0dd9\u0db1 \u0dbd\u0daf\u0dd3."
      ],
