    "si": {
      "title": "\u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dc0\u0dc3\u0dbb 25 \u0dad\u0dd4\u0dc5 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0dd2\u0dad \u0dbb\u0da7\u0d9a\u0dca \u0dc0\u0dda\u0dc0\u0dd2 - \u0db8\u0ddd\u0daf\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dc0\u0dc3\u0dbb 25 \u0dad\u0dd4\u0dc5 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0dd2\u0dad \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba\u0dba\u0d9a\u0dca \u0db6\u0dc0 \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0db1\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0db8 \u0dba\u0dd4\u0dad\u0dd4\u0d9a\u0db8\u0dca \u0d89\u0da7\u0dd4 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0db1\u0dbb\u0dda\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb \u0db8\u0ddd\u0daf\u0dd2 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0dc3\u0dd2\u0dba 76 \u0dc0\u0dd0\u0db1\u0dd2 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0daf\u0dd2\u0db1\u0dba \u0dc3\u0db8\u0dbb\u0db1 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0daf\u0dd2\u0dbd\u0dca\u0dbd\u0dd2 \u0dbb\u0dad\u0dd4 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0da2\u0dcf\u0dad\u0dd2\u0dba \u0d85\u0db8\u0dad\u0db8\u0dd2\u0db1\u0dca \u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0db8\u0dd9\u0dc3\u0dda \u0db4\u0dc0\u0dc3\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0dba."
