          },
          {
            "text": "\u0d85\u0dbd\u0dd2 \u0dc3\u0db6\u0dca\u0dbb\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0db0\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dba\u0daf\u0dcf\u0dc3 \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
