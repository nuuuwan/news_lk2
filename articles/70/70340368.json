      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b85\u0bb2\u0bbf \u0b9a\u0baa\u0bcd\u0bb0\u0bbf",
            "label": "PERSON"
          },
          {
            "text": "\u0b9c\u0bc6\u0ba9\u0bc0\u0bb5\u0bbe",
            "label": "GPE"
          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "51\u0bb5\u0ba4\u0bc1",
            "label": "DATE"
          },
          {
            "text": "\u0b90\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bae\u0ba9\u0bbf\u0ba4 \u0b89\u0bb0\u0bbf\u0bae\u0bc8\u0b95\u0bb3\u0bcd \u0baa\u0bc7\u0bb0\u0bb5\u0bc8",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc1\u0bb1\u0bb5\u0bc1 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b85\u0bb2\u0bbf \u0b9a\u0baa\u0bcd\u0bb0\u0bbf",
            "label": "PERSON"
          },
          {
            "text": "\u0ba8\u0bbf\u0ba4\u0bbf",
            "label": "PERSON"
          },
          {
            "text": "\u0bb5\u0bbf\u0b9c\u0baf\u0ba4\u0bbe\u0b9a \u0bb0\u0bbe\u0b9c\u0baa\u0b95\u0bcd\u0bb7",
            "label": "PERSON"
          },
          {
            "text": "\u0b9c\u0bc6\u0ba9\u0bb0\u0bb2\u0bbf\u0ba9\u0bcd",
            "label": "ORG"
          },
