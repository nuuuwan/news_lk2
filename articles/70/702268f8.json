          {
            "text": "\u0b9a\u0bb0\u0bcd\u0b83\u0baa\u0bcd \u0b8e\u0b95\u0bcd\u0b9a\u0bc6\u0bb2\u0bcd",
            "label": "PERSON"
          },
          {
