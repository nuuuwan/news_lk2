        [
          {
            "text": "\u0db1\u0dd9\u0dbb\u0db1\u0dca\u0da9",
            "label": "NORP"
          },
          {
            "text": "\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dcf\u0dbb\u0db8\u0dca\u0dbd \u0db8\u0dba\u0dd4\u0dbb\u0db4\u0dcf\u0dbb \u0db8\u0db0\u0dca\u200d\u0dba \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0db1",
            "label": "ORDINAL"
          }
        ],
        [
          {
            "text": "\u0dad\u0db8\u0dd2\u0dbd\u0dca\u0dc0\u0dcf\u0db1\u0db1\u0dca \u0dad\u0dd4\u0dc0\u0dcf\u0dbb\u0d9a\u0dda\u0dc2\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0da9\u0d9a\u0dbd\u0db4\u0dd4\u0dc0 \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db8\u0dba\u0dd2\u0d9a\u0dbd\u0dca \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0db1",
            "label": "ORDINAL"
          }
        ],
        [
          {
            "text": "\u0d89\u0dc2\u0dd2\u0db1\u0dd2 \u0db1\u0dda\u0dc4\u0dcf \u0d85\u0db8\u0dbb\u0dbb\u0dad\u0dca\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dc0\u0dbd\u0dd3 \u0db6\u0dcf\u0dbd\u0dd2\u0d9a\u0dcf'",
