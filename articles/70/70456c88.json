    "si": {
      "title": "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d96\u0dc2\u0db0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0d96\u0dc2\u0db0 \u0dc0\u0dbb\u0dca\u0d9c 3\u0da7 \u0d89\u0dc4\u0dc5 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d96\u0dc2\u0db0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0db8\u0dd1\u0dad\u0d9a\u0daf\u0dd3 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc0\u0dd9\u0dc5\u0dd9\u0db3\u0db4\u0ddc\u0dbd\u0da7 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd4\u0db1\u0dca \u0dbd\u0dd9\u0dc0\u0dad\u0dd2\u0dbb\u0ddc\u0dc2\u0dd2\u0db1\u0dca 50, \u0d94\u0db8\u0db4\u0dbb\u0dc2\u0ddd\u0dbd\u0dca 20 \u0dc3\u0dc4 \u0db8\u0dd9\u0dc6\u0db1\u0db8\u0dd2\u0d9a\u0dca \u0d87\u0dc3\u0dd2\u0da9\u0dca 500 \u0dba\u0db1 \u0d96\u0dc2\u0db0 \u0dc0\u0dbb\u0dca\u0d9c \u0dad\u0dd4\u0db1\u0da7 \u0d89\u0dc4\u0dc5 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d91\u0db8 \u0d96\u0dc2\u0db0 \u0dad\u0dd4\u0db1 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbb\u0da7\u0db8 \u0d86\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d87\u0db1\u0dc0\u0dd4\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d9a\u0dd3 \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0d91\u0db8 \u0d87\u0db1\u0dc0\u0dd4\u0db8\u0dca \u0dc4\u0dd0\u0d9a\u0dd2 \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0d86\u0d9a\u0dcf\u0dbb\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d9a\u0da7\u0dba\u0dad\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0 \u0daf \u0dc3\u0daf\u0d9f\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dbb\u0da7 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db8\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0d9a \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba\u0d9a\u0da7 \u0db8\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0dc0\u0da9\u0dcf\u0dad\u0dca \u0dc0\u0dd0\u0db3\u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0daf \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
