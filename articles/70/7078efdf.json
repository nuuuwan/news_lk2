      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dc4 \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4",
