    "si": {
      "title": "\u0d9c\u0dcf\u0dbd\u0dd4\u0db8\u0dd4\u0dc0\u0daf\u0ddc\u0dbb \u0d85\u0dbb\u0d9c\u0dbd\u0dba\u0da7 \u0daf\u0dd2\u0db1 100\u0d9a\u0dca \u0dc3\u0db4\u0dd2\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9c\u0dcf\u0dbd\u0dd4 \u0db8\u0dd4\u0dc0\u0daf\u0ddc\u0dbb \u0da2\u0db1 \u0d85\u0dbb\u0d9c\u0dbd\u0dba\u0dda \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0ddd \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0da2\u0db1 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dca\u200d\u0dbb\u0daf\u0dcf\u0dba\u0dd2\u0d9a \u0da0\u0dcf\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dbb \u0dc0\u0dcf\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dbb \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd0\u0db8\u0dbb\u0dd4\u0db8\u0dca \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0db1 100 \u0dc3\u0db1\u0dd2\u0da7\u0dd4\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dc4. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0d9a\u0dd4\u0dc2\u0dcf\u0db1\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dcf\u0da2"
      ],
