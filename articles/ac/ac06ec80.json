    "si": {
      "title": "\u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db4\u0dca\u200d\u0dbb\u0db8\u0dd2\u0dad\u0dd2 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda \u0db4\u0dd2\u0dc5\u0dd2\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0d87\u0d9c\u0dba\u0dd3\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8",
      "author": "\u0dc0\u0dd2\u0dc2\u0dca\u0dab\u0dd4",
      "body_lines": [
        "\u0d92 \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda \u0daf\u0dd9\u0dc0\u0db1 \u0d85\u0daf\u0dd2\u0dba\u0dbb\u0dda \u0d87\u0d9c\u0dba\u0dd3\u0db8\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dcf.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0db4\u0dad\u0dca\u200d\u0dbb \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda \u0db4\u0dd2\u0dc5\u0dd2\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dad\u0dca\u200d\u0dbb \u0d87\u0d9c\u0dba\u0dd3\u0db8\u0dda \u0daf\u0dd9\u0dc0\u0db1 \u0d85\u0daf\u0dd2\u0dba\u0dbb \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc3\u0db8\u0dd4\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d87\u0d9c\u0dba\u0dd3\u0db8\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0d85\u0daf\u0dd2\u0dba\u0dbb \u0dc3\u0dcf\u0dbb\u0dca\u0dae\u0d9a\u0dc0 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dbb \u0d87\u0dad. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dad\u0dca\u200d\u0dbb \u0d87\u0d9c\u0dba\u0dd3\u0db8\u0dda \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c \u0db8\u0db0\u0dca\u200d\u0dba\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dcf.",
        "\u0dad\u0dc0\u0daf, 2021 \u0dc0\u0dc3\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0d85.\u0db4\u0ddc.\u0dc3 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0da7\u0dd2\u0db4\u0dcf\u0da7\u0dd2 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dda. \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0dbd\u0db6\u0db1 10 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba.",
        "\u0d85\u0db4\u0ddc\u0dc3 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1 \u0db4\u0dad\u0dca\u200d\u0dbb \u0d87\u0d9c\u0dba\u0dd3\u0db8\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d85\u0daf\u0dd2\u0dba\u0dbb\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dda. 2021 \u0dc0\u0dc3\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0d85.\u0db4\u0ddc.\u0dc3 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd \u0db8\u0dda \u0db8\u0dc3 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc4\u0ddd \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dc3 \u0db8\u0dd4\u0dbd\u0dca \u0dc3\u0dad\u0dd2 \u0daf\u0dd9\u0d9a \u0d87\u0dad\u0dd4\u0dc5\u0dad \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
