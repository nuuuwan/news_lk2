        [
          {
            "text": "937",
            "label": "CARDINAL"
          },
          {
            "text": "\u0baa\u0bbe\u0b95\u0bbf\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bcd",
            "label": "GPE"
          }
