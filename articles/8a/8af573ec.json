    "si": {
      "title": "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dbb\u0dcf\u0dab\u0dd2 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dda\u0dc0\u0dba \u0d87\u0dbb\u0db9\u0dda",
      "author": "T. Saranya",
      "body_lines": [
        "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc3\u0dc4 \u0d9a\u0dd2\u0dbd\u0dd2\u0db1\u0ddc\u0da0\u0dca\u0da0\u0dd2\u0dba \u0d85\u0dad\u0dbb \u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dda\u0dc0\u0dcf\u0dc0 \u0d85\u0daf \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dd2\u0dba.",
        "\u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc4\u0dcf \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0db4\u0dc4\u0dc3\u0dd4\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0daf\u0dd3 \u0d87\u0dad.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0dba\u0dcf\u0db4\u0db1\u0dba \u0d9a\u0dca\u0dc0\u0dd3\u0db1\u0dca\u0dc3\u0dca \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 06.00 \u0da7 \u0d9a\u0db1\u0dca\u0d9c\u0dda\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0dbb\u0dda \u0dc3\u0dd2\u0da7 \u0db4\u0dd2\u0da7\u0dad\u0dca\u0dc0 \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 8.11 \u0da7 \u0db8\u0dd4\u0dbb\u0dd2\u0d9a\u0db1\u0dca\u0da9\u0dd2 \u0dc0\u0dd9\u0dad \u0dc5\u0d9f\u0dcf \u0dc0\u0dda.",
        "\u0db1\u0dd0\u0dc0\u0dad \u0d91\u0dad\u0dd0\u0db1\u0dca \u0dc3\u0dd2\u0da7 \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 10.00 \u0da7 \u0dba\u0dcf\u0db4\u0db1\u0dba \u0db6\u0dbd\u0dcf \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 11.20 \u0da7 \u0dba\u0dcf\u0db4\u0db1\u0dba\u0da7 \u0dc5\u0d9f\u0dcf \u0dc0\u0dda.",
        "\u0db1\u0dd0\u0dc0\u0dad \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d9a\u0db1\u0dca\u0d9c\u0dda\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0dbb\u0dda \u0dc3\u0dd2\u0da7 \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 02.00 \u0da7 \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0\u0dd3 \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 4.10 \u0da7 \u0db8\u0dd4\u0dbb\u0dd2\u0d9a\u0db1\u0dca\u0da9\u0dd2 \u0dc0\u0dd9\u0dad \u0dc5\u0d9f\u0dcf \u0dc0\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db1\u0dd0\u0dc0\u0dad\u0dad\u0dca \u0db8\u0dd4\u0dbb\u0dd2\u0d9a\u0db1\u0dca\u0da9\u0dd2 \u0dc3\u0dd2\u0da7 \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 4.40 \u0da7 \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0\u0dd3 \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 7.20 \u0da7 \u0d9a\u0db1\u0dca\u0d9c\u0dda\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0dbb\u0dba \u0dc0\u0dd9\u0dad \u0dc5\u0d9f\u0dcf \u0dc0\u0dda.",
        "\u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d9a\u0dd2\u0dbd\u0dd2\u0db1\u0ddc\u0da0\u0dca\u0da0\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d91\u0d9a\u0dca \u0d9c\u0db8\u0db1\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 90 \u0d9a\u0dca, \u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc3\u0dd2\u0da7 \u0db4\u0dbd\u0dd9\u0dba\u0dd2 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 60 \u0d9a\u0dca \u0dc3\u0dc4 \u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc3\u0dd2\u0da7 \u0d9a\u0ddc\u0da9\u0dd2\u0d9c\u0db8\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 35 \u0d9a\u0dd2."
      ],
