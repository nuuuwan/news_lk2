          {
            "text": "\u0d91\u0da9\u0db4\u0dca\u0db4\u0dcf\u0da9\u0dd2 \u0db4\u0dbd\u0db1\u0dd2\u0dc3\u0dca\u0dc0\u0dcf\u0db8\u0dd2",
