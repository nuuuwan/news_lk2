    "si": {
      "title": "\u0db8\u0dc4\u0db4\u0ddc\u0dc5\u0da7, \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0dcf\u0db0\u0dcf\u0dbb\u0dc0\u0dbd\u0da7 \u0d9c\u0dd2\u0dba \u0dc0\u0dc3\u0dbb\u0dda \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 2000\u0d9a\u0dca \u0dc0\u0dd0\u0dba \u0d9a\u0dbb\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0db1\u0dca\u0da7 \u0db8\u0dc4\u0db4\u0ddc\u0dc5 \u0dc4\u0dcf \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0dcf\u0db0\u0dcf\u0dbb \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0d9c\u0dd2\u0dba \u0dc0\u0dc3\u0dbb\u0dda\u0daf\u0dd3 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 2000\u0d9a\u0dca \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dc0\u0dd0\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d9c\u0dd2\u0dba \u0dc0\u0dc3\u0dbb\u0dda \u0db8\u0dc4\u0db4\u0ddc\u0dc5 \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0dcf\u0db0\u0dcf\u0dbb \u0dbd\u0dd0\u0db6\u0dd6 \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 62891\u0d9a\u0dca \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0dc1\u0dd2\u0dc3\u0dca\u200d\u0dba\u0dcf\u0db0\u0dcf\u0dbb \u0dbd\u0dd0\u0db6\u0dd6 \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 29491\u0d9a\u0dca \u0dc0\u0dd2 \u0d87\u0dad.",
        "\u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0d9c\u0dd8\u0dc4 \u0d86\u0daf\u0dcf\u0dba\u0db8 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 5\u0d9a \u0dc3\u0dd3\u0db8\u0dcf\u0dc0 \u0dba\u0da7\u0dad\u0dda \u0db8\u0dc4\u0db4\u0ddc\u0dc5 \u0dc4\u0dcf \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0dcf\u0db0\u0dcf\u0dbb \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd9\u0dba\u0dd2.",
        "2020/2021 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0dc0\u0dbb\u0dca\u0dc2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca 41755\u0d9a\u0dca \u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dad\u0dbb, \u0dbb\u0da7\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dc0\u0dcf\u0dad\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dba\u0da7\u0dad\u0dda \u0d91\u0db8 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca on - line \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc4\u0daf\u0dcf\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0dba\u0dd2."
      ],
