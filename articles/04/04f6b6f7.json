    "si": {
      "title": "\u0db4\u0dcf\u0daf \u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0\u0dda \u0dba\u0dd9\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0dad\u0dca\u0dc0\u0dd0\u0dbd\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0dd4\u0db8\u0db1 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0db1\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0dda \u0dc3\u0dd2\u0da7 \u0d9a\u0dd4\u0db9\u0dd4\u0d9a\u0dca\u0d9a\u0db1\u0dca \u0d94\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0daf\u0dd2\u0dc0\u0dd9\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u2018\u0db4\u0dcf\u0daf \u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u2019 \u0db1\u0db8\u0dd2\u0db1\u0dca \u0dc4\u0dd0\u0db3\u0dd2\u0db1\u0dca\u0dc0\u0dd9\u0db1 \u0db4\u0dcf\u0daf \u0dc0\u0db1\u0dca\u0daf\u0db1\u0dcf\u0dc0\u0dda \u0dba\u0dd9\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0db4\u0dd4\u0dbb\u0dd4\u0daf\u0dca\u0daf\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dad\u0db8 \u0d86\u0db0\u0dcf\u0dbb \u0d8b\u0db4\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0dba\u0dd2. \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dca\u200d\u0dbb\u0daf\u0dcf\u0dba\u0dd2\u0d9a \u0db4\u0dcf\u0daf \u0dc0\u0db1\u0dca\u0daf\u0db1\u0dcf\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a\u0dc0 \u0db6\u0ddc\u0dc4\u0ddd \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2."
      ],
