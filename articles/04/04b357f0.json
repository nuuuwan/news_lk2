    "si": {
      "title": "\u0dc3\u0dd2\u0d9c\u0dbb\u0dd0\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0d9a\u0dca \u0d9c\u0dab\u0db1\u0dca \u0d8b\u0dc3\u0dca\u0dc3\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0dd2\u0d9c\u0dbb\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dad\u0dd4\u0db1\u0dda \u0dc3\u0dd2\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 15 \u0d85\u0dad\u0dbb \u0db8\u0dd2\u0dbd\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dbd\u0d82\u0d9a\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0d9a\u0ddc\u0dc5 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dc0\u0dc3\u0dba\u0dd2 .",
        "\u0db8\u0dd9\u0db8 \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u00a0\u0d8a\u0dba\u0dd9 (01) \u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0d85\u0dad\u0dbb\u00a0\u00a0 \u0d9a\u0dd0\u0db4\u0dca\u0da7\u0db1\u0dca \u0dc0\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0dc3\u0dd2\u0d9c\u0dbb\u0dd0\u0da7\u0dca \u0d91\u0d9a\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 3 \u0d9a\u0dd2\u0db1\u0dca \u0daf , \u0db6\u0dca\u200d\u0dbb\u0dd2\u0dc3\u0dca\u0da7\u0dbd\u0dca \u0dc3\u0dc4 \u0d9c\u0ddd\u0dbd\u0dca\u0dbd\u0dd3\u0dc6\u0dca \u0dc0\u0dbb\u0dca\u0d9c\u0dc0\u0dbd \u0dc3\u0dd2\u0d9c\u0dbb\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 05 \u0d9a\u0dd2\u0db1\u0dca \u0daf .\u0da9\u0db1\u0dca\u0dc4\u0dd2\u0dbd\u0dca \u0dc3\u0dd4\u0dc0\u0dd2\u0da0\u0dca \u0dc3\u0dc4 \u0da9\u0db1\u0dca\u0dc4\u0dd2\u0dbd\u0dca \u0da9\u0db6\u0dbd\u0dca \u0dc3\u0dd4\u0dc0\u0dd2\u0da0\u0dca \u0dc0\u0dbb\u0dca\u0d9c \u0dc0\u0dbd \u0dc3\u0dd2\u0d9c\u0dbb\u0da7\u0dca \u0d91\u0d9a\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10 \u0d9a\u0dd2\u0db1\u0dca \u0daf , \u0da9\u0db1\u0dca\u0dc4\u0dd2\u0dbd\u0dca \u0db6\u0dca\u0dbd\u0dd4\u0d9c\u0dca\u200d\u0dbb\u0dda \u0dc3\u0dd2\u0d9c\u0dbb\u0dd0\u0da7\u0dca \u0d91\u0d9a\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 15 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dc0\u0dc3\u0dba\u0dd2 .",
        "\u0dc0\u0dd0\u0da7\u0dca \u0db6\u0daf\u0dca\u0daf \u0dc3\u0dd2\u0dba\u0dba\u0da7 12 \u0dc3\u0dd2\u0da7 15% \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0d9c\u0dbb\u0dd0\u0da7\u0dca \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dbd\u0d82\u0d9a\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0d9a\u0ddc\u0dc5 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
