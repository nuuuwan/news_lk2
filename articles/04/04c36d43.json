    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd0\u0dc0\u0dca \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0dc5\u0d9f \u0d91\u0db1\u0dc0\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dde\u0d9a\u0dcf \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0db8\u0dd9\u0db8 \u0dc3\u0dad\u0dd2\u0dba \u0dad\u0dd4\u0dc5 \u0d9a\u0ddc\u0dc5\u0db9\u0da7 \u0dc5\u0d9c\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0dcf\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0dc4\u0dd9\u0da7 (12) \u0dc3\u0dd2\u0da7 15 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0daf, \u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0db8\u0dda \u0db8\u0dc3 14 \u0dc3\u0dc4 16 \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0daf, \u0daf\u0dd0\u0dc0\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0db8\u0dda \u0db8\u0dc3 15 \u0dc3\u0dc4 17 \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0daf, \u0dc5\u0d9c\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0\u0dad\u0dca\u00a0 \u0d91\u0db8 \u0db1\u0dde\u0d9a\u0dcf \u0d9a\u0ddc\u0dc5\u0db9\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db8\u0dda \u0db8\u0dc3 17 \u0dc3\u0dc4 19 \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0dc5\u0d9c\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc4\u0dd9\u0da7 (12) \u0d9c\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
