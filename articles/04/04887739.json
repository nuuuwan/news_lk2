    "si": {
      "title": "\u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0da2\u0dbd\u0dcf\u0dc1\u0dba\u0dda \u0dc0\u0dcf\u0db1\u0dca \u0daf\u0ddc\u0dbb\u0da7\u0dd4 3\u0d9a\u0dca \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0d9a\u0db3\u0dd4\u0d9a\u0dbb\u0dba\u0da7\u00a0 \u0d87\u0daf \u0dc4\u0dd0\u0dbd\u0dd9\u0db1 \u0dc0\u0dbb\u0dca\u0dc2\u0dcf\u0dc0 \u0db1\u0dd2\u0dc3\u0dcf \u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0da2\u0dbd\u0dcf\u0dc1\u0dba\u0dda \u0dc0\u0dcf\u0db1\u0dca \u0daf\u0ddc\u0dbb\u0da7\u0dd4 3\u0d9a\u0dca \u0d8a\u0dba\u0dda (01) \u0daf\u0dd2\u0db1 \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dda\u0dbd\u0dca\u0dbd \u0db7\u0dcf\u0dbb \u0d89\u0d82\u0da2\u0dd2\u0db1\u0dda\u0dbb\u0dd4 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u00a0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0dc0\u0dda\u0dbd\u0dca\u0dbd\u0dda \u0dc0\u0dcf\u0db1\u0dca \u0daf\u0ddc\u0dbb\u0da7\u0dd4 \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0d85\u0da9\u0dd2 1 \u0d85\u0d9c\u0dbd\u0dca 6 (1'.6\") \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7 \u0d94\u0dc3\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db8\u0dda \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0da2\u0dbd\u0dcf\u0dc1\u0dba \u0db4\u0dc4\u0dc5\u0da7 \u0db8\u0dc4\u0dc0\u0dd0\u0dbd\u0dd2 \u0d9c\u0d9f\u0da7 \u0dad\u0dad\u0dca\u0db4\u0dbb\u0dba\u0da7 \u0d9d\u0dab \u0d85\u0da9\u0dd2\u00a0 4,500 \u0d9a \u0da2\u0dbd \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca\u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0daf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dda \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0dc0\u0dda\u0dbd\u0dca\u0dbd\u0da7 \u0db4\u0dc4\u0dc5\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u0da7\u0ddd\u0dbb\u0dd2\u0dba\u0dcf \u0da2\u0dbd\u0dcf\u0dc1\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u00a0 \u0db8\u0dc4\u0dc0\u0dd0\u0dbd\u0dd2 \u0d9c\u0d9f \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dbb\u0db1 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d85\u0dc0\u0db0\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd3\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0d91\u0db8 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u00a0 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ],
