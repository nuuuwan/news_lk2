          {
            "text": "\u0db4\u0dd0\u0dbb\u0dd2\u0dc3\u0dca \u0dc3\u0db8\u0dcf\u0da2\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db4\u0dd0\u0dbb\u0dd2\u0dc3\u0dca \u0dc3\u0db8\u0dcf\u0da2\u0dba",
