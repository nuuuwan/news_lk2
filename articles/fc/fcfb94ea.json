        ],
        [
          {
            "text": "\u0db4\u0dd0\u0dbb\u0dd2\u0dc3\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0dc3\u0db8\u0dcf\u0da2\u0dba",
