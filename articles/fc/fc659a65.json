          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0d9c\u0d82\u0d9c\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0db8\u0db0\u0dd4\u0dbb \u0dc0\u0dd2\u0dad\u0dcf\u0db1 \u0db4\u0daf\u0db1\u0db8",
