  "text_idx": {
    "en": {
      "title": "Sri Lanka property developers allowed to import tiles",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT \u2013 Sri Lanka President Ranil Wickremesinghe has allowed property developers to import tiles for their own use in a gazette notice after they were banned under a surge of economic nationalism made possible by money printing that broke an exchange rate peg.",
        "Imports of tiles and stones (HS codes 25.16, 25.16, 68.02, 68.10) for the purpose of \u201cdirect usage\u201d and not for resale has been allowed.",
        "Approved condominiums, mixed development projects,  approved hotels and government projects not coming under the Board of Investment would be allowed to import the material set in the bill of quantities.",
        "Construction vehicles for government funded projects for direct use will also be allowed."
      ],
      "title_ents": [
        {
          "text": "Sri Lanka",
          "label": "GPE"
        }
      ],
