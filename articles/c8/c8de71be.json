            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 27",
            "label": "DATE"
          },
          {
            "text": "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 9",
            "label": "DATE"
          },
          {
            "text": "\u0db1\u0dd2\u0dc0\u0dc3",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dbb\u0dc4\u0dca\u0db8\u0dcf\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0dbb\u0d9c\u0dbd\u0dba",
            "label": "NORP"
          },
          {
            "text": "\u0dc6\u0dd2\u0da0\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9c\u0dd9\u0dba\u0dd2\u0db1\u0dca \u0d9c\u0dd9\u0da7 \u0d8b\u0dc3\u0dcf\u0dc0\u0dd2\u0dba",
            "label": "ORG"
          },
          {
