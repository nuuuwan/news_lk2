    "si": {
      "title": "\u0dc4\u0dd9\u0da7 \u0d9a\u0ddc\u0dc5\u0db9\u0da7 \u0db4\u0dd0\u0dba 10\u0d9a \u0da2\u0dbd \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd2\u0dba\u0dd4\u0dab\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf (20) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 11.00 \u0dc3\u0dd2\u0da7 \u0d89\u0dbb\u0dd2\u0daf\u0dcf (21) \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 9.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a \u0db4\u0dd0\u0dba 10\u0d9a \u0da2\u0dbd \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1 \u0db6\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba (NWSDB) \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0ddc\u0dc5\u0db9 5 \u0dc3\u0dc4 6 \u0dba\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d9a\u0ddc\u0dc5\u0db9 4 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0da9\u0dd4 \u0db4\u0dd3\u0da9\u0db1\u0dba\u0d9a\u0dca \u0dba\u0da7\u0dad\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dd4 \u0d87\u0dad\u0dd2.",
        "NWSDB \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dc0\u0dad\u0dca \u0dad\u0dbb\u0db8\u0dca \u0da2\u0dbd\u0dba \u0db4\u0dd4\u0dbb\u0dc0\u0db1 \u0dbd\u0dd9\u0dc3 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0daf\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd6 \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf\u0dc0\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d9a\u0dab\u0d9c\u0dcf\u0da7\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb\u0dba\u0dd2. \u0da2\u0dbd\u0dba \u0db4\u0dbb\u0dd2\u0dc3\u0dca\u0dc3\u0db8\u0dd2\u0db1\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0daf \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2. (\u0da0\u0dad\u0dd4\u0dbb\u0d82\u0d9c \u0dc3\u0db8\u0dbb\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8)"
      ],
