    "si": {
      "title": "\u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0d85\u0daf (26) \u0dc3\u0dd2\u0da7 \u0d94\u0da7\u0ddd \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0db1 \u0db6\u0dc0 \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dcf\u0dc4\u0db1 \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0db1 \u0db6\u0dc0\u0dba\u0dd2 \u0d91\u0db8 \u0dc3\u0d82\u0d9c\u0db8\u0dba \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dc5\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dcf\u0dc4\u0db1 \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "WORK_OF_ART"
