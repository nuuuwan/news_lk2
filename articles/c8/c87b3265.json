          }
        ],
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0dc4\u0da2\u0db1 \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
