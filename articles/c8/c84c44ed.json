    "si": {
      "title": "WFP \u0d86\u0dc3\u0dd2\u0dba\u0dcf \u0dc3\u0dc4 \u0db4\u0dd0\u0dc3\u0dd2\u0dc6\u0dd2\u0d9a\u0dca \u0d9a\u0dbd\u0dcf\u0db4\u0dd3\u0dba \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d85\u0dbd\u0dd2 \u0dc3\u0db6\u0dca\u0dbb\u0dd2 \u0dc4\u0db8\u0dd4\u0dc0\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbd\u0ddd\u0d9a \u0d86\u0dc4\u0dcf\u0dbb \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1\u0dda (WFP) \u0d86\u0dc3\u0dd2\u0dba\u0dcf \u0dc3\u0dc4 \u0db4\u0dd0\u0dc3\u0dd2\u0dc6\u0dd2\u0d9a\u0dca \u0d9a\u0dbd\u0dcf\u0db4\u0dd3\u0dba \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0ddd\u0db1\u0dca \u0d85\u0dba\u0dd2\u0dbd\u0dd3\u0dc6\u0dca, \u0daf\u0dd0\u0db1\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dad\u0dbb, 2022 \u0dc3\u0dd0\u0db4\u0dca\u0dad\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca 01 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d85\u0dbd\u0dd2 \u0dc3\u0db6\u0dca\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0dc4\u0db8\u0dd4\u0dc0\u0dd2\u0dba."
      ],
