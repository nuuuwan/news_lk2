            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0ba8\u0bc7\u0bb1\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "\u0b9c\u0bc2\u0bb2\u0bc8 21",
            "label": "DATE"
