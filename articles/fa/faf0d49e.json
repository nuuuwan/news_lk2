    "si": {
      "title": "\u0dc3\u0dd9\u0dbd\u0dca\u0dc6\u0dd2 \u0d8b\u0db1\u0dca\u0db8\u0dcf\u0daf\u0dba \u0dad\u0dc0\u0dad\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba\u0d9a\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0d9c\u0db1\u0dd3; \u0dad\u0dbb\u0dd4\u0dab \u0daf\u0dd2\u0dba \u0d87\u0dbd\u0dca\u0dbd\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0dbd\u0dca\u0daf\u0dd4\u0db8\u0dca\u0db8\u0dd4\u0dbd\u0dca\u0dbd \u0d8b\u0da9\u0dc0\u0dda\u0dbb\u0dd2\u0dba \u0dc0\u0dad\u0dca\u0dad\u0dda \u0daf\u0dd3 \u0d8a\u0dba\u0dda \u0dc3\u0dd9\u0dbd\u0dca\u0dc6\u0dd2 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dba\u0d9a\u0dca \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dd9\u0d9a\u0dd4 \u0daf\u0dd2\u0dba \u0d87\u0dbd\u0dca\u0dbd\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dd2\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0daf\u0dd2\u0dba \u0d87\u0dbd\u0dca\u0dbd \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d89\u0db1\u0dca \u0d91\u0d9a\u0dca \u0d85\u0dba\u0dd9\u0d9a\u0dd4 \u0dc3\u0dd9\u0dbd\u0dca\u0dc6\u0dd2\u0dba\u0d9a\u0dca \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dba\u0dcf\u0db8\u0dda\u0daf\u0dd3 \u0db4\u0dba \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0daf\u0dd2\u0dba \u0d87\u0dbd\u0dca\u0dbd\u0da7 \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0daf\u0dd2\u0dba \u0d87\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dd2\u0da7 \u0db8\u0dd3\u0da7\u0dbb\u0dca 200\u0d9a\u0dca \u0db4\u0db8\u0dab \u0db4\u0dc4\u0dc5\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0d9c\u0dda \u0db8\u0dc5 \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb \u0dc4\u0db8\u0dd4\u0dc0\u0dd3 \u0d87\u0dad."
      ],
