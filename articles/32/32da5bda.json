    "si": {
      "title": "\u0dba\u0dcf\u0dbd\u0dd2 \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0db6\u0dc3\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dba\u0dae\u0dcf \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9c\u0db8\u0db1\u0dcf\u0d9c\u0db8\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0dba\u0dcf\u0db4\u0db1\u0dba. \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0dda\u0dc0\u0d9a \u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba \u0d85\u0dad\u0dca\u0dc4\u0dbb\u0dd3.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0dba\u0dcf\u0db4\u0db1\u0dba. \u0dba\u0dcf\u0db4\u0db1\u0dba \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0d85\u0daf \u0dc3\u0dd2\u0da7 \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db6\u0dc3\u0dca \u0dbb\u0dae 50%\u0d9a\u0dd2\u0db1\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0db1 \u0db6\u0dc0 \u0dba\u0dcf\u0db4\u0db1\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba. \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d92\u0d9a\u0dcf\u0db6\u0daf\u0dca\u0db0 \u0db6\u0dc3\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0da2\u0dcf\u0dbd\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd3 \u0db4\u0dd3.\u0d9a\u0dda\u0db1\u0dca\u0d9c\u0daf\u0dbb\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dba\u0dcf\u0db4\u0db1\u0dba. \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9c\u0db8\u0db1\u0dcf\u0d9c\u0db8\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0dc3\u0dc4 \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db6\u0dc3\u0dca \u0dbb\u0dae \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0daf\u0dd2\u0db1 \u0daf\u0dd9\u0d9a\u0dda \u0dc3\u0dd2\u0da7 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd3\u0db8 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca. (\u0d92)"
      ],
