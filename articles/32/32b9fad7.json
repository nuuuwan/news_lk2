          },
          {
            "text": "\u0dc3\u0dde\u0d9b\u0dca\u0dba\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db8\u0dbb\u0dd2\u0dba\u0dcf\u0db1\u0ddd \u0db6\u0dd9\u0dba\u0dd2\u0dbd\u0dcf\u0da9\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
