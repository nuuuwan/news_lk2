        ],
        [
          {
            "text": "'\u0dc5\u0db8\u0dcf \u0dc3\u0dd4\u0dbb\u0d9a\u0dd2\u0db1\u0dca\u0db1' \u0d86\u0dba\u0dad\u0db1\u0dba",
