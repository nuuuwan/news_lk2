          },
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0d9c\u0db6\u0da9\u0dcf \u0db4\u0dbb\u0dca\u0dba\u0db1\u0dca\u0dad\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dad\u0dbb\u0dd4\u0dab \u0db6\u0dbd\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          },
          {
