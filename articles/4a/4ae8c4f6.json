            "label": "QUANTITY"
          },
          {
            "text": "3,000 \u0bae\u0bc6\u0b9f\u0bcd\u0bb0\u0bbf\u0b95\u0bcd \u0b9f\u0ba9\u0bcd",
            "label": "QUANTITY"
          },
