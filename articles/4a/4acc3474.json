    "si": {
      "title": "\u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0d85\u0dbd\u0dd2 \u0dbb\u0ddd\u0d9c \u0dc3\u0dcf\u0dba\u0db1\u0dba...",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0dbd\u0dd2 \u0d87\u0dad\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dba\u0db1 \u0dbb\u0ddd\u0d9c \u0daf\u0dd9\u0d9a\u0dd9\u0dc4\u0dd2\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca, \u0d85\u0dbd\u0dd2 \u0d87\u0dad\u0dd4\u0db1\u0dca \u0da7\u0dca\u200d\u0dbb\u0dd9\u0db4\u0ddc\u0db1\u0dd3\u0db8\u0dcf \u0dbb\u0ddd\u0d9c\u0dba \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d85\u0dad\u0dbb \u0d87\u0dad\u0dd2 \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0d86\u0dc3\u0dcf\u0daf\u0db1 \u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dd2\u0dbb\u0dd2\u0db6\u0dad\u0dca\u0d9c\u0ddc\u0da9 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0dcf\u0dba\u0db1\u0dba\u0d9a\u0dca \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0dbd\u0daf\u0dd3. \u0db8\u0dc4\u0da2\u0db1 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9a\u0dca\u200d\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3 (PHFO) \u0db1\u0dd2\u0dbb\u0dd2\u0dc2\u0dca \u0db8\u0db0\u0dd4\u0dc2\u0dcf\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0dc3\u0dc4 \u0dbb\u0dcf\u0d9c\u0db8 \u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2 (181) \u0dc3\u0dde\u0db8\u0dca\u200d\u0dba \u0dc3\u0ddd\u0db8\u0dc3\u0dd2\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba\u0d9c\u0dda \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dba \u0d87\u0dad\u0dd2\u0dc0 \u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0d85\u0dbd\u0dd2 \u0dbb\u0ddd\u0d9c \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0d92\u0d9a\u0d9a\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dc3\u0dcf\u0dba\u0db1\u0dba \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0dbd\u0daf\u0dd3. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db1\u0dd2\u0db8\u0dbd\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0d91\u0daf\u0dd2\u0dbb\u0dd2\u0dc3\u0dd2\u0d82\u0dc4"
      ],
