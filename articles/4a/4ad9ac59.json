          {
            "text": "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dad\u0dd2\u0dbd\u0dcf\u0db1\u0dca \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0d86\u0dba\u0ddd\u0da2\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dcf\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd6\u0dbb\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba \u0dc3\u0dc4",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0ddd\u0da7\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0dd3\u0dad\u0dd2\u0da5 \u0db1\u0dd2\u0dc4\u0dcf\u0dbd\u0dca \u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dcf\u0dba \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc3\u0d82\u0dc3\u0dca\u0d9a\u0dbb\u0dab \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0dd3\u0dad\u0dd2\u0dba \u0dc4\u0dbb\u0dca\u0dc2 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0da0\u0db1\u0dca\u0daf\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
