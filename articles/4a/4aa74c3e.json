          {
            "text": "\u0baa\u0bbf\u0bb0\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf\u0bb7\u0bcd",
            "label": "NORP"
          },
          {
            "text": "\u0baa\u0bcb\u0bb0\u0bbf\u0bb8\u0bcd \u0b9c\u0bbe\u0ba9\u0bcd\u0b9a\u0ba9\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0bb2\u0bbe \u0bb5\u0bbf\u0bb8\u0bcd\u0b9f\u0bbe",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b9c\u0bbe\u0ba9\u0bcd\u0b9a\u0ba9\u0bcd",
            "label": "PERSON"
