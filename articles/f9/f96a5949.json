    "si": {
      "title": "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0 \u0db6\u0dd9\u0dbd\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2 \u0daf\u0dd9\u0db1\u0dc0\u0dcf\u0dbd\u0dd4",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0 \u0db6\u0dd9\u0dbd\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0da7 Iskander-M \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2 \u0dc3\u0db4\u0dba\u0db1\u0dd4 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc0\u0dca\u0dbd\u0dd0\u0daf\u0dd2\u0db8\u0dd3\u0dbb\u0dca \u0db4\u0dd6\u0da7\u0dd2\u0db1\u0dca \u0db6\u0dd9\u0dbd\u0dcf\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d87\u0dbd\u0dd9\u0d9a\u0dca\u0dc3\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca \u0dbd\u0dd4\u0d9a\u0dc2\u0dd9\u0db1\u0dca\u0d9a\u0ddd \u0dc3\u0db8\u0d9c \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dc3\u0d82\u0dc0\u0dcf\u0daf\u0dba\u0d9a\u0daf\u0dd3\u00a0\u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dcf\u0dc3 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dad \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "Iskander-M \u0dba\u0db1\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb\u0dca 500 (\u0dc3\u0dd0\u0dad\u0db4\u0dd4\u0db8\u0dca 300) \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dbb\u0dcf\u0dc3\u0dba\u0d9a\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0da2\u0d82\u0d9c\u0db8 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0ddd\u0db4\u0daf\u0dda\u0dc1 \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba\u0d9a\u0dd2. \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd\u0dc0\u0dbd\u0da7 \u0dc3\u0db8\u0dca\u0db4\u0dca\u200d\u0dbb\u0daf\u0dcf\u0dba\u0dd2\u0d9a \u0dc4\u0ddd \u0db1\u0dca\u200d\u0dba\u0dc2\u0dca\u0da7\u0dd2\u0d9a \u0dba\u0dd4\u0db0 \u0dc4\u0dd2\u0dc3\u0dca \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0dba\u0dcf \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0daf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0dd9\u0dba\u0dd2."
      ],
