    "si": {
      "title": "\u2018\u2018\u0d9a\u0dbb\u0db1\u0dca\u0db1 \u0db6\u0dd0\u0dbb\u0dd2\u0db1\u0db8\u0dca \u0daf\u0db8\u0dbd \u0d9c\u0dc4\u0dbd \u0dba\u0dcf \u0dba\u0dd4\u0dad\u0dd4\u0dba\u0dd2\u2018\u2018",
      "author": "unknown",
      "body_lines": [
        "\u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0dd2 \u0dc0\u0dbb\u0db8 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0dbd\u0dd0\u0db6\u0dd4\u0db1\u0ddc\u0dad\u0dca \u0db6\u0dba \u0db1\u0dd0\u0dad\u0dd2\u0dc0 \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0 \u0d85\u0dbb\u0d9c\u0dad \u0dba\u0dd4\u0dad\u0dd4\u0dba\u0dd0\u0dba\u0dd2 \u0daf \u0db6\u0dd9\u0dbd\u0dca\u0dbd \u0dad\u0dd2\u0dba\u0dbd \u0d9a\u0dbb\u0db1\u0dca\u0db1 \u0db6\u0dd0\u0dbb\u0dd2 \u0db1\u0db8\u0dca \u0daf\u0db8\u0dbd \u0d9c\u0dc4\u0dbd \u0dba\u0dcf \u0dba\u0dd4\u0dad\u0dd4 \u0dba\u0dd0\u0dba\u0dd2\u0daf \u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc3\u0dbb\u0dad\u0dca \u0dc6\u0ddc\u0db1\u0dca\u0dc3\u0dda\u0d9a\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0d85\u0daf 6 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d85\u0db4\u0dca\u0db4\u0dd2\u0dbb\u0dd2\u0dba \u0dc0\u0dd9\u0dbd\u0dcf \u0db1\u0db8\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0daf\u0dbb \u0dba\u0db1\u0dca\u0db1 \u0d9a\u0dd2\u0dba\u0db1\u0dc0\u0dcf \u0db1\u0db8\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0 \u0dc3\u0dc4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d91\u0dbd\u0dc0\u0db1\u0dca\u0db1 \u0db4\u0dd9\u0dc5\u0d9c\u0dd0\u0dc3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dc0\u0dcf \u0db1\u0db8\u0dca \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0d85\u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0d92 \u0dc0\u0dbb\u0db8 \u0dbd\u0dd0\u0db6\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0d9a\u0dd3 \u0dc6\u0ddc\u0db1\u0dca\u0dc3\u0dda\u0d9a\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dbb\u0db8 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0ddc\u0dad\u0dca \u0db6\u0dc4\u0dd4\u0dad\u0dbb\u0dba \u0dc3\u0dd4\u0dc5\u0dd4\u0dad\u0dbb\u0dba \u0d9c\u0dd0\u0db1 \u0d9a\u0dad\u0dcf \u0d9a\u0dbb \u0d9a\u0dbb \u0d89\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dad\u0dd2\u0dc0 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba \u0dc0\u0d9c\u0d9a\u0dd3\u0db8\u0dca \u0db6\u0dcf\u0dbb\u0d9c\u0dad \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0dc6\u0ddc\u0db1\u0dca\u0dc3\u0dda\u0d9a\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dd3\u0dba.",
        "\u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dbb\u0dca\u0dc0 \u0db4\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0\u0d9a\u0dca \u0dc4\u0daf\u0db1\u0dca\u0db1 \u0db4\u0dd4\u0dc5\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dd0\u0dba\u0dd2 \u0dad\u0db8\u0dcf \u0dc4\u0dd2\u0dad\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0d8a\u0da7 113 \u0dc4\u0db8\u0dca\u0db6 \u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0dc6\u0ddc\u0db1\u0dca\u0dc3\u0dda\u0d9a\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
