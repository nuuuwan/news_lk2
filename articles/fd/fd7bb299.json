    "si": {
      "title": "\u0daf\u0dd9\u0dc0\u0dd2\u0db1\u0dd4\u0dc0\u0dbb \u0db4\u0d82\u0da0 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0d9d\u0dcf\u0dad\u0db1\u0dba\u0da7 \u0dc4\u0dba\u0d9a\u0dca \u0db4\u0ddd\u0dbb\u0d9a\u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dd3\u0da7 \u0dc0\u0dc3\u0dbb 22\u0d9a\u0da7 \u0db4\u0dd9\u0dbb \u0db1\u0da9\u0dd4 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0da7\u00a0 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd2\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dba\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dbb\u0dd0\u0d9c\u0dad\u0dca \u0dc0\u0dd1\u0db1\u0dca \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0db6\u0dcf \u0db4\u0dc3\u0dca \u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0da7 \u0dc0\u0dbb\u0daf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc0\u0dd6 \u0daf\u0d9a\u0dd4\u0dab\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0da7 \u0db8\u0dad\u0dca\u0d9a\u0dd4\u0da9\u0dd4 \u0da2\u0dcf\u0dc0\u0dcf\u0dbb\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0db6\u0dc0 \u0d9a\u0dd2\u0dba\u0db1 \u0da0\u0db8\u0dd2\u0dbd\u0dca \u0db1\u0db8\u0dd0\u0dad\u0dca\u0dad\u0dcf \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc4\u0dba \u0daf\u0dd9\u0db1\u0d9a\u0dd4\u0da7 \u0db8\u0dcf\u0dad\u0dbb \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0dad\u0dcf\u0db8\u0dbb \u0dad\u0dd9\u0db1\u0dca\u0db1\u0d9a\u0ddd\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dbb\u0dab \u0daf\u0dac\u0dd4\u0dc0\u0db8 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db8\u0dbb\u0dab \u0daf\u0dac\u0dd4\u0dc0\u0db8 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dca\u0daf\u0dda \u0daf\u0dd9\u0dc0\u0dca\u0db1\u0dd4\u0dc0\u0dbb \u0db1\u0dcf\u0dbb\u0dcf\u0dad\u0ddc\u0da7 \u0dc4\u0dda\u0dc0\u0d9c\u0dda \u0dad\u0db8\u0dd2\u0dbd\u0dca \u0d85\u0da2\u0dd2\u0dad\u0dca \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0db1\u0ddc\u0dc4\u0ddc\u0dad\u0dca \u0d9a\u0dd4\u0da9\u0dd4 \u0da0\u0db8\u0dd2\u0dbd\u0dca, \u0dc3\u0dd4\u0db8\u0dd2\u0dad\u0dca \u0d9a\u0dd4\u0db8\u0dcf\u0dbb,\u0dc3\u0dc0\u0dd4\u0db1\u0dca\u0daf\u0dcf \u0dc4\u0dd0\u0db1\u0dca\u0db1\u0daf\u0dd2\u0d9c\u0dda \u0da0\u0db8\u0dd2\u0db1\u0dca\u0daf, \u0d85\u0db6\u0dda\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dcf\u0d9c\u0db8\u0dca\u0db4\u0dad\u0dca\u0dad\u0dd4 \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dcf\u0db1\u0d9c\u0dda \u0db1\u0dcf\u0db8\u0dbd\u0dca, \u0d85\u0db6\u0dda\u0dbb\u0dad\u0dca\u0db1 \u0dc0\u0dd3\u0dbb\u0dc3\u0dda\u0d9a\u0dbb \u0db4\u0da7\u0db6\u0dd0\u0db3\u0dd2\u0d9c\u0dda \u0dbb\u0ddc\u0dc2\u0dcf\u0db1\u0dca \u0daf\u0dd2\u0dbd\u0dca\u0dbb\u0dd4\u0d9a\u0dca\u0dc2, \u0d85\u0db6\u0dda\u0dad\u0dbb\u0db1 \u0dc0\u0dd3\u0dbb\u0dc3\u0dda\u0d9a\u0dbb \u0db4\u0da7\u0db6\u0dd0\u0db3\u0dd2\u0d9c\u0dda \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dba\u0db1 \u0dc3\u0dba \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd2.",
        "2000 \u0dc0\u0dc3\u0dbb\u0dda \u0db1\u0ddc\u0dc0\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca \u0db8\u0dc3 14 \u0daf\u0dd2\u0db1 \u0dc4\u0ddd \u0d8a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0daf\u0dd2\u0db1\u0dba\u0d9a\u0daf\u0dd3 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0dc0\u0dd2\u0db1\u0dd4\u0dc0\u0dbb \u0d94\u0dbb\u0dbd\u0ddd\u0dc3\u0dd4 \u0d9a\u0dab\u0dd4\u0dc0 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7\u0daf\u0dd3 \u0dc0\u0dd1\u0db1\u0dca \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0db6\u0dcf \u0db4\u0dc3\u0dca \u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0da7 \u0db1\u0dd3\u0dad\u0dd2\u0db4\u0dad\u0dd2 \u0d85\u0db0\u0dd2 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0d9c\u0ddc\u0db1\u0dd4 \u0d9a\u0dc5\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0dc4\u0dba",
          "label": "CARDINAL"
        },
        {
          "text": "\u0daf\u0dd9\u0dc0\u0dd2\u0db1\u0dd4\u0dc0\u0dbb",
          "label": "GPE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db8\u0dcf\u0dad\u0dbb \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "Tamara Tennakoon",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dba",
            "label": "CARDINAL"
          },
          {
            "text": "\u0da0\u0db8\u0dd2\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0d9a\u0dd4\u0dab\u0dd4",
            "label": "LOC"
          },
          {
            "text": "\u0db4\u0dc4",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 22\u0d9a\u0da7 \u0d9a\u0dbd\u0dd2\u0db1\u0dca",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0dc0\u0dd2\u0db1\u0dd4\u0dc0\u0dbb \u0db1\u0dcf\u0dbb\u0dad\u0ddc\u0da7 \u0dc4\u0dda\u0dc0\u0d9c\u0dda \u0dad\u0db8\u0dd2\u0dbd\u0dca \u0d85\u0da2\u0dd2\u0dad\u0dca \u0d9a\u0dd4\u0db8\u0dcf\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd4\u0da9\u0dd4 \u0da0\u0db8\u0dd2\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd4\u0db8\u0dd2\u0dad\u0dca \u0d9a\u0dd4\u0db8\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dde\u0db1\u0dca\u0daf \u0dc4\u0dd0\u0db1\u0dca\u0db1\u0daf\u0dd2\u0d9c\u0dda \u0da0\u0db8\u0dd2\u0db1\u0dca\u0daf",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db6\u0dda\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dcf\u0d9c\u0db8\u0dca\u0db4\u0dad\u0dca\u0dad\u0dd4 \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dcf\u0db1\u0d9c\u0dda \u0db1\u0dcf\u0db8\u0dbd\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db6\u0dda\u0dbb\u0dad\u0dca\u0db1 \u0dc0\u0dd3\u0dbb\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0da7\u0db6\u0dd0\u0db3\u0dd2\u0d9c\u0dda \u0dbb\u0ddc\u0dc2\u0dcf\u0db1\u0dca \u0daf\u0dd2\u0dbd\u0dca\u0dbb\u0dd4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db6\u0dda\u0dad\u0dd9\u0dbb\u0dab \u0dc0\u0dd3\u0dbb\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dad\u0db6\u0dd0\u0db3\u0dd2\u0d9c\u0dda \u0db1\u0dd2\u0dc1\u0dcf\u0d9a\u0dd3",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "2000 \u0db1\u0ddc\u0dc0\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca 14 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0db4\u0db8\u0dab",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dc4",
            "label": "CARDINAL"
          },
          {
            "text": "\u0daf\u0dd9\u0dc0\u0dd2\u0db1\u0dd4\u0dc0\u0dbb \u0d94\u0dbb\u0dbd\u0ddd\u0dc3\u0dd4 \u0d9a\u0dab\u0dd4\u0dc0",
            "label": "FAC"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0ba4\u0bc6\u0bb5\u0bbf\u0ba8\u0bc1\u0bb5\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb2\u0bcd \u0b95\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0b85\u0bb1\u0bc1\u0bb5\u0bb0\u0bcd \u0baa\u0b9f\u0bc1\u0b95\u0bca\u0bb2\u0bc8!",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "22 \u0bb5\u0bb0\u0bc1\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bb0\u0bcd, \u0bae\u0bbe\u0ba4\u0bcd\u0ba4\u0bb1\u0bc8 \u0bae\u0bc7\u0bb2\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1 \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0ba4\u0bbf\u0bb0\u0bc1.\u0ba4\u0bbe\u0bae\u0bb0 \u0ba4\u0bc6\u0ba9\u0bcd\u0ba9\u0b95\u0bcb\u0ba9\u0bcd, \u0ba4\u0bc6\u0ba9\u0bcd\u0ba9\u0bbf\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0bbf\u0bb0\u0baa\u0bb2 \u0baa\u0bcb\u0ba4\u0bc8\u0baa\u0bcd\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bcd \u0bb5\u0bbf\u0baf\u0bbe\u0baa\u0bbe\u0bb0\u0bbf \u0b8e\u0ba9 \u0b95\u0bc2\u0bb1\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b9a\u0bae\u0bcd\u0bae\u0bbf\u0bb2\u0bcd \u0ba8\u0bae\u0b9f\u0bcd\u0b9f \u0b89\u0b9f\u0bcd\u0baa\u0b9f 6 \u0baa\u0bc7\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1, 5 \u0baa\u0bc7\u0bb0\u0bc8 \u0b9a\u0bc1\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bcd \u0b95\u0bca\u0ba9\u0bcd\u0bb1 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b9a\u0bcd\u0b9a\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0baa\u0bc7\u0bb0\u0bbf\u0bb2\u0bcd \u0ba4\u0ba3\u0bcd\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd. \u0bb5\u0bbf\u0b9a\u0bbe\u0bb0\u0ba3\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1 \u0b95\u0bca\u0bb3\u0bcd\u0bb3 \u0b9a\u0bc6\u0bb2\u0bcd\u0bb2\u0bc1\u0bae\u0bcd \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb4\u0bc1.",
        "\u0ba4\u0bc6\u0bb5\u0bbf\u0ba8\u0bc1\u0bb5\u0bb0 \u0ba8\u0bbe\u0bb0\u0ba4\u0bca\u0b9f\u0bcd\u0b9f \u0bb9\u0bc7\u0bb5\u0b95\u0bc7 \u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0b85\u0b9c\u0bbf\u0ba4\u0bcd \u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0b8e\u0ba9\u0bcd\u0bb1 \u0b95\u0bc1\u0b9f\u0bc1 \u0b9a\u0bae\u0bbf\u0bb2\u0bcd, \u0b9a\u0bc1\u0bae\u0bbf\u0ba4\u0bcd \u0b95\u0bc1\u0bae\u0bbe\u0bb0, \u0b9a\u0bb5\u0bc1\u0ba8\u0bcd\u0ba4 \u0bb9\u0bc6\u0ba9\u0bcd\u0ba9\u0b9f\u0bbf\u0b95\u0bc7 \u0b9a\u0bae\u0bbf\u0ba8\u0bcd\u0ba4, \u0b85\u0baa\u0bc7\u0bb0\u0ba4\u0bcd\u0ba9 \u0bae\u0bbe\u0b95\u0bae\u0bcd\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 \u0bae\u0b95\u0bbe \u0bb5\u0bbf\u0ba4\u0bbe\u0ba9\u0b95\u0bc7 \u0ba8\u0bbe\u0bae\u0bb2\u0bcd, \u0b85\u0baa\u0bc7\u0bb0\u0ba4\u0bcd\u0ba9 \u0bb5\u0bc0\u0bb0\u0b9a\u0bc7\u0b95\u0bb0 \u0baa\u0b9f\u0baa\u0bc6\u0ba8\u0bcd\u0ba4\u0bbf\u0b95\u0bc7 \u0bb0\u0bca\u0bb7\u0bbe\u0ba9\u0bcd \u0ba4\u0bbf\u0bb2\u0bcd\u0bb0\u0bc1\u0b95\u0bcd\u0bb7\u0bbe, \u0b85\u0baa\u0bc7\u0ba4\u0bb0\u0ba9 \u0bb5\u0bc0\u0bb0\u0b9a\u0bc7\u0b95\u0bb0 \u0ba8\u0bbf\u0bb7\u0bbe\u0b95\u0bbf\u0baa\u0bc6\u0ba8\u0bcd\u0ba4\u0bbf \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc7 \u0bae\u0bb0\u0ba3 \u0ba4\u0ba3\u0bcd\u0b9f\u0ba9\u0bc8 \u0bb5\u0bbf\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "2000 \u0b86\u0bae\u0bcd \u0b86\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8\u0bb5\u0bae\u0bcd\u0baa\u0bb0\u0bcd \u0bae\u0bbe\u0ba4\u0bae\u0bcd 14 \u0b86\u0bae\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0b85\u0ba9\u0bcd\u0bb1\u0bc8\u0baf \u0ba4\u0bbf\u0ba9\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba4\u0bc6\u0bb5\u0bbf\u0ba8\u0bc1\u0bb5\u0bb0 \u0bae\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bc1 \u0b95\u0bcb\u0baa\u0bc1\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0baa\u0bbe\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0bae\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bc1 \u0b95\u0bcb\u0baa\u0bc1\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0baa\u0bbe\u0b95 \u0b90\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc7\u0bb0\u0bc8 \u0b9a\u0bc1\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bcd \u0b95\u0bca\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd."
      ],
