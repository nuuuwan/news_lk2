    "si": {
      "title": "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba\u0da7 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba \u0db1\u0db8\u0dca\u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2\u0dc0\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dd2 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dbb\u0ddc\u0dc2\u0dcf\u0db1\u0dca \u0dbb\u0dab\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba \u0dbd\u0db6\u0dcf \u0daf\u0dd2 \u0dad\u0dd2\u0db6\u0dda. \u0daf\u0dc3\u0dd4\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0d9a\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dc4\u0dcf \u0da0\u0dbb\u0dd2\u0dad\u0dca \u0d85\u0dc3\u0dbd\u0d82\u0d9a\u0d9c\u0dda \u0d8b\u0db4\u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0db8\u0dd9\u0db8 \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0db1\u0dca 20\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0dba\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0daf\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dcf\u0dbd\u0d9c\u0dda\u0da7 \u0db8\u0dd9\u0db8 \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba\u0dda \u0d89\u0da9\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2 \u0db1\u0ddc\u0dc0\u0dd4\u0dab\u0dad\u0dca \u0db1\u0dc0\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0db1\u0dca \u0dc0\u0db1 \u0da9\u0dd2\u0dbd\u0dca\u0dc2\u0dcf\u0db1\u0dca \u0db8\u0db0\u0dd4\u0dc1\u0d82\u0d9a, \u0db1\u0dd4\u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba - \u0daf\u0dc3\u0dd4\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0d9a (\u0db1\u0dcf\u0dba\u0d9a), \u0da0\u0dbb\u0dd2\u0dad\u0dca \u0d85\u0dc3\u0dbd\u0d82\u0d9a (\u0d8b\u0db4\u0db1\u0dcf\u0dba\u0d9a), \u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a \u0d9c\u0dd4\u0dab\u0dad\u0dd2\u0dbd\u0d9a, \u0db4\u0dd0\u0dad\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dc1\u0dca\u0dc1\u0d82\u0d9a, \u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca (\u0d9a\u0da9\u0dd4\u0dbd\u0dd4 \u0dbb\u0d9a\u0dd2\u0db1\u0dca\u0db1\u0dcf), \u0db7\u0dcf\u0db1\u0dd4\u0d9a \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 (\u0d9a\u0da9\u0dd4\u0dbd\u0dd4 \u0dbb\u0d9a\u0dd2\u0db1\u0dca\u0db1\u0dcf), \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8\u0dcf\u0dbd\u0dca (\u0d9a\u0da9\u0dd4\u0dbd\u0dd4 \u0dbb\u0d9a\u0dd2\u0db1\u0dca\u0db1\u0dcf), \u0d85\u0dc1\u0dda\u0db1\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb, \u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf, \u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0dc4\u0dc3\u0dbb\u0d82\u0d9c, \u0db8\u0dc4\u0dd3\u0dc2\u0dca \u0dad\u0dd3\u0d9a\u0dca\u0dc2\u0dab, \u0da2\u0dd9\u0dc6\u0dca\u0dbb\u0dd2 \u0dc0\u0dd0\u0db1\u0dca\u0da9\u0dc3\u0dda, \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0db1\u0dca \u0da2\u0dba\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8, \u0daf\u0dd4\u0dc2\u0dca\u0db8\u0db1\u0dca\u0dad \u0da0\u0db8\u0dd3\u0dbb, \u0db6\u0dd2\u0db1\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4, \u0da0\u0dcf\u0db8\u0dd2\u0d9a \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1, \u0da9\u0dd2\u0dbd\u0dca\u0dc2\u0dcf\u0db1\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dab, \u0d9a\u0dc3\u0dd4\u0db1\u0dca \u0dbb\u0dcf\u0da2\u0dd2\u0dad, \u0db1\u0dd4\u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4, \u0db8\u0dad\u0dd3\u0dc2 \u0db4\u0dad\u0dd2\u0dbb\u0dab"
      ],
      "title_ents": [
        {
          "text": "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba",
          "label": "EVENT"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dbb\u0ddc\u0dc2\u0dcf\u0db1\u0dca \u0dbb\u0dab\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba",
            "label": "EVENT"
          },
          {
            "text": "20",
            "label": "CARDINAL"
          },
          {
            "text": "\u0daf\u0dc3\u0dd4\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0da0\u0dbb\u0dd2\u0dad\u0dca \u0dc3\u0dc3\u0d82\u0d9a",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dcf\u0dbd\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dd2\u0dbd\u0dca\u0dc2\u0dcf\u0db1\u0dca \u0db8\u0db0\u0dd4\u0dc1\u0d82\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd4\u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba - \u0daf\u0dc3\u0dd4\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0da0\u0dbb\u0dd2\u0dad\u0dca \u0d85\u0dc3\u0d82\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a \u0d9c\u0dd4\u0dab\u0dad\u0dd2\u0dbd\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dd0\u0dad\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dc1\u0d82\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db7\u0dcf\u0db1\u0dd4\u0d9a \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8\u0dcf\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0dc1\u0dda\u0db1\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0dc4\u0dc3\u0dbb\u0d82\u0d9c",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4\u0dd3\u0dc2\u0dca \u0dad\u0dd3\u0d9a\u0dca\u0dc2\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd9\u0dc6\u0dca\u0dbb\u0dd2 \u0dc0\u0dd0\u0db1\u0dca\u0da9\u0dc3\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0db1\u0dca \u0da2\u0dba\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd4\u0dc2\u0dca\u0db8\u0db1\u0dca\u0dad \u0da0\u0db8\u0dd2\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0dd2\u0db1\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0da0\u0dcf\u0db8\u0dd2\u0d9a \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dd2\u0dbd\u0dca\u0dc2\u0dcf\u0db1\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dc3\u0dd4\u0db1\u0dca \u0dbb\u0dcf\u0da2\u0dd2\u0dad",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd4\u0dc0\u0db1\u0dd2\u0db3\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dad\u0dd3\u0dc2 \u0db4\u0dad\u0dd2\u0dbb\u0dab",
            "label": "ORG"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b86\u0b9a\u0bbf\u0baf \u0b95\u0bcb\u0baa\u0bcd\u0baa\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b85\u0ba3\u0bbf \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b86\u0b9a\u0bbf\u0baf \u0b95\u0bbf\u0ba3\u0bcd\u0ba3 \u0b95\u0bbf\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0b99\u0bcd\u0b95\u0bc7\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b95\u0bbf\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0b85\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb1\u0bc8 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bb0\u0bcd \u0ba4\u0bbf\u0bb0\u0bc1.\u0bb0\u0bca\u0bb7\u0bbe\u0ba9\u0bcd \u0bb0\u0ba3\u0b9a\u0bbf\u0b99\u0bcd\u0b95 \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd. \u0ba4\u0b9a\u0bc1\u0ba9\u0bcd \u0bb7\u0ba9\u0b95 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b89\u0baa\u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0b9a\u0bb0\u0bbf\u0ba4\u0bcd \u0b9a\u0b9a\u0b99\u0bcd\u0b95 \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bbe\u0ba9 \u0b87\u0ba8\u0bcd\u0ba4 \u0b85\u0ba3\u0bbf\u0baf\u0bbf\u0bb2\u0bcd 20 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0b9f\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0b85\u0ba3\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb3\u0bae\u0bcd \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0ba4\u0bc1\u0ba9\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bb2\u0bcd\u0bb2\u0bbe\u0bb2\u0b95\u0bc7 \u0b87\u0b9f\u0bae\u0bcd \u0baa\u0bc6\u0bb1\u0bbe\u0ba4 \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd, \u0baa\u0bc1\u0ba4\u0bc1\u0bae\u0bc1\u0b95 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bbe\u0ba9 \u0b9f\u0bbf\u0bb2\u0bcd\u0bb7\u0bbe\u0ba9\u0bcd \u0bae\u0ba4\u0bc1\u0bb7\u0b99\u0bcd\u0b95 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bc1\u0bb5\u0ba9\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b87\u0ba8\u0bcd\u0ba4 \u0b85\u0ba3\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0bc7\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b85\u0ba3\u0bbf - \u0ba4\u0b9a\u0bc1\u0ba9\u0bcd \u0bb7\u0ba9\u0b95 (\u0b95\u0bc7\u0baa\u0bcd\u0b9f\u0ba9\u0bcd), \u0b9a\u0bb0\u0bbf\u0ba4\u0bcd \u0b85\u0b9a\u0b99\u0bcd\u0b95 (\u0ba4\u0bc1\u0ba3\u0bc8 \u0b95\u0bc7\u0baa\u0bcd\u0b9f\u0ba9\u0bcd), \u0ba4\u0ba9\u0bc1\u0bb7\u0bcd\u0b95 \u0b95\u0bc1\u0ba3\u0ba4\u0bbf\u0bb2\u0b95\u0bc7, \u0baa\u0ba4\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb7\u0b99\u0bcd\u0b95, \u0b95\u0bc1\u0b9a\u0bb2\u0bcd \u0bae\u0bc6\u0ba3\u0bcd\u0b9f\u0bbf\u0bb8\u0bcd (\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0b95\u0bc0\u0baa\u0bcd\u0baa\u0bb0\u0bcd), \u0baa\u0bbe\u0ba9\u0bc1\u0b95 \u0bb0\u0bbe\u0b9c\u0baa\u0b95\u0bcd\u0b9a\u0bc7 (\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0b95\u0bc0\u0baa\u0bcd\u0baa\u0bb0\u0bcd), \u0ba4\u0bbf\u0ba9\u0bc7\u0bb7\u0bcd \u0b9a\u0ba3\u0bcd\u0b9f\u0bbf\u0bae\u0bbe\u0bb2\u0bcd (\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0b95\u0bc0\u0baa\u0bcd\u0baa\u0bb0\u0bcd), \u0b85\u0bb7\u0bc7\u0ba9\u0bcd \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0, \u0ba4\u0ba9\u0b9e\u0bcd\u0b9a\u0baf \u0b9f\u0bbf \u0b9a\u0bbf\u0bb2\u0bcd\u0bb5\u0bbe \u0bb9\u0b9a\u0bb0\u0b99\u0bcd\u0b95, \u0bae\u0bb9\u0bbf\u0bb7\u0bcd \u0ba4\u0bc0\u0b95\u0bcd\u0bb7\u0ba9, \u0b9c\u0bc6\u0b83\u0baa\u0bcd\u0bb0\u0bbf \u0bb5\u0ba3\u0bcd\u0b9f\u0b9a\u0bc7, \u0baa\u0bbf\u0bb0\u0bb5\u0bc0\u0ba9\u0bcd \u0b9c\u0baf\u0bb5\u0bbf\u0b95\u0bcd\u0bb0\u0bae, \u0ba4\u0bc1\u0bb7\u0bcd\u0bae\u0ba8\u0bcd\u0ba4 \u0b9a\u0bae\u0bbf\u0bb0, \u0baa\u0bbf\u0ba9\u0bc1\u0bb0 \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb, \u0b9a\u0bbe\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0b95\u0bb0\u0bc1\u0ba3\u0bbe\u0bb0\u0ba4\u0bcd\u0ba9, \u0b9f\u0bbf\u0bb2\u0bcd\u0bb7\u0bbe\u0ba9\u0bcd \u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0ba9, \u0b95\u0b9a\u0bc1\u0ba9\u0bcd \u0bb0\u0bbe\u0b9c\u0bbf\u0ba4, \u0ba8\u0bc1\u0bb5\u0ba9\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb, \u0bae\u0ba4\u0bbf\u0bb7\u0bbe \u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0ba9"
      ],
