          },
          {
            "text": "\u0d9c\u0dd2\u0dba \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0db1\u0dad\u0dca \u0d9a\u0dd9\u0da7\u0dd4\u0db8\u0dca\u0db4\u0dad 104",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0db1 \u0dc3\u0d82\u0dc4\u0dcf\u0dbb \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc3\u0dad\u0dd2\u0db4\u0dad\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0\u0dda \u0d94\u0db1\u0dca\u0da7\u0dcf\u0dbb\u0dd2\u0dba\u0ddd \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d94\u0db1\u0dca\u0da7\u0dcf\u0dbb\u0dd2\u0dba\u0ddd \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc0\u0dd2\u0da2\u0dda \u0dad\u0db1\u0dd2\u0d9a\u0dcf\u0da0\u0dbd\u0db8\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d94\u0db1\u0dca\u0da7\u0dcf\u0dbb\u0dd2\u0dba\u0ddd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0db1 \u0dc3\u0d82\u0dc4\u0dcf\u0dbb \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc3\u0dad\u0dd2 \u0db4\u0db1\u0dad",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "60 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2",
