    "si": {
      "title": "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0dba\u0dda \u0dad\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0d9c\u0dd0\u0db1 \u0db1\u0dc0\u0dad\u0db8 \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0db1\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0dba\u0dda \u0dad\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0db1\u0dca,\u00a0\u0db1\u0dd2\u0dba\u0db8\u0dba\u0db1\u0dca \u0dc4\u0dcf \u0d9a\u0ddc\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db1\u0dc0\u0dad\u0db8 \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d85\u0dad \u0d87\u0dad\u0dd2 \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc0\u0dd2\u0db0\u0dd2\u0db8\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba\u0da7 \u0d86\u0d9a\u0dbb\u0dca\u0dc2\u0dab\u0dba \u0d9a\u0dbb\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd2\u0db1\u0dca \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca,\u00a02017 \u0d85\u0d82\u0d9a 12 \u0daf\u0dbb\u0dab \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0db4\u0db1\u0dad\u0dda 8 \u0dc0\u0db1 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba \u0dba\u0da7\u0dad\u0dda \u0db1\u0dd2\u0dba\u0db8\u0dba\u0db1\u0dca \u0db4\u0dc4\u0dad \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "1.) \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db1\u0dda\u0dc0\u0dcf\u0dc3\u0dd2\u0d9a \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4\u0da7 \u0dad\u0db8 \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0dba\u0dda \u0dbb\u0db3\u0dc0\u0dcf \u0dad\u0db6\u0dcf \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0d87.\u0da9\u0ddc. 15,000 \u0dc3\u0dd2\u0da7 \u0d87.\u0da9\u0ddc.10,000 \u0dc4\u0ddd \u0d8a\u0da7 \u0dc3\u0db8\u0dcf\u0db1 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d85\u0da9\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8.",
        "2.) \u0db4\u0dc4\u0dad \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0daf\u0dd1\u00a0\u0dc3\u0db3\u0dc4\u0dcf,\u00a0\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc4\u0ddd \u0db1\u0dda\u0dc0\u0dcf\u0dc3\u0dd2\u0d9a \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf,\u00a0\u0db1\u0dd2\u0dba\u0db8\u0dba \u0db6\u0dbd\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0daf\u0dd2\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da7 (2022 \u0da2\u0dd4\u0db1\u0dd2 16) \u0dc0\u0dd0\u0da9 \u0d9a\u0dbb\u0db1 \u0daf\u0dd2\u0db1 14\u0d9a \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0db8\u0dcf \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8.",
        "i) \u0db1\u0dd2\u0dba\u0db8\u0dba\u0dda \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db4\u0dbb\u0dd2\u0daf\u0dd2,\u00a0\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0d9a\u0da7 \u0dc4\u0ddd \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0d9a\u0da7 \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7",
        "ii) \u0db6\u0dbd\u0dba\u0dbd\u0dad\u0dca \u0dc0\u0dd9\u0dc5\u0dd9\u0db1\u0dca\u0db3\u0dd9\u0d9a\u0dd4\u0da7 (\u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dbd\u0dcf\u0db7\u0dd3 \u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0da7 \u0dc4\u0ddd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0da7) \u0dc0\u0dd2\u0d9a\u0dd2\u0dab\u0dd3\u0db8\u0da7",
        "\u0d91\u0d9a\u0dd3 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0db8\u0dcf \u0d9a\u0dcf\u0dbd\u0dba \u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0db1\u0dd2\u0dba\u0db8\u0dba \u0d8b\u0dbd\u0dca\u0dbd\u0d82\u0d9d\u0dab\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dad\u0db8\u0dcf \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0dba\u0dda \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dad\u0db6\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0db4\u0db1\u0dad\u0dda \u0dc0\u0dd2\u0db0\u0dd2\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dbb\u0dc0 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0d86\u0dbb\u0db8\u0dca\u0db7\u00a0\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0dba\u0dd2\u0dad\u0dd2\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0dc3\u0dad\u0dd4\u0dc0 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db6\u0dc0\u0daf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd9\u0dba\u0dd2.",
        "\u0d85) \u0d95\u0db1\u0dd1\u0db8 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dbd\u0dcf\u0db7\u0dd3 \u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0d9a\u0dca \u0dc4\u0ddd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0dc3\u0db8\u0d9c \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u00a0\u0dc0\u0dd3\u0db8\u0da7,",
        "\u0d86) \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db1\u0dd2\u0dbd \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba \u0dc0\u0db1 www.dfe.lk \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0db4\u0db1\u0dad\u0dda 8 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba \u0dba\u0da7\u0dad\u0dda \u0dc0\u0dd6 \u0db1\u0dd2\u0dba\u0db8\u0dba\u0da7 2022 \u0da2\u0dd4\u0db1\u0dd2 16 \u0daf\u0dd2\u0db1\u0dd0\u0dad\u0dd2 \u0d85\u0d82\u0d9a 2284/34 \u0daf\u0dbb\u0dab (\u0d85\u0dad\u0dd2 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2) \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0d89\u0dc4\u0dad \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba\u0db1\u0dca \u0db4\u0dbb\u0dd2\u0dc1\u0dd3\u0dbd\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7,",
        "\u0d87) dfe@cbsl.lk \u0dba\u0db1 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dd4\u0dad\u0dca \u0dbd\u0dd2\u0db4\u0dd2\u0db1\u0dba\u0dd9\u0db1\u0dca \u0dc4\u0ddd 011-2477255 \u0dc4\u0ddd 011-2398511 \u0dba\u0db1 \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0d85\u0d82\u0d9a \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u00a0\u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc4\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u00a0\u0dc0\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3\u00a0\u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
