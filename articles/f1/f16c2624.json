          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dbb\u0dbd\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0d86\u0dba\u0dad\u0db1\u0dba",
