    "si": {
      "title": "\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dda \u0d89\u0dad\u0dd2\u0dbb\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 70\u0d9a\u0dca \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2\u0dbd\u0dcf \u0dc4\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "2021 \u0dc0\u0dc3\u0dbb\u0dda \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dcf\u0dc3\u0dba \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dba\u0d9a \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dd4\u0dc0\u0d9a \u0d85\u0daf \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc0\u0da7\u0dd2\u0db1\u0dcf\u0d9a\u0db8 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 30000\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dc4\u0dbb\u0dca\u0dc2\u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.\u0d85\u0dba\u0dc0\u0dd0\u0dba \u0dc0\u0dd2\u0dc0\u0dcf\u0daf\u0dba\u0da7 \u0d92\u0d9a\u0dca\u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db8\u0dda \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.",
        "\"\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 30\u0d9a\u0dca 40\u0d9a\u0dca \u0dc0\u0dd0\u0da9 \u0d9a\u0dbb\u0dbd\u0dcf \u0d89\u0dad\u0dd4\u0dbb\u0dd4\u0d9a\u0dbb \u0d9c\u0dad\u0dca\u0dad \u0daf\u0dda\u0da7 \u0db8\u0ddc\u0d9a\u0d9a\u0dca\u0daf \u0dc0\u0dd4\u0dab\u0dda? 2019 \u0d89\u0daf\u0db1\u0dca 2022\u0da7 \u0db6\u0dbd\u0db1\u0dca\u0db1 \u0d95\u0db1 \u0db1\u0dd1. \u0d91\u0dc4\u0dd9\u0db8 \u0db6\u0dd0\u0dbd\u0dd4\u0dc0\u0ddc\u0dad\u0dca \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dd4\u0db8\u0dcf\u0da7\u0dad\u0dca \u0d9a\u0dbd\u0db1\u0dca\u0dad\u0dda \u0daf\u0dcf\u0dba\u0dd2.",
        "2021 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0daf\u0dbd\u0dcf 2022 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0dc0\u0dd9\u0db1\u0d9a\u0db8\u0dca \u0db6\u0dbd\u0db1\u0dca\u0db1 \u0db8\u0ddc\u0d9a\u0d9a\u0dca\u0daf \u0dc0\u0dd4\u0db1\u0dda \u0d9a\u0dd2\u0dba\u0dbd\u0dcf. \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dba\u0d9a\u0dca \u0d9a\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc4\u0dbb\u0dd2 \u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0d9a\u0dbb\u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf\u0db1\u0db8\u0dca \u0db8\u0dda \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dca\u0daf \u0dad\u0dd4\u0dc5 \u0d92 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0dc0\u0da7\u0dd2\u0db1\u0dcf\u0d9a\u0db8 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 30000\u0da7 \u0d85\u0da9\u0dd4\u0dc0\u0dd9\u0dbd\u0dcf. \u0d85\u0da9\u0dd4\u0d9a\u0dbb\u0dbd\u0dcf.",
        "\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dda \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0d89\u0dad\u0dd2\u0dbb\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 70\u0d9a\u0dca \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2\u0dbd\u0dcf \u0dc4\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb\u0dbd\u0dcf \u0d9a\u0dd2\u0dc0\u0dca\u0dc0\u0ddc\u0dad\u0dca \u0d92\u0d9a \u0dc0\u0dd0\u0dbb\u0daf\u0dd2 \u0db1\u0dd1 \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dad\u0dd4\u0db8\u0db1\u0dd2. \u0d92\u0d9a \u0dad\u0db8\u0dba\u0dd2 \u0d87\u0dad\u0dca\u0dad \u0d9a\u0dae\u0dcf\u0dc0, \u0d92\u0d9a \u0dad\u0db8\u0dba\u0dd2 \u0dc0\u0dd9\u0dbd\u0dcf \u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca\u0db1\u0dda. \""
      ],
