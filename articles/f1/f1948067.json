        [
          {
            "text": "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 04",
            "label": "DATE"
          },
          {
            "text": "\u0db6\u0dca\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "04",
            "label": "CARDINAL"
          }
        ],
        [],
        [
          {
            "text": "\u0d9c\u0dbd\u0dca\u0d9a\u0dd2\u0dc3\u0dca\u0dc3",
            "label": "LOC"
          },
          {
            "text": "\u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0d9a\u0ddd\u0dc3\u0dbd \u0dc3\u0dda\u0db1\u0dcf\u0db0\u0dd3\u0dbb",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0d9a",
