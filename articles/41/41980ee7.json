    "si": {
      "title": "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba\u0da7 \u0dad\u0dd9\u0dbd\u0dca \u0daf\u0dd9\u0db1\u0dca\u0db1 \u0dad\u0dc0\u0dad\u0dca \u0dc2\u0dd9\u0da9\u0dca \u0daf\u0dc4\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1 \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd9\u0db1\u0dca\u0d9a\u0dd9\u0dbb\u0dd9\u0db1\u00a0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 84 \u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0dbb\u0da2\u0dba\u00a0 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1 \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd4\u00a0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 74 \u0d9a\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb\u00a0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dc3\u0dc4 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca\u00a0 \u00a0\u0dbd\u0dd3\u0da7\u0dbb\u0dca 6600 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca\u00a0 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dbb\u0dd2\u0db1 \u0dbd\u0dd9\u0dc3 \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2\u00a0 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0daf\u0dd3 \u0d87\u0dad"
      ],
