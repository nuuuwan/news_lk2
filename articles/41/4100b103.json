          }
        ],
        [
          {
            "text": "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2 \u0daf\u0dd9\u0d9a",
            "label": "DATE"
          },
          {
            "text": "\u0db6\u0ddd\u0dc0\u0db1 \u0dbb\u0ddd\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0db8\u0dd2\u0dad \u0d9a\u0dd2\u0db1\u0dd2\u0d9a\u0dda",
