    "si": {
      "title": "\u0da9\u0dd3\u0dc3\u0dbd\u0dca, \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0db4\u0da7\u0dc0\u0dcf\u0d9c\u0dad\u0dca \u0db1\u0dd0\u0dc0\u0dca 3\u0d9a\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dda\u0daf\u0dd3 IOC \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad",
      "author": "T. Saranya",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf IOC \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dc3\u0dc4 \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0db4\u0da7\u0dc0\u0dcf\u0d9c\u0dad\u0dca \u0db1\u0dde\u0d9a\u0dcf \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0da2\u0dd6\u0dbd\u0dd2 13 - 15 \u0d85\u0dad\u0dbb \u0d91\u0d9a\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0daf \u0da2\u0dd6\u0dbd\u0dd2 29 - 31 \u0d85\u0dad\u0dbb \u0dad\u0dc0\u0dad\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0daf \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 10 - 15 \u0d85\u0dad\u0dbb \u0db8\u0dd3\u0dc5\u0d9f \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0dad\u0dca \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0 \u0dbd\u0d82\u0d9a\u0dcf IOC \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0daf\u0db1\u0dca\u0dc0\u0dcf \u0d87\u0dad."
      ],
