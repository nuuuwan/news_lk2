    "en": {
      "title": "The one-hour power cut will be extended for another 20 minutes",
      "author": "unknown",
      "body_lines": [
        "The Public Utilities Commission says that due to the lack of sufficient water and fuel for electricity generation, it has approved electricity cuts for two hours and 20 minutes tomorrow and the day after (15 and 16).",
        "Accordingly, the Electricity Board said that the power cut will be implemented from 6.00 pm to 9.30 pm in 20 zones from 'A' to 'W'."
      ],
      "title_ents": [
        {
          "text": "one-hour",
          "label": "TIME"
        },
        {
          "text": "another 20 minutes",
          "label": "TIME"
        }
      ],
