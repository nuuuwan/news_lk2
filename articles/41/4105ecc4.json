    "si": {
      "title": "\u201c\u0dbb\u0da7\u0dca\u0da7\u0dcf\u201d \u0dc3\u0dc4 \u0dbd\u0dc4\u0dd2\u0dbb\u0dd4 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0d9a\u0dd4\u0da7 \u0d87\u0db4 \u0db1\u0dd2\u0dba\u0db8 \u0dc0\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc3\u0db8\u0dcf\u0da2 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc3\u0dc4 \u0dba\u0dd6 \u0da7\u0dd2\u0dba\u0dd4\u0db6\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0dbb\u0dad\u0dd2\u0db3\u0dd4 \u0dc3\u0dda\u0db1\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db1\u0ddc\u0dc4\u0ddc\u0dad\u0dca \u201c\u0dbb\u0da7\u0dca\u0da7\u0dcf\u201d, \u2018\u0dc0\u0dd9\u0db1\u0dc3\u0da7 \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0db1\u0dca\u2019 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0dbd\u0dc4\u0dd2\u0dbb\u0dd4 \u0dc0\u0dd3\u0dbb\u0dc3\u0dda\u0d9a\u0dbb \u0dc3\u0dc4 \u0db4\u0dd6\u0da2\u0dca\u200d\u0dba \u0dbb\u0dad\u0dca\u0d9a\u0dbb\u0dc0\u0dca\u0dc0\u0dda \u0da2\u0dd2\u0db1\u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0da7 \u0d85\u0daf (\u0da2\u0dd4\u0dbd\u0dd2 01) \u0d87\u0db4 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dcf."
      ],
