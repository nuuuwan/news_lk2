            "text": "\u0db4\u0dcf\u0dbd\u0dd2\u0dad \u0dbb\u0d82\u0d9c \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0da2\u0dd2\u0dbb \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
