          {
            "text": "\u0baa\u0bbe\u0bb2\u0bbf\u0ba4 \u0bb0\u0b99\u0bcd\u0b95 \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0",
            "label": "PERSON"
