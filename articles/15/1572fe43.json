{
  "newspaper_id": "lankadeepa-lk",
  "url": "https://www.lankadeepa.lk/latest_news/\u0d89\u0db1\u0dca\u0db0\u0db1-\u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba-\u0d8b\u0d9c\u0dca\u200d\u0dbb-\u0dc0\u0dd9\u0db1\u0dc0\u0dcf/1-615430",
  "time_ut": 1656249731,
  "original_lang": "si",
  "original_title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0d8b\u0d9c\u0dca\u200d\u0dbb \u0dc0\u0dd9\u0db1\u0dc0\u0dcf",
  "text_idx": {
    "en": {
      "title": "The fuel crisis is escalating",
      "author": "unknown",
      "body_lines": [
        "The Minister of Power and Energy Kanchana Wijesekera stated that the date of receipt of a fuel tanker is not certain and that a more serious situation could arise in the future fuel crisis.",
        "Minister Wijesekera also apologized to the people for not being able to supply the required fuel to the people and said that the importation of fuel had become a serious crisis as the old suppliers had not come forward and the new suppliers had to go.",
        "The Minister also requested the people not to wait in queues at petrol stations and said that kerosene could no longer be provided."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [],
        [
          {
            "text": "Wijesekera",
            "label": "PERSON"
          }
        ],
        []
      ]
    },
    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0d8b\u0d9c\u0dca\u200d\u0dbb \u0dc0\u0dd9\u0db1\u0dc0\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0daf\u0dd2\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dd2\u0dad\u0dc0 \u0d9a\u0dd2\u0dc0\u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0d85\u0db1\u0dcf\u0d9c\u0dad\u0dba\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba\u0dda \u0dc0\u0da9\u0dcf\u0dad\u0dca \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dad\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (26) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2\u0dc0\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d9a\u0dc5\u0d9c\u0dcf\u0da7\u0dd4\u0dc0 \u0db4\u0dc5\u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb\u0db8 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0dc0 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0 \u0d9a\u0dd3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0dbb\u0dab\u0dd2 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0db1\u0ddc\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db1\u0dc0 \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7\u00a0 \u0dba\u0dd1\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d86\u0db1\u0dba\u0db1\u0dba \u0daf\u0dd0\u0da9\u0dd2 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca\u0dba.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca\u0dc0\u0dbd \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0dbb\u0dd0\u0daf\u0dd3 \u0d8b\u0daf\u0dca\u0d9d\u0ddd\u0dc2\u0dab\u0dba \u0db1\u0ddc\u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dad\u0dbb\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0dad\u0dc0 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd2\u0dba \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
