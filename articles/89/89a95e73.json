          },
          {
            "text": "Susil Premajayantha",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "the end of November",
            "label": "DATE"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1\u0dba. \u0db8\u0dda \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dd4 \u0db1\u0dd1 \u0d9a\u0dd2\u0dba\u0dbd\u0dcf \u0d87\u0db8\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0dcf \u0d9a\u0dd2\u0dba\u0db1\u0dc0\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dd9\u0db8 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dd4 \u0dbd\u0db6\u0dcf \u0db1\u0ddc\u0daf\u0dd9\u0db1 \u0db6\u0dc0 \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc3\u0dd4\u0dc3\u0dd2\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0da2\u0dba\u0db1\u0dca\u0dad \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0, \u0db8\u0d9c \u0dc4\u0dd0\u0dbb\u0dd4\u0dab\u0dd4 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0db1\u0ddc\u0dc0\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca \u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dcf\u0da9\u0db8\u0dca \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1\u0dd4 \u0d87\u0dad."
      ],
      "title_ents": [
