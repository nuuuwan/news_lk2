    "si": {
      "title": "\u0d85\u0dbd\u0dd4\u0dad\u0dca\u0dc0\u0dd0\u0da9\u0dd2\u0dba\u0dcf \u0d9a\u0dc5 \u0dbd\u0d82\u0d9c\u0db8 \u0db6\u0dc3\u0dca 800\u0d9a\u0dca \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0d9c\u0db8\u0db1\u0dcf \u0d9c\u0db8\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda (\u0dbd\u0d82\u0d9c\u0db8) \u0da9\u0dd2\u0db4\u0ddd 105 \u0d9a\u0dd2\u0db1\u0dca \u0d85\u0db8\u0dad\u0dbb \u0db6\u0dc3\u0dca \u0dbb\u0dae 800 \u0d9a\u0dca \u0dbd\u0db6\u0db1 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dc3 1 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7 \u0dba\u0ddc\u0daf\u0dc0\u0db1 \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0da7\u0dba\u0dbb\u0dca \u0dc3\u0dc4 \u0d85\u0db8\u0dad\u0dbb \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc3\u0dca \u0dbb\u0dae 800 \u0d9a\u0dca \u0d85\u0dbd\u0dd4\u0dad\u0dca\u0dc0\u0dd0\u0da9\u0dd2\u0dba\u0dcf \u0d9a\u0dbb \u0db8\u0dd9\u0dc3\u0dda \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7 \u0dba\u0ddc\u0daf\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0da7\u0dba\u0dbb\u0dca \u0dc3\u0dc4 \u0d85\u0db8\u0dad\u0dbb \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0db6\u0dc3\u0dca \u0dbb\u0dae \u0db8\u0dcf\u0dc3 \u0d9c\u0dab\u0db1\u0d9a\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd4\u0dab \u0daf \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0d9a\u0dbb \u0d85\u0db8\u0dad\u0dbb \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0d89\u0d9a\u0dca\u0db8\u0dab\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5 \u0db6\u0dc0\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dd3\u0dba."
      ],
