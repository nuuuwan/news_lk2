          {
            "text": "\u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0d95\u0dc3\u0dca\u0da7\u0dca\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0dad\u0dd3\u0d9a\u0dca\u0dc2\u0dab",
            "label": "PERSON"
