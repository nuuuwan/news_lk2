        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0ddc\u0dc5\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4",
            "label": "NORP"
          },
          {
            "text": "\u0d9a\u0daf\u0dd4\u0dbb\u0dd4\u0dc0\u0dd9\u0dbd \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0ddc\u0dbd\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4\u0dc0 \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db4\u0ddc\u0dc5\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4 \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db4\u0ddc\u0dbd\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4\u0dc0 \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0daf\u0dd4\u0dbb\u0dd4\u0dc0\u0dd9\u0dbd \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd",
            "label": "FAC"
          }
        ],
        [],
        [
          {
            "text": "\u0db4\u0ddc\u0dbd\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4\u0dc0 \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd",
