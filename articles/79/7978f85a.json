    "si": {
      "title": "\u2018\u0d85\u0db4\u0dda \u0da2\u0db1 \u0db6\u0dbd \u0db4\u0d9a\u0dca\u0dc2\u0dba\u2019 \u0db1\u0dcf\u0dba\u0d9a \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0db1\u0dd4\u0dc2\u0dca\u200d\u0dba \u0d9d\u0dcf\u0dad\u0db1\u0dba\u0d9a\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dba\u0dd0\u0dba\u0dd2 \u0d9a\u0dd2\u0dba\u0db1 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4\u0da7 \u0dbb\u0dd0\u0d9a\u0dc0\u0dbb\u0dab\u0dba \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u2018\u0d85\u0db4\u0dda \u0da2\u0db1 \u0db6\u0dbd \u0db4\u0d9a\u0dca\u0dc2\u0dba\u2019 (\u0d85\u0db4\u0dda \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba \u0dc4\u0ddd OPPP) \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0db8\u0db1\u0dca \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1 \u0d85\u0db1\u0dca\u0daf\u0db8\u0da7 \u0db8\u0dd9\u0db8 \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dc3 05 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d9a\u0dd4\u0da9\u0dcf\u0dc0\u0dd0\u0dbd\u0dca\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3\u0dba."
      ],
