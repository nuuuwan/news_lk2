    "si": {
      "title": "LPL 2022 \u0d9a\u0dcf\u0dbd\u0dc3\u0da7\u0dc4\u0db1 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3; \u0db8\u0dd4\u0dc5\u0dd4 \u0dad\u0dbb\u0d9c 24\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dd2\u0db8\u0dd2\u0dba\u0dbb\u0dca \u0dbd\u0dd3\u0d9c\u0dca 2022 2022 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 01 \u0dc0\u0db1\u0daf\u0dcf \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0db1 \u0db6\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dc5\u0dda \u0dc0\u0dad\u0dca\u0db8\u0db1\u0dca \u0dc1\u0dd6\u0dbb\u0dba\u0db1\u0dca \u0dc0\u0db1 \u0da2\u0dd0\u0dc6\u0dca\u0db1\u0dcf \u0d9a\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca 2021 \u0dc3\u0d82\u0dc3\u0dca\u0d9a\u0dbb\u0dab\u0dba\u0dda \u0d85\u0db1\u0dd4\u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0 \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0dad\u0dca \u0d9c\u0dcf\u0dbd\u0dd4 \u0d9c\u0dca\u0dbd\u0dd0\u0da9\u0dd2\u0dba\u0dda\u0da7\u0dbb\u0dca\u0dc3\u0dca \u0dc3\u0db8\u0d9f \u0dad\u0dbb\u0d9f \u0dc0\u0daf\u0dd2\u0db8\u0dd2\u0db1\u0dd2.",
        "\u0dc3\u0db8\u0dc3\u0dca\u0dad\u0dba\u0d9a\u0dca \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca, \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dad\u0dd4\u0dc5 \u0dad\u0dbb\u0d9f 24 \u0d9a\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d85\u0dad\u0dbb, \u0db4\u0dc5\u0db8\u0dd4 \u0dc0\u0da7\u0dba\u0dda \u0dad\u0dbb\u0d9f 20 \u0d9a\u0dca \u0dc3\u0dc4 \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0dc0\u0da7\u0dba\u0dda \u0dad\u0dbb\u0d9f 4 \u0d9a\u0dca, \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dad\u0dbb\u0d9f \u0daf \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0dc0\u0dda.",
        "\u0db4\u0dc5\u0db8\u0dd4 \u0dad\u0dbb\u0d9f 14 \u0d9a\u0ddc\u0dc5\u0db9 RPICS \u0dc4\u0dd2\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba 2022 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 13 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 \u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 MRICS \u0dc0\u0dd9\u0dad \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0d87\u0dad.",
        "\u0db8\u0dc4\u0da2\u0db1 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db8\u0dd1\u0dad\u0daf\u0dd3 \u0db1\u0dd9\u0dbb\u0db4\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba\u0d9c\u0dda \u0dc0\u0dd3\u0dc3\u0dcf \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8 '\u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4 \u0d9a\u0dbb\u0dba\u0dd2' - \u0dc4\u0dd2\u0db1\u0dca\u0daf\u0dd4",
        "Cryptocurrencies \u0dc4\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca CBSL \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0d85\u0d9f\u0dc0\u0dba\u0dd2"
      ],
