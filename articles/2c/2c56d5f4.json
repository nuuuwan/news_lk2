        [
          {
            "text": "\u0db8\u0dd9\u0db8 \u0dc0\u0dcf\u0dbb\u0dd2\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0dde\u0db7\u0dcf\u0d9c\u0dca\u200d\u0dba \u200b\u200b\u0dc0\u0dd0\u0dc0\u0dca \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2\u0dba",
