  "original_title": "\u0dc3\u0dcf\u0db4\u0dd9\u0dc5 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dba\u0ddd\u0d9c\u0dd2\u0d9a \u0db4\u0dbb\u0dd2\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd2\u0db1 \u0db4\u0dc4\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dca\u0dc3\u0da7",
  "text_idx": {
    "en": {
      "title": "SAPELA Practical Tests back in five days",
      "author": "unknown",
      "body_lines": [
        "Examination Commissioner General L. M. D. Dharmasena says that the practical tests related to the aesthetic subjects of the General Certificate of Education 2021 examination will begin on the 20th of this month.",
        "Mr. Dharmasena also says that the practical tests were scheduled to start on the 15th of this month, but due to unavoidable reasons, it had to be postponed.",
        "The examination commissioner also says that the evaluation work of the examination is at the final stage.",
        "Mr. Dharmasena also said that it will take another two months to release the results of the general examination."
      ],
      "title_ents": [
        {
          "text": "five days",
          "label": "DATE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "L. M. D. Dharmasena",
            "label": "PERSON"
          },
