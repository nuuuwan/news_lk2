        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dbb\u0dcf\u0db0\u0dd2\u0d9a\u0dcf \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dca\u0dc0\u0dcf\u0db8\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a",
            "label": "GPE"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dbb\u0dad\u0dd4 \u0d9a\u0dd4\u0dbb\u0dd4\u0dc3 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d89\u0dad\u0dd2\u0dba\u0ddd\u0db4\u0dd2\u0dba\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dcf\u0db1\u0dc0 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8\u0dca \u0d9a\u0dc0\u0dd4\u0db1\u0dca\u0dc3\u0dd2\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "Federico Willegas",
            "label": "PERSON"
          },
          {
            "text": "28",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dbb\u0dcf\u0db0\u0dd2\u0d9a\u0dcf \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dca\u0dc0\u0dcf\u0db8\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dad\u0dd9\u0dc0\u0db1",
            "label": "ORDINAL"
          },
          {
            "text": "\u0d9a\u0dbb\u0dd2 \u0db4\u0dd9\u0dbb\u0dd3 \u0db8\u0dd4\u0dbb\u0dd4\u0d82\u0d9c\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dd9\u0db1\u0dca\u0dba\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0dca\u0da7\u0dd3\u0dc0\u0db1\u0dca \u0dbb\u0db1\u0dbb\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dcf\u0dbb\u0dca\u0dad\u0dd4",
            "label": "DATE"
          },
          {
            "text": "2",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0dc6\u0dd9\u0dbb\u0ddd \u0db6\u0dd9\u0db1\u0dca\u0dc3\u0dd4\u0da9\u0dcf",
            "label": "ORG"
          },
          {
            "text": "8) \u0dc0\u0dc3\u0dbb",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dcf\u0db1\u0dc0 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8\u0dca \u0d9a\u0dc0\u0dd4\u0db1\u0dca\u0dc3\u0dd2\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd9\u0dc3\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca 17, 2021",
            "label": "DATE"
          },
          {
