    "si": {
      "title": "STF \u0daf\u0dd4\u0db4\u0dca\u0db4\u0dad\u0dca \u0db4\u0dc0\u0dd4\u0dbd\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0dba\u0dc5\u0dd2 \u0dc3\u0dbd\u0dcf\u0d9a \u0db6\u0dd9\u0daf\u0dcf \u0daf\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0daf\u0dd2\u0dc5\u0dd2\u0db3\u0dd4 \u0db4\u0dc0\u0dd4\u0dbd\u0dca 200\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0dba\u0dc5\u0dd2 \u0d86\u0dc4\u0dcf\u0dbb \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca 200\u0d9a\u0dca \u0db6\u0dd9\u0daf\u0dcf \u0daf\u0dd9\u0db1 \u0dbd\u0daf\u0dd3. \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db6\u0da7\u0dc4\u0dd2\u0dbb \u0dc0\u0dd9\u0dbb\u0dc5 \u0dad\u0dd3\u0dbb\u0dba\u0dda \u0dc0\u0dd9\u0dc3\u0dd9\u0db1 \u0dbb\u0dcf\u0da2\u0d9a\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d86\u0daf\u0dd2 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dd4\u0dbd\u0dca\u200d\u0dba \u0daf\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dc0\u0dd2\u0dba\u0dc5\u0dd2 \u0dc3\u0dbd\u0dcf\u0d9a\u0dba \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0dbd\u0daf\u0dd3."
