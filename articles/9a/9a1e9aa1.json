          }
        ]
      ]
    },
    "si": {
      "title": "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc3\u0dcf\u0dba \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc0\u0dca\u200d\u0dba\u0dd4\u0dc4\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d92\u0d9a\u0d9a\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0da2\u0dba \u0dc3\u0dad\u0dd4 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dcf\u0dc3\u0dba \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc0\u0dca\u200d\u0dba\u0dd4\u0dc4 \u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d92\u0d9a\u0d9a\u0dba\u0d9a\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 200\u0d9a\u0dca \u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
