    "si": {
      "title": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0d86\u0dba\u0dd4 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0d86\u0dba\u0dd4 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 2019 \u0dc3\u0dc4 2021 \u0d85\u0dad\u0dbb \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbb\u0ddd\u0d9c \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0dc3\u0dc4 \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1 (CDC) \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0d9a \u0dc4\u0dd9\u0dc5\u0dd2 \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0d91\u0dba 1961-1963 \u0dc0\u0dc3\u0dbb\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0db4\u0dc5\u0db8\u0dd4 \u0dc0\u0dc3\u0dbb \u0daf\u0dd9\u0d9a\u0d9a \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd3\u0db8 \u0dbd\u0dd9\u0dc3\u0daf \u0dc3\u0dd0\u0dbd\u0d9a\u0dd9\u0dba\u0dd2.",
        "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc0\u0dc3\u0dbb \u0daf\u0dd9\u0d9a \u0dad\u0dd4\u0dc5, \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0d86\u0dba\u0dd4 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0dc0\u0dc3\u0dbb 2.7\u0d9a\u0dd2\u0db1\u0dca \u0d85\u0da9\u0dd4 \u0dc0\u0dd6 \u0d85\u0dad\u0dbb, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0d86\u0dba\u0dd4 \u0d9a\u0dcf\u0dbd\u0dba \u0dc0\u0dc3\u0dbb 76.1\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda,\u00a01996 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0d86\u0db4\u0dc3\u0dd4 \u0dba\u0db8\u0dd2\u0db1\u0dd2.",
        "CDC \u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0d86\u0dba\u0dd4 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0d85\u0da9\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dc3\u0dcf\u0db0\u0d9a\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca-19 \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba\u0dba\u0dd2. \u0d91\u0dba \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1\u0dba\u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dbb\u0dab\u0dc0\u0dbd\u0da7 \u0daf\u0dcf\u0dba\u0d9a \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba\u0da7 \u0db4\u0dd9\u0dbb, \u0dc4\u0dd8\u0daf \u0dbb\u0ddd\u0d9c \u0db6\u0ddc\u0dc4\u0ddd \u0d9a\u0dbd\u0d9a \u0dc3\u0dd2\u0da7 \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db8\u0dbb\u0dab \u0dc3\u0db3\u0dc4\u0dcf \u0d89\u0dc4\u0dc5\u0db8 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9c\u0dad \u0dc4\u0dda\u0dad\u0dd4\u0dc0 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2."
      ],
