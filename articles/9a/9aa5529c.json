          {
            "text": "\u0da9\u0dd0\u0db1\u0dd2\u0dba\u0dd9\u0dbd\u0dca \u0db6\u0dd6\u0da9\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a \u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0dc3\u0dc4 \u0dc0\u0dd9\u0dc5\u0db3",
