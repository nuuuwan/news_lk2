            "text": "\u0d9a\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0da2\u0dba\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0d82\u0d9a\u0dbb \u0dc3\u0dd9\u0db1\u0dd9\u0dc0\u0dd2\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dc3\u0dca \u0d94\u0db6\u0dda\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
