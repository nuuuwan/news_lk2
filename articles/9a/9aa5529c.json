          },
          {
            "text": "CIPM",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0d82\u0d9c\u0db8\u0dca \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba",
