    "si": {
      "title": "\u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1 \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca  \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0db1\u0dd9\u0dbb\u0db4\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc0\u0dca\u0dbd\u0ddc\u0daf\u0dd2\u0db8\u0dd3\u0dbb\u0dca \u0dc3\u0dd9\u0dbd\u0dd9\u0db1\u0dca\u0dc3\u0dca\u0d9a\u0dd3, \u0d91\u0dbb\u0da7 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d9a\u0dd3\u0db4 \u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0db1\u0dd9\u0dbb\u0db4\u0dcf \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0db4\u0dd4\u0dc0\u0dad\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0dd9\u0dbd\u0dd9\u0db1\u0dca\u0dc3\u0dca\u0d9a\u0dd2 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd9\u0dbb\u0db4\u0dcf \u0daf\u0db8\u0db1\u0dd4 \u0dbd\u0dd0\u0db6 \u0d87\u0dad\u0dca\u0dad\u0dda \u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1\u0dba\u0dda \u0da2\u0dbb\u0dca\u0db8\u0db1\u0dca, \u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba, \u0da0\u0dd9\u0d9a\u0dca, \u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dda \u0dc3\u0dc4 \u0dc4\u0d82\u0d9c\u0dda\u0dbb\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0dba.",
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0dd9\u0dbd\u0dd9\u0db1\u0dca\u0dc3\u0dca\u0d9a\u0dd3 \u0db8\u0dd9\u0db8 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0db1\u0dd9\u0dbb\u0db4\u0dcf \u0daf\u0dd0\u0db8\u0dd4\u0dc0\u0dda \u0d87\u0dba\u0dd2\u0daf\u0dd0\u0dba\u0dd2 \u0dba\u0db1\u0dca\u0db1 \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0db1\u0dd0\u0dad."
      ],
