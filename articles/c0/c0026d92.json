          },
          {
            "text": "\u0b9c\u0baa\u0bbf\u0baf\u0bc1\u0bb2\u0bcd\u0bb2\u0bbe \u0bae\u0bc1\u0b9c\u0bbe\u0bb9\u0bbf\u0ba4\u0bcd",
