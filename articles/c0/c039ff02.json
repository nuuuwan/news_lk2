          },
          {
            "text": "\u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0dd4\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dc0\u0dcf\u0dbd\u0dd4\u0d9a\u0dcf\u0dbb\u0dcf\u0db8\u0dba",
