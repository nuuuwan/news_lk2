        [
          {
            "text": "\u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0dd4\u0db6\u0dd2\u0da7\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
