          {
            "text": "\u0bb0\u0ba3\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb0\u0bae\u0b9a\u0bbf\u0b99\u0bcd\u0b95",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0ba8\u0ba8\u0bcd\u0ba4\u0ba9 \u0b85\u0bae\u0bb0\u0b9a\u0bbf\u0b99\u0bcd\u0b95",
            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0 \u0b87\u0bb3\u0b99\u0bcd\u0b95\u0b9a\u0bbf\u0b99\u0bcd\u0b95",
            "label": "PERSON"
