    "si": {
      "title": "TUCC \u0dba\u0ddd\u0da2\u0db1\u0dcf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb\u0dba\u0dd2...",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dd3\u0d9a\u0dbb\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba (TUCC) \u0d85\u0daf \u0d9a\u0ddc\u0dc5\u0db9 \u0db8\u0dc4\u0da2\u0db1 \u0db4\u0dd4\u0dc3\u0dca\u0dad\u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba\u0d9a\u0daf\u0dd3 \u0dbb\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0daf\u0dd0\u0dc0\u0dd9\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1 \u0dc0\u0dd2\u0dc3\u0db3\u0dd3\u0db8\u0dda \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dd2\u0db1\u0dca \u0dba\u0ddd\u0da2\u0db1\u0dcf \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dc5\u0dda\u0dba. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dd2\u0dad\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0daf \u0db8\u0dd9\u0dbd\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dd2"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dd3\u0d9a\u0dbb\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
