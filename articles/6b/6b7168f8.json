            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bc7\u0bb0\u0bbe\u0baf\u0bb0\u0bcd \u0bae\u0bc6\u0bb2\u0bcd\u0b95\u0bae\u0bcd \u0b95\u0bb0\u0bcd\u0ba4\u0bbf\u0ba9\u0bbe\u0bb2\u0bcd",
            "label": "ORG"
          },
          {
