    "si": {
      "title": "\u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0d9c\u0dd9\u0db8\u0dca\u0db6\u0ddd \u0dc0\u0dd9\u0db1\u0dca\u0db1 \u0d9c\u0dd2\u0dba\u0ddc\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0daf\u0dac\u0dd4\u0dc0\u0db8\u0dca \u0daf\u0dda\u0dc0\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0d9c\u0dd9\u0db8\u0dca\u0db6\u0ddd \u0dc0\u0d9c\u0dda \u0d91\u0dc4\u0dcf\u0da7 \u0db8\u0dd9\u0dc4\u0dcf\u0da7 \u0db4\u0dd0\u0db1\u0dca\u0db1\u0ddc\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0d92\u0dc0\u0dcf\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0da0\u0dcf\u0dbb \u0dc0\u0dd2\u0daf\u0dd2\u0db1\u0dca\u0db1\u0da7 \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0d85\u0daf (27)\u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0dc0\u0dd2\u0dc0\u0dcf\u0daf\u0dba\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0db8\u0dda \u0db6\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d85\u0daf \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0 \"\u0dc4\u0daf\u0dd2\u0dc3\u0dd2\u0dba\" \u0d9c\u0dd0\u0db1 \u0d9a\u0dad\u0dcf \u0d9a\u0dbb\u0db1 \u0db1\u0db8\u0dd4\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0dad\u0dd2\u2063\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd2\u00a0 \u0da2\u0dd3\u0dc0\u0dad\u0dca \u0dc0\u0dd3\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dc4\u0daf\u0dd2\u0dc3\u0dd2\u0dba\u0d9a\u0dca \u0dba\u0dd0\u0dba\u0dd2\u0daf \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0\u0da7 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dca\u0db1\u0dda\u00a0 \u0dad\u0dbb\u0dca\u0da2\u0db1\u0dba \u0d9c\u0dbb\u0dca\u0da2\u0db1\u0dba\u00a0 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dad\u0dca\u200d\u0dbb\u0dc3\u0dca\u0dad\u0dc0\u0dcf\u0daf\u0dba \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dca\u0dad \u0d9a\u0dbb\u0db1 \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0dba\u0dd0\u0dba\u0dd2\u0daf \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0d9a\u0dd3\u0dba.",
        "\u0da2\u0db1\u0db4\u0dad\u0dd2\u0d9c\u0dda \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0dc3\u0db7\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dad\u0dd4\u0db8\u0db1\u0dca\u0dbd\u0dcf\u0d9c\u0dda \u0dc3\u0dd2\u0dc4\u0dd2\u0db1\u0dba \u0dc3\u0dd0\u0db6\u0dd1 \u0dc0\u0dd4\u0dab \u0db1\u0db8\u0dd4\u0dad\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u00a0 220 \u0d9a\u0dca \u0dc0\u0db1 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dda \u0dc3\u0dd2\u0dc4\u0dd2\u0db1 \u0d9a\u0dd4\u0da9\u0dd4\u0db4\u0da7\u0dca\u0da7\u0db8\u0dca \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0\u0daf \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0d9a\u0dd3\u0dba."
      ],
