    "si": {
      "title": "\u0db4\u0ddd\u0da7\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd2\u0da7 \u0d86\u0db8\u0dbb\u0dca \u0dc0\u0dd3\u0daf\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0db8\u0d82\u0dad\u0dd3\u0dbb\u0dd4\u0dc0",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0d9a\u0ddc\u0dc5\u0db9 \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0db8\u0dc4 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0 \u0db1\u0dc0 \u0db8\u0d82\u0dad\u0dd3\u0dbb\u0dd4\u0dc0\u0d9a\u0dca \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba.",
        "\u0d9a\u0ddc\u0dc5\u0db9 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dc0 \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0d89\u0da9\u0db8 \u0dc3\u0dc4 \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0db1\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba\u0da7 \u0dc0\u0dd2\u0dc3\u0db3\u0dd4\u0db8\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d9a\u0ddc\u0dc5\u0db9 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0 \u0db8\u0dd9\u0db8 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0db4\u0dc5\u0db8\u0dd4 \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0d89\u0da9\u0db8 \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d86\u0db8\u0dbb\u0dca \u0dc0\u0dd3\u0daf\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd4\u0dc0\u0dda \u0d9a\u0ddc\u0dc5\u0db9 \u0db1\u0d9c\u0dbb\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0db1\u0dd2 \u0dbb\u0ddd\u0dc3\u0dd2 \u0dc3\u0dda\u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dd2."
      ],
