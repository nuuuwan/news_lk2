    "si": {
      "title": "\u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf \u0d85\u0dc4\u0dd2\u0db8\u0dd2 \u0dc0\u0dd6\u0dc0\u0db1\u0dca\u0da7 \u0dc3\u0dc4\u0db1 \u0dc3\u0dd0\u0dbd\u0dc3\u0dd3\u0db8\u0da7 \u0db1\u0dc0 \u0db1\u0dd3\u0dad\u0dd2\u0dba\u0d9a\u0dca",
