    "si": {
      "title": "\u0d9c\u0dd9\u0daf\u0dbb\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dc4\u0dd9\u0d9a\u0dd4\u0da7 \u0d9c\u0dd9\u0daf\u0dbb \u0dba\u0db1\u0dca\u0db1\u0dd0\u0dba\u0dd2 \u0d9a\u0dd3\u0db8 \u0d9a\u0dcf\u0dbd\u0dba \u0db1\u0dcf\u0dc3\u0dca\u0dad\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0d9c\u0dd9\u0daf\u0dbb \u0dba\u0db1\u0dca\u0db1\u0dd0 \u0dba\u0dd2 \u0d9a\u0dd2\u0dba\u0dcf \u0db4\u0dd9\u0dc5\u0db4\u0dcf\u0dc5\u0dd2\u00a0 \u0d9c\u0dd2\u0dba\u0dcf\u0da7 \u0dad\u0db8\u0dcf\u0da7 \u0dba\u0db1\u0dca\u0db1\u0da7 \u0d9c\u0dd9\u0daf\u0dbb\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd0\u0dba\u0dd2 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d9c\u0dd9\u0daf\u0dbb\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dc4\u0dd9\u0d9a\u0dd4\u0da7 \u0d9c\u0dd9\u0daf\u0dbb \u0dba\u0db1\u0dca\u0db1\u0dd0\u0dba\u0dd2 \u0d9a\u0dd2\u0dba\u0dcf \u0db4\u0dd9\u0dc5\u0db4\u0dcf\u0dc5\u0dd2\u00a0 \u0dba\u0dcf\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dbd\u0d9a\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0dc4\u0dd9\u0dba\u0dd2\u0db1\u0dca \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0d9a\u0dbb \u0d91\u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dda \u0d9a\u0dbb \u0d9a\u0dcf\u0dbd\u0dba \u0db1\u0dcf\u0dc3\u0dca\u0dad\u0dd2 \u0db1\u0ddc\u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0daf \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0d9a\u0dd3\u0dba.",
        "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0d9a\u0dca\u0dc2 \u0dc3\u0dc4 \u0db4\u0ddc\u0daf\u0dd4 \u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca,\u0dc4\u0dd2\u0da7\u0db4\u0dd4\u00a0 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0db4\u0dcf\u0dbd\u0db1 \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0db1\u0dca \u0dc4\u0dcf \u0d86\u0dc3\u0db1 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d85\u0db8\u0dad\u0db8\u0dd2\u0db1\u0dca \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dda \u0db6\u0dc0 \u0d9a\u0dd3\u0dba.",
        "\"\u0d94\u0dba\u0d9c\u0ddc\u0dbd\u0dca\u0dbd\u0ddc \u0dbd\u0dd1\u0dc3\u0dca\u0dad\u0dd2 \u0db1\u0db8\u0dca \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0dc3\u0dd9\u0db1\u0d9f\u0d9a\u0dca \u0d9c\u0dda\u0db1\u0dca\u0db1.\u0db8\u0dcf\u0dc3 \u0dc4\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dad \u0db8\u0d9c\u0dda \u0d9c\u0dd9\u0daf\u0dbb \u0dc4\u0daf\u0dbd\u0dcf \u0daf\u0dd9\u0db1\u0dca\u0db1.\u0d91\u0dc4\u0dd9\u0db8 \u0d9c\u0dd9\u0daf\u0dbb \u0dc4\u0daf\u0dbd\u0dcf \u0db8\u0db8 \u0d91\u0dc4\u0dd2 \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2\u0dba\u0da7 \u0d9c\u0dd2\u0dba\u0dcf\u0da7 \u0db4\u0dc3\u0dca\u0dc3\u0dda \u0d87\u0dc0\u0dd2\u0dad\u0dca \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0d9c\u0dd9\u0daf\u0dbb \u0dba\u0db1\u0dca\u0db1\u00a0 \u0d9a\u0dd2\u0dba\u0dbd\u0dcf \u0d9a\u0dd2\u0dba\u0db1\u0dca\u0db1.\u0d9c\u0db8 \u0dc4\u0daf\u0db1\u0dca\u0db1. \u0db1\u0dd0\u0dad\u0dca\u0db1\u0db8\u0dca \u0db8\u0d9c\u0dda \u0d9c\u0dd9\u0daf\u0dbb \u0dc4\u0daf\u0db1\u0dca\u0db1. \u0d92 \u0daf\u0dd9\u0d9a\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0d9a\u0dca \u0d9a\u0dbb\u0db1\u0dca\u0db1 .\u0d91\u0dc4\u0dd9\u0db8 \u0db1\u0dd0\u0dad\u0dd2\u0dc0 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0d9c\u0dd9\u0daf\u0dbb \u0dba\u0db1\u0dca\u0db1 \u0d9a\u0dd2\u0dba\u0db1\u0dca\u0db1 \u0d91\u0db4\u0dcf\"\u0dba\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0daf \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ],
