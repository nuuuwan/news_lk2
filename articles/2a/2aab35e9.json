    "si": {
      "title": "\u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc3\u0dcf\u0db4\u0dca\u0db4\u0dd4 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0db4\u0dcf \u0db4\u0dd0\u0daf\u0dd2\u0dba\u0da7 \u0d89\u0da9\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dda \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db6\u0ddc\u0dc4\u0ddd \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db4\u0dcf \u0db4\u0dd0\u0daf\u0dd2 \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba\u0da7 \u0dc4\u0dd4\u0dbb\u0dd4\u0dc0 \u0d87\u0dad. \u0d9a\u0ddc\u0dc5\u0db9 \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0daf \u0db6\u0ddc\u0dc4\u0ddd \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db4\u0dcf \u0db4\u0dd0\u0daf\u0dd2\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0d9c\u0db8\u0db1\u0dca \u0db6\u0dd2\u0db8\u0db1\u0dca\u0dc0\u0dbd \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf\u0dd0\u0d9a\u0d9c\u0dad \u0dc4\u0dd0\u0d9a.",
        "\u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d9a\u0ddc\u0dc5\u0db9 \u0d87\u0dad\u0dd0\u0db8\u0dca \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca \u0d85\u0dc3\u0dbd \u0daf \u0db4\u0dcf \u0db4\u0dd0\u0daf\u0dd2 \u0db1\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0d87\u0dad\u0dd2 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dd4 \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dda.",
        "\u0d9a\u0ddc\u0dc5\u0db9, \u0d9a\u0ddc\u0db8\u0dca\u0db4\u0da4\u0dca\u0da4\u0dc0\u0dd3\u0daf\u0dd2\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u2018\u0d9a\u0dc5\u0db8\u0dca\u0db6\u0dd4 \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd9\u0db1\u0dca\u0da7\u0dbb\u0dca\u2019\u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0daf \u0db4\u0dcf \u0db4\u0dd0\u0daf\u0dd2 \u0db1\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db4\u0dd2\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0dc3\u0dc4 \u0d91\u0dc4\u0dd2 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0db4\u0dcf \u0db4\u0dd0\u0daf\u0dd2 \u0db1\u0dc0\u0dad\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dc0\u0dbd \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dda."
      ],
