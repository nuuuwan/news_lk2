        [
          {
            "text": "\u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2\u0dbd\u0dcf",
            "label": "GPE"
          },
          {
            "text": "\u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2\u0dbd\u0dcf",
            "label": "GPE"
          },
          {
            "text": "\u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0d82\u0dc0\u0dd2\u0db8",
            "label": "GPE"
          }
        ],
        [],
        [
          {
            "text": "\u0dbb\u0dab\u0dc0\u0d9a",
