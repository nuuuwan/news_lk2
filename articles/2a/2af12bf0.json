          },
          {
            "text": "$ 1,000 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0ba9\u0bcd",
            "label": "MONEY"
          },
          {
            "text": "\u0b85\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0bae\u0bbe\u0ba4\u0bae\u0bcd 25 \u0b86\u0bae\u0bcd \u0ba4\u0bc7\u0ba4\u0bbf",
            "label": "DATE"
          },
          {
            "text": "$ 250 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0ba9\u0bcd",
            "label": "MONEY"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
            "label": "GPE"
