    "si": {
      "title": "\u0db4\u0d9a\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc3\u0db8\u0d9c \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0daf\u0dd9\u0dc0\u0db1 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9f\u0dba \u0da2\u0dba \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd4\u0dab\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: 378/10 (\u0dc3\u0da7\u0db1: \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8\u0dcf\u0dbd\u0dca 80, \u0db1\u0dd2\u0dbb\u0ddd\u0dc2\u0db1\u0dca \u0daf\u0dd2\u0d9a\u0dca\u0dc0\u0dd0\u0dbd\u0dca\u0dbd 51, \u0d95\u0dc2\u0daf \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 50, \u0d87\u0db1\u0dca\u0da2\u0dbd\u0ddd \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dca\u0dc3\u0dca 42, \u0daf\u0dd2\u0db8\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 40, \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca 35, \u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 33. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0dc2\u0dcf\u0dc3\u0dd3\u0dbb\u0dca 3, \u0db1\u0dc3\u0dd3\u0db8\u0dca 3 / 83, \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db1\u0dc0\u0dcf\u0dc3\u0dca 2/80, \u0db1\u0dd9\u0dbd\u0db8\u0db1\u0dca \u0d85\u0dbd\u0dd2 1/64)",
        "\u0db4\u0d9a\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba: 231/10 (\u0dc3\u0da7\u0db1: \u0d85\u0d9c\u0dcf \u0dc3\u0dbd\u0dca\u0db8\u0dcf\u0db1\u0dca 62, \u0d89\u0db8\u0dcf\u0db8\u0dca \u0d8b\u0dbd\u0dca \u0dc4\u0d9a\u0dca 32, \u0dba\u0dc3\u0dd3\u0dbb\u0dca \u0dc2\u0dcf 26, \u0dc4\u0dc3\u0db1\u0dca \u0d85\u0dbd\u0dd3 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 21. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca 5/47, \u0db4\u0dca\u200d\u0dbb\u0db7\u0dcf\u0dad\u0dca \u0da2\u0dba\u0dc3\u0dd6\u0dbb\u0dd2\u0dba 3/80 \u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf 1/15, \u0d85\u0dc3\u0dd2\u0dad \u0dc6\u0dd9\u0dbb\u0dca\u0db1\u0dcf\u0db1\u0dca\u0da9\u0ddd 1/62)",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: 360/8 (\u0dc3\u0da7\u0db1: \u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf 109, \u0daf\u0dd2\u0db8\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 61, \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca \u0d92 45, \u0d87\u0db1\u0dca\u0da2\u0dbd\u0ddd \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dca\u0dc3\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 35. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0db1\u0dc3\u0dd3\u0db8\u0dca \u0dc2\u0dcf 2/44, \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db1\u0dc0\u0dcf\u0dc3\u0dca 2/75, \u0d85\u0d9a\u0dcf \u0dc3\u0dbd\u0dca\u0db8\u0db1\u0dca \u0d85\u0dbd\u0dd3 1/41, 1/54, \u0dba\u0dc3\u0dd3\u0dbb\u0dca \u0dc2\u0dcf 1/80)",
        "\u0db4\u0d9a\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba: 261/10 (\u0db6\u0dcf\u0db6\u0dd2\u0d82: \u0db6\u0dcf\u0db6\u0dbb\u0dca \u0d85\u0dc3\u0dcf\u0db8\u0dca 81, \u0d89\u0db8\u0dcf\u0db8\u0dca \u0d8b\u0dbd\u0dca \u0dc4\u0d9a\u0dca 49, \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0dbb\u0dd2\u0dc3\u0dca\u0dc0\u0dcf\u0db1\u0dca 37, \u0dba\u0dc3\u0dd3\u0dbb\u0dca \u0dc2\u0dcf \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 27. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0db4\u0dca\u200d\u0dbb\u0db7\u0dcf\u0dad\u0dca \u0da2\u0dba\u0dc3\u0dd6\u0dbb\u0dd2\u0dba 5/117, \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca 4/101)"
      ],
