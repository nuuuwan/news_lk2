            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dcf\u0dbb\u0d82\u0d9c\u0dd2 \u0db0\u0dd2\u0dbb\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
