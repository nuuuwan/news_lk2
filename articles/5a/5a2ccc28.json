          },
          {
            "text": "\u0d9a\u0dc5\u0dd4 \u0d9c\u0d9f",
            "label": "GPE"
          },
          {
            "text": "\u0db4\u0dd0\u0dbd\u0dca\u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd2\u0dc0\u0dd2\u0dad\u0dd2\u0d9c\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0dbb\u0dad\u0dca\u0db1\u0db4\u0dd4\u0dbb\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0dd4\u0dbb\u0dd4\u0dc0\u0dd2\u0da7",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0dba\u0d9c\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0dbd\u0db4\u0dcf\u0dad",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0dd3 \u0dc3\u0dd4\u0d9c\u0dd3\u0dc2\u0dca\u0dc0\u0dbb",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0d86\u0db4\u0daf\u0dcf \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
