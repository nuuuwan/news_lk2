        [
          {
            "text": "\u0db6\u0dde\u0daf\u0dca\u0db0 \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc4\u0dd2\u0db1\u0dca\u0daf\u0dd4 \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca",
            "label": "NORP"
          },
          {
            "text": "\u0d9a\u0dd2\u0dad\u0dd4\u0db1\u0dd4\u0dc0\u0db1\u0dca",
            "label": "NORP"
          },
          {
            "text": "\u0db8\u0dc4\u0da2\u0db1 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0da2\u0db1 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db4\u0dca\u0dbb\u0db0\u0dcf\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0db8\u0dca\u0db6\u0ddd\u0db0\u0dd2 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0db6\u0dbd\u0d9a\u0ddc\u0da7\u0dd4\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d89\u0dad\u0dca\u0dad\u0daf\u0dd9\u0db8\u0dbd\u0dd2\u0dba\u0dda \u0d89\u0db1\u0dca\u0daf\u0dc3\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dd2\u0db1\u0dca\u0daf\u0dd4",
            "label": "NORP"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0d9a\u0dd4\u0dbb\u0dd4\u0d9a\u0dca\u0d9a\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0db8\u0dca\u0db6\u0dbd\u0db4\u0dd2\u0da7\u0dd2\u0dba, \u0d89\u0dc3\u0dca\u0dbd\u0dcf\u0db8\u0dd3\u0dba \u0dc3\u0dda\u0dc0\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dda\u0dc1\u0db6\u0db1\u0dca\u0daf\u0dd4 \u0d85\u0dbd\u0dca \u0dc4\u0da2\u0dca \u0dc6\u0dba\u0dd2\u0dc3\u0dcf\u0dbd\u0dca \u0dc4\u0dc3\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dc0\u0da7\u0d9c\u0dc4 \u0da2\u0dd4\u0db8\u0dca\u0db8\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0d87\u0db1\u0dca\u0da7\u0db1\u0dca \u0dbb\u0ddd\u0dc4\u0dd2\u0dad",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db4\u0dd2\u0dbd\u0dd2\u0db4\u0dca \u0db8\u0dbb\u0dd2\u0dba\u0dcf",
            "label": "FAC"
          },
          {
            "text": "\u0db4\u0dd2\u0da7\u0d9a\u0ddc\u0da7\u0dd4\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0db8\u0dc4\u0da2\u0db1 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dda \u0d86\u0dba\u0dad\u0db1\u0dd2\u0d9a \u0dc3\u0dc4 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d89\u0dbb\u0ddd\u0dc2\u0dd2\u0db1\u0dd3 \u0dc0\u0dd2\u0da2\u0dda\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0dba\u0dd2\u0da9\u0dd2\u0dba\u0dbd\u0dca \u0dc3\u0db8\u0dd6\u0dc4\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0 \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [],
        []
      ]
    },
    "ta": {
      "title": "\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0b99\u0bcd\u0b95\u0bbf \u0ba4\u0ba9\u0ba4\u0bc1 61\u0bb5\u0ba4\u0bc1 \u0b86\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8\u0bbf\u0bb1\u0bc8\u0bb5\u0bc8\u0b95\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbe\u0b9f\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1",
      "author": "\u0ba4\u0bbf\u0bb2\u0bbf\u0ba9 \u0bb5\u0bb2\u0bcd\u0baa\u0bca\u0bb2",
      "body_lines": [
        "\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0b99\u0bcd\u0b95\u0bbf, \u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 02 \u0b87\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 \u0bb5\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba4\u0bae\u0ba4\u0bc1 61\u0bb5\u0ba4\u0bc1 \u0b86\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8\u0bbf\u0bb1\u0bc8\u0bb5\u0bc8 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0b9c\u0bc2\u0bb2\u0bc8 1\u0b86\u0bae\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf \u0bb5\u0bb0\u0bc8 \u0b9a\u0bbe\u0ba4\u0bbe\u0bb0\u0ba3\u0bae\u0bbe\u0ba9 \u0bb5\u0bbf\u0bb4\u0bbe\u0bb5\u0bc8 \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0ba4\u0bc1. \u0b87\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bbf\u0bb2\u0bcd \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0b9a\u0bc1\u0b9c\u0bc0\u0bb5 \u0bb0\u0bbe\u0b9c\u0baa\u0b95\u0bcd\u0bb7 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bae \u0ba8\u0bbf\u0bb1\u0bc8\u0bb5\u0bc7\u0bb1\u0bcd\u0bb1\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf/\u0baa\u0bca\u0ba4\u0bc1 \u0bae\u0bc1\u0b95\u0bbe\u0bae\u0bc8\u0baf\u0bbe\u0bb3\u0bb0\u0bcd \u0bb0\u0b9e\u0bcd\u0b9a\u0bbf\u0ba4\u0bcd \u0b95\u0bca\u0b9f\u0bbf\u0ba4\u0bc1\u0bb5\u0bbe\u0b95\u0bcd\u0b95\u0bc1 \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bcd \u0b89\u0bb0\u0bc8\u0baf\u0bbe\u0bb1\u0bcd\u0bb1\u0bbf\u0ba9\u0bb0\u0bcd.",
        "\u0bae\u0bc7\u0bb2\u0bc1\u0bae\u0bcd, \u0baa\u0bcc\u0ba4\u0bcd\u0ba4 \u0b9a\u0b99\u0bcd\u0b95\u0bae\u0bcd, \u0b87\u0ba8\u0bcd\u0ba4\u0bc1 \u0b9a\u0b99\u0bcd\u0b95\u0bae\u0bcd, \u0bae\u0bc1\u0bb8\u0bcd\u0bb2\u0bbf\u0bae\u0bcd \u0bae\u0b9c\u0bcd\u0bb2\u0bbf\u0bb8\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bbf\u0bb1\u0bbf\u0bb8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b95\u0bbf\u0bb2\u0bcd\u0b9f\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0ba9 \u0b87\u0ba3\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba8\u0bbe\u0b9f\u0bc1, \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd, \u0bb5\u0bbe\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0baf\u0bbe\u0bb3\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bc8 \u0bb8\u0bcd\u0ba4\u0bbe\u0baa\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0ba4\u0bcd\u0ba4 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bcb\u0b9f\u0bbf\u0ba4\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b86\u0b9a\u0bbf\u0bb0\u0bcd\u0bb5\u0bbe\u0ba4\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bb5\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0bae\u0baf \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0b95\u0bb3\u0bcd \u0b8f\u0bb1\u0bcd\u0baa\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba9.",
        "\u0b85\u0ba4\u0ba9\u0bcd\u0baa\u0b9f\u0bbf, \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0b95\u0bcd \u0b95\u0bbe\u0bb0\u0bbf\u0baf\u0bbe\u0bb2\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0ba4\u0bcd \u0b93\u0ba4\u0bc1\u0ba4\u0bb2\u0bcd \u0b87\u0b9f\u0bae\u0bcd\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0b85\u0ba4\u0ba9\u0bc8\u0ba4\u0bcd \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1 \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0b9a\u0bae\u0bcd\u0baa\u0bcb\u0ba4\u0bbf \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba9\u0bcd\u0ba9\u0ba4\u0bbe\u0ba9\u0bae\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bae \u0b85\u0ba4\u0bbf\u0ba4\u0bbf\u0baf\u0bbe\u0b95 \u0b85\u0ba4\u0bbf\u0baa\u0bb0\u0bbf\u0ba9\u0bcd \u0b85\u0ba9\u0bc1\u0b9a\u0bb0\u0ba3\u0bc8\u0baf\u0bc1\u0b9f\u0ba9\u0bcd \u0b87\u0b9f\u0bae\u0bcd\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1. \u0baa\u0bc7\u0bb0\u0bbe\u0b9a\u0bbf\u0bb0\u0bbf\u0baf\u0bb0\u0bcd \u0b87\u0ba4\u0bcd\u0ba4\u0ba4\u0bc6\u0bae\u0bbe\u0bb2\u0bbf\u0baf\u0bc7 \u0b87\u0ba8\u0bcd\u0ba4\u0b9a\u0bb0 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd. \u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0ba4\u0bb5\u0ba4\u0b95\u0bb9\u0bbe \u0b9c\u0bc1\u0bae\u0bcd\u0bae\u0bbe \u0baa\u0bb3\u0bcd\u0bb3\u0bbf\u0bb5\u0bbe\u0b9a\u0bb2\u0bbf\u0bb2\u0bcd \u0ba4\u0bc7\u0b9a\u0baa\u0ba8\u0bcd\u0ba4\u0bc1 \u0b85\u0bb2\u0bcd \u0bb9\u0bbe\u0b9c\u0bcd \u0baa\u0bc8\u0b9a\u0bb2\u0bcd \u0bb9\u0b9a\u0ba9\u0bcd \u0bae\u0bcc\u0bb2\u0bb5\u0bbf \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbe\u0bb2\u0bcd \u0ba8\u0b9f\u0bbe\u0ba4\u0bcd\u0ba4\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b87\u0bb8\u0bcd\u0bb2\u0bbe\u0bae\u0bbf\u0baf \u0b9a\u0bc7\u0bb5\u0bc8 \u0baa\u0bae\u0bcd\u0baa\u0bb2\u0baa\u0bcd\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0bb8\u0bcd\u0bb0\u0bc0 \u0ba8\u0bbf\u0bb5\u0bbe\u0b9a \u0b95\u0bc1\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bbe\u0bb2\u0bcd \u0b87\u0ba8\u0bcd\u0ba4\u0bc1 \u0baa\u0bc2\u0b9c\u0bc8\u0baf\u0bc1\u0bae\u0bcd, \u0baa\u0bc0\u0baa\u0bcd\u0baa\u0bbf\u0bb3\u0bcd\u0bb8\u0bcd \u0baa\u0bc7\u0b99\u0bcd\u0b95\u0bcd \u0baa\u0bc1\u0ba9\u0bbf\u0ba4 \u0baa\u0bbf\u0bb2\u0bbf\u0baa\u0bcd \u0bae\u0bc7\u0bb0\u0bbf\u0bb8\u0bcd \u0ba4\u0bc7\u0bb5\u0bbe\u0bb2\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b86\u0ba9\u0bcd\u0b9f\u0ba9\u0bcd \u0bb0\u0bcb\u0bb9\u0bbf\u0ba4\u0bbe \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbe\u0bb2\u0bcd \u0baa\u0bc1\u0ba9\u0bbf\u0ba4 \u0bb5\u0bb4\u0bbf\u0baa\u0bbe\u0b9f\u0bc1\u0bae\u0bcd \u0b87\u0b9f\u0bae\u0bcd\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1. \u0b87\u0ba8\u0bcd\u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b95\u0bbe\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bb0\u0bc7\u0b9f\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb0\u0bcd\u0bb5\u0bbe\u0b95 \u0ba8\u0bbf\u0bb0\u0bcd\u0bb5\u0bbe\u0b95\u0bae\u0bcd, \u0bb5\u0b99\u0bcd\u0b95\u0bbf \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b93\u0baf\u0bcd\u0bb5\u0bc1 \u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0baa\u0ba3\u0bbf\u0baf\u0bbe\u0bb3\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1 \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0ba9\u0bb0\u0bcd.",
        "\u0b90\u0b9f\u0bbf\u0baf\u0bb2\u0bcd \u0b95\u0bc1\u0bb4\u0bc1\u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0b87\u0bb0\u0bcb\u0bb7\u0bbf\u0ba9\u0bbf \u0bb5\u0bbf\u0b9c\u0bc7\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95 \u0b89\u0bb2\u0b95 \u0bae\u0b95\u0bb3\u0bbf\u0bb0\u0bcd \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5 \u0b95\u0bbe\u0b99\u0bcd\u0b95\u0bbf\u0bb0\u0bb8\u0bbf\u0bb2\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bc8 \u0baa\u0bbf\u0bb0\u0ba4\u0bbf\u0ba8\u0bbf\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bbf\u0bb1\u0bbe\u0bb0\u0bcd",
        "\u0b92\u0bb0\u0bc1 \u0baa\u0ba4\u0bbf\u0bb2\u0bc8 \u0bb5\u0bbf\u0b9f\u0bc1\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0ba4\u0bbf\u0bb2\u0bc8 \u0bb0\u0ba4\u0bcd\u0ba4\u0bc1\u0b9a\u0bc6\u0baf\u0bcd \u0b89\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bbf\u0ba9\u0bcd\u0ba9\u0b9e\u0bcd\u0b9a\u0bb2\u0bcd \u0bae\u0bc1\u0b95\u0bb5\u0bb0\u0bbf \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bbf\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bbe\u0ba4\u0bc1. \u0ba4\u0bc7\u0bb5\u0bc8\u0baf\u0bbe\u0ba9 \u0baa\u0bc1\u0bb2\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9 *\u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0bc6\u0baf\u0bb0\u0bcd *",
        "\u0b85\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0bae\u0bc1\u0bb1\u0bc8 \u0ba8\u0bbe\u0ba9\u0bcd \u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95, \u0b8e\u0ba9\u0ba4\u0bc1 \u0baa\u0bc6\u0baf\u0bb0\u0bcd, \u0bae\u0bbf\u0ba9\u0bcd\u0ba9\u0b9e\u0bcd\u0b9a\u0bb2\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b87\u0ba3\u0bc8\u0baf\u0ba4\u0bb3\u0ba4\u0bcd\u0ba4\u0bc8 \u0b87\u0ba8\u0bcd\u0ba4 \u0b89\u0bb2\u0bbe\u0bb5\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0bc7\u0bae\u0bbf\u0b95\u0bcd\u0b95\u0bb5\u0bc1\u0bae\u0bcd."
