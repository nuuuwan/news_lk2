          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dbb\u0dda\u0d9c\u0dd4 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db4\u0dcf\u0dbd\u0db1 \u0d85\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
