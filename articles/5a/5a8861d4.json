  "original_title": "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2",
  "text_idx": {
    "en": {
      "title": "Electricity tariff will go up in August",
      "author": "unknown",
      "body_lines": [
        "Public Utility Commission Chairman Mr. Janaka Rathnayake said that the electricity tariff will be increased from the beginning of next August and the existing electricity tariff is likely to increase by 69%.",
        "Mr. Ratnayake further said that although the Electricity Board demanded a 130 percent tariff hike, the tariff hike will be implemented by providing relief to the lowest electricity consumers."
      ],
      "title_ents": [
        {
          "text": "August",
          "label": "DATE"
        }
      ],
