    "si": {
      "title": "\u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a\u0da7 \u0dc4\u0dcf \u0dc1\u0dcf\u0db1\u0dd4\u0d9a\u0da7 \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba\u0dda \u0d89\u0dc4\u0dc5 \u0db4\u0dd4\u0da7\u0dd4",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0dca\u200d\u0dba\u0dd9\u0dc2\u0dca\u0da8 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dc0\u0dda\u0daf\u0dd3 \u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca \u0dad\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda. \u0d91\u0dc3\u0dda\u0db8 \u0dc1\u0dcf\u0db1\u0dd4\u0d9a \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
