    "si": {
      "title": "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca 33,600\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0d9a\u0dca",
      "author": "",
      "body_lines": [
        "\u0db8\u0dd3\u0dbb\u0dd2\u0d9a\u0db8 \u0dad\u0d82\u0d9c\u0ddd\u0dc0\u0dd2\u0da7 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0dc4\u0dc5\u0dd4\u0d9a\u0db8 \u0d9a\u0db1\u0dca\u0daf\u0dda\u0daf\u0dd3 \u0d85\u0daf (23) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0d9a\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd4\u0dad\u0dd4\u0dbb\u0dcf\u0da2\u0dc0\u0dd9\u0dbd \u0dc3\u0dd2\u0da7 \u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dcf\u0db1 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1\u0dba \u0d9a\u0dc5 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca 33,600\u0d9a\u0dca \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0dda \u0dad\u0dd2\u0db6\u0dd3 \u0d87\u0dad.",
        "\u0dc4\u0dc5\u0dd4\u0d9a\u0db8 \u0d9a\u0db1\u0dca\u0daf \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba \u0dc4\u0daf\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0db4\u0dc3\u0dd4\u0db4\u0dc3\u0da7 \u0dba\u0dcf\u0db8\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d85\u0db1\u0dad\u0dd4\u0dbb \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1\u0dc0\u0dbd\u0daf\u0dd3 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda."
      ],
