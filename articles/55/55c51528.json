      "title": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 10\u0d9a\u0da7 \u0d9a\u0dbd\u0dca \u0dad\u0db6\u0dba\u0dd2",
      "author": "unknown",
