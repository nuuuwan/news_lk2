    "si": {
      "title": "\u0da0\u0dd3\u0db1\u0dba\u0da7 \u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0d9a\u0dca:13\u0d9a\u0dca \u0db8\u0dbb\u0dd4\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0da0\u0dd3\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da0\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6 \u0db7\u0dd6 \u0da0\u0dbd\u0db1\u0dba\u0d9a\u0dd2\u0db1\u0dca 13 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0da0\u0dd3\u0db1 \u0dc0\u0dda\u0dbd\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0daf (05) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 1 \u0da7 \u0db4\u0db8\u0dab \u0db8\u0dd9\u0db8 \u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dc4\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd\u0dad\u0dca\u0dc0\u0dba\u00a0 \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dba\u0dda 6.8 \u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc3\u0da7\u0dc4\u0db1\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0da0\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0dbb\u0dd0\u0dc4\u0dd0\u0db1\u0dca \u0d9a\u0da9\u0dcf \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d9a\u0db3\u0dd4 \u0db1\u0dcf\u0dba\u0dba\u0dd1\u0db8\u0dca \u0daf \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba.",
        "2017 \u0dc0\u0dc3\u0dbb\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0dc3\u0dd2\u0da0\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0da7 \u0db6\u0dbd\u0db4\u0dd1 \u0daf\u0dbb\u0dd4\u0dab\u0dd4\u0dad\u0db8 \u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0db8\u0dd9\u0dba \u0db6\u0dc0 \u0da0\u0dd3\u0db1 \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dc4\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dc4.",
        "\u0db1\u0dcf\u0dba\u0dba\u0dd1\u0db8\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc0\u0dbd\u0da7 \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dd2 \u0db4\u0dc3\u0dca \u0d89\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0daf\u0dd0\u0db1\u0da7\u0db8\u0dad\u0dca \u0dc3\u0dc4\u0db1 \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dba\u0ddc\u0daf\u0dc0\u0dcf \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0da0\u0dd3\u0db1 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0da0\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dda \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc0\u0dbd\u0da7\u0daf \u0dc4\u0dcf\u0db1\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0da0\u0dd3\u0db1 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba."
      ],
