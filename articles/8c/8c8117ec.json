        [
          {
            "text": "\u0d94\u0d9a\u0dca\u0dc3\u0dd2\u0da7\u0ddc\u0dc3\u0dd2\u0db1\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd2\u0dc3\u0ddc\u0db4\u0dca\u0dbb\u0ddc\u0dc3\u0dca\u0da7\u0ddd\u0dbd\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd0\u0d9c\u0dca\u0db1\u0dd3\u0dc3\u0dd2\u0dba\u0db8\u0dca \u0dc3\u0dbd\u0dca\u0dc6\u0dda\u0da7\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd2\u0dc6\u0dd2\u0dbd\u0dd2\u0dc3\u0dca",
            "label": "NORP"
