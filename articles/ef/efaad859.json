    "si": {
      "title": "\u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5\u0dda\u0daf\u0dd3 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca 6 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dad\u0dd3\u0dbb\u0dd4\u0db6\u0daf\u0dd4 \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dcf \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0dc3\u0dc4 \u0dbb\u0db1\u0dca \u0d86\u0db7\u0dbb\u0dab \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0d9c\u0dd9\u0db1 \u0d92\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca\u0d9a\u0dc5 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
        "\u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db8\u0dd3\u0d9c\u0db8\u0dd4\u0dc0, \u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba \u0dc3\u0dc4 \u0d85\u0d9c\u0dd4\u0dbb\u0dd4\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dc0\u0dca \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0dba\u0dd2."
      ],
