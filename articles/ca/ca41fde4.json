  "original_title": "\u0bb5\u0bbf\u0bb5\u0b9a\u0bbe\u0baf \u0ba4\u0bbf\u0ba3\u0bc8\u0b95\u0bcd\u0b95\u0bb3 \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0bae\u0bc1\u0bb1\u0bc8\u0b95\u0bb3\u0bcd \u0b87\u0bb0\u0ba4\u0bcd\u0ba4\u0bc1 ",
  "text_idx": {
    "en": {
      "title": "Holidays of employees of the Department of Agriculture canceled",
      "body_lines": [
        "Holidays of all employees belonging to companies under the Ministry of Agriculture have been canceled from July 6 to facilitate efficient distribution of urea fertilizer.",
        "Arrangements have been made to transport 65,000 metric tons of urea to the country from July 7 to 15 and finally hand it over to the farmers.",
        "Therefore, the holidays of the employees of the Ministry of Agriculture, Department of Agrarian Services, National Fertilizer Secretariat, Ceylon Fertilizer Company and Commercial Fertilizer Company will be canceled during this period."
      ],
      "title_ents": [
        {
          "text": "the Department of Agriculture",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
