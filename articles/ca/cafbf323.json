          {
            "text": "\u0da2\u0dd3.\u0d91\u0dbd\u0dca. \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd4\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0d9c\u0db4\u0dd9\u0dbb\u0dd4\u0db8",
            "label": "PERSON"
          },
          {
