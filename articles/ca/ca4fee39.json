    "si": {
      "title": "ACME \u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb\u0dab \u0dc3\u0dc4 \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca JF \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d85\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "ACME \u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb\u0dab \u0dc3\u0dc4 \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d91\u0dc4\u0dd2 \u0d85\u0db1\u0dd4\u0db6\u0daf\u0dca\u0db0\u0dd2\u0dad J F Packaging Ltd. \u0dc4\u0dd2 LCPLC \u0dc4\u0dd2 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca 51% \u0dc4\u0ddd \u0d8a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dcf\u0dbd\u0db1 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0d85\u0dad\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0db8\u0dc0\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0db1 Lankem Ceylon PLC (LCPLC) \u0dc4\u0dd2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc3\u0db8\u0d9f \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0dbd\u0da7 \u0d91\u0dc5\u0db9 \u0d87\u0dad. JFP).",
        "ACME \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db8\u0dd9\u0db8 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0 \u0db6\u0ddc\u0dc4\u0ddd \u0daf\u0dd4\u0dbb\u0da7 \u0d86\u0dbb\u0db8\u0dca\u0db7\u0d9a \u0d85\u0dc0\u0db0\u0dd2\u0dba\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2 \u0d9a\u0ddc\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2 \u0d87\u0dad\u0dd4\u0dc5\u0dd4\u0dc0 \u0d85\u0dad\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dda\u0daf \u0db1\u0dd0\u0daf\u0dca\u0daf \u0dba\u0db1\u0dca\u0db1 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0dd2\u0dc3\u0dd2\u0daf\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dad\u0dd3\u0dbb\u0dab \u0d9c\u0dd9\u0db1 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2. \u0dad\u0dc0\u0daf, J F Packaging Ltd. \u0dc4\u0dd2 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dad\u0d9a\u0dca\u0dc3\u0dda\u0dbb\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dc0\u0dba\u0db8 \u0d91\u0d9a\u0d9f \u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0d9c\u0db1\u0dd4\u0daf\u0dd9\u0db1\u0dd4\u0dc0 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0d9c\u0dd9\u0db1 \u0dba\u0dcf\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1 \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba\u0db1\u0dca (\u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0daf\u0dd2) \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0db8\u0dad\u0daf \u0dc0\u0dd2\u0db7\u0dc0 \u0d9c\u0db1\u0dd4\u0daf\u0dd9\u0db1\u0dd4\u0dc0 \u0dbb\u0db3\u0dcf \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d91\u0dc4\u0dd2 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0dda. \u0d91\u0d9a\u0dca \u0d91\u0d9a\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd \u0d91\u0dc3\u0dda \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc1\u0d9a\u0dca\u200d\u0dba \u0db6\u0dc0 \u0dc3\u0dbd\u0d9a\u0db1\u0dca\u0db1\u0dda \u0db1\u0db8\u0dca.",
        "ACME \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda, \u0db8\u0dd9\u0db8 \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0 \u0daf\u0dd0\u0db1\u0da7 \u0d91\u0dc4\u0dd2 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0d85\u0daf\u0dd2\u0dba\u0dbb\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db1\u0db8\u0dd4\u0dad\u0dca, \u0d9a\u0ddc\u0dc5\u0db9 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0ddc\u0dbd\u0dda \u0dbd\u0dd0\u0dba\u0dd2\u0dc3\u0dca\u0dad\u0dd4\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db1\u0dd3\u0dad\u0dd2\u0dbb\u0dd3\u0dad\u0dd2\u0dc0\u0dbd\u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0da7 \u0d91\u0dc4\u0dd2 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db4\u0dd6\u0dbb\u0dca\u0dab \u0dc4\u0dd9\u0dc5\u0dd2\u0daf\u0dbb\u0dc0\u0dca\u0dc0\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0dc0\u0d9c\u0d9a\u0dd3\u0db8\u0dca\u0dc0\u0dbd\u0da7 \u0d85\u0db1\u0dd4\u0d9a\u0dd6\u0dbd\u0dc0 \u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0ddc\u0dc5\u0da7 \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1 \u0db6\u0dc0\u0dba\u0dd2. \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0da2\u0dd4\u0db1\u0dd2 23 \u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dd2\u0db1 \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d85\u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db8\u0dc4\u0dcf \u0dc3\u0db7\u0dcf \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0db1\u0dd4\u0db8\u0dad \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc3\u0dc4 \u0daf\u0dd0\u0db1\u0da7 \u0dc0\u0dc3\u0dcf \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dd4\u0dc0 (\u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 556) \u0dc3\u0dbd\u0d9a\u0dcf \u0db6\u0dbd\u0db1 \u0dc0\u0dd2\u0da7.",
        "\u0dbd\u0d82\u0d9a\u0dd9\u0db8\u0dca \u0dc3\u0db8\u0dd6\u0dc4\u0dba\u0da7 ACME \u0dc4\u0dd2 88.27% \u0d9a \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0dda. JF \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0d82\u0d9a\u0dd9\u0db8\u0dca \u0dc4\u0dd2 \u0d86\u0dba\u0ddd\u0da2\u0db1 \u0db4\u0dd2\u0dbb\u0dd2\u0dc0\u0dd0\u0dba \u0dbb\u0dd4. \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.12 \u0d9a\u0dd2.",
        "\u0db8\u0dcf\u0dbb\u0dca\u0dad\u0dd4 31 \u0daf\u0dd2\u0db1\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd6 \u0dc0\u0dbb\u0dca\u0dc2\u0dba \u0dc3\u0db3\u0dc4\u0dcf ACME \u0dc3\u0db8\u0dd6\u0dc4\u0dba\u0dda \u0d86\u0daf\u0dcf\u0dba\u0db8 \u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 948, \u0db4\u0dd9\u0dbb \u0dc0\u0dc3\u0dbb\u0da7 \u0dc0\u0da9\u0dcf 33% \u0d9a\u0dd2\u0db1\u0dca \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba. \u0d91\u0dba \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 161 \u0d9a \u0dbd\u0dcf\u0db7\u0dba\u0d9a\u0da7 \u0dc3\u0dcf\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dc0 \u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 34 \u0d9a\u0dd2. \u0db6\u0daf\u0dd4 \u0d9c\u0dd9\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db4\u0dcf\u0da9\u0dd4\u0dc0 \u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 309 \u0dc3\u0dd2\u0da7 \u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 119 \u0d9a\u0dd2. \u0db8\u0dcf\u0dbb\u0dca\u0dad\u0dd4 31 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc3\u0db8\u0dd4\u0da0\u0dca\u0da0\u0dd2\u0dad \u0db4\u0dcf\u0da9\u0dd4 \u0dbb\u0dd4. \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 701 \u0d9a\u0dca \u0dc3\u0dc4 \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0db8\u0da7\u0dca\u0da7\u0db8\u0dd2\u0db1\u0dca \u0dbb\u0dd4. \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0db8\u0da7\u0dca\u0da7\u0db8\u0dd2\u0db1\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.",
        "\u0daf\u0dd9\u0dc3\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 ACME \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca 3 \u0dc3\u0db3\u0dc4\u0dcf 1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dd4\u0dc0\u0d9a\u0dca \u0dbb\u0dd4. 4.50 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dbb\u0dd4. \u0d9a\u0dcf\u0dbb\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dcf\u0d9c\u0dca\u0db0\u0db1\u0dba \u0dc3\u0db4\u0dd4\u0dbb\u0dcf\u0dbd\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 555.68 \u0d9a\u0dd2. \u0d8a\u0dba\u0dda ACME \u0dc4\u0dd2 \u0d9a\u0ddc\u0da7\u0dc3\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 6.30, \u0dc1\u0dad 10 \u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd2\u0dba."
      ],
