    "si": {
      "title": "\u0da0\u0dd3\u0db1 \u0db8\u0dd2\u0dad\u0dd4\u0dbb\u0dcf \u0db4\u0dd2\u0da7\u0dc0 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0dc0\u0dbb\u0dcf\u0dba\u0dda \u0db1\u0dd0\u0d82\u0d9c\u0dd4\u0dbb\u0db8\u0dca \u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0dba\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0dc0\u0dd0\u0db1\u0dca\u0d9c\u0dca 5 \u0da0\u0dd3\u0db1 \u0d9c\u0dc0\u0dda\u0dc1\u0db1 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 (22) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 \u0dc0\u0dda \u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dc0\u0dbb\u0dcf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad\u0dca\u0dc0 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dc0\u0dbb\u0dcf\u0dba\u0da7\u00a0\u0d89\u0d9a\u0dd4\u0dad\u0dca 16 \u0daf\u0dd2\u0db1\u00a0 \u0db4\u0dd0\u0db8\u0dd3\u0dab \u0db8\u0dd9\u0db8 \u0d9c\u0dc0\u0dda\u0dc2\u0dab \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0d9a\u0dc0\u0dbb \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dc5\u0dda\u0daf \u0dba\u0db1\u0dca\u0db1 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dc0\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0dc0\u0dd3 \u0db1\u0dd0\u0dad.",
        "\u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0dc0\u0dbb\u0dcf\u0dba\u0dd9\u0db1\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0db4\u0dd2\u0da7\u0dad\u0dca\u0dc0 \u0dba\u0db1 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dd9\u0dad \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db4\u0dc0\u0dcf \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0dc0\u0dbb\u0dcf\u0dba \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db8\u0da7 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1 \u0db7\u0dcf\u0dbb \u0db1\u0dd2\u0dc5\u0db0\u0dcf\u0dbb\u0dd3\u0dab\u0dd2\u0dba\u0d9c\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0db8\u0dc3\u0dcf \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0daf\u0dd3 \u0d92 \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0dc3\u0dbb \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dd4\u0dba\u0dad\u0dd4 \u0d9a\u0dc5\u0dd9\u0daf \u0db1\u0dd0\u0dad."
      ],
