    "si": {
      "title": "\u0dc3\u0dd4\u0dc3\u0dcf\u0db1 \u0db7\u0dd6\u0db8\u0dd2\u0dba\u0dda \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dbb \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0\u0da7 \u0d85\u0dba\u0dad\u0dca \u0dc0\u0db1\u0dbb\u0dcf\u0da2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba - \u0daf\u0dbb\u0dc0\u0dbd \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dc5\u0dc0\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0daf\u0dda\u0dc4\u0dba\u0db1\u0dca \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0dc3\u0ddc\u0dc4\u0ddc\u0db1\u0dca \u0db6\u0dd2\u0db8 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0d92\u0d9a\u0db8\u0dad\u0dd2\u0d9a\u0dc0 \u0dc3\u0db8\u0dca\u0db8\u0dad \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0\u0dda \u0db8\u0dcf\u0dc3\u0dd2\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8 \u0d8a\u0dba\u0dda (18) \u0dc3\u0db7\u0dcf\u0dc0\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dbb\u0dc0\u0dd3 \u0d9a\u0dd4\u0da9\u0dca\u0da9\u0dc0\u0dda\u0dbd\u0dd4 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0da9\u0dd2\u0db1\u0dca\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dab\u0dca\u0da9\u0db4\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0dc0\u0db1\u0dbb\u0dcf\u0da2\u0dcf \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0da7 \u0d85\u0dba\u0dad\u0dca \u0daf\u0dbb\u0dc0\u0dbd \u0d9a\u0ddc\u0dbd\u0db1\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dbb\u0db1 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0dd4\u0dc3\u0dcf\u0db1 \u0db7\u0dd6\u0db8\u0dd2\u0dba\u0dda \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d85\u0dba\u0d9c\u0dda \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb\u0dd4 \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0da7\u0db1\u0dca - \u0dad\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0 \u0d85\u0dc0\u0dc3\u0dbb \u0db1\u0ddc\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0dbb\u0dca\u0dc0\u0dd2\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d91\u0db8\u0dca.\u0dbb\u0dcf\u0db8\u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5\u0dda\u0dba. \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dc5\u0dc0\u0dd4\u0db1\u0dca.",
        "\u0dc4\u0dd0\u0da7\u0db1\u0dca - \u0daf\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf \u0db6\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0da7 \u0d85\u0dba\u0dad\u0dca \u0daf\u0dbb\u0dc0\u0dbd \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0dd4\u0dc3\u0dcf\u0db1 \u0db7\u0dd6\u0db8\u0dd2\u0dba\u0dda \u0d8a\u0dba\u0dda (17) \u0dc3\u0dc0\u0dc3 \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d9a\u0dad\u0dd2\u0dbb\u0dca\u0dc0\u0dda\u0dbd\u0dca\u0d9c\u0dda \u0daf\u0dda\u0dc4\u0dba \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0da7\u0db1\u0dca - \u0daf\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0daf\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0dcf\u0da7 \u0d85\u0dc0\u0dc3\u0dbb \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd3\u0db8 \u0d9a\u0dab\u0d9c\u0dcf\u0da7\u0dd4\u0dc0\u0da7 \u0d9a\u0dbb\u0dd4\u0dab\u0d9a\u0dca. \u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0d85\u0db8\u0dcf\u0db1\u0dd4\u0dc2\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0db4\u0dad\u0da7 \u0db4\u0dad\u0dca \u0d85\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0dad\u0dca\u0d9c\u0dda \u0db4\u0dc0\u0dd4\u0dbd\u0da7 \u0db1\u0ddc\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0dc3\u0dd2 \u0db4\u0dd2\u0dc5\u0dd2\u0dba\u0db8\u0d9a\u0dca \u0dc3\u0dbd\u0dc3\u0dcf \u0daf\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4\u0dba.",
        "\u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d85\u0dba\u0d9c\u0dda \u0daf\u0dda\u0dc4\u0dba \u0d85\u0daf (18) \u0dc3\u0dc0\u0dc3 03 \u0da7 \u0d86\u0daf\u0dcf\u0dc4\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dd6\u0daf\u0dcf\u0db1\u0db8\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3 \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 11.30 \u0db4\u0db8\u0dab \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0db8\u0dda \u0dc0\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0dc4\u0dd0\u0da7\u0db1\u0dca - \u0dad\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0 \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0dc0\u0dc5\u0d9a\u0dca \u0d9a\u0dd0\u0db4\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd2\u0db4\u0dad\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd6\u0dc0\u0db1\u0dca \u0db8\u0dcf \u0dc3\u0db8\u0d9c \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dcf. \u0dc3\u0ddc\u0dc4\u0ddc\u0db1\u0dca \u0db6\u0dd2\u0db8 \u0dc3\u0dc4 \u0d89\u0dad\u0dd2\u0dbb\u0dd2\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db4\u0dd0\u0dba \u0dad\u0dd4\u0db1\u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0dca \u0db4\u0db8\u0dab\u0dd2.",
        "\u0dc3\u0dd4\u0dc3\u0dcf\u0db1 \u0db7\u0dd6\u0db8\u0dd2\u0dba \u0db4\u0dca\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0\u0da7 \u0dc4\u0ddd \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0da7 \u0db4\u0dd0\u0dc0\u0dbb\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0d85\u0dba\u0dd2\u0dad\u0dd2 \u0d9a\u0dbb \u0d9c\u0dad \u0db1\u0ddc\u0dc4\u0dd0\u0d9a. \u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0dd4\u0da7\u0db1\u0dca-\u0da7\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0dda \u0db8\u0dd9\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0 \u0daf\u0dd0\u0da9\u0dd2 \u0db4\u0dd2\u0dc5\u0dd2\u0d9a\u0dd4\u0dbd\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dd4\u0dc0 \u0dc4\u0dd9\u0dc5\u0dcf \u0daf\u0d9a\u0dd2\u0db1 \u0d85\u0dad\u0dbb \u0dc0\u0dd2\u0db4\u0dad\u0da7 \u0db4\u0dad\u0dca \u0db4\u0dc0\u0dd4\u0dbd\u0da7 \u0db8\u0dcf\u0d9c\u0dda \u0dc1\u0ddd\u0d9a\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb\u0db8\u0dd2.",
        "\u0d89\u0dc4\u0dad \u0d9a\u0dd3 \u0dc3\u0ddc\u0dc4\u0ddc\u0db1\u0dca \u0db6\u0dd2\u0db8 \u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf \u0db6\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0da7 \u0d85\u0dba\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0d9a\u0dca \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0daf\u0dbb\u0dc0\u0dbd \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dc5 \u0dc3\u0dd4\u0dc3\u0dcf\u0db1 \u0db7\u0dd6\u0db8\u0dd2\u0dba \u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd2\u0dba \u0dc3\u0db7\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d89\u0da9 \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d87\u0db1\u0dcf\u0d9c\u0dda \u0daf\u0dda\u0dc4\u0dba \u0db8\u0dd2\u0dc4\u0dd2\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0daf \u0db8\u0db8 \u0d85\u0dc0\u0dc3\u0dbb \u0daf\u0dd9\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba. \u0d91\u0d9a\u0db8 \u0dc3\u0ddc\u0dc4\u0ddc\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda.",
        "\u0db8\u0dd9\u0dba\u0da7 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0dd6 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dba \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0db4\u0dc3\u0dd4 \u0dc0\u0db1\u0dbb\u0dcf\u0da2\u0dcf \u0dba\u0da7\u0dad\u0dda \u0d87\u0dad\u0dd2 \u0daf\u0dbb\u0dc0\u0dbd \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d91\u0db8 \u0dc3\u0ddc\u0dc4\u0ddc\u0db1\u0dca \u0db6\u0dd2\u0db8 \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0da7 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0 \u0dc3\u0db8\u0dca\u0db8\u0dad \u0dc0\u0dd2\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [],
        [
          {
            "text": "\u0db8\u0dcf\u0dc3\u0dd2\u0d9a\u0dc0",
            "label": "DATE"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          },
          {
            "text": "18",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc3\u0db7\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dc0\u0dd3 \u0d9a\u0dd4\u0da9\u0dca\u0da9\u0dc0\u0dda\u0dbd\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd2\u0db1\u0dca\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dab\u0dca\u0da9\u0db4\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc3\u0db8\u0dbb\u0dca\u0dc0\u0dd2\u0dbd\u0dca \u0daf\u0dda\u0dc1\u0dd3\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0db8\u0dca \u0dbb\u0dcf\u0db8\u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dd0\u0da7\u0db1\u0dca-\u0da7\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0dda",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dbb\u0dc0\u0dbd \u0d9a\u0ddc\u0dbd\u0db1\u0dd2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc4\u0dd0\u0da7\u0db1\u0dca \u2013 \u0daf\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0db8\u0dc4 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          },
          {
            "text": "17) \u0dc3\u0dc0\u0dc3",
            "label": "TIME"
          },
          {
            "text": "\u0daf\u0dbb\u0dc0\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0ddc\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dbd\u0dca\u0dbd\u0dd2\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "18",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc3\u0dc0\u0dc3 03 \u0da7",
            "label": "TIME"
          },
          {
            "text": "11.30 \u0db4\u0dd9.\u0dc0.",
            "label": "TIME"
          },
          {
            "text": "\u0dc4\u0dd0\u0da7\u0db1\u0dca-\u0da7\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd0\u0dba \u0dad\u0dd4\u0db1\u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0dca",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dbd\u0dca\u0dbd\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc4\u0dd4\u0da7\u0db1\u0dca-\u0da7\u0dd2\u0d9a\u0dca\u0d94\u0dba \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0ddd\u0dbb\u0dca\u0dc0\u0dd4\u0da9\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dbb\u0dc0\u0dbd \u0da2\u0db1\u0db4\u0daf\u0dba",
