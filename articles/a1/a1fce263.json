          },
          {
            "text": "\u0d87\u0db1\u0dcf",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0dbb\u0dc0\u0dbd \u0da2\u0db1\u0db4\u0daf\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0dc0\u0db1\u0dbb\u0dcf\u0da2\u0dcf",
