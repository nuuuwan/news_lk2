    "si": {
      "title": "\u0dbb\u0d9a\u0dca\u0db1\u0dcf \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dba\u0da7\u0dad\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dbb\u0d9a\u0dca\u0db1\u0dcf \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0d86\u0dba\u0ddd\u0da2\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0dba\u0da7\u0dad\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd2\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dc4\u0dcf \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dba\u0da7\u0dad\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dc3\u0dd9\u0dbd\u0db1\u0dca\u0daf\u0dd2\u0dc0 \u0d89\u0db1\u0dca\u0dc0\u0dd9\u0dc3\u0dca\u0da7\u0dca\u0db8\u0db1\u0dca\u0da9\u0dca \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca \u0dc4\u0dcf \u0dc4\u0ddc\u0da7\u0dd9\u0dbd\u0dca \u0da9\u0dd2\u0dc0\u0dbd\u0db4\u0dbb\u0dca\u0dc3\u0dca (\u0dbd\u0d82\u0d9a\u0dcf) \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca \u0dba\u0db1 \u0d86\u0dba\u0dad\u0db1 \u0daf\u0dd9\u0d9a\u0dd9\u0daf \u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0dba\u0da7\u0dad\u0dda \u0d87\u0dad\u0dd2 \u0d86\u0dba\u0ddd\u0da2\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0da7 \u0d91\u0d9a\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [
        {
          "text": "\u0dbb\u0d9a\u0dca\u0db1\u0dcf \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8",
          "label": "PERSON"
        },
        {
          "text": "\u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0d9a\u0dca\u0db1\u0dcf \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dcf\u0d9c\u0db8",
            "label": "PERSON"
          },
          {
            "text": "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "Selandiva Investment Limited \u0dc3\u0dc4 Hotel Developers",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dc4\u0dcf \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d86\u0dba\u0ddd\u0da2\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0bb0\u0b95\u0bcd\u0ba9\u0bbe \u0b9a\u0bc6\u0b95\u0bcd\u0baf\u0bc2\u0bb0\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bae\u0bcd \u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe\u0bb5\u0bc1\u0b95\u0bcd\u0b95\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0bb0\u0b95\u0bcd\u0ba9\u0bbe \u0b9a\u0bc6\u0b95\u0bcd\u0baf\u0bc2\u0bb0\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0ba4\u0bcd\u0ba4\u0bc8 \u0bae\u0bc1\u0ba4\u0bb2\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0b8a\u0b95\u0bcd\u0b95\u0bc1\u0bb5\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bb0\u0bcd \u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bb0\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0bb5\u0bbf\u0b9a\u0bc7\u0b9f \u0bb5\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bae\u0bbe\u0ba9\u0bbf\u0baf\u0bc8 \u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bbe\u0baa\u0baf \u0bb0\u0bbe\u0b9c\u0baa\u0b95\u0bcd\u0bb7 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0ba4\u0bbf\u0b95\u0bae\u0bbe\u0b95 \u0ba8\u0b95\u0bb0 \u0b85\u0baa\u0bbf\u0bb5\u0bbf\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0bc0\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 Selandiva Investment Limited \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd Hotel Developers (Lanka) Limited \u0b86\u0b95\u0bbf\u0baf \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0ba4\u0bbf\u0bb0\u0bc1.\u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bcd \u0bae\u0bc1\u0ba4\u0bb2\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0b8a\u0b95\u0bcd\u0b95\u0bc1\u0bb5\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1\u0b9f\u0ba9\u0bcd \u0b87\u0ba3\u0bc8\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9."
      ],
      "title_ents": [
        {
          "text": "\u0bb0\u0b95\u0bcd\u0ba9\u0bbe \u0b9a\u0bc6\u0b95\u0bcd\u0baf\u0bc2\u0bb0\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bae\u0bcd",
          "label": "PERSON"
        },
        {
          "text": "\u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b95\u0bcb\u0ba4\u0bcd\u0ba4\u0baa\u0bbe\u0baf \u0bb0\u0bbe\u0b9c\u0baa\u0b95\u0bcd\u0b9a",
            "label": "PERSON"
          },
          {
            "text": "\u0bb0\u0b95\u0bcd\u0ba9\u0bbe \u0b9a\u0bc6\u0b95\u0bcd\u0baf\u0bc2\u0bb0\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bae\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1",
            "label": "CARDINAL"
          },
          {
            "text": "\u0b9a\u0bc6\u0bb2\u0ba8\u0bcd\u0ba4\u0bbf\u0bb5\u0bbe \u0b87\u0ba9\u0bcd\u0bb5\u0bc6\u0bb8\u0bcd\u0b9f\u0bcd\u0bae\u0bc6\u0ba9\u0bcd\u0b9f\u0bcd \u0bb2\u0bbf\u0bae\u0bbf\u0b9f\u0bc6\u0b9f\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb9\u0bcb\u0b9f\u0bcd\u0b9f\u0bb2\u0bcd \u0b9f\u0bc6\u0bb5\u0bb2\u0baa\u0bcd\u0baa\u0bb0\u0bcd\u0bb8\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba8\u0b95\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bc1\u0bb1 \u0bb5\u0bb3\u0bb0\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1\u0bb5\u0b9a\u0ba4\u0bbf \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0bae\u0bc1\u0ba4\u0bb2\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0b8a\u0b95\u0bcd\u0b95\u0bc1\u0bb5\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe",
            "label": "PERSON"
          }
        ]
      ]
    }
  }
