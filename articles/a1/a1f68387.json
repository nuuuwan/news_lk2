          {
            "text": "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb, \u0db4\u0ddc\u0dc5\u0ddc\u0db1\u0dca\u0db1\u0dbb\u0dd4\u0dc0",
