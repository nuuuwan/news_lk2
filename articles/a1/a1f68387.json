          },
          {
            "text": "\u0dc4\u0daf\u0db1\u0dca\u0d9c\u0db8\u0dd4\u0dc0 \u0dc4\u0dd9\u0da7\u0dca\u0da7\u0dd2\u0db4\u0ddc\u0dbd",
