      "title": "Appointment of Presidential Media Officers",
      "author": "unknown",
      "body_lines": [
        "Dhanushka Ramanayake, Presidential Media Director (Print Media) Piyasena Dissanayake and Presidential Media Director (Electronic Media) Shanukka Karunaratne have been appointed as Director General of Presidential Media."
      ],
      "title_ents": [],
      "body_line_ents_list": [
