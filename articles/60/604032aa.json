          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dc0\u0dba\u0dc3\u0dca \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0db1\u0dd4\u0db8\u0dca \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dbd\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "2019",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dcf\u0db4\u0db1\u0dca\u0daf\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf \u0db8\u0dbd\u0dd3\u0d9a\u0dcf \u0d85\u0db8\u0dd2\u0dad\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0db4\u0dcf\u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dbd\u0dd2\u0dba",
            "label": "WORK_OF_ART"
          },
          {
            "text": "2021",
            "label": "DATE"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0dd4\u0dbd\u0dd3\u0dc3\u0dcf \u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dca\u0d9a\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0db6\u0da7\u0dc4\u0dd2\u0dbb \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dba\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0d9a\u0db1\u0dd2\u0dc2\u0dca\u0da8 \u0dc0\u0dda\u0d9c\u0dc0\u0dad\u0dca \u0dc4\u0dcf \u0db6\u0dca\u0dbd\u0dd2\u0da7\u0dca\u0dc3\u0dca \u0da0\u0dd9\u0dc3\u0dca \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dbd\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "2019",
            "label": "DATE"
          },
          {
            "text": "\u0da2\u0dda\u0dc3\u0db1\u0dca \u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dba\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0db4\u0dd0\u0dbb\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d8b\u0dc5\u0dd9\u0dbd 2021",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0ddd\u0dbd\u0dca\u0da9\u0db1\u0dca \u0d8a\u0d9c\u0dbd\u0dca \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba",
            "label": "PRODUCT"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dc3\u0dca\u0dad\u0dd4\u0dbb\u0dd2 \u0da0\u0dd9\u0dbd\u0dca\u0dbd\u0dbb\u0dcf\u0da2\u0dcf \u0dc0\u0dd2\u0dbd\u0dca\u0dc3\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb\u0dba",
            "label": "ORG"
