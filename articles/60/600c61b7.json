          },
          {
            "text": "\u0da2\u0dd3 \u0dc3\u0dad\u0dcf\u0dc3\u0dd2\u0dc0\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dc3\u0dca.\u0da2\u0dd3.\u0dc3\u0dad\u0dcf\u0dc3\u0dd2\u0dc0\u0db8\u0dca",
            "label": "PERSON"
