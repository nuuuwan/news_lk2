    "si": {
      "title": "Tyeab Akbarally \u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "Tyeab Akbarally \u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0dc3\u0dca\u0dc0\u0dcf\u0db0\u0dd3\u0db1 \u0db1\u0ddc\u0dc0\u0db1 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0ddc\u0dc0\u0db1 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d85\u0d9a\u0dca\u0db6\u0dcf\u0dbb\u0dcf\u0dbd\u0dd2 1979 \u0dc3\u0dd2\u0da7 \u0d85\u0d9a\u0dca\u0db6\u0dcf\u0dbb\u0dca \u0db6\u0dca\u200d\u0dbb\u0daf\u0dbb\u0dca\u0dc3\u0dca \u0dc3\u0db8\u0dd6\u0dc4 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0dc0\u0dbb\u0dca\u0dad\u0db8\u0dcf\u0db1\u0dba\u0dda \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0dad\u0db1\u0dad\u0dd4\u0dbb \u0daf\u0dbb\u0dab \u0d85\u0dad\u0dbb \u0dad\u0dda \u0dc3\u0dc4 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0db4\u0db1\u0dba\u0db1 \u0dc0\u0dd9\u0dc5\u0db3\u0dcf\u0db8\u0dda \u0dc3\u0d9a\u0dca\u200d\u0dbb\u0dd3\u0dba\u0dc0 \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dda. \u0d94\u0dc4\u0dd4 \u0d9a\u0ddc\u0dc5\u0db9 \u0dad\u0dda \u0dc0\u0dd9\u0dc5\u0db3\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0dc4 \u0d9a\u0dd4\u0dc5\u0dd4\u0db6\u0da9\u0dd4 \u0dc3\u0dc4 \u0d92 \u0d86\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4 \u0dc0\u0dd9\u0dc5\u0db3 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dba. \u0d94\u0dc4\u0dd4 \u0d85\u0db8\u0dcf\u0db1\u0dcf \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0d9a\u0dd4 \u0dc3\u0dc4 \u0d85\u0db8\u0dcf\u0db1\u0dcf \u0dad\u0d9a\u0dcf\u0dc6\u0dd4\u0dbd\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0daf \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0dad\u0dc0\u0dad\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dc0\u0dbd \u0daf \u0dc3\u0dd2\u0da7\u0dd3.",
        "\u0d85\u0d9a\u0dca\u0db6\u0dcf\u0dbb\u0dca \u0db6\u0dca\u200d\u0dbb\u0daf\u0dbb\u0dca\u0dc3\u0dca \u0dc3\u0dad\u0dd4\u0dc0 \u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0dc4\u0dd2 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 49.2 \u0d9a\u0dca \u0dc4\u0ddd 10% \u0d9a \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db1\u0dc0\u0dad\u0db8 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0dc4\u0dd2 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d85\u0db8\u0dbd\u0dca \u0d9a\u0db6\u0dca\u0dbb\u0dcf\u0dbd\u0dca, \u0dc3\u0db8\u0dd6\u0dc4 \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0dc0\u0dd3.\u0d9c\u0ddd\u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dc3\u0dcf\u0db8\u0dd2, \u0d91\u0dc3\u0dca.\u0dbb\u0dad\u0dca\u0dc0\u0dad\u0dca\u0dad, \u0d91\u0da0\u0dca.\u0da9\u0dd3. \u0d85\u0db6\u0dda\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8, \u0d92.\u0da9\u0dd3.\u0db6\u0dd3. \u0dad\u0dbd\u0dca\u0dc0\u0dad\u0dca\u0dad, \u0d91\u0dc3\u0dca.\u0dc2\u0dd2\u0dc2\u0dd6, \u0da2\u0dd3.\u0dc3\u0dad\u0dcf\u0dc3\u0dd2\u0dc0\u0db8\u0dca, \u0d91\u0dc3\u0dca.\u0da2\u0dd3.\u0dc3\u0dad\u0dcf\u0dc3\u0dd2\u0dc0\u0db8\u0dca, \u0d91\u0dc3\u0dca.\u0da2\u0dda\u0db1\u0dca, \u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca.\u0dc0\u0dba\u0dd2.\u0d86\u0dbb\u0dca. \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4, \u0d91\u0dc3\u0dca.\u0dbb\u0dd9\u0db1\u0dca\u0d9c\u0db1\u0dcf\u0daf\u0db1\u0dca \u0dc3\u0dc4 \u0da7\u0dd3.\u0d85\u0d9a\u0dca\u0db6\u0dbb\u0dbd\u0dd2."
      ],
      "title_ents": [
        {
          "text": "\u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0db1\u0dca\u0d9c\u0dca\u0dc3\u0dca \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0d9a\u0dca\u0db6\u0dcf\u0dbb\u0dca \u0dc3\u0dc4\u0ddd\u0daf\u0dbb \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0dc3\u0db8\u0dd6\u0dc4\u0dba",
            "label": "ORG"
          },
          {
            "text": "1979",
            "label": "DATE"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0dad\u0dda \u0dc0\u0dd9\u0dc5\u0dd9\u0db3 \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd4\u0dc5\u0dd4\u0db6\u0da9\u0dd4",
            "label": "PRODUCT"
          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0db6\u0daf\u0dca\u0db0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0d9a\u0dba\u0dd2\u0db1\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db8\u0dcf\u0db1\u0dcf \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db8\u0dcf\u0db1\u0dcf \u0dad\u0d9a\u0dcf\u0dc6\u0dd4\u0dbd\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0d9a\u0dca\u0db6\u0dbb\u0dca \u0dc3\u0dc4\u0ddd\u0daf\u0dbb\u0dba\u0ddd",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 49.2 \u0d9a\u0dd2",
            "label": "CARDINAL"
          },
          {
            "text": "10%",
            "label": "PERCENT"
          },
          {
            "text": "\u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0db1\u0dca\u0d9c\u0dca\u0dc3\u0dca",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0db1\u0dca\u0d9c\u0dca\u0dc3\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db8\u0dbd\u0dca \u0d9a\u0db6\u0dca\u0dbb\u0dcf\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd3 \u0d9c\u0ddd\u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dc3\u0dcf\u0db8\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dc3\u0dca \u0dbb\u0dad\u0dca\u0dc0\u0dad\u0dca\u0dad\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0da0\u0dca.\u0da9\u0dd3. \u0d85\u0db6\u0dda\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8",
            "label": "PERSON"
          },
          {
            "text": "\u0d92.\u0da9\u0dd3.\u0db6\u0dd3. \u0dad\u0dbd\u0dca\u0dc0\u0dad\u0dca\u0dad",
            "label": "ORG"
          },
          {
