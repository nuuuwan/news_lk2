            "label": "ORG"
          },
          {
            "text": "\u0bae\u0b9a\u0bbe\u0bb2\u0bbe",
            "label": "PRODUCT"
          },
          {
            "text": "\u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bc1\u0b9f\u0bc8\u0baf \u0ba4\u0baf\u0bbe\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0b95\u0bb3\u0bcd \u0ba4\u0baf\u0bbe\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bbe\u0bb3\u0bb0\u0bcd\u0b95\u0bb3\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b85\u0bae\u0bbe\u0ba9\u0bbe \u0bb5\u0b99\u0bcd\u0b95\u0bbf",
            "label": "ORG"
          },
          {
            "text": "\u0b85\u0bae\u0bbe\u0ba9\u0bbe \u0ba4\u0b95\u0bcd\u0b95\u0bbe\u0b83\u0baa\u0bc1\u0bb2\u0bcd \u0baa\u0bbf\u0b8e\u0bb2\u0bcd\u0b9a\u0bbf",
