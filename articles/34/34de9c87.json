          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0da2\u0dba\u0db1\u0dca\u0dad \u0dc3\u0db8\u0dbb\u0dc0\u0dd3\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db8\u0dd4\u0dc3\u0db8\u0dca\u0db8\u0dd2\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd3\u0dbb\u0dc3\u0dd4\u0db8\u0db1 \u0dc0\u0dd3\u0dbb\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0ddc\u0db8\u0dd2\u0dba\u0dd4\u0db1\u0dd2\u0dc3\u0dca\u0da7\u0dca \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
