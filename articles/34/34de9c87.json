          }
        ],
        [
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dad\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0daf\u0dd3",
            "label": "NORP"
          },
          {
            "text": "\u0dc0\u0db8\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dcf\u0dc3\u0dd4\u0daf\u0dda\u0dc0 \u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dca\u0d9a\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd2\u0dc0\u0dd2\u0dad\u0dd4\u0dbb\u0dd4 \u0dc4\u0dd9\u0dc5 \u0d8b\u0dbb\u0dd4\u0db8\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0d8b\u0daf\u0dba \u0d9c\u0db8\u0dca\u0db8\u0db1\u0dca\u0db4\u0dd2\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
