          },
          {
            "text": "\u0d9c\u0dd9\u0dc0\u0dd2\u0db3\u0dd4 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
