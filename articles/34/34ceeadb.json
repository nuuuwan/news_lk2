    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da7\u0dca\u200d\u0dbb\u0dd9\u0dc2\u0dbb\u0dd3\u0dc3\u0dca \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2, \u0db8\u0dcf\u0dc3 3 \u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 32.11 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT - \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da7\u0dca\u200d\u0dbb\u0dd9\u0dc2\u0dbb\u0dd3\u0dc3\u0dca \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0d9a\u0dbd\u0dca\u0db4\u0dd2\u0dbb\u0dd9\u0db1 \u0d9a\u0dcf\u0dbd\u0dba \u0db4\u0dd4\u0dbb\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dab\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0daf\u0dad\u0dca\u0dad \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0db8\u0dcf\u0dc3 12\u0d9a \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0db4\u0daf\u0db1\u0db8\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 403\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 32.11\u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dcf\u0dc3 \u0dad\u0dd4\u0db1\u0dda \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0 \u0dc3\u0dd2\u0dba\u0dba\u0da7 35\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d9c\u0dab\u0db1\u0dca \u0db6\u0dbd\u0dcf \u0d87\u0dad.",
        "\u0daf\u0dd2\u0db1\u0d9a\u0da7 \u0db4\u0dd9\u0dbb 7 \u0dc0\u0dc3\u0dbb\u0d9a \u0db6\u0dd0\u0db3\u0dd4\u0db8\u0dca\u0d9a\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0db4\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0daf\u0dd0\u0da9\u0dd2 \u0dbd\u0dd9\u0dc3 \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0dbd \u0dc0\u0dca\u200d\u0dba\u0dcf\u0d9a\u0dd6\u0dbd \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dcf\u0dc3 6 \u0d9a \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1,802\u0d9a\u0dca \u0dc3\u0db8\u0d9f\u0dd2\u0db1\u0dca \u0db4\u0daf\u0db1\u0db8\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 227\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 31.01\u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 2,059\u0d9a\u0dca \u0dc3\u0db8\u0d9f\u0dd2\u0db1\u0dca \u0db8\u0dcf\u0dc3 12\u0d9a \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0d89\u0dc4\u0dc5 \u0d9c\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dba\u0dba\u0da7 1.76\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab\u0dd2.",
        "\u0db8\u0dcf\u0dc3 6 \u0dc3\u0dc4 12 \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca \u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0da7\u0dd0\u0db4\u0dca \u0d91\u0d9a\u0dd9\u0db1\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. (\u0d9a\u0ddc\u0dc5\u0db9/\u0da2\u0dd6\u0dbd\u0dd212/2022)"
      ],
