          },
          {
            "text": "\u0dc3\u0dba\u0dd2\u0db4\u0dca\u0dbb\u0dc3\u0dca",
            "label": "NORP"
          },
          {
            "text": "\u0dbd\u0ddd\u0db1\u0dd2\u0dc3\u0dca \u0d9a\u0dd0\u0dc3\u0ddc\u0dbd\u0dd2\u0da9\u0dd2\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dd0\u0dbd\u0dda\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4",
