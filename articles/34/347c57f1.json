          },
          {
            "text": "\u0dc3\u0dba\u0dd2\u0dc6\u0dd4\u0daf\u0dd3\u0db1\u0dca \u0d85\u0db6\u0dca\u0daf\u0dd4\u0dbd\u0dca\u0dbd\u0dcf",
