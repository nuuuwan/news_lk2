        },
        {
          "text": "\u0db4\u0ddc\u0daf\u0dd4\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca",
          "label": "ORG"
