    "si": {
      "title": "\u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dcf \u0db6\u0dc3\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dd3 \u0db8\u0dd2\u0dba \u0d9c\u0dd2\u0dba\u0dda\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0dd4\u0dbb\u0dd4\u0db4\u0dcf\u0db4\u0dd2\u0dbd \u0d9a\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0db6\u0dc5\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0db6\u0dbd\u0dcf \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dba\u0d9a \u0d9c\u0db8\u0db1\u0dca \u0d9c\u0dad\u0dca 22 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db1\u0dd2\u0dc1\u0dca\u0dc1\u0d82\u0d9a \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc3\u0dd2\u0dbb\u0dd2 \u0db1\u0dd0\u0db8\u0dd0\u0dad\u0dd2 \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dcf \u0db6\u0dc3\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad.",
        "\u0dbb\u0dc3\u0dca\u0d9a\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dcf \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0dd9\u0dc5 \u0d9c\u0dd0\u0dc3\u0dd3\u0db8\u0da7 \u0db6\u0dc3\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0db4\u0dba \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0dc0\u0dd0\u0da7\u0dd3 \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
