          {
            "text": "\u0d86\u0dbb\u0dca \u0d91\u0dbd\u0dca \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9a\u0dcf",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc2\u0dbb\u0dca\u0db8\u0db1\u0dca",
