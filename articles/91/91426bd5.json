          }
        ],
        [
          {
            "text": "\u0d91\u0da9\u0dca\u0dbb\u0dcf\u0dc0\u0dd4\u0dbb\u0dca \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a \u0d8b\u0dc3\u0dcf\u0dc0\u0dd2\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d86\u0dbb\u0dca \u0da2\u0dd9\u0dba\u0dc3\u0dd2\u0d82\u0dc4\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da0\u0dd2\u0db1\u0dca\u0db1\u0dad\u0dd4\u0dbb\u0dd9\u0dba\u0dd2 \u0da2\u0d9c\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dca\u0dba\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0daf\u0dcf\u0dba\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
