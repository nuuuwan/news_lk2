    "si": {
      "title": "\u0db4\u0dcf\u0db1\u0dca \u0dbb\u0dcf\u0dad\u0dca\u0dad\u0dbd\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4 300\u0da7 \u0d91\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0ddc\u0dc5 \u0dad\u0dd4\u0dc5 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dad\u0dd2\u0dbb\u0dd2\u0d9f\u0dd4 \u0db4\u0dd2\u0da7\u0dd2 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0db1\u0dca \u0dbb\u0dcf\u0dad\u0dca\u0dad\u0dbd\u0d9a \u0db8\u0dd2\u0dbd \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dbb\u0dd4 250-300\u0dad\u0dca \u0d85\u0dad\u0dbb \u0db8\u0dd2\u0dbd\u0d9a\u0da7 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u200c\u200c\u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd3. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0db6\u0ddc\u0dc4\u0ddd \u0db6\u0dda\u0d9a\u0dbb\u0dd2 \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dcf\u0db1\u0dca \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0ddc\u0dc5 \u0dad\u0dd4\u0dc5 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dad\u0dd2\u0dbb\u0dd2\u0d9f\u0dd4 \u0db4\u0dd2\u0da7\u0dd2 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0dc3\u0dda \u0db4\u0dcf\u0db1\u0dca \u0db8\u0dd2\u0dbd \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0dba\u0dd1\u0db8\u0da7 \u0dc4\u0dda\u0dad\u0dd4 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda."
      ],
