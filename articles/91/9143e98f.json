            "text": "\u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd4\u0db6\u0dc3\u0dcf\u0db0\u0db1 \u0dc3\u0db8\u0dcf\u0da2\u0dba",
