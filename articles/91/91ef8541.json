    "si": {
      "title": "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dab\u0dba \u0dbb\u0dda\u0d9b\u0dcf\u0dc0 \u0dba\u0da7\u0dad\u0dda \u0dba\u0dd6\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dab\u0dba \u0dbb\u0dda\u0d9b\u0dcf\u0dc0 \u0dba\u0da7\u0dad\u0dda \u0dba\u0dd6\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca \u0dc4\u0dad\u0dc5\u0dd2\u0dc3\u0dca \u0dc4\u0dba\u0daf\u0dc4\u0dc3\u0d9a\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dc5\u0d9f\u0dcf \u0dc0\u0dd2\u0dba. \u0db8\u0dd9\u0db8 \u0dad\u0ddc\u0d9c\u0dba \u0d8a\u0dba\u0dda \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dbb\u0da2\u0dba\u0dda \u0d9c\u0db6\u0da9\u0dcf \u0dc0\u0dd9\u0dad \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad. \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0db1\u0dc0\u0db1 \u0dbd\u0daf \u0dad\u0dc4\u0db1\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db4\u0dc5\u0db8\u0dd4 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0db8\u0dd9\u0dba\u0dba\u0dd2. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db4\u0dca\u200d\u0dbb\u0daf\u0dd3\u0db4\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dab"
      ],
