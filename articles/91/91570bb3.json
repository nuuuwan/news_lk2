    "si": {
      "title": "\u0dbd\u0dcf\u0dc6\u0dca\u0dc3\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dbd\u0dcf\u0dc6\u0dca\u0dc3\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0d9a\u0dd2\u0db1\u0dca \u0d85\u0da9\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. 1,050/- \u0d85\u0daf (17) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0db6\u0dc0 \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf (16) LPG \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \"GAS CHALLENGER\" LP \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3120\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0dc4\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0dc0\u0dbb\u0dcf\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab LAUGFS \u0db4\u0dbb\u0dca\u0dba\u0db1\u0dca\u0dad \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8 \u0dc0\u0dd9\u0dad \u0db8\u0dd4\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dd6 \u0dc0\u0dc4\u0dcf\u0db8 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0dad\u0ddc\u0d9c \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db4\u0dbb\u0dd2\u0db7\u0ddd\u0da2\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd4\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1 \u0db6\u0dc0 \u0dbd\u0dcf\u0dc6\u0dca\u0dc3\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dc6\u0dda\u0dc3\u0dca\u0db6\u0dd4\u0d9a\u0dca \u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0dad\u0db6\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db4\u0dd2\u0da7\u0dd4\u0dc0\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db1\u0da9\u0dd4\u0dc0 \u0d85\u0dc4\u0dd2\u0db8\u0dd2 \u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0dc3\u0dca\u0d9a\u0ddc\u0da7\u0dca\u0dbd\u0db1\u0dca\u0dad \u0d89\u0db1\u0dca\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dcf\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0dc4\u0db1\u0dca - \u0d86\u0d9c\u0db8\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
        "\u0dba\u0dd4\u0dc0\u0dcf\u0db1\u0dca \u0dc0\u0dd0\u0db1\u0dca\u0d9c\u0dca 5: \u0da0\u0dd3\u0db1\u0dba\u0dda \u0daf\u0dd0\u0da9\u0dd2 \u0db4\u0dd3\u0da9\u0db1\u0dba\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dba\u0da7\u0dad\u0dca \u0dc0\u0dd6 \u0db6\u0dc0 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0db4\u0dc0\u0dc3\u0dba\u0dd2"
      ],
