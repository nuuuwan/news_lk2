          {
            "text": "\u0db1\u0dc0 \u0dc3\u0dd2\u0d82\u0dc4\u0dbd\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba",
