    "si": {
      "title": "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc4\u0dcf \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba\u0dda \u0d9a\u0dd0\u0db4\u0dd3 \u0db4\u0dd9\u0db1\u0dd9\u0db1 \u0d85\u0da9\u0dd4\u0dc0\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9c \u0d9c\u0dad\u0dc0\u0dd6 \u0dc3\u0dad\u0dd2 \u0dad\u0dd4\u0db1\u0d9a \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d9a\u0dd0\u0db4\u0dd2 \u0db4\u0dd9\u0db1\u0db1 \u0d85\u0da9\u0dd4\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0db4\u0dd9\u0db1\u0dd9\u0db1\u0dca\u0db1\u0da7 \u0dad\u0dd3\u0db6\u0dda.",
        "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd \u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u00a0\u0d9a\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc3\u0dd2\u0dba \u0da7\u0dca\u0dc0\u0dd2\u0da7\u0dbb\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dd9\u0db1\u0dca \u0d89\u0daf\u0dd3\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0daf\u0dad\u0dca\u0dad \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dda \u0db6\u0dc0 \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0d92\u0dca \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dc3 \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dad\u0dd2 \u0dad\u0dd4\u0db1 \u0dad\u0dd4\u0dc5\u0daf\u0dd3 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dc5\u0dd2\u0db1\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 23.5\u0d9a\u0dca, 22.1\u0d9a\u0dca \u0dc4\u0dcf 21.0 \u0dbd\u0dd9\u0dc3 \u0db4\u0dc4\u0dad \u0db6\u0dd0\u0dc3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d92\u0dc3\u0dda\u0db8 \u0daf\u0ddb\u0db1\u0dd2\u0d9a \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dbb\u0db1 \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0d92\u0db8 \u0dc3\u0dad\u0dd2 \u0dad\u0dd4\u0db1\u0dda\u0daf\u0dd3 \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dc5\u0dd2\u0db1\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 3.3\u0d9a\u0dca, 3.1\u0d9a\u0dca \u0dc4\u0dcf 3.0\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dc4\u0dad \u0db6\u0dd0\u0dc3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0dbd\u0d9a\u0dcf \u0db6\u0dd0\u0dbd\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dad\u0dd2\u0dba\u0da7 \u0dc0\u0da9\u0dcf\u00a0 \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dad\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd3\u0dbb\u0dd3\u0db8 \u0d89\u0dc4\u0dc5 \u0d9c\u0dd2\u0dba\u0dad\u0dca \u0dad\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dad\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0d91\u0dba \u0db4\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd3\u0db6\u0dda.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dad\u0dd2 \u0dad\u0dd4\u0dc5 \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dbd\u0dd3\u0dd3\u0da7\u0dbb\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dc5\u0dd2\u0db1\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 13.0\u0d9a\u0dca, 14.0\u0d9a\u0dca \u0dc4\u0dcf 12.7\u0d9a\u0dca \u0dc0\u0dd2\u0dba. \u0daf\u0ddb\u0db1\u0dd2\u0d9a \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dbd\u0dd3\u0da7\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.8\u0d9a\u0dca,2.0\u0d9a\u0dca \u0dc4\u0dcf 1.8\u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc0\u0dcf\u0dc4\u0db1 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 6\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf\u0daf\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9c \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dbd\u0dca \u0d85\u0dc3\u0dc5 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd2\u0dba."
      ],
