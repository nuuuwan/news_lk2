      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0dc0\u0dca \u0dba\u0ddd\u0dbb\u0dca\u0d9a\u0dca \u0db1\u0d9c\u0dbb\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda",
            "label": "ORG"
          },
          {
            "text": "193",
            "label": "CARDINAL"
          },
          {
            "text": "77 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dc4\u0dcf \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
