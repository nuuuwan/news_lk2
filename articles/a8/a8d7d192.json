          }
        ],
        [
          {
            "text": "\u0db8\u0dbd\u0dca\u0dc0\u0dad\u0dd4 \u0db6\u0dde\u0daf\u0dca\u0db0 \u0db8\u0dc4\u0dcf \u0db4\u0dd3\u0da8\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db8\u0dbb\u0db4\u0dd4\u0dbb \u0db8\u0dc4\u0dcf \u0db1\u0dd2\u0d9a\u0dcf\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0dcf\u0db8\u0da4\u0dca\u0da4 \u0db8\u0dc4\u0dcf \u0db1\u0dd2\u0d9a\u0dcf\u0dba",
            "label": "PERSON"
          }
        ],
