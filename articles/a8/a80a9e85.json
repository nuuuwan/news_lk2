          {
            "text": "\u0b95\u0baf\u0bbe\u0ba9\u0bbf \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0ba4\u0bae\u0bcd\u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bc8 \u0b86\u0ba4\u0bbe\u0bb0 \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bbe\u0bb2\u0bc8",
            "label": "FAC"
