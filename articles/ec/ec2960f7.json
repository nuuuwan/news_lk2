    "si": {
      "title": "\u0db6\u0dba\u0dd2\u0da9\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9c\u0dad \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0dba\u0dc0\u0dd0\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d91\u0dbd\u0dd0\u0db9\u0dd9\u0db1 \u0dc0\u0dc3\u0dbb\u0dda \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0dba\u0dc0\u0dd0\u0dba \u0d87.\u0da9\u0ddc.\u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 800\u0d9a\u0dca \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dd3\u0db8\u0da7 \u0db8\u0d9c \u0db4\u0dcf\u0daf\u0db8\u0dd2\u0db1\u0dca, \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0da2\u0ddd \u0db6\u0dba\u0dd2\u0da9\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dba\u0ddd\u0da2\u0db1\u0dcf \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9c\u0dad \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db4\u0db1\u0dad \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc3\u0db7\u0dcf\u0dc0 329\u0da7101\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0da1\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd9\u0db1\u0dca\u0da7\u0d9c\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db4\u0dad\u0dca\u0dad\u0dd2 \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db6\u0dbd\u0dba \u0db4\u0dd0\u0dc0\u0dbb\u0dd3\u0db8\u0dda \u0db4\u0db1\u0dad \u0dc4\u0ddd NDAA \u0dc4\u0dd2 \u0d85\u0db1\u0dd4\u0dc0\u0dcf\u0daf\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dc3\u0dd9\u0db1\u0dd9\u0da7\u0dca \u0dc3\u0db7\u0dcf\u0dc0 \u0dad\u0dc0\u0db8\u0dad\u0dca \u0d91\u0dc4\u0dd2 \u0d85\u0db1\u0dd4\u0dc0\u0dcf\u0daf\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad \u0d9a\u0dbb \u0db1\u0dd0\u0dad\u0dd2 \u0db1\u0db8\u0dd4\u0dad\u0dca \u0dc3\u0dd9\u0db1\u0dd9\u0da7\u0dca \u0dc3\u0db1\u0dca\u0db1\u0daf\u0dca\u0db0 \u0dc3\u0dda\u0dc0\u0dcf \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0db6\u0dba\u0dd2\u0da9\u0db1\u0dca\u0d9c\u0dda \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0daf\u0dd0\u0db1\u0da7\u0db8\u0dad\u0dca \u0dba\u0ddd\u0da2\u0db1\u0dcf \u0d9a\u0dbb \u0d87\u0dad."
      ],
      "title_ents": [
        {
          "text": "\u0db6\u0dba\u0dd2\u0da9\u0dd9\u0db1\u0dca",
