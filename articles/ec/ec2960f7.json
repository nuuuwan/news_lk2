          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db6\u0dbd\u0dba \u0db4\u0dd0\u0dc0\u0dbb\u0dd3\u0db8\u0dda \u0db4\u0db1\u0dad",
            "label": "ORG"
