            "text": "NDAA",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd9\u0db1\u0dca\u0da7\u0d9c\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dd9\u0db1\u0dd9\u0da7\u0dca \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd9\u0db1\u0dd9\u0da7\u0dca \u0dc3\u0db1\u0dca\u0db1\u0daf\u0dca\u0db0 \u0dc3\u0dda\u0dc0\u0dcf \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
