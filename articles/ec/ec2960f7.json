          {
            "text": "\u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0b85\u0b99\u0bcd\u0b95\u0bc0\u0b95\u0bbe\u0bb0 \u0b9a\u0b9f\u0bcd\u0b9f\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b8e\u0ba9\u0bcd.\u0b9f\u0bbf.\u0b8f.\u0b8f",
            "label": "ORG"
          },
          {
            "text": "\u0b90\u0b99\u0bcd\u0b95\u0bc7\u0bbe\u0ba3\u0bae\u0bcd",
            "label": "ORG"
          }
        ],
        [
          {
