    },
    "si": {
      "title": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0d91\u0db1\u0dad\u0dd4\u0dbb\u0dd4",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad \u0d86\u0dba\u0dad\u0db1\u0dba\u0da7 \u0d9c\u0dd1\u0dc3\u0dca \u0d91\u0db1\u0dad\u0dd9\u0d9a\u0dca\u00a0 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0daf\u0dd0\u0db1\u0da7 \u0daf\u0dd2\u0db1 \u0dc0\u0dd2\u0dc3\u0dca\u0dc3\u0d9a\u0dca \u0dad\u0dd2\u0dc3\u0dca\u0dc3\u0dda \u0dc4\u0dd2\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dca \u0dba\u0d9a\u0da9 \u0dc0\u0dd0\u0da7\u0d9a \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0da7 \u0dad\u0db6\u0dcf \u0daf\u0db8\u0dca\u0dc0\u0dd0\u0dbd\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca\u00a0 \u0d9c\u0dd0\u0da7\u0d9c\u0dc3\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dda.",
        "\u0daf\u0dd2\u0db1\u0db4\u0dad\u0dcf \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0d9c\u0dd9\u0db1\u0dcf \u0dc4\u0dd2\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dca \u0dc3\u0dd2\u0dba \u0d9c\u0dab\u0db1\u0d9a\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0dad\u0dd9\u0d9a\u0dca \u0d86\u0dba\u0dad\u0db1\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0db8\u0dd9\u0dc3\u0dda \u0d9c\u0dd0\u0da7 \u0d9c\u0dc3\u0dcf \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0d92\u0da2\u0db1\u0dca\u0dc3\u0dd2\u0dba",
            "label": "FAC"
