          },
          {
            "text": "\u0dc0\u0dc3\u0db1\u0dca\u0dad \u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0db8\u0dd4\u0daf\u0dd6\u0dbb",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "\u0d9c\u0ddd\u0da7\u0dcf \u0d9c\u0ddd \u0d9c\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0d85\u0dbb\u0d9c\u0dbd\u0dca \u0db7\u0dd6\u0db8\u0dd2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0d9c\u0dda",
