    "en": {
      "title": "Power cuts will be reduced in 40 minutes",
      "author": "unknown",
      "body_lines": [
        "The Ceylon Electricity Board has worked to reduce the current three-hour power cut in Sri Lanka to two hours and 20 minutes.",
        "Accordingly, from August 30 to September 2, this two-hour and 20-minute power cut will be in effect. There will be a one-hour power cut in the afternoon and an hour and 20-minute power cut at night."
      ],
      "title_ents": [
        {
          "text": "40 minutes",
          "label": "TIME"
        }
      ],
