    "si": {
      "title": "\u0dbd\u0d82\u0d9c\u0db8 \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0d9a; \u0db6\u0dc3\u0dca \u0dbb\u0dae \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7 \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0dca \u0d91\u0dbd\u0dca\u0dbd \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0db1\u0dd0\u0dc0\u0dad \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd9\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0dbd\u0d82\u0d9c\u0db8 \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2 \u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0db1 \u0db6\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9c\u0db8\u0db1\u0dcf\u0d9c\u0db8\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc3\u0dc4 \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dbb\u0dd4. 250/- ; PUCSL \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dcf \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0\u0da7 \u0d9a\u0dd2\u0dba\u0dba\u0dd2"
