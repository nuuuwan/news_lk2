    "si": {
      "title": "\u0da2\u0dd3\u0dc0\u0db1\u0dca \u0dad\u0db8\u0db1\u0dca\u0dc0 \u0dc0\u0dd0\u0dc5\u0db3\u0d9c\u0dad\u0dca \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0dcf\u0da7 \u0daf\u0dd1\u0dad\u0dca \u0db1\u0db8\u0dcf \u0d86\u0da0\u0dcf\u0dbb \u0d9a\u0dc5\u0dda\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db1\u0dc0 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0db4\u0dad\u0dca\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0ddc\u0daf\u0dd4\u0da2\u0db1 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d91\u0d9a\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dcf.",
        "\u0db1\u0dc0 \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0da2\u0dd3\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0dab\u0dca\u0da9\u0db8\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0d86\u0da0\u0dcf\u0dbb \u0d9a\u0dc5\u0dda\u0dba. \u0d91\u0dc0\u0dd2\u0da7 \u0d85\u0dad\u0da7 \u0d85\u0dad \u0daf\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0dc5\u0d9a\u0dd4\u0dab\u0dd4 \u0da2\u0dd3\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0dab\u0dca\u0da9\u0db8\u0db1\u0dca \u0daf\u0dd1\u0dad\u0dca \u0db6\u0dd0\u0db3 \u0dc0\u0dd0\u0db1\u0dca\u0daf\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0da2\u0dd3\u0dc0\u0db1\u0dca",
          "label": "PERSON"
        }
      ],
