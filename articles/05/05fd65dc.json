      "body_line_ents_list": [
        [
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "15",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db1\u0dd2\u0db8\u0dbd\u0dca \u0dc3\u0dd2\u0dbb\u0dd2\u0db4\u0dcf\u0dbd \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd6\u0dc2\u0dab \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf\u0daf\u0dd3\u0db4",
            "label": "ORG"
          },
          {
