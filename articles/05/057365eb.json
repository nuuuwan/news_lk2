          {
            "text": "\u0bb5\u0bbe\u0b9a\u0bc1\u0ba4\u0bcd\u0bb5 \u0ba8\u0bbe\u0ba3\u0baf\u0b95\u0bcd\u0b95\u0bbe\u0bb0",
