            "text": "\u0da9\u0ddd\u0db1\u0dd2\u0dba\u0dbb\u0dca 228 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba",
            "label": "PRODUCT"
