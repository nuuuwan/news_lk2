    "si": {
      "title": "\u0dc3\u0dd2\u0db4\u0dd9\u0da7\u0dca\u0d9a\u0ddd \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "10.00 \u0dc3\u0dd2\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dd3\u0dad\u0dd2\u0d9c\u0dad \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0db4\u0dc0\u0dc3\u0dba\u0dd2. \u0d85\u0daf (\u0da2\u0dd6\u0dbd\u0dd2 17)",
        "\u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dba\u0d9a (\u0d94\u0d9a\u0dca\u0da7\u0dda\u0db1\u0dca 92) \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 20 \u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dc4 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca (\u0d94\u0d9a\u0dca\u0da7\u0dda\u0db1\u0dca 95) \u0dbb\u0dd4. \u0dbd\u0dd3\u0da7\u0dbb\u0dba\u0d9a\u0da7 10 \u0d9a\u0dd2.",
        "\u0d94\u0da7\u0ddd \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dbb\u0dd4. 20 \u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dc4 \u0dc3\u0dd4\u0db4\u0dbb\u0dca \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dba\u0d9a\u0dca \u200b\u200b\u0dbb\u0dd4. \u0dbd\u0dd3\u0da7\u0dbb\u0dba\u0d9a\u0da7 10 \u0d9a\u0dd2."
      ],
