    "si": {
      "title": "\u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0dba\u0dc5\u0dd2 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0db0\u0dd6\u0dbb\u0dba\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dd9\u0db1\u0dbb\u0dcf\u0dbd\u0dca (\u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dd2\u0d9a) \u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dba\u0dc5\u0dd2 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dda \u0d9a\u0dd3\u0dbb\u0dca\u0dad\u0dd2\u0db8\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0dab\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1, \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca 2019 \u0db1\u0ddc\u0dc0\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d91\u0db8 \u0dad\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc0\u0dbb\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0d94\u0dc4\u0dd4 \u0dc0\u0db1\u0dca\u0db1\u0dd2 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dc3\u0dda\u0db1\u0dcf \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d86\u0da5\u0dcf\u0db4\u0dad\u0dd2, 53 \u0dc0\u0db1 \u0dc3\u0dda\u0db1\u0dcf\u0d82\u0d9a\u0dba\u0dda (\u0da2\u0dd3\u0d95\u0dc3\u0dd3) \u0dc3\u0dda\u0db1\u0dcf\u0d82\u0d9a\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2, \u0dbb\u0dd9\u0da2\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca, \u0dba\u0dcf\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a \u0db4\u0dcf\u0db6\u0dbd \u0dbb\u0dd9\u0da2\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 (MIR) \u0dc3\u0dc4 \u0dba\u0dd4\u0db0 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db8\u0dcf\u0dc3\u0dca\u0da7\u0dbb\u0dca \u0da2\u0dd9\u0db1\u0dbb\u0dbd\u0dca \u0dba\u0dd4\u0db0\u0ddd\u0db4\u0d9a\u0dbb\u0dab (MGO) \u0dc0\u0dda.",
        "\u0d94\u0dc4\u0dd4 \u0db6\u0dca\u200d\u0dbb\u0dc3\u0dd3\u0dbd\u0dba\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0daf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0d87\u0dad.",
        "2016 \u0dc3\u0dd0\u0db4\u0dca\u0dad\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dba\u0dda \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2 \u0dba\u0dd4\u0daf\u0dca\u0db0\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u2018\u0dbb\u0ddd\u0da9\u0dca \u0da7\u0dd4 \u0db1\u0db1\u0dca\u0daf\u0dd2\u0d9a\u0da9\u0dcf\u0dbd\u0dca\u2019 \u0d9a\u0dd8\u0dad\u0dd2\u0dba\u0d9a\u0dca \u0dbb\u0da0\u0db1\u0dcf \u0d9a\u0dc5\u0dda\u0dba."
      ],
