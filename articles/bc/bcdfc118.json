      "body_line_ents_list": [
        [
          {
            "text": "\u0b95\u0bcb\u0bb5\u0bbf\u0b9f\u0bcd \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bc1\u0b9f\u0bcd\u0baa\u0b95\u0bcd \u0b95\u0bc1\u0bb4\u0bc1",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0b85\u0bb0\u0b9a \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0bae\u0bcd",
            "label": "ORG"
