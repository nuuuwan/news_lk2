    "si": {
      "title": "\u0da2\u0db4\u0dcf\u0db1\u0dba \u0daf\u0dd0\u0db1\u0dca \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0d8b\u0daf\u0dc0\u0dca \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dc4\u0dd0",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d8a\u0dba\u0dda \u0daf\u0dd2\u0db1 \u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dd6 \u0d9a\u0ddc\u0dc5\u0db9 \u0da2\u0db4\u0dcf\u0db1 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 Mizukoshi Hideaki \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db8\u0dd6\u0dbd\u0dca\u200d\u0dba \u0d86\u0db0\u0dcf\u0dbb \u0d85\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0dc0\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0d9a\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d92 \u0db1\u0dd2\u0dc3\u0dcf \u0da2\u0db4\u0dcf\u0db1\u0dba \u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0dbb\u0da7\u0da7 \u0dc3\u0dc4\u0dba \u0db1\u0ddc\u0daf\u0dd9\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0db4\u0dc0\u0dc3\u0dcf \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda."
      ],
