        [
          {
            "text": "\u0b90\u0bb0\u0bc7\u0bbe\u0baa\u0bcd\u0baa\u0bbf\u0baf \u0b92\u0ba9\u0bcd\u0bb1\u0bbf\u0baf\u0bae\u0bcd",
            "label": "ORG"
