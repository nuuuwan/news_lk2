          },
          {
            "text": "\u0db4\u0dd2\u0dbd\u0dd2\u0db4\u0dd3\u0db1\u0dba",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "64 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0dc6\u0dbb\u0dca\u0da9\u0dd2\u0db1\u0db1\u0dca\u0da9\u0dca \u0db8\u0dcf\u0d9a\u0ddd\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d9a\u0dde\u0dad\u0dd4\u0d9a\u0dcf\u0d9c\u0dcf\u0dbb\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd0\u0db1\u0dd2\u0dbd\u0dcf",
            "label": "GPE"
          },
          {
            "text": "92 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0d89\u0db8\u0dd9\u0dbd\u0dca\u0da9\u0dcf",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "\u0db8\u0dcf\u0d9a\u0ddd\u0dc3\u0dca",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "15,000 \u0d9a\u0da7 \u0dc0\u0da9\u0dcf",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dad\u0dd4\u0db1\u0dca",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0dd2\u0dbd\u0dd2\u0db4\u0dd3\u0db1\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0dc6\u0dd2\u0daf\u0dd9\u0dbd\u0dca \u0dbb\u0db8\u0ddd\u0dc3\u0dca",
