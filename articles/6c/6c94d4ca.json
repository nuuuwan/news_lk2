    "si": {
      "title": "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dbd\u0ddd\u0dbd\u0dd3\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0dc0\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dda \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db1\u0dcf\u0dba\u0d9a \u0dc0\u0dd2\u0dbb\u0dcf\u0dad\u0dca \u0d9a\u0ddd\u0dbd\u0dd2 \u0dc3\u0dc4 \u0dbb\u0ddd\u0dc4\u0dd2\u0dad\u0dca \u0dc2\u0dbb\u0dca\u0db8\u0dcf \u0d86\u0db6\u0dcf\u0db0\u0dd2\u0dad \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dbb\u0dc3\u0dd2\u0d9a \u0d9a\u0dba\u0db1\u0dca \u0dc3\u0dda\u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dc4\u0db8\u0dd4\u0dc0\u0dd4\u0dab\u0dcf.",
        "2022 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0dc4\u0dd2\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0d8a\u0dba\u0dda (28) \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0dc3\u0dc4 \u0db4\u0d9a\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0d85\u0dad\u0dbb \u0dad\u0dbb\u0d9f\u0dba \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
        "\u0dc0\u0dd2\u0dbb\u0dcf\u0dad\u0dca \u0d9a\u0ddd\u0dbd\u0dd2 \u0dc3\u0dc4 \u0dbb\u0ddd\u0dc4\u0dd2\u0dad\u0dca \u0dc2\u0dbb\u0dca\u0db8\u0dcf \u0d9c\u0dba\u0dcf\u0db1\u0dca \u0dc3\u0dda\u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dc4\u0db8\u0dd4\u0dc0\u0dd6\u0dba\u0dda \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dba\u0da7 \u0db4\u0dc3\u0dd4 \u0daf\u0dd2\u0db1 (29) \u0dba.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0d9c\u0dba\u0dcf\u0db1\u0dca \u0dc3\u0dda\u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0daf \u0dc0\u0dd2\u0dbb\u0dcf\u0dad\u0dca \u0d9a\u0ddd\u0dbd\u0dd2\u0d9c\u0dda \u0dc0\u0dd2\u0dc0\u0dcf\u0dc4 \u0db8\u0d82\u0d9c\u0dbd\u0dca\u200d\u0dba \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0dba. (\u0d92)"
      ],
