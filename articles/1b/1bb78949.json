    "si": {
      "title": "\u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0db8\u0dd2\u0dbd \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db1\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0db8\u0dd2\u0dbd \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dd2 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "2015 \u0d85\u0d82\u0d9a 5 \u0daf\u0dbb\u0db1 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d96\u0dc2\u0db0 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dda (NMRA) \u0db4\u0db1\u0dad\u0dda 142 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba \u0dba\u0da7\u0dad\u0dda \u0dc3\u0dcf\u0daf\u0db1 \u0dbd\u0daf \u0dbb\u0dd9\u0d9c\u0dd4\u0dbd\u0dcf\u0dc3\u0dd2\u0dc0\u0dbd\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0dd9\u0dc4\u0dd9\u0dc5\u0dd2\u0dba \u0dbb\u0db9\u0dd4\u0d9a\u0dca\u0dc0\u0dd0\u0dbd\u0dca\u0dbd \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3.",
        "2022-09-01 \u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba Scribd \u0dc4\u0dd2 Adaderana Online \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a MRP"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [],
        [
          {
            "text": "\u0dc3\u0dde\u0d9b\u0dca\u0dba\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd9\u0dc4\u0dd9\u0dc5\u0dd2\u0dba \u0dbb\u0db9\u0dd4\u0d9a\u0dca\u0dc0\u0dd0\u0dbd\u0dca\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "142 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba",
            "label": "LAW"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d96\u0dc2\u0db0 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "5",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a MRP \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0daf\u0daf\u0dd9\u0dbb\u0dab \u0d94\u0db1\u0dca\u0dbd\u0dba\u0dd2\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "Scribd",
            "label": "ORG"
