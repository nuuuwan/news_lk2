    "si": {
      "title": "\u0d87\u0dbd\u0dca\u0dbd \u0d94\u0da9\u0dd9\u0dc3\u0dd2\u2019 \u0dad\u0dc0\u0dad\u0dca \u0daf\u0dd2\u0db1 \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dc5\u0db9 \u0dc3\u0dd2\u0da7 \u0db1\u0d9c\u0dbb\u0dcf\u0db1\u0dca\u0dad\u0dbb \u0dc3\u0dad\u0dd2 \u0d85\u0db1\u0dca\u0dad \u0d85\u0db0\u0dd2 \u0dc3\u0dd4\u0d9b\u0ddd\u0db4\u0db7\u0ddd\u0d9c\u0dd3 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5 \u2018\u0d87\u0dbd\u0dca\u0dbd \u0d94\u0da9\u0dd9\u0dc3\u0dd2\u2019 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db8\u0dd9\u0db8 \u0db8\u0dc3 8 \u0dc3\u0dc4 9 \u0daf\u0dd9\u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd\u0da7 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db1\u0dd2\u0dc5\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d89\u0dc4\u0dc5 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a \u0d86\u0d9a\u0dbb\u0dca\u0dc1\u0db1\u0dba\u00a0 \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0dad\u0dca \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d9c\u0db8\u0db1\u0dcf\u0db1\u0dca\u0dad\u0dba\u0d9a\u0dca \u0dc0\u0db1 \u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0db1 \u0db8\u0dd9\u0db8 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba\u00a0 \u0db1\u0dad\u0dbb\u0d9a\u0dbb \u0daf\u0dcf\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d9a\u0dd0\u0db4\u0dd3 \u0db4\u0dd9\u0db1\u0dd9\u0db1 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2."
      ],
