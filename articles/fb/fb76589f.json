          }
        ],
        [
          {
            "text": "\u0b86\u0baf\u0bbf\u0bb0\u0b95\u0bcd\u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bbe\u0ba9",
            "label": "CARDINAL"
          },
          {
            "text": "\u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b9c\u0bc2\u0bb2\u0bc8 1983",
            "label": "DATE"
          },
