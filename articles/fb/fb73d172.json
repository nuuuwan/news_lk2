    "si": {
      "title": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0d86\u0dc4\u0dcf\u0dbb \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db4\u0dc4\u0d9a \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf (23) \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d86\u0dc4\u0dcf\u0dbb \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db4\u0dc4\u0d9a \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dc5 \u0db6\u0dc0 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db4\u0dc3\u0db3 \u0dba\u0dcf\u0db4\u0dcf \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0ddc\u0db1\u0dca\u0db1\u0dd2 \u0dc3\u0db8\u0dca\u0db6\u0dcf (\u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf) \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 21 \u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dc4 \u0db1\u0dcf\u0da9\u0dd4 (\u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf) \u0dbb\u0dd4. 2 \u0d9a\u0dca \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0dbb\u0dd4. 25",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0dc4\u0dcf\u0dbd\u0dca\u0db8\u0dd0\u0dc3\u0dca\u0dc3\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 25 \u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dc4 \u0daf\u0dd4\u0db9\u0dd4\u0dbb\u0dd4 \u0dc3\u0dd3\u0db1\u0dd2 \u0dbb\u0dd4. \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0da7 2 \u0d9a\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dad\u0ddc\u0dc3 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0dc3\u0dd0\u0dbd\u0dca \u0dc0\u0dbd \u0db1\u0dc0 \u0db8\u0dd2\u0dbd \u0d9c\u0dab\u0db1\u0dca \u0db8\u0dd9\u0dc3\u0dda\u0dba."
      ],
