{
  "newspaper_id": "ada-lk",
  "url": "https://www.ada.lk/breaking_news/\u0d85\u0daf-\u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca-\u0dc3\u0dda\u0dc0\u0dcf-400\u0d9a\u0da7-\u0db4\u0db8\u0dab\u0dba\u0dd2/11-394773",
  "time_ut": 1656036748,
  "original_lang": "si",
  "original_title": "\u0d85\u0daf \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0dc3\u0dda\u0dc0\u0dcf 400\u0d9a\u0da7 \u0db4\u0db8\u0dab\u0dba\u0dd2",
  "text_idx": {
    "si": {
      "title": "\u0d85\u0daf \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0dc3\u0dda\u0dc0\u0dcf 400\u0d9a\u0da7 \u0db4\u0db8\u0dab\u0dba\u0dd2",
      "body_lines": [
        "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0db4\u0dbb\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca, \u0d85\u0daf (24\u0daf\u0dcf)\u00a0 \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 400 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db4\u0dba\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0db8\u0dda \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0da7\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0dc3\u0dd2\u0dba \u0d9a\u0db1\u0d9c\u0dcf\u0da7\u0dd4\u0dc0 \u0db4\u0dc5 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0daf \u0d91\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd9\u0dba\u0dd2."
      ]
    },
    "ta": {
      "title": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1 400 \u0ba4\u0bc2\u0ba4\u0bb0\u0b95 \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bb3\u0bcd \u0bae\u0b9f\u0bcd\u0b9f\u0bc1\u0bae\u0bc7 \u0b89\u0bb3\u0bcd\u0bb3\u0ba9",
      "body_lines": [
        "\u0bb5\u0bc6\u0bb3\u0bbf\u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b95\u0bca\u0ba9\u0bcd\u0b9a\u0bbf\u0baf\u0bc2\u0bb2\u0bb0\u0bcd \u0b85\u0bb2\u0bc1\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 \u0bb5\u0bb3\u0bbe\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0bc7\u0bb1\u0bcd\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0baa\u0bb0\u0bbe\u0bae\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0baa\u0bcd \u0baa\u0ba3\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bbe\u0bb0\u0ba3\u0bae\u0bbe\u0b95 \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (24\u0b86\u0bae\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf) 400 \u0bb5\u0bbf\u0ba3\u0bcd\u0ba3\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bbe\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bae\u0bc7 \u0ba4\u0bc2\u0ba4\u0bb0\u0b95 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bb3\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b8e\u0ba9 \u0bb5\u0bc6\u0bb3\u0bbf\u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0ba4\u0ba9\u0bbe\u0bb2\u0bcd \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b85\u0b9a\u0bcc\u0b95\u0bb0\u0bbf\u0baf\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba4\u0bc2\u0ba4\u0bb0\u0b95 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 \u0bb5\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bbe\u0b95 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1 \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3 \u0b85\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1."
      ]
    },
    "en": {
      "title": "Today there are only 400 consular services",
      "body_lines": [
        "Due to maintenance work carried out on the premises of the Consular Affairs Division of the Ministry of External Affairs, today (24th) the Consular Affairs Division will provide services to only 400 applicants, the Ministry of External Affairs stated. The Consular Affairs Division regrets the inconvenience caused by this, the ministry said in a statement."
      ]
    }
  },
  "title": "\u0d85\u0daf \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0dc3\u0dda\u0dc0\u0dcf 400\u0d9a\u0da7 \u0db4\u0db8\u0dab\u0dba\u0dd2",
  "body_lines": [
    "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0db4\u0dbb\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca, \u0d85\u0daf (24\u0daf\u0dcf)\u00a0 \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 400 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db4\u0dba\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0db8\u0dda \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0da7\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0dc3\u0dd2\u0dba \u0d9a\u0db1\u0d9c\u0dcf\u0da7\u0dd4\u0dc0 \u0db4\u0dc5 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0daf \u0d91\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd9\u0dba\u0dd2."
  ],
  "translate": {
    "si": {
      "title": "\u0d85\u0daf \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0dc3\u0dda\u0dc0\u0dcf 400\u0d9a\u0da7 \u0db4\u0db8\u0dab\u0dba\u0dd2",
      "body_lines": [
        "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0db4\u0dbb\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca, \u0d85\u0daf (24\u0daf\u0dcf)\u00a0 \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 400 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db4\u0dba\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0db8\u0dda \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0da7\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dd2\u0dba\u0dd4\u0dbd\u0dbb\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0d82\u0dc1\u0dba \u0dc3\u0dd2\u0dba \u0d9a\u0db1\u0d9c\u0dcf\u0da7\u0dd4\u0dc0 \u0db4\u0dc5 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0daf \u0d91\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd9\u0dba\u0dd2."
      ]
    },
    "ta": {
      "title": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1 400 \u0ba4\u0bc2\u0ba4\u0bb0\u0b95 \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bb3\u0bcd \u0bae\u0b9f\u0bcd\u0b9f\u0bc1\u0bae\u0bc7 \u0b89\u0bb3\u0bcd\u0bb3\u0ba9",
      "body_lines": [
        "\u0bb5\u0bc6\u0bb3\u0bbf\u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b95\u0bca\u0ba9\u0bcd\u0b9a\u0bbf\u0baf\u0bc2\u0bb2\u0bb0\u0bcd \u0b85\u0bb2\u0bc1\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 \u0bb5\u0bb3\u0bbe\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bae\u0bc7\u0bb1\u0bcd\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0baa\u0bb0\u0bbe\u0bae\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0baa\u0bcd \u0baa\u0ba3\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bbe\u0bb0\u0ba3\u0bae\u0bbe\u0b95 \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (24\u0b86\u0bae\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf) 400 \u0bb5\u0bbf\u0ba3\u0bcd\u0ba3\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bbe\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bae\u0bc7 \u0ba4\u0bc2\u0ba4\u0bb0\u0b95 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bb3\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b8e\u0ba9 \u0bb5\u0bc6\u0bb3\u0bbf\u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. \u0b87\u0ba4\u0ba9\u0bbe\u0bb2\u0bcd \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b85\u0b9a\u0bcc\u0b95\u0bb0\u0bbf\u0baf\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba4\u0bc2\u0ba4\u0bb0\u0b95 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 \u0bb5\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bbe\u0b95 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1 \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3 \u0b85\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1."
      ]
    },
    "en": {
      "title": "Today there are only 400 consular services",
      "body_lines": [
        "Due to maintenance work carried out on the premises of the Consular Affairs Division of the Ministry of External Affairs, today (24th) the Consular Affairs Division will provide services to only 400 applicants, the Ministry of External Affairs stated. The Consular Affairs Division regrets the inconvenience caused by this, the ministry said in a statement."
      ]
    }
  }
}