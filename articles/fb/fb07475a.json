    "si": {
      "title": "43 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0dbd\u0dc3\u0dda\u0db1\u0dcf\u0dc0\u0dda \u0da0\u0db8\u0dca\u0db4\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a \u0da2\u0dc0\u0dd2\u0db4\u0dd9 \u0db1\u0dcf\u0dba\u0d9a\u0dba\u0dcf \u0dc4\u0db8\u0dd4\u0dc0\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dcf\u0da8\u0dbd\u0dd3 \u0da0\u0db8\u0dca\u0db4\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca 43 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0dbd\u0dc3\u0dda\u0db1\u0dcf\u0dc0\u0dda \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0d85\u0daf \u0da2\u0db1\u0dad\u0dcf \u0dc0\u0dd2\u0db8\u0dd4\u0d9a\u0dca\u0dad\u0dd2 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0db1\u0dcf\u0dba\u0d9a \u0d85\u0db1\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0da2\u0dc0\u0dd2\u0db4\u0dd9 \u0db8\u0dd4\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0dc4\u0db8\u0dd4\u0dc0\u0dd2\u0dba.",
        "43 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0dc5\u0d9a\u0dcf\u0dba \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0da8\u0dbd\u0dd3 \u0da0\u0db8\u0dca\u0db4\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a, \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db4\u0dbb\u0dab\u0dc0\u0dd2\u0dad\u0dcf\u0db1, \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dc0\u0dbb\u0dca\u0dab\u0dc3\u0dd2\u0d82\u0dc4, \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc3\u0dda\u0d9a\u0dbb \u0dc3\u0dc4 \u0dc3\u0dd4\u0db8\u0dda\u0daf\u0dcf \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dba\u0d9a \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4 \u0db8\u0dd9\u0db8 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0da2\u0dc0\u0dd2\u0db4\u0dd9 \u0db1\u0dcf\u0dba\u0d9a \u0d85\u0db1\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a, \u0da2\u0dc0\u0dd2\u0db4\u0dd9 \u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd \u0dc3\u0db7\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc0\u0db1 \u0dc3\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0dc4\u0daf\u0dd4\u0db1\u0dca\u0db1\u0dd9\u0dad\u0dca\u0dad\u0dd2 \u0dc3\u0dc4 \u0dbd\u0dcf\u0dbd\u0dca\u0d9a\u0dcf\u0db1\u0dca\u0dad \u0da2\u0dc0\u0dd2\u0db4\u0dd9 \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dc5\u0dc4.",
        "\u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dca\u0dad\u0dda \u0dbb\u0da7\u0dda \u0dc0\u0dad\u0dca\u0db8\u0db1\u0dca \u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0\u0dba\u0dd2.",
        "\u0da2\u0db1\u0dad\u0dcf \u0dc0\u0dd2\u0db8\u0dd4\u0d9a\u0dca\u0dad\u0dd2 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba\u0dda \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dc0\u0dd4\u0dc6\u0dca \u0dc4\u0d9a\u0dd3\u0db8\u0dca \u0daf \u0dc4\u0db8\u0dd4\u0dc0\u0dd4\u0dab\u0dcf. (\u0d85\u0da2\u0dd2\u0dad\u0dca \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1)"
      ],
      "title_ents": [
        {
          "text": "43 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0dbd\u0dc3\u0dda\u0db1\u0dcf\u0dc0",
          "label": "ORG"
        },
        {
          "text": "\u0da0\u0db8\u0dca\u0db4\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a",
          "label": "ORG"
        },
        {
          "text": "\u0da2.\u0dc0\u0dd2.\u0db4\u0dd9",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "43 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0dbd\u0dc3\u0dda\u0db1\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0da8\u0dbd\u0dd3 \u0da0\u0db8\u0dca\u0db4\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0da2.\u0dc0\u0dd2.\u0db4\u0dd9",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0da2.\u0dc0\u0dd2.\u0db4\u0dd9",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db4\u0dbb\u0dab\u0dc0\u0dd2\u0dad\u0dcf\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dc0\u0dbb\u0dca\u0dab\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0da2.\u0dc0\u0dd2.\u0db4\u0dd9",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0dc4\u0daf\u0dd4\u0db1\u0dca\u0db1\u0dd9\u0dad\u0dca\u0dad\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dbd\u0dcf\u0dbd\u0dca \u0d9a\u0dcf\u0db1\u0dca\u0dad",
            "label": "PERSON"
          },
          {
            "text": "\u0da2.\u0dc0\u0dd2.\u0db4\u0dd9",
            "label": "PRODUCT"
          }
        ],
        [],
        [
          {
            "text": "\u0da2.\u0dc0\u0dd2.\u0db4\u0dd9",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0ddc\u0d82\u0d9c\u0dca\u0dbb\u0dc3\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dc0\u0dd4\u0dc6\u0dca \u0dc4\u0d9a\u0dd3\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0da2\u0dd2\u0dad\u0dca \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          }
        ]
      ]
    },
    "ta": {
      "title": "43\u0bb5\u0ba4\u0bc1 \u0baa\u0b9f\u0bc8\u0baf\u0ba3\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95 \u0bb0\u0ba3\u0bb5\u0b95\u0bcd\u0b95 \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bb2\u0bbf \u0b9a\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95 \u0bb0\u0ba3\u0bb5\u0b95\u0bcd\u0b95 \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bbe\u0ba9 43 \u0b86\u0bb5\u0ba4\u0bc1 \u0baa\u0b9f\u0bc8\u0baf\u0ba3\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bc1\u0bb4\u0bc1\u0bb5\u0bbf\u0ba9\u0bb0\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0b85\u0ba9\u0bc1\u0bb0\u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0ba4\u0bbf\u0bb8\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95\u0bb5\u0bc8 \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd.",
        "43\u0bb5\u0ba4\u0bc1 \u0baa\u0bbf\u0bb0\u0bbf\u0baa\u0bc7\u0b9f\u0bc1 \u0b9a\u0bbe\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bb2\u0bbf \u0b9a\u0bae\u0bcd\u0baa\u0bbf\u0b95\u0bcd\u0b95 \u0bb0\u0ba3\u0bb5\u0b95\u0bcd\u0b95, \u0b95\u0bb0\u0bc1\u0ba3\u0bbe\u0bb0\u0ba4\u0bcd\u0ba9 \u0baa\u0bb0\u0ba3\u0bb5\u0bbf\u0ba4\u0bbe\u0ba9, \u0ba8\u0bbf\u0bb7\u0bbe\u0ba8\u0bcd\u0ba4 \u0bb8\u0bcd\u0bb0\u0bc0 \u0bb5\u0bb0\u0bcd\u0ba3\u0b9a\u0bbf\u0b99\u0bcd\u0b95, \u0baa\u0ba8\u0bcd\u0ba4\u0bc1\u0bb2 \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0b9a\u0bc7\u0b95\u0bb0 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bc1\u0bae\u0bc7\u0ba4 \u0bb0\u0ba4\u0bcd\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95 \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf.\u0baf\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0b85\u0ba9\u0bc1\u0bb0\u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0ba4\u0bbf\u0bb8\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95, \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf.\u0baf\u0bbf\u0ba9\u0bcd \u0b85\u0bb0\u0b9a\u0bbf\u0baf\u0bb2\u0bcd \u0baa\u0bc0\u0b9f \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd\u0b95\u0bb3\u0bbe\u0ba9 \u0b9a\u0bc1\u0ba9\u0bbf\u0bb2\u0bcd \u0bb9\u0ba4\u0bc1\u0ba9\u0bcd\u0ba8\u0bc6\u0ba4\u0bcd\u0ba4\u0bbf, \u0bb2\u0bbe\u0bb2\u0bcd\u0b95\u0bbe\u0ba8\u0bcd\u0ba4 \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf.",
        "\u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0ba4\u0bb1\u0bcd\u0baa\u0bcb\u0ba4\u0bc8\u0baf \u0b85\u0bb0\u0b9a\u0bbf\u0baf\u0bb2\u0bcd \u0ba8\u0bbf\u0bb2\u0bb5\u0bb0\u0bae\u0bcd \u0b95\u0bc1\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1\u0bb0\u0bc8\u0baf\u0bbe\u0b9f\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd.",
        "\u0bb8\u0bcd\u0bb0\u0bc0\u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0bae\u0bc1\u0bb8\u0bcd\u0bb2\u0bbf\u0bae\u0bcd \u0b95\u0bbe\u0b99\u0bcd\u0b95\u0bbf\u0bb0\u0bb8\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0bb0\u0bb5\u0bc2\u0baa\u0bcd \u0bb9\u0b95\u0bcd\u0b95\u0bc0\u0bae\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0b9c\u0bc7.\u0bb5\u0bbf.\u0baa\u0bbf.\u0baf\u0bbf\u0ba9\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bbf\u0ba8\u0bbf\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b85\u0ba3\u0bcd\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd. (\u0b85\u0b9c\u0bbf\u0ba4\u0bcd \u0b9a\u0bbf\u0bb1\u0bbf\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9)"
