        ],
        [
          {
            "text": "\u0bb5\u0bc6\u0bb2\u0bbf\u0b95\u0bcd\u0b95\u0b9f\u0bc8 \u0b95\u0bbe\u0bb5\u0bb2\u0bcd\u0ba4\u0bc1\u0bb1\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0b92\u0baa\u0bc7\u0b9a\u0bc7\u0b95\u0bb0\u0baa\u0bc1\u0bb0",
            "label": "GPE"
          },
          {
            "text": "Nanayakkara Mawathi",
            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0bca\u0bb0\u0bb3\u0bc8-\u0b95\u0bcb\u0b9f\u0bae\u0bbf",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0b87\u0bae\u0bcd\u0bae\u0bbe\u0ba4\u0bae\u0bcd 13\u0b86\u0bae\u0bcd \u0ba4\u0bc7\u0ba4\u0bbf \u0b87\u0bb0\u0bb5\u0bc1",
            "label": "TIME"
          },
          {
            "text": "\u0b85\u0bb0\u0b9a\u0bbf\u0baf\u0bb2\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0bb5\u0bc6\u0bb2\u0bbf\u0b95\u0b9f \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1",
