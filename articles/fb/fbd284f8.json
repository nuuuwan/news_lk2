            "label": "ORG"
          },
          {
            "text": "\u0d94\u0db6\u0dda\u0dc3\u0dda\u0d9a\u0dbb\u0db4\u0dd4\u0dbb",
            "label": "GPE"
          },
          {
            "text": "Nanayakkara Mawathi",
