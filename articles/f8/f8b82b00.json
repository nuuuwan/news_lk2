      "body_line_ents_list": [
        [
          {
            "text": "\u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0db1\u0ddd\u0dc4\u0dbb\u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dda\u0dc2\u0dca\u0da8\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
