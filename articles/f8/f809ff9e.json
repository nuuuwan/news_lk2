    "si": {
      "title": "\u0db4\u0dca\u200d\u0dbb\u0dc3\u0dd2\u0daf\u0dca\u0db0 \u0d9c\u0dcf\u0dba\u0d9a\u0dba\u0dd9\u0d9a\u0dca \u0d85\u0db7\u0dcf\u0dc0\u0db4\u0dca\u200d\u0dbb\u0dcf\u0db4\u0dca\u0dad \u0dc0\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d92.\u0d86\u0dbb\u0dca. \u0db6\u0db8\u0dca\u0db6\u0dcf \u0db7\u0dcf\u0d9c\u0dca\u200d\u0dba\u0dcf \u0d9c\u0dcf\u0dba\u0dd2\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0dd2\u0db1\u0db8\u0dcf\u0dc0\u0da7 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0dbb\u0dc4\u0dca\u0db8\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0dd3\u0dad\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0dcf\u0dc0\u0dab\u0dcf\u0db1\u0dca \u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb\u0db4\u0da7\u0dd2\u0dba\u0dd9\u0db1\u0dd2.",
        "\u0d89\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0dbb\u0dc4\u0dca\u0db8\u0dcf\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0dd3\u0dad\u0dba\u0dd9\u0db1\u0dca 2.O, Bigil, Sarkar, Ponniin Selvan-1 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd3\u0dad \u0dbb\u0dd0\u0dc3\u0d9a\u0dca \u0d9c\u0dcf\u0dba\u0db1\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d9a\u0dd9\u0da7\u0dd2 \u0d9a\u0dbd\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dad\u0dd2\u0dbb\u0d9c\u0dad \u0dc0\u0dd6 \u0db4\u0ddc\u0db1\u0dca\u0db1\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0dd9\u0dbd\u0dca\u0dc0\u0db1\u0dca-1 \u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb\u0db4\u0da7\u0dba\u0dda \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u201c\u0db4\u0ddc\u0db1\u0dca\u0db1\u0dcf\u0daf\u0dd3...\u201d \u0d9c\u0dd3\u0dad\u0dba \u0d9c\u0dcf\u0dba\u0db1\u0dcf \u0d9a\u0dc5\u0dda \u0d92.\u0d86\u0dbb\u0dca. \u0d94\u0dc4\u0dd4 \u0dbb\u0dc4\u0dca\u0db8\u0dcf\u0db1\u0dca \u0dc3\u0db8\u0d9f \u0d9c\u0dcf\u0dba\u0db1\u0dcf \u0d9a\u0dc5\u0dda\u0dba. (\u0d92)"
      ],
