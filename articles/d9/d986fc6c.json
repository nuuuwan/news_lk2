          }
        ],
        [
          {
            "text": "\u0da0\u0db8\u0dbd\u0dca \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0dd4\u0daf\u0dd2\u0dad\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dcf\u0db1\u0dca\u0dad\u0dd2 \u0dc3\u0ddc\u0dba\u0dd2\u0dc3\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dba\u0dcf\u0dc2\u0dcf\u0db1\u0dca \u0db1\u0dc0\u0db1\u0dca\u0daf",
            "label": "PERSON"
          },
          {
