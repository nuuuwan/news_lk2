          {
            "text": "\u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db8\u0dbb\u0dab \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf",
