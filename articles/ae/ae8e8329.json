          },
          {
            "text": "\u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda",
            "label": "ORG"
