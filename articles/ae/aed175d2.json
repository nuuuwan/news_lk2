          },
          {
            "text": "\u0ba4\u0bb5\u0bb1\u0bbe\u0ba9 \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf",
            "label": "PRODUCT"
          },
          {
            "text": "\u0ba4\u0bbf\u0bb0\u0bc1\u0b95\u0bcb\u0ba3\u0bae\u0bb2\u0bc8",
            "label": "NORP"
          }
        ],
        [
          {
