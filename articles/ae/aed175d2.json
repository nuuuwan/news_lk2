            "label": "DATE"
          },
          {
            "text": "\u0b95\u0bcb\u0b9f\u0bcd \u0baa\u0bc7 \u0bae\u0bc0\u0ba9\u0bcd\u0bb5\u0bb3\u0ba4\u0bcd \u0ba4\u0bc1\u0bb1\u0bc8\u0bae\u0bc1\u0b95\u0bae\u0bcd",
            "label": "FAC"
          },
          {
            "text": "\u0ba4\u0bbf\u0bb0\u0bc1\u0b95\u0bcb\u0ba3\u0bae\u0bb2\u0bc8",
            "label": "NORP"
          },
          {
