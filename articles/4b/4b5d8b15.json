          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db8\u0dd4\u0dc3\u0db8\u0dca\u0db8\u0dd2\u0dbd\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
