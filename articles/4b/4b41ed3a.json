            "label": "PERSON"
          },
          {
            "text": "\u0b9a\u0bbe\u0ba3\u0b95\u0bcd\u0b95\u0bbf\u0baf\u0ba9\u0bcd \u0bb0\u0bbe\u0b9c\u0bae\u0bbe\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bae\u0bcd",
            "label": "PERSON"
          },
          {
