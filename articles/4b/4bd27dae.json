    "si": {
      "title": "\u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0db4\u0ddc\u0d9a\u0dd4\u0dab\u0da7 \u0dc0\u0dd0\u0da7\u0dd3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 3 \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0db8\u0dbb\u0dd4\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0db1\u0dca\u0dc0\u0dd2\u0dbd, \u0db8\u0da9\u0dd4 \u0d9a\u0dd0\u0dbd\u0dda \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0dc3\u0dd4\u0dbb\u0dad\u0dbd\u0dca \u0db8\u0dc3\u0dd4\u0db1\u0dca \u0d87\u0dad\u0dd2\u0d9a\u0dbb\u0db1 \u0db4\u0ddc\u0d9a\u0dd4\u0dab\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dd6\u0dbb\u0dd4\u0daf\u0dd4 3\u0d9a \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0db8\u0dd2\u0daf\u0dd4\u0dbd\u0dda \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0ddc\u0d9a\u0dd4\u0dab\u0da7 \u0dc0\u0dd0\u0da7\u0dd2 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dba\u0dd2. \u0db8\u0dd8\u0dad \u0dc1\u0dbb\u0dd3\u0dbb\u0dba \u0db8\u0da9\u0dd4\u0d9a\u0dd0\u0dbd\u0dda \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.\u0db4\u0db1\u0dca\u0dc0\u0dd2\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dba\u0dd2."
      ],
