          },
          {
            "text": "\u0db8\u0dbd\u0dbd\u0dca\u0d9c\u0ddc\u0da9",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dbd\u0dca.\u0da7\u0dd3.\u0db6\u0dd3. \u0daf\u0dd9\u0dc4\u0dd2\u0daf\u0dd9\u0dab\u0dd2\u0dba",
            "label": "ORG"
