            "label": "PERSON"
          },
          {
            "text": "\u0b95\u0bc6\u0bb9\u0bb2\u0bbf\u0baf \u0bb0\u0bae\u0bcd\u0baa\u0bc1\u0b95\u0bcd\u0bb5\u0bc6\u0bb2\u0bcd\u0bb2",
            "label": "PERSON"
          },
          {
            "text": "\u0b9a\u0bc6\u0baa\u0bcd\u0b9f\u0bae\u0bcd\u0baa\u0bb0\u0bcd 01, 2022",
            "label": "DATE"
          }
        ],
        [
          {
