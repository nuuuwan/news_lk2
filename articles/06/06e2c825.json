          }
        ],
        [
          {
            "text": "\u0baa\u0bc2\u0b9a\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0baf\u0bb2\u0bcd \u0ba8\u0bbf\u0baa\u0bc1\u0ba3\u0bb0\u0bcd",
