    "si": {
      "title": "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0d9c\u0dda \u0db1\u0dcf\u0dc3\u0dca \u0db4\u0ddc\u0dbd\u0dca\u0dbd \u0d9a\u0dd0\u0da9\u0dd9\u0db1\u0dca\u0db1 \u0d9c\u0dc4\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0dc5\u0dd4\u0dad\u0dbb \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dba\u0dd9\u0d9a\u0dca \u0db4\u0dd0\u0daf\u0dc0\u0dd6 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0d85\u0daf(01\u0daf\u0dcf)\u00a0 \u0dc3\u0dd2\u0dc0\u0dd2\u0dbd\u0dca \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db6\u0dc5\u0d9a\u0dcf \u0db1\u0dd2\u0dc5\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dd4 \u0d9c\u0dd0\u0da7\u0dd3\u0db8\u0dda \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0d9a\u0dca \u0db8\u0dd4\u0dbd\u0dca \u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dba\u0dcf\u0da7 \u0db1\u0dcf\u0dc3\u0dca \u0db4\u0ddc\u0dbd\u0dca\u0dbd \u0db4\u0dd4\u0db4\u0dd4\u0dbb\u0dcf\u0dba\u0db1 \u0dbd\u0dd9\u0dc3 \u0dc4\u0dd9\u0dbd\u0dca\u0db8\u0da7\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dbb \u0daf\u0dd4\u0db1\u0dca \u0db6\u0dc0 \u0d9a\u0dd2\u0dba\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4 \u0dc3\u0ddc\u0dba\u0dcf \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0db6\u0dc0 \u0d9a\u0dc5\u0dd4\u0dad\u0dbb \u0daf\u0d9a\u0dd4\u0dab \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db4\u0dc4\u0dbb \u0d9a\u0dd1\u0db8\u0dd9\u0db1\u0dca \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d9c\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dca\u0dad\u0dda, \u0db8\u0ddc\u0dbb\u0ddc\u0db1\u0dca\u0dad\u0dd4\u0da9\u0dd4\u0dc0 , \u0db8\u0dc4 \u0d9c\u0ddd\u0db1\u0daf\u0dd6\u0dc0 , \u0db1\u0dcf\u0d9c\u0dc4\u0dc0\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d9c\u0db8\u0d9c\u0dda \u0d85\u0dbb\u0dd4\u0dab \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf\u00a0 \u0db1\u0db8\u0dd0\u0dad\u0dd2 40 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db4\u0dc4\u0dbb\u0d9a\u0dd1\u0db8\u0da7 \u0dbd\u0d9a\u0dca \u0dad\u0dd0\u0db1\u0dd0\u0dad\u0dca\u0dad\u0dcf \u0d9a\u0dbd\u0dd4\u0dad\u0dbb \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u00a0 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db6\u0dbb\u0dc0\u0dcf \u0dbb\u0ddd\u0d9c \u0d9a\u0dd3\u0da7 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc3\u0dc4\u0dcf\u0dba\u0d9a\u0dba\u0d9a\u0dd4\u00a0 \u0dbd\u0dd9\u0dc3\u0dd2\u0db1\u0dca \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd2 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0d94\u0dc4\u0dd4\u00a0 \u0d9a\u0dc5\u0dd4\u0dad\u0dbb\u00a0 \u0db8\u0dd0\u0daf \u0db4\u0dcf\u0dbb\u0dda \u0d9c\u0dcf\u0dbd\u0dd4 \u0daf\u0dd9\u0dc3\u0da7 \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0db4\u0daf\u0dd2\u0d9a \u0db8\u0dcf\u0dbb\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0dbb \u0db8\u0dcf\u0dbb\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba \u0dc3\u0dd2\u0dc0\u0dd2\u0dbd\u0dca \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db6\u0dc5\u0d9a\u0dcf \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dba\u0d9a\u0dd4\u0d9c\u0dda \u0d9a\u0d9a\u0dd4\u0dbd\u0dda \u0dba\u0db1\u0dca\u0dad\u0db8\u0dd2\u0db1\u0dca \u0d9c\u0dd0\u0da7\u0dd3\u00a0 \u0d85\u0db1\u0dad\u0dd4\u0dbb \u0dc3\u0db8\u0dae\u0dba\u0d9a\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda .",
        "\u0d92 \u0db8\u0ddc\u0dc4\u0ddc\u0dad\u0dda \u0d87\u0dad\u0dd2\u0dc0\u0dd6 \u0d9a\u0dad\u0dcf\u0db6\u0dc4\u0da7 \u0d92 \u0d85\u0dc3\u0dbd\u0dd2\u0db1\u0dca \u0d9c\u0db8\u0db1\u0dca \u0d9c\u0dad\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0d9a\u0dd4\u0daf\u00a0 \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb , \u0db4\u0dc3\u0dd4\u0dc0 \u0d94\u0dc4\u0dd4 \u0d85\u0dad \u0dad\u0dd2\u0db6\u0dd6 \u0dc4\u0dd9\u0dbd\u0dca\u0db8\u0da7\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf\u0d9c\u0dda \u0db8\u0dd4\u0dc4\u0dd4\u0dab\u0da7 \u0dc0\u0dd0\u0dbb\u0dd9\u0db1\u0dca \u0db4\u0dc4\u0dbb\u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda\u00a0 \u0dc3\u0daf\u0dc4\u0db1\u0dca\u0dc0 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2 .",
        "\u0db4\u0dc4\u0dbb\u0d9a\u0dd1\u0db8\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd6 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0d9a\u0dc5\u0dd4\u0dad\u0dbb\u00a0 \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca \u0d9a\u0dbb\u00a0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca, \u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db1\u0dcf\u0dc3\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d85\u0dc3\u0dca\u0dae\u0dd2\u0dba\u0da7 \u0dc4\u0dcf\u0db1\u0dd2 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dca\u0daf \u0dba\u0db1\u0dca\u0db1 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd6\u0d9a\u0dca\u0dc2\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d92\u0d9a\u0d9a\u0dba\u0da7 \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca \u0d9a\u0dbb \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d86\u0dbb\u0d82\u0da0\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0daf\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db4\u0dc4\u0dbb\u0daf\u0dd3 \u0db4\u0dbd\u0dcf\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2\u00a0 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf \u0dc3\u0ddc\u0dba\u0dcf \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d9a\u0dc5\u0dd4\u0dad\u0dbb \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a \u0dc3\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dd2 \u0d85\u0d82\u0dc1 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf\u00a0 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dad\u0dd2."
      ],
