  "original_title": "\u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0dc3\u0dca\u0dc0\u0dcf\u0db0\u0dd3\u0db1 \u0dc0\u0dd9\u0dba\u0dd2",
