    "ta": {
      "title": "\u0baa\u0bc6\u0bb2\u0bcd\u0b9c\u0bbf\u0baf \u0b95\u0bbf\u0bb0\u0bbe\u0ba3\u0bcd\u0b9f\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0b95\u0bcd\u0bb8\u0bcd \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bc6\u0bb0\u0bcd\u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd\u0baa\u0ba9\u0bcd \u0baa\u0baf\u0ba3\u0bae\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0bae\u0bc7\u0b95\u0bcd\u0bb8\u0bcd \u0bb5\u0bc6\u0bb0\u0bcd\u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd\u0baa\u0ba9\u0bcd \u0ba4\u0ba9\u0ba4\u0bc1 \u0b95\u0bbf\u0bb0\u0bbf\u0b9f\u0bcd \u0baa\u0bc6\u0ba9\u0bbe\u0bb2\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bc8 \u0b87\u0bb2\u0b95\u0bc1\u0bb5\u0bbe\u0b95\u0b9a\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bc1, 2022 \u0baa\u0bc6\u0bb2\u0bcd\u0b9c\u0bbf\u0baf \u0b95\u0bbf\u0bb0\u0bbe\u0ba3\u0bcd\u0b9f\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0b95\u0bcd\u0bb8\u0bc8 P14 \u0b87\u0bb2\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b9a\u0bc6\u0bb0\u0bcd\u0b9c\u0bbf\u0baf\u0bcb \u0baa\u0bc6\u0bb0\u0bc6\u0bb8\u0bbe\u0bb2\u0bcd \u0b86\u0ba4\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb0\u0bc6\u0b9f\u0bcd \u0baa\u0bc1\u0bb2\u0bcd \u0b92\u0ba9\u0bcd\u0bb1\u0bc1-\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd, \u0b85\u0ba4\u0bc7 \u0ba8\u0bc7\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0bcb\u0bb2\u0bcd-\u0b9a\u0bbf\u0b9f\u0bcd\u0b9f\u0bb0\u0bcd \u0b95\u0bbe\u0bb0\u0bcd\u0bb2\u0bcb\u0bb8\u0bcd \u0b9a\u0bc8\u0ba9\u0bcd\u0bb8\u0bcd \u0b83\u0baa\u0bc6\u0bb0\u0bbe\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc1 P3 \u0b90 \u0bae\u0bc1\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0bb2\u0bc2\u0baf\u0bbf\u0bb8\u0bcd \u0bb9\u0bbe\u0bae\u0bbf\u0bb2\u0bcd\u0b9f\u0ba9\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb \u0b85\u0bb2\u0bcb\u0ba9\u0bcd\u0b9a\u0bcb \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0bb2\u0bc7\u0baa\u0bcd 1 \u0b87\u0bb2\u0bcd \u0bb2\u0bc6\u0bb8\u0bcd \u0b95\u0bcb\u0bae\u0bcd\u0baa\u0bcd\u0bb8\u0bbf\u0bb2\u0bcd \u0b9a\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bcd, \u0bae\u0bc6\u0bb0\u0bcd\u0b9a\u0bbf\u0b9f\u0bbf\u0bb8\u0bcd \u0b9f\u0bbf\u0bb0\u0bc8\u0bb5\u0bb0\u0bc8 \u0baa\u0ba8\u0bcd\u0ba4\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc7\u0bb1\u0bcd\u0bb1\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd, \u0bb5\u0bbe\u0bb2\u0bcd\u0b9f\u0bc7\u0bb0\u0bbf \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbe\u0bb8\u0bcd \u0ba8\u0bbf\u0b95\u0bcd\u0b95\u0bcb\u0bb2\u0bb8\u0bcd \u0bb2\u0bbe\u0b9f\u0bbf\u0b83\u0baa\u0bbf\u0baf\u0bc8\u0ba4\u0bcd \u0ba4\u0bb5\u0bbf\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb2\u0bc7\u0baa\u0bcd 2 \u0b87\u0bb2\u0bcd \u0b92\u0bb0\u0bc1 \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0b95\u0bbe\u0bb0\u0bc8 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc7 \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0ba8\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0bae\u0bb1\u0bc1\u0ba4\u0bca\u0b9f\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bb0\u0bcd\u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd\u0baa\u0ba9\u0bcd \u0b8e\u0b9f\u0bcd\u0b9f\u0bbe\u0bb5\u0ba4\u0bc1 \u0b87\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0b85\u0ba4\u0bc7 \u0ba8\u0bc7\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b9a\u0bc8\u0ba9\u0bcd\u0bb8\u0bcd \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bbe\u0ba9 \u0baa\u0bc6\u0bb0\u0bc6\u0bb8\u0bcd - \u0bb2\u0bc6\u0b95\u0bcd\u0bb2\u0bc6\u0bb0\u0bcd\u0b95\u0bcd \u0ba4\u0ba9\u0ba4\u0bc1 \u0baa\u0bbf\u0bb0\u0bc7\u0b95\u0bcd \u0b9f\u0b95\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0b92\u0bb0\u0bc1 \u0b95\u0bbf\u0bb4\u0bbf\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b8a\u0b9f\u0b95\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0bbf\u0b9f\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0baf \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba4\u0bc1. \u0bb5\u0bc6\u0bb0\u0bcd\u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd\u0baa\u0bc6\u0ba9\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bcb\u0b95\u0bcd\u0b95\u0bbf\u0b9a\u0bcd \u0b9a\u0bc6\u0bb2\u0bcd\u0bb2\u0bc1\u0bae\u0bcd \u0b95\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bc8 \u0bb5\u0bbf\u0bb0\u0bc8\u0bb5\u0bbe\u0b95\u0b9a\u0bcd \u0b9a\u0bc6\u0baf\u0bb2\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd, \u0baa\u0bc6\u0bb0\u0bc6\u0bb8\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bc8\u0ba9\u0bcd\u0bb8\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc8 \u0bae\u0b9f\u0bcd\u0b9f\u0bc1\u0bae\u0bc7 \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb2\u0bc7\u0baa\u0bcd 8 \u0b87\u0bb2\u0bcd P3 \u0b87\u0bb2\u0bcd \u0bb8\u0bcd\u0bb5\u0bc0\u0baa\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0bb2\u0bc7\u0baa\u0bcd 12 \u0b87\u0bb2\u0bcd, \u0baa\u0bc6\u0bb0\u0bc6\u0bb8\u0bcd \u0bb5\u0bc6\u0bb0\u0bcd\u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd\u0baa\u0ba9\u0bc8\u0b95\u0bcd \u0b95\u0b9f\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0b95\u0bcd\u0b95 \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0baa\u0bcb\u0ba4\u0bc1, \u200b\u200b\u0b9a\u0bc8\u0ba9\u0bcd\u0bb8\u0bcd \u0b9a\u0bbe\u0b83\u0baa\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0bae\u0bc0\u0b9f\u0bbf\u0baf\u0bae\u0bcd\u0bb8\u0bcd \u0bb5\u0bb0\u0bc8 \u0b86\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd. \u0b9f\u0b9a\u0bcd\u0b9a\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0bb0\u0bb0\u0bcd \u0bb2\u0bc7\u0baa\u0bcd 15 \u0bb5\u0bb0\u0bc8 \u0ba4\u0ba9\u0ba4\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0bb2\u0bc8\u0baf\u0bc8 \u0ba8\u0bc0\u0b9f\u0bcd\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1, \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0b9f\u0bc8\u0bb5\u0bc8 \u0b9a\u0bc8\u0ba9\u0bcd\u0bb8\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0ba4\u0bcd \u0ba4\u0bbf\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0bbf, \u0bb2\u0bc7\u0baa\u0bcd 19 \u0b87\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0bb2\u0bc8 \u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd - \u0bb2\u0bc7\u0baa\u0bcd 31 \u0b87\u0bb2\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bca\u0bb0\u0bc1 \u0b87\u0bb2\u0bb5\u0b9a \u0baa\u0bbf\u0b9f\u0bcd \u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 - \u0bae\u0bc7\u0bb2\u0bbe\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0b95\u0bcd \u0b95\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0bb2\u0bcd 18 \u0bb5\u0bbf\u0ba9\u0bbe\u0b9f\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd \u0baa\u0bc6\u0bb0\u0bc6\u0bb8\u0bc8 \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd. \u0bae\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0bc1\u0bb5\u0b95\u0bcd\u0b95.",
        "\u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0ba4\u0bbe\u0b95 \u0b9a\u0bbe\u0bb0\u0bcd\u0bb2\u0bb8\u0bcd \u0bb2\u0bc6\u0b95\u0bcd\u0bb2\u0bc6\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bc8\u0ba4\u0bcd \u0ba4\u0bbe\u0ba3\u0bcd\u0b9f\u0bbf\u0baf \u0bae\u0bc6\u0bb0\u0bcd\u0b9a\u0bbf\u0b9f\u0bbf\u0bb8\u0bbf\u0ba9\u0bcd \u0b9c\u0bbe\u0bb0\u0bcd\u0b9c\u0bcd \u0bb0\u0bb8\u0bcd\u0bb8\u0bb2\u0bc8 \u0bb5\u0bbf\u0b9f \u0b9a\u0bc8\u0ba9\u0bcd\u0bb8\u0bcd \u0bae\u0bc7\u0b9f\u0bc8\u0baf\u0bc8 \u0ba8\u0bbf\u0bb1\u0bc8\u0bb5\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0b86\u0ba9\u0bbe\u0bb2\u0bcd \u0b85\u0bb5\u0bb0\u0bcd \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb5\u0bbf\u0ba9\u0bbe\u0b9f\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd \u0b87\u0bb1\u0bc1\u0ba4\u0bbf \u0bae\u0bc7\u0b9f\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0bcb\u0bb1\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd.",
        "\u0bb2\u0bc6\u0b95\u0bcd\u0bb2\u0bc6\u0bb0\u0bcd\u0b95\u0bcd \u0bae\u0bbf\u0b95 \u0bb5\u0bc7\u0b95\u0bae\u0bbe\u0b95 \u0bae\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b8f\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0baf\u0bb1\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bae\u0bc6\u0ba9\u0bcd\u0bae\u0bc8\u0baf\u0bbe\u0ba9 \u0b9f\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba4\u0bbe\u0bae\u0ba4\u0bae\u0bbe\u0b95 \u0baa\u0bbf\u0b9f\u0bcd \u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0b86\u0ba9\u0bbe\u0bb2\u0bcd \u0baa\u0bcb\u0ba9\u0bb8\u0bcd \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf\u0baf\u0bc8\u0ba4\u0bcd \u0ba4\u0bb5\u0bb1\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd, \u0bae\u0bc7\u0bb2\u0bc1\u0bae\u0bcd \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb \u0b85\u0bb2\u0bcb\u0ba9\u0bcd\u0b9a\u0bcb\u0bb5\u0bc8 \u0bb5\u0bbf\u0b9f P5 \u0b90 \u0bae\u0b9f\u0bcd\u0b9f\u0bc1\u0bae\u0bc7 \u0baa\u0bbf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd. \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bc1\u0bae\u0bcd, \u0baa\u0bbf\u0b9f\u0bcd \u0bb2\u0bc7\u0ba9\u0bbf\u0bb2\u0bcd \u0bb5\u0bc7\u0b95\u0bae\u0bbe\u0b95\u0b9a\u0bcd \u0b9a\u0bc6\u0ba9\u0bcd\u0bb1\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0b95 \u0baa\u0bbf\u0b9f\u0bbf\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0bbf\u0bb1\u0b95\u0bc1, \u0b90\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0ba9\u0bbe\u0b9f\u0bbf \u0baa\u0bc6\u0ba9\u0bbe\u0bb2\u0bcd\u0b9f\u0bbf \u0b85\u0bb5\u0bb0\u0bc8 P6 \u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bc0\u0bb4\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0ba4\u0bc1.",
        "\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0bae\u0bc1\u0bb1\u0bc8 \u0b9a\u0bbe\u0bae\u0bcd\u0baa\u0bbf\u0baf\u0ba9\u0bbe\u0ba9 \u0b83\u0baa\u0bc6\u0bb0\u0bbe\u0bb0\u0bbf \u0b95\u0b9f\u0bc8\u0b9a\u0bbf \u0bae\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b83\u0baa\u0bc6\u0bb0\u0bbe\u0bb0\u0bbf\u0baf\u0bbe\u0bb2\u0bcd \u0bae\u0bc0\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0b95\u0b9f\u0ba8\u0bcd\u0ba4\u0bc1 \u0b9a\u0bc6\u0ba9\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd, \u0b86\u0ba9\u0bbe\u0bb2\u0bcd \u0baa\u0ba8\u0bcd\u0ba4\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0ba4\u0bbe\u0bae\u0ba4\u0bae\u0bbe\u0b95 \u0b9a\u0bc6\u0baa\u0bbe\u0bb8\u0bcd\u0b9f\u0bbf\u0baf\u0ba9\u0bcd \u0bb5\u0bc6\u0b9f\u0bcd\u0b9f\u0bb2\u0bcd (\u0baa\u0bbf 8) \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bbf\u0baf\u0bb0\u0bcd \u0b95\u0bc7\u0bb8\u0bcd\u0bb2\u0bbf (\u0baa\u0bbf 9) \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc8 \u0bae\u0bbe\u0bb1\u0bcd\u0bb1\u0bbf\u0baf\u0bae\u0bc8\u0ba4\u0bcd\u0ba4 \u0b85\u0ba3\u0bbf\u0ba4\u0bcd \u0ba4\u0bcb\u0bb4\u0bb0\u0bcd \u0b8e\u0bb8\u0bcd\u0b9f\u0bc6\u0baa\u0ba9\u0bcd \u0b93\u0b95\u0bbe\u0ba9\u0bc8 \u0bb5\u0bbf\u0b9f \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7\u0bb1\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd. \u0b85\u0bb2\u0bc6\u0b95\u0bcd\u0bb8\u0bcd \u0b86\u0bb2\u0bcd\u0baa\u0ba9\u0bcd \u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0bae\u0bcd\u0bb8\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd 10 \u0b87\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0b87\u0bb1\u0bc1\u0ba4\u0bbf\u0baa\u0bcd \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0bb2\u0bbe\u0ba9\u0bcd\u0bb8\u0bcd \u0bb8\u0bcd\u0b9f\u0bcd\u0bb0\u0bcb\u0bb2\u0bc8\u0ba4\u0bcd \u0ba4\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0bb1\u0bbe\u0bb0\u0bcd.",
        "\u0baa\u0ba8\u0bcd\u0ba4\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0b9f\u0bbf\u0bb5\u0bbf\u0bb2\u0bcd \u0bb2\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb \u0ba8\u0bcb\u0bb0\u0bbf\u0bb8\u0bcd \u0b85\u0bb2\u0bcd\u0baa\u0bbe\u0ba9\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb8\u0bcd\u0b9f\u0bcd\u0bb0\u0bcb\u0bb2\u0bc8 \u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0bb0\u0bbe\u0b9f\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd, \u0b86\u0ba9\u0bbe\u0bb2\u0bcd \u0bae\u0bc6\u0b95\u0bcd\u0bb2\u0bbe\u0bb0\u0ba9\u0bcd \u0b93\u0b9f\u0bcd\u0b9f\u0bc1\u0ba8\u0bb0\u0bcd \u0b86\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bc1 12\u0bb5\u0ba4\u0bc1 \u0b87\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0b85\u0bb5\u0bb0\u0bcd \u0b86\u0bb2\u0bcd\u0b83\u0baa\u0bbe \u0bb0\u0bcb\u0bae\u0bbf\u0baf\u0bcb\u0bb5\u0bbf\u0ba9\u0bcd \u0b9c\u0bbe\u0bb5\u0bcd \u0b95\u0bc1\u0bb5\u0bbe\u0ba9\u0bcd\u0baf\u0bc1\u0bb5\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bbe\u0b95 \u0ba4\u0bbe\u0bae\u0ba4\u0bae\u0bbe\u0ba9 \u0baa\u0ba8\u0bcd\u0ba4\u0baf\u0baa\u0bcd \u0baa\u0bcb\u0bb0\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1 \u0baf\u0bc1\u0b95\u0bbf \u0b9a\u0bc1\u0ba9\u0bcb\u0b9f\u0bbe\u0bb5\u0bc8 \u0bb5\u0bbf\u0b9f \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7\u0bb1\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0ba4\u0bc1 \u0bb9\u0bbe\u0bb8\u0bcd \u0b9c\u0bcb\u0b9f\u0bbf\u0baf\u0bc8 \u0bb5\u0bbf\u0b9f P15 \u0b87\u0bb2\u0bcd \u0b9f\u0bc7\u0ba9\u0bbf\u0baf\u0bb2\u0bcd \u0bb0\u0bbf\u0b9a\u0bcd\u0b9a\u0bbf\u0baf\u0bbe\u0bb0\u0bcd\u0b9f\u0bcb\u0bb5\u0bc8 \u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1\u0b9a\u0bcd \u0b9a\u0bc6\u0ba9\u0bcd\u0bb1\u0ba4\u0bc1 - \u0b95\u0bc6\u0bb5\u0bbf\u0ba9\u0bcd \u0bae\u0bc7\u0b95\u0bcd\u0ba9\u0bc1\u0b9a\u0bc6\u0ba9\u0bcd 16\u0bb5\u0ba4\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bbf\u0b95\u0bcd \u0bb7\u0bc2\u0bae\u0bc7\u0b95\u0bcd\u0b95\u0bb0\u0bcd 17\u0bb5\u0ba4\u0bc1 - \u0ba8\u0bbf\u0b95\u0bcd\u0b95\u0bcb\u0bb2\u0bb8\u0bcd \u0bb2\u0ba4\u0bbf\u0b83\u0baa\u0bbf \u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1 \u0baa\u0bbf\u0b9f\u0bcd \u0bb8\u0bcd\u0b9f\u0bbe\u0baa\u0bcd\u0b95\u0bb3\u0bc8 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 18\u0bb5\u0ba4\u0bc1 \u0b87\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd."
