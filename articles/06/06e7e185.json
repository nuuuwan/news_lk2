    "si": {
      "title": "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dbb\u0dd0\u0dc4\u0dd0\u0db1\u0dd9\u0db1\u0dca \u0d86 \u0db8\u0dbb\u0dd4\u0dc0\u0dcf \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0da9\u0dd0\u0dc4\u0dd0 \u0d9c\u0db1\u0dd3",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd0\u0dbd\u0dca\u0dbd\u0dc0\u0dcf\u0dba \u0d9a\u0ddc\u0da7\u0dc0\u0dd9\u0dc4\u0dd9\u0dbb\u0d9c\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dd9\u0dc1\u0dba\u0dda \u0da5\u0dad\u0dd2 \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca \u0d9a\u0dbb\u0db8\u0dca\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 11 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc3\u0dd0\u0dbb \u0dc0\u0dd0\u0daf\u0dd2 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2 .",
        "\u0db8\u0dd9\u0dc3\u0dda \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca\u0dad\u0dda \u0db8\u0dbd\u0dca\u0dc0\u0dad\u0dca\u0dad\u0dcf\u0dc0\u0dbd \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda 06 \u0dc0\u0dc3\u0dbb\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0dd0\u0db6 \u0d86\u0dbb\u0dca \u0d92\u0db8\u0dca \u0db1\u0dd4\u0dc0\u0db1\u0dca \u0db1\u0dd9\u0dad\u0dca\u0dc3\u0dbb \u0db1\u0dd0\u0db8\u0dad\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd2 .",
        "\u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0da5\u0dcf\u0dad\u0dd2 \u0db1\u0dd2\u0dc0\u0dc3\u0d9a\u00a0 \u0dc3\u0dd9\u0dbd\u0dca\u0dbd\u0db8\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d92\u00a0 \u0d85\u0dc3\u0dbd \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0d9a\u0ddc\u0dc3\u0dca\u0d9c\u0dc3\u0d9a\u0dca \u0d85\u0dc3\u0dc5\u0da7 \u0d85\u0da7\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd4 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dbb\u0dd0\u0dc4\u0dd0\u0dab\u0d9a \u0db8\u0dd9\u0db8 \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0db4\u0dd0\u0da7\u0dbd\u0dd2 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u200c\u0db6\u0dda."
      ],
      "title_ents": [],
