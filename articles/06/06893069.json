            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0dbd\u0dd2\u0dad\u0dca \u0dc0\u0dda\u0dbb\u0d9c\u0ddc\u0da9 - \u0dc3\u0db8\u0dd6\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db8\u0dcf\u0db1\u0dc0 \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd4\u0dbd\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0da2\u0dba\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0dbb\u0ddd\u0dc2\u0dd2 \u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dca\u0d9a\u0dcf\u0dbb - \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0dbb\u0ddc\u0da7\u0dbb\u0dd2 \u0dc3\u0db8\u0dcf\u0da2\u0dba \u0dc3\u0dc4 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0ddc\u0dc0\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd0\u0dbd\u0dab\u0dd2\u0dc0\u0dd0\u0dbd\u0dd2 \u0dc0\u0dd0\u0dc0\u0dd2\u0dbd\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d9a\u0dcf\u0dc0\u0dda\u0dbb\u0dd2",
            "label": "LOC"
          },
          {
            "text": "\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8\u0dca \u0daf\u0dca\u200d\u0dbb\u0ddd\u0dab\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "FTG",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0dd2\u0dbd \u0d87\u0d9f\u0dbd\u0dd4\u0db8\u0dca \u0dc0\u0dd2\u0dc3\u0db3\u0dd4\u0db8\u0dca \u0dc3\u0dc4\u0d9a\u0dbb\u0dd4",
            "label": "ORG"
          },
          {
            "text": "J.P. Morgan",
            "label": "PERSON"
