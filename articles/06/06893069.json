        [
          {
            "text": "\u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0dcf\u0dbb\u0d9a \u0dbb\u0db1\u0dca\u0dc0\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3/\u0dc3\u0db8\u0dd6\u0dc4 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
