    "si": {
      "title": "\u0daf\u0d9a\u0dd4\u0dab\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0daf\u0dd2\u0db1 \u0db4\u0dc4\u0db8:\u0dc3\u0dd9\u0dc3\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dca\u0dc0\u0dbd \u0dc3\u0dad\u0dd2\u0dba\u0da7 \u0daf\u0dd2\u0db1 \u0dad\u0dd4\u0db1\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dc4 \u0dbb\u0da2\u0dba\u0dda \u0d85\u0db1\u0dd4\u0db8\u0dad \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc4\u0dd9\u0da7 \u0dc3\u0dd2\u0da7 \u0dba\u0dc5\u0dd2 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db8\u0dd2\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dc3\u0dd1\u0db8 \u0dc3\u0dad\u0dd2\u0dba\u0d9a\u0db8 \u0dc3\u0db3\u0dd4\u0daf\u0dcf,\u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf \u0dc3\u0dc4 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0dc0\u0dda\u0dbd\u0dcf\u0dc0\u0da7 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0d9c\u0dad \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0d89\u0d9c\u0dd0\u0db1\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0daf \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf\u0dc0 \u0dba\u0da7\u0dad\u0dda \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0daf\u0dd2\u0db1 \u0db4\u0dc4\u0dda\u0daf\u0dd3\u0db8 \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf\u0dc0 \u0d9a\u0dd2\u0dba\u0dba\u0dd2."
