    "si": {
      "title": "\u0d85\u0daf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0d9a\u0daf\u0dd2\u0dbb\u0d9c\u0dcf\u0db8\u0db8\u0dca \u0db0\u0da2\u0dba \u0d91\u0dc3\u0dc0\u0dd3\u0db8",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d93\u0dad\u0dd2\u0dc4\u0dcf\u0dc3\u0dd2\u0d9a \u0d9a\u0dad\u0dd2\u0dbb\u0dca\u0d9c\u0dcf\u0db8\u0db8\u0dca \u0d9a\u0db1\u0dca\u0daf\u0db1\u0dca \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0db0\u0da2\u0dba \u0d91\u0dc3\u0dc0\u0dd3\u0db8\u0dda \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0d85\u0daf (29) \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc3\u0dc0\u0dc3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0d85\u0db1\u0dd9\u0d9a\u0dca \u0d85\u0dad\u0da7 \u0d8b\u0da9\u0dc0\u0dba\u0dd2 \u0d9a\u0db3\u0dd4\u0d9a\u0dbb \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0db8\u0dd4\u0dbb\u0dd4\u0d9c\u0db1\u0dca \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db0\u0da2\u0dba \u0d91\u0dc3\u0dc0\u0dd3\u0db8\u0dda \u0db8\u0d82\u0d9c\u0dbd\u0dca\u200d\u0dba\u0dba \u0d91\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d9c\u0dd4\u0dbb\u0dd4 \u0dc1\u0dd2\u0dc0\u0dc3\u0dd2\u0dbb\u0dd2 \u0d9a\u0dda.\u0d9a\u0dda.\u0dc3\u0dd3\u0dad\u0dcf\u0dbb\u0db8\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d85\u0daf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dda.",
        "\u0db0\u0da2\u0dba \u0d91\u0dc3\u0dc0\u0dd3\u0db8, \u0db6\u0dd9\u0dbb\u0dc4\u0dbb \u0d86\u0daf\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0db1 \u0d8b\u0dad\u0dca\u0dc3\u0dc0 \u0daf\u0dd2\u0db1 15 \u0d9a\u0dca \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0d85\u0dad\u0dbb, 12 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d9a\u0dad\u0dd2\u0dbb\u0dca\u0d9c\u0db8\u0dca\u0dc4\u0dd2\u0daf\u0dd3 \u0dad\u0dd3\u0dbb\u0dca\u0dad \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0daf, \u0d91\u0dc3\u0dda\u0db8 11 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d8b\u0daf\u0dca\u0d9c\u0dba\u0dd2 \u0db8\u0dd4\u0dbb\u0dd4\u0d9c\u0db1\u0dca \u0d9a\u0ddd\u0dc0\u0dd2\u0dbd\u0dda \u0dad\u0dd3\u0dbb\u0dca\u0dae \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0daf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dda.",
        "\u0d9a\u0dad\u0dd2\u0dbb\u0dca\u0d9c\u0dcf\u0db8\u0da7\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0d9c\u0db8\u0db1\u0dca \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca \u0d85\u0d9b\u0dab\u0dca\u0da9 \u0dc0\u0dbb\u0dca\u0dc2\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd3\u0da9\u0dcf\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc3\u0dd9\u0dbd\u0dca\u0dc0\u0da0\u0dca \u0dc3\u0db1\u0dca\u0db1\u0dd2\u0db0\u0dd2 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0db4\u0dd2\u0da7\u0dad\u0dca\u0dc0 \u0d9c\u0dd2\u0dba \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db4\u0dcf\u0daf\u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf \u0dc0\u0db1\u0dca\u0daf\u0db1\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 9000\u0d9a\u0dca \u0db4\u0db8\u0dab \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d9a\u0dad\u0dd2\u0dbb\u0dca\u0d9c\u0db8\u0dca \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2."
      ],
