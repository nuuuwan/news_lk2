    "si": {
      "title": "\u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db1\u0dd0\u0dc0\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0daf \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0dc4\u0dcf \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0d85\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0dbb\u0da2\u0dba \u0dc4\u0dbb\u0dc4\u0dcf \u0d95\u0db8\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 40,000\u0d9a\u0dca \u0d9c\u0dd9\u0db1 \u0d91\u0db1 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0d85\u0daf (5\u0daf\u0dcf)\u00a0 \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dc5\u0d9f\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dad\u0dca \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dbb\u0dc5\u0dd4 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8 \u0dbd\u0db6\u0db1 9\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0dbd\u0dca \u0dba\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d87\u0db8\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d87\u0db8\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0db8\u0dda \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0dad\u0dd3\u0dbb\u0dab \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0daf\u0dd3\u0db8\u0dda \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dda\u0daf\u0dd3\u0dba."
      ],
