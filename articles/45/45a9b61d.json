  "original_title": "\u0b9c\u0bcb\u0b9f\u0bbf\u0baf\u0bc8 \u0baa\u0bbe\u0bb0\u0bc1\u0b99\u0bcd\u0b95\u0bb3\u0bcd",
  "text_idx": {
    "en": {
      "title": "Check out the pair",
      "author": "unknown",
      "body_lines": [
        "Protesters have seized the Prime Minister's office in Colombo. A couple who had participated in the struggle to capture him expressed affection for each other."
      ],
