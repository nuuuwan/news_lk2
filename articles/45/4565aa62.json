    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7\u0dad\u0dca \u0d9a\u0ddc\u0da7\u0db1\u0dca\u0db1\u0db1 \u0d9c\u0dd2\u0dba \u0d85\u0dba\u0d9a\u0dd4 \u0db8\u0dd9\u0dbd\u0dca\u0dbd \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0dd4\u0dbb\u0dd4\u0dab\u0dd1\u0d9c\u0dbd  \u0d9c\u0ddd\u0db1\u0d9c\u0db8 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0da7  \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dd9\u0db1\u0dca  \u0db4\u0dd0\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0d91\u0dba",
        "\u0dad\u0dd2\u0dba\u0dab\u0dd4 \u0d86\u0dba\u0dd4\u0daf\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dbb \u0daf\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2 .",
        "\u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4  \u0d85\u0dc3\u0dbd \u0dad\u0dd2\u0db6\u0dd6 \u0db8\u0dcf\u0dc5\u0dd4 \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dbd\u0d9a\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d91\u0dc4\u0dd2 \u0db8\u0db1\u0dca\u0db1\u0dba \u0dbb\u0dd0\u0d9c\u0dd9\u0db1  \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0db1\u0dca\u0da7  \u0db4\u0dc4\u0dbb \u0daf\u0dd3\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db8\u0db1\u0dca\u0db1 \u0db4\u0dc4\u0dbb  \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf   \u0d91\u0d9a\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dd4 \u0d85\u0dad\u0dca \u0dc0\u0dd2\u0dbd\u0d82\u0d9c\u0dd4 \u0dc0\u0dd9\u0db1\u0dca  \u0db4\u0dc4\u0dbb\u0daf\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0d87\u0dad .",
        "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4  \u0db8\u0dd9\u0dbd\u0dca\u0dbd \u0d9a\u0dbb \u0d94\u0dc4\u0dd4 \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d9c\u0dad \u0d9a\u0dbb \u0d87\u0dad .",
        "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0d9c\u0dda    \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0da7 \u0db6\u0dcf\u0db0\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 ,  \u0d9a\u0dbd\u0dc4\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2 \u0dbd\u0dd9\u0dc3 \u0dc4\u0dd0\u0dc3\u0dd2\u0dbb\u0dd3\u0db8 ,\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0db4\u0dc4\u0dbb \u0daf\u0dd3\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 ,\u0d86\u0daf\u0dd3 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0db8\u0dad   \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2."
      ],
