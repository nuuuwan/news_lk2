  "text_idx": {
    "en": {
      "title": "One of the cashiers was arrested",
      "author": "unknown",
      "body_lines": [
        "A 26-year-old youth has been arrested on suspicion of damaging property at the Presidential Palace during the people's protest on the 9th, police said.",
        "He has been arrested on suspicion based on investigations carried out regarding the destruction of property by the civilians who seized the Presidential Palace on the 9th.",
        "The suspect was identified in a video posted on social media as being among the group counting the money after the siege of the Presidential Palace."
      ],
