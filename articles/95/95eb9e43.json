  "time_ut": 1656220151,
  "original_lang": "si",
  "original_title": "\u0db6\u0dad\u0dca \u0db4\u0dd0\u0d9a\u0da7\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dd2\u0dba\u0dba\u0da7 10\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
  "text_idx": {
    "en": {
      "title": "10 percent increase on all foods, including rice packets",
      "author": "unknown",
      "body_lines": [
        "The All Ceylon Restaurant Owners' Association says it will increase all food items, including rice packets, by about 10 percent. This increase is in line with the increase in fuel prices."
      ],
      "title_ents": [
        {
          "text": "10 percent",
          "label": "PERCENT"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "about 10 percent",
            "label": "PERCENT"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0db6\u0dad\u0dca \u0db4\u0dd0\u0d9a\u0da7\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dd2\u0dba\u0dba\u0da7 10\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0dad\u0dca \u0db4\u0dd0\u0d9a\u0da7\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d86\u0dc4\u0dcf\u0dbb \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0dc3\u0dd2\u0dba\u0dba\u0da7 10\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0d86\u0db4\u0db1\u0dc1\u0dcf\u0dbd\u0dcf \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2. \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0dc3\u0dcf\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dc0 \u0db8\u0dd9\u0db8 \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [
