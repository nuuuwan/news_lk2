            "label": "CARDINAL"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0dba - \u0d91\u0d9a \u0db1\u0dd3\u0dad\u0dd2\u0dba\u0d9a\u0dca'",
            "label": "EVENT"
          },
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
