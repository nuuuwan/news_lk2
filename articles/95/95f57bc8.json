            "label": "GPE"
          },
          {
            "text": "\u0db8\u0dd0\u0dba\u0dd2 \u0dc3\u0dc4 \u0da2\u0dd6\u0db1\u0dd2 \u0db8\u0dcf\u0dc3",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0db4\u0dca\u0db4\u0dcf\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dab \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca\u0db4\u0dad\u0dd2",
            "label": "ORG"
