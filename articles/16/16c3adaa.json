        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0bb0\u0ba3\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb0\u0bae\u0b9a\u0bbf\u0b99\u0bcd\u0b95",
            "label": "PERSON"
          },
          {
            "text": "\u0ba8\u0bbf\u0ba4\u0bbf \u0b92\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0bae\u0b9a\u0bcb\u0ba4\u0bbe",
            "label": "LAW"
          },
          {
            "text": "\u0b86\u0b95\u0bb8\u0bcd\u0b9f\u0bcd 30",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0b86\u0b95\u0bb8\u0bcd\u0b9f\u0bcd 31 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bc6\u0baa\u0bcd\u0b9f\u0bae\u0bcd\u0baa\u0bb0\u0bcd 1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd 2",
            "label": "DATE"
          }
        ]
      ]
    }
