    "si": {
      "title": "LP \u0d9c\u0dd1\u0dc3\u0dca \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0dbd\u0dd9\u0dc3 \u0dc0\u0dbb\u0dca\u0d9c \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0daf\u0dca\u200d\u0dbb\u0dc0 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0ddd\u0dbd\u0dd2\u0dba\u0db8\u0dca (LP) \u0d9c\u0dd1\u0dc3\u0dca \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db7\u0dcf\u0dab\u0dca\u0da9\u0dba\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad. \u0d91\u0db8 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0dc0\u0dd9\u0dc5\u0db3, \u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0dc4\u0dcf \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dd4\u0dbb\u0d9a\u0dca\u0dc2\u0dd2\u0dad\u0dad\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db1\u0dbd\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d8a\u0dba\u0dda \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd4\u0dc0\u0dcf.",
        "\u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dda (CAA) \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db8\u0dd9\u0db8 \u0d86\u0dc4\u0dcf\u0dbb \u0db4\u0dd2\u0dc3\u0dd3\u0db8\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1\u0dba \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0db8\u0da7 \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db6\u0dc0 \u0dc3\u0dbd\u0d9a\u0dcf \u0db8\u0dd9\u0db8 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, CAA \u0dc4\u0dd2 \u0d85\u0d82\u0d9a 09 \u0daf\u0dbb\u0db1 \u0d85\u0d82\u0d9a 18 \u0daf\u0dbb\u0db1 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba \u0dba\u0da7\u0dad\u0dda \u201c\u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dd2\u0dad \u0db7\u0dcf\u0dab\u0dca\u0da9\u201d \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba \u0dba\u0da7\u0dad\u0dda \u0db8\u0dd9\u0db8 \u0db1\u0dd2\u0dba\u0ddd\u0d9c\u0dba \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbb \u0d87\u0dad. 2003 (\u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad). (\u0da0\u0dad\u0dd4\u0dbb\u0d82\u0d9c \u0dc3\u0db8\u0dbb\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0daf\u0dca\u0dbb\u0dc0\u0dd3\u0d9a\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd9\u0dc5\u0db3, \u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0dc3\u0dc4 \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dd4\u0dbb\u0d9a\u0dca\u0dc2\u0dd2\u0dad\u0dad\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dbd\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "18 \u0dc0\u0db1 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba",
            "label": "LAW"
          },
          {
            "text": "CAA",
            "label": "ORG"
          },
          {
            "text": "2003 09",
            "label": "DATE"
