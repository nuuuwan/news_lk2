    "si": {
      "title": "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0daf\u0dc4\u0dcf \u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d85\u0daf (07\u0daf\u0dcf) \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0db8\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0db6\u0dc4\u0dbb\u0dda\u0db1\u0dca \u0dc3\u0dd2\u0da7 \u0d9c\u0dbd\u0dca\u0dc6\u0dca \u0d91\u0dba\u0dcf \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba\u0dda \u0da2\u0dd3.\u0d91\u0dc6\u0dca.- 144 \u0daf\u0dbb\u0db1 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca 07/07 \u0daf\u0dd2\u0db1 \u0d8b\u0daf\u0dd1\u0dc3\u0db1 9.00 \u0da7 \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0db8\u0ddc\u0dc3\u0dca\u0d9a\u0dc0\u0dca \u0db1\u0dd4\u0dc0\u0dbb \u0dc3\u0dc4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0d85\u0dad\u0dbb \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d8d\u0da2\u0dd4 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0d9c\u0db8\u0db1\u0dca \u0d87\u0dab \u0dc4\u0dd2\u0da7 \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0db8\u0dd9\u0db8 \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0db1\u0dca \u0db6\u0dc4\u0dbb\u0dda\u0db1\u0dca \u0dc4\u0dbb\u0dc4\u0dcf \u0db8\u0dd9\u0dc3\u0dda \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0db8\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0db4\u0dd2\u0dc5\u0dd2\u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0daf\u0dc4\u0dcf \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0db1\u0dcf\u0dba\u0d9a \u0dc0\u0dd2\u0db8\u0dbd\u0dca \u0dc0\u0dd3\u0dbb\u0dc0\u0d82\u0dc1 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0dcf \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d85\u0db8\u0dd4\u0dad\u0dca\u0dad\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dd0\u0daf\u0dd2\u0dbb\u0dd2\u0dba \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dc4."
      ],
