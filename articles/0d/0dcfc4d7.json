    "si": {
      "title": "\u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0dab \u0dc3\u0dd2\u0db1\u0db8\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0da9\u0ddc\u0db1\u0dbd\u0dca\u0da9\u0dca \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0db7\u0dcf\u0dc0\u0db4\u0dca\u200d\u0dbb\u0dcf\u0db4\u0dca\u0dad \u0dc0\u0dd9\u0dba\u0dd2",
