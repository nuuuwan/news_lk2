    "si": {
      "title": "\u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0d8b\u0daf\u0dca\u0d9d\u0ddd\u0dc2\u0dab\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0dc3\u0dda\u0dc0\u0dcf \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba, \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d85\u0dbb\u0d9c\u0dbd \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc3\u0dc4 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d8b\u0daf\u0dd9\u0dc3\u0dcf \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0d8b\u0daf\u0dca\u0d9d\u0ddd\u0dc2\u0dab\u0dba \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0d85\u0daf (19) \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0d86\u0dba\u0dad\u0db1\u0dba \u0dad\u0dd4\u0dc5 \u0dbb\u0dd0\u0d9a\u0dc0\u0dbb\u0dab\u0dba, \u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4 \u0dc4\u0dcf \u0dc3\u0db8\u0dcf\u0da2\u0dba\u0dd3\u0dba \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u00a0 \u0db1\u0ddc\u0dc0\u0dd2\u0dc3\u0db3\u0dcf,\u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0db1\u0dca \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc3\u0dda\u0dc0\u0dba\u0da7 \u0d9a\u0dd0\u0db3\u0dc0\u0dd3\u0db8\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dc4\u0dcf \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc0\u0dc4\u0dbd\u0dca\u0d9a\u0db8\u0da7 \u0daf\u0dd0\u0d9a\u0dca\u0d9a\u0dd3\u0db8\u0da7 \u0d91\u0dbb\u0dc4\u0dd2\u0dc0 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc0\u0dd2\u0dbb\u0ddd\u0daf\u0dba \u0db4\u0dbd \u0d9a\u0dbd\u0dc4."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0dc3\u0dda\u0dc0\u0dcf \u0db8\u0db0\u0dca\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd2\u0daf\u0dc4\u0dc3 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "19",
            "label": "CARDINAL"
          }
        ],
        []
      ]
    },
    "ta": {
      "title": "\u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0baa\u0bbe\u0b95 \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bae\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0ba4\u0ba9\u0bbf\u0ba8\u0baa\u0bb0\u0bcd \u0b9a\u0bc7\u0bb5\u0bc8 \u0bae\u0bc8\u0baf\u0bae\u0bcd, \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0baa\u0bcb\u0bb0\u0bbe\u0b9f\u0bcd\u0b9f \u0bae\u0bc8\u0baf\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bc1\u0ba4\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bcd \u0b87\u0baf\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bb5\u0bb1\u0bcd\u0bb1\u0bbf\u0ba9\u0bcd \u0b8f\u0bb1\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (19) \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0baa\u0bbe\u0b95 \u0baa\u0bcb\u0bb0\u0bbe\u0b9f\u0bcd\u0b9f\u0bae\u0bcd \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1.",
        "\u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0baa\u0bb0\u0bbe\u0bae\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bc1, \u0bb5\u0bbe\u0b95\u0ba9\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0b9a\u0bcd\u0ba9\u0bc8, \u0b9a\u0bae\u0bc2\u0b95\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0b9a\u0bcd\u0ba9\u0bc8\u0b95\u0bb3\u0bcd \u0ba4\u0bc0\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bbe\u0bae\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd, \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bc8 \u0b87\u0bb0\u0bb5\u0bc1 \u0bb5\u0bc7\u0bb2\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bb4\u0bc8\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd, \u0baa\u0bb3\u0bcd\u0bb3\u0bbf\u0b95\u0bcd \u0b95\u0bc1\u0bb4\u0ba8\u0bcd\u0ba4\u0bc8\u0b95\u0bb3\u0bc8 \u0b85\u0b9f\u0bbf\u0bae\u0bc8\u0b95\u0bb3\u0bbe\u0b95\u0baa\u0bcd \u0baa\u0bbe\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bc1\u0ba4\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0ba4\u0ba9\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b9a\u0bc7\u0bb5\u0bc8 \u0bae\u0bc8\u0baf\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0bc1\u0ba4\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bcd \u0b87\u0baf\u0b95\u0bcd\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "19",
