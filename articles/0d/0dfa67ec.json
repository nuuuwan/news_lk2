    "si": {
      "title": "\u0dbd\u0ddd\u0d9a \u0dc0\u0dd4\u0dc2\u0dd4 \u0d9a\u0dd4\u0d82 \u0dc6\u0dd4 \u0daf\u0dd2\u0db1\u0dba \u0dc3\u0db8\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 2022 \u0dbd\u0ddd\u0d9a \u0dc0\u0dd4\u0dc2\u0dd4 \u0d9a\u0dd4\u0d82 \u0dc6\u0dd4 \u0daf\u0dd2\u0db1\u0dba (WWKD) \u0dc3\u0db8\u0dbb\u0db1 \u0dbd\u0daf\u0dd3, \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0da0\u0dd3\u0db1 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 Zhang Yingbao \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d86\u0dbb\u0dcf\u0db0\u0dd2\u0dad \u0d85\u0db8\u0dd4\u0dad\u0dca\u0dad\u0dcf \u0dbd\u0dd9\u0dc3 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0da0\u0dad\u0dd4\u0dbb\u0dc1\u0dca\u200d\u0dbb\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2. \u0db4\u0dca\u200d\u0dbb\u0daf\u0dbb\u0dca\u0dc1\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0daf \u0db8\u0dd9\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0dc0\u0dbb\u0dca\u0dab\u0dc0\u0dad\u0dca \u0d9a\u0dc5\u0dda\u0dba. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db4\u0dca\u200d\u0dbb\u0daf\u0dd3\u0db4\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dab"
      ],
