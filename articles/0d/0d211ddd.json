            "label": "WORK_OF_ART"
          },
          {
            "text": "\u0db8\u0dd9\u0da7\u0dca\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 45 \u0d9a\u0dd2",
            "label": "QUANTITY"
          }
        ],
        [
          {
