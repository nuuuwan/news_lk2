            "text": "\u0b86\u0b95\u0bb8\u0bcd\u0b9f\u0bcd 29 \u0ba4\u0bbf\u0b99\u0bcd\u0b95\u0b9f\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8",
