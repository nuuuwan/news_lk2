    "en": {
      "title": "The IOC announced the ship's arrival dates",
      "author": "unknown",
      "body_lines": [
        "Lanka IOC has announced that 3 ships loaded with 90,000 metric tons of fuel blocks, including petrol and diesel, will arrive in Sri Lanka by mid-August.",
        "The company said that the first ship will reach the country between 13th and 15th of this month, the second ship between 29th and 31st and the third ship between 10th and 15th of August."
      ],
      "title_ents": [
        {
          "text": "IOC",
          "label": "ORG"
        }
      ],
