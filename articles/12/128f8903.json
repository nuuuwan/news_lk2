    "si": {
      "title": "\u0d86\u0dbb\u0dd4\u0d9a\u0dca\u0d9a\u0dd4 \u0db1\u0dc0\u0dba\u0dda \u0db4\u0dcf\u0dbd\u0db8\u0dda \u0db6\u0db9\u0dbb \u0d87\u0dc0\u0dd2\u0dc3\u0dca\u0dc3\u0dd2\u0db8\u0dd9\u0db1\u0dca \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0db6\u0dcf\u0db0\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d8b\u0da9\u0dbb\u0da7 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0d87\u0dbd\u0dca\u0dbd \u0daf\u0dd9\u0db8\u0ddd\u0daf\u0dbb \u0d86\u0dbb\u0dd4\u0d9a\u0dca\u0d9a\u0dd4 \u0db1\u0dc0\u0dba\u0dda \u0db4\u0dcf\u0dc5\u0db8\u0dda \u0d9a\u0dd4\u0dc5\u0dd4\u0dab\u0dd4 \u0db8\u0dad \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0db9\u0dbb \u0d87\u0dc0\u0dd2\u0dc3\u0dca\u0dc3\u0dd2\u0db8\u0dd9\u0db1\u0dca \u0db1\u0dd2\u0dad\u0dbb \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u0dd2\u0dba \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb \u0dc0\u0dbd\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd9\u0db1 \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dcf\u0dc3\u0dd3\u0db1\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d86\u0dbb\u0dd4\u0d9a\u0dca\u0d9a\u0dd4 \u0db1\u0dc0\u0dba\u0dda \u0db4\u0dcf\u0dbd\u0db8\u0dda\u00a0 \u0d9c\u0dbd\u0dca \u0d9a\u0dd4\u0dc5\u0dd4\u0dab\u0dd4 \u0db8\u0dad \u0daf\u0dd3\u0dbb\u0dca\u0d9c \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dad\u0dd2\u0dc3\u0dca\u0dc3\u0dda \u0db6\u0dd0\u0daf \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0db9\u0dbb \u0d8b\u0d9a\u0dd4\u0dc3\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dc0\u0dbd\u0da7 \u0dc4\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd2 \u0d87\u0dad\u0dd2\u0dc0\u0db1 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0da7 \u0dc0\u0dd2\u0dc3\u0dd3\u0dbb\u0dd3 \u0dba\u0db1 \u0dc3\u0dad\u0dd4\u0db1\u0dca \u0db4\u0dcf\u0dbd\u0db8 \u0db8\u0dad \u0dc3\u0dd2\u0dbb\u0dd2 \u0db1\u0dbb\u0db9\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0daf\u0dc2\u0dca\u0da8 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d9a\u0dd2\u0dba\u0dba\u0dd2,",
        "\u0db1\u0dd2\u0dad\u0dbb \u0db6\u0db9\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb \u0dc0\u0dbd\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0db1 \u0daf\u0dda\u0dc1\u0dd2\u0dba \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dc3\u0daf\u0dc4\u0dcf \u0daf\u0dd9\u0db8\u0ddd\u0daf\u0dbb,\u0d87\u0dbd\u0dca\u0dbd,\u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb\u0dc0\u0dd9\u0dc5 \u0dc4 \u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0dc3\u0daf\u0dc4\u0dcf \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0d85\u0daf\u0dcf\u0dbd \u0db6\u0dc5\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dc0\u0dbb\u0d9a\u0dca\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dcf\u0dc3\u0dd3\u0db1\u0dca \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dad\u0dca \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0dba\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd3\u00a0\u0db1\u0dd0\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0dc0\u0dc3\u0dad\u0dd2."
      ],
