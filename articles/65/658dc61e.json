  "time_ut": 1660800746,
  "original_lang": "si",
  "original_title": "\u0dc3\u0dad\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0d9a\u0dd1\u0db8 \u0dbb\u0da7\u0dd2\u0db1\u0dca \u0d9c\u0dda\u0db1\u0dca\u0db1 \u0dba\u0dba\u0dd2",
  "text_idx": {
    "en": {
      "title": "Food for the animals will be brought from the country",
      "author": "unknown",
      "body_lines": [
        "The Minister of Agriculture is preparing to submit a proposal to the Council of Ministers requesting permission to import maize and soy imported for animal feed under the open account system.",
        "According to the Ministry of Agriculture, this decision has been reached because there is a problematic situation in the market to purchase enough soy and maize for the production of animal feed in view of the current economic problems.",
        "Agriculture Minister Mahinda Amaraweera said that due to the shortage of animal feed, the farmers and businessmen involved in the production of liquid milk, chicken meat and eggs are in trouble and the animal production capacities needed to improve the nutritional conditions of the people have also decreased."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "the Council of Ministers",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "the Ministry of Agriculture",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "Mahinda Amaraweera",
            "label": "PERSON"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dc3\u0dad\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0d9a\u0dd1\u0db8 \u0dbb\u0da7\u0dd2\u0db1\u0dca \u0d9c\u0dda\u0db1\u0dca\u0db1 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0dad\u0dca\u0dc0 \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db6\u0da9 \u0d89\u0dbb\u0dd2\u0d9f\u0dd4 \u0dc4\u0dcf \u0dc3\u0ddd\u0dba\u0dcf \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc0\u0dda\u0daf\u0dba\u0da7 \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dbb \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0dd6\u0daf\u0dcf\u0db1\u0db8\u0dca \u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0daf\u0dd0\u0db1\u0da7 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d9c\u0dd0\u0da7\u0dc5\u0dd4 \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0dc3\u0dad\u0dca\u0dc0 \u0d86\u0dc4\u0dcf\u0dbb \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0ddd\u0dba\u0dcf \u0dc4\u0dcf \u0db6\u0da9\u0d89\u0dbb\u0dd2\u0d9f\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dc0\u0dad\u0dca \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd9\u0dc5\u0dd9\u0db3 \u0db4\u0ddc\u0dc5\u0dda \u0db8\u0dd2\u0dbd \u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d9c\u0dd0\u0da7\u0dbd\u0dd4 \u0dc3\u0dc4\u0d9c\u0dad \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dad\u0dd3\u0dbb\u0dab\u0dba\u0da7 \u0d91\u0dc5\u0dd0\u0db9\u0dd2 \u0db6\u0dc0 \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc3\u0dad\u0dca\u0dc0 \u0d86\u0dc4\u0dcf\u0dbb \u0dc4\u0dd2\u0d9f\u0dba \u0db1\u0dd2\u0dc3\u0dcf\u00a0 \u0daf\u0dd2\u0dba\u0dbb\u0d9a\u0dd2\u0dbb\u0dd2, \u0d9a\u0dd4\u0d9a\u0dd4\u0dc5\u0dd4 \u0db8\u0dc3\u0dca \u0dc4\u0dcf \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba\u0dda \u0dba\u0dd9\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca\u00a0 \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dd2\u0d9a\u0dba\u0db1\u0dca \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dda \u0db4\u0ddd\u0dc2\u0dca\u200d\u0dba \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0db1\u0dca \u0db1\u0d82\u0dc0\u0dcf\u0dbd\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dad\u0dca\u0dc0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0db0\u0dcf\u0dbb\u0dd2\u0dad\u0dcf\u0dc0\u0dba\u0db1\u0dca \u0daf \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7\u00a0 \u0db4\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0d85\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
