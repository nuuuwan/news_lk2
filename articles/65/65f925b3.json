            "label": "DATE"
          },
          {
            "text": "\u0dbd\u0dd2\u0dc3\u0dca \u0da7\u0dca\u200d\u0dbb\u0dc3\u0dca",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0db6\u0dca\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u0dba\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dbb\u0dca\u0dc0\u0dda\u0da7\u0dd2\u0dc0\u0dca \u0db4\u0d9a\u0dca\u0dc2\u0dba",
