      ]
    },
    "si": {
      "title": "\u0dbd\u0dd2\u0dc4\u0dd2\u0dc3\u0dd2 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dbd \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0d85\u0daf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0dbd\u0dd2\u0dc4\u0dd2\u0dc3\u0dd2 \u0dad\u0dd9\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dbd\u0dba \u0d85\u0daf \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf\u0dc0\u0da7 \u0dbd\u0d9a\u0dca \u0d9a\u0dd9\u0dbb\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0dbd\u0dd2\u0dc4\u0dd2\u0dc3\u0dd2 \u0dad\u0dd9\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dba\u0d9a\u0dca \u0d85\u0da9\u0d82\u0d9c\u0dd4 \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0d91\u0dc4\u0dd2 \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dbd \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8\u0dda \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da2\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd3\u0db8\u0daf \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2. (\u0d92)"
      ],
      "title_ents": [
