    "si": {
      "title": "\u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0d85\u0dc0\u0db1\u0dca\u0dc4\u0dbd\u0d9a\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc3\u0dd0\u0dbb \u0dc0\u0dd0\u0daf\u0dd3 \u0db8\u0dd2\u0dba \u0dba\u0dba\u0dd2",
      "body_lines": [
        "\u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0db6\u0da7\u0dca \u0d9a\u0db8\u0dd2\u0db1\u0dca\u0dc3\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d85\u0dc0\u0db1\u0dca\u0dc4\u0dbd\u0d9a\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0dc0\u0dd3\u0db8\u0d9a\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d94\u0dc4\u0dd4 \u0dc3\u0dd2\u0dba \u0da7\u0dca\u0dc0\u0dd2\u0da7\u0dbb\u0dca \u0db4\u0dd2\u0da7\u0dd4\u0dc0\u0dda \u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0daf \u0dad\u0db6\u0dcf \u0d87\u0dad.",
        "\"\u0db8\u0dda \u0dc3\u0dad\u0dd2\u0dba\u0dd9 \u0d9a\u0dbd\u0dd2\u0db1\u0dca \u0d85\u0db4\u0dd2 \u0d9c\u0dd2\u0dba\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0dc0\u0dd4\u0dab\u0dd4 \u0d85\u0dc0\u0db1\u0dca\u0dc4\u0dbd\u0d9a\u0da7. \u0d85\u0db4\u0dd2 \u0db6\u0dbd\u0db1\u0dca \u0d89\u0db1\u0dca\u0db1\u0dc0\u0dcf \u0d9a\u0dbb\u0db1\u0dca\u0da7\u0dca \u0d91\u0d9a \u0d91\u0db1\u0d9a\u0db8\u0dca. \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0d86\u0db4\u0dd4 \u0d9c\u0db8\u0db1\u0dca \u0dbb\u0dd1 \u0d9a\u0dd1\u0db8 \u0daf\u0dd2\u0d9c\u0da7\u0db8.",
        "\"\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0daf\u0dd0\u0db1\u0dca \u0daf\u0dd4\u0dc2\u0dca\u0d9a\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0db4\u0dc3\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db1\u0db8\u0dd4\u0dad\u0dca \u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0d85\u0db4\u0dc0 \u0db4\u0dd4\u0daf\u0dd4\u0db8\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db8\u0dd9\u0dc4\u0dd2 \u0dc3\u0dd2\u0da7\u0dd3\u0db8 \u0d9c\u0dd0\u0db1 \u0d85\u0db4\u0dd2 \u0dc3\u0dca\u0dad\u0dd6\u0dad\u0dd2\u0dc0\u0db1\u0dca\u0dad \u0dc0\u0dd9\u0db8\u0dd4,\" \u0d94\u0dc4\u0dd4 \u0dc3\u0dd2\u0dba \u0da7\u0dca\u0dc0\u0dd2\u0da7\u0dbb\u0dca \u0db4\u0dd2\u0da7\u0dd4\u0dc0\u0dda \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
