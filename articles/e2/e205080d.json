          {
            "text": "\u0da7\u0dca\u0dbb\u0ddc\u0d9a\u0dca\u0dc3\u0dd2",
            "label": "GPE"
          },
          {
            "text": "24",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0db4\u0dc5\u0dcf\u0dad\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0d9a\u0dd4\u0dbd\u0dda\u0dc1\u0dca\u0dc0\u0dbb\u0dd3 \u0db4\u0dd2\u0dbd\u0dca\u0dbd\u0dd9\u0db1\u0dcf\u0dba\u0d9a\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dda.\u0d85\u0dbb\u0dd4\u0dbd\u0dcf\u0db1\u0db1\u0dca\u0daf\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db0\u0dca\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0d9c\u0dbb\u0dd4 \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0db3\u0dd4\u0daf\u0dcf",
            "label": "DATE"
          },
          {
