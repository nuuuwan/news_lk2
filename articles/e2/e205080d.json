          {
            "text": "\u0d9a\u0dcf\u0dbd\u0dd2\u0da9\u0dca \u0db8\u0dd4\u0dc4\u0dba\u0dd2\u0db8\u0dd2\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dd4\u0db6\u0dcf\u0dbb\u0d9a\u0dca \u0d85\u0dc3\u0dcf\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd6\u0dbb\u0dca \u0da2\u0dc4\u0dcf\u0db1\u0dca\u0d9c\u0dda",
