            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0dc3\u0db3\u0dd4\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "27",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dba\u0dda \u0d86\u0dba\u0dad\u0db1 \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0da7\u0dd2 \u0dc3\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dba\u0dda 185 \u0dc0\u0d9c\u0db1\u0dca\u0dad\u0dd2\u0dba",
            "label": "LAW"
          }
        ],
        [
          {
            "text": "\u0d9c\u0dbb\u0dd4 \u0dc3\u0db7\u0dcf\u0dc0",
