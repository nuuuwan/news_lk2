            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0d91\u0db8\u0dca.\u0d91\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0dbb\u0dd2\u0dc6\u0dca \u0dc3\u0db8\u0dca\u0dc3\u0dd4\u0daf\u0dd3\u0db1\u0dca",
            "label": "PERSON"
