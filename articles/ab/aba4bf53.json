    "si": {
      "title": "\u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0d9a\u0ddd\u0da7\u0dd2 4.7\u0d9a\u0dca \u0dc0\u0da7\u0dd2\u0db1\u0dcf \u0dbb\u0dad\u0dca\u200d\u0dbb\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd0\u0db1\u0dd2\u0dab\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db1\u0dd3\u0dad\u0dd2\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dbd\u0dd9\u0dc3 \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d86 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 47\u0d9a\u0dca \u0dc0\u0da7\u0dd2\u0db1\u0dcf \u0dbb\u0db1\u0dca \u0db6\u0dd2\u0dc3\u0dca\u0d9a\u0da7\u0dca 16\u0d9a\u0dca \u0dc3\u0dc4 \u0dbb\u0db1\u0dca \u0d9a\u0dd0\u0db6\u0dbd\u0dd2 4\u0d9a\u0dca \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5\u0dda\u0daf\u0dd3 \u0dbb\u0dda\u0d9c\u0dd4 \u0db7\u0dcf\u0dbb\u0dba\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0d9a\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0d85\u0daf \u0d85\u0dbd\u0dd4\u0dba\u0db8 1\u0da7 \u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0dc3\u0dd2\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d86 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 98\u0d9a\u0dca \u0db6\u0dbb\u0dd0\u0dad\u0dd2 \u0dbb\u0dad\u0dca\u200d\u0dbb\u0d82 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 2\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0dbb\u0dda\u0d9c\u0dd4 \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0da2\u0dda\u0dbb\u0dad\u0dca\u0db1 \u0db7\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbb\u0dda\u0d9c\u0dd4 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u200d\u0dc2\u0dab\u0dba \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf \u0db1\u0dd3\u0dad\u0dd2\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dbd\u0dd9\u0dc3 \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dbb\u0dad\u0dca\u200d\u0dbb\u0d82 \u0dad\u0ddc\u0d9c\u0dba \u0dbb\u0dcf\u0da2\u0dc3\u0db1\u0dca\u0dad\u0d9a \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dad\u0dca \u0dad\u0dd9\u0db8\u0da7\u0d9c\u0ddc\u0da9 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 35 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 50,000 \u0d9a \u0daf\u0da9 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0d9c\u0dd9\u0dc0\u0db1 \u0dbd\u0dd9\u0dc3 \u0daf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0dbb\u0dda\u0d9c\u0dd4 \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dc5\u0dcf."
      ],
