  "original_title": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0dc4\u0dd0\u0da7\u0dd2 \u0d94\u0db6 \u0daf\u0dd0\u0d9a \u0dad\u0dd2\u0db6\u0dda\u0daf?",
  "text_idx": {
    "en": {
      "title": "Have you seen the treatment at the Dehiwala Animal Hospital?",
      "author": "",
      "body_lines": [
        "Veterinarians who treat animals have a different experience than veterinarians who treat humans.",
        "One of the main reasons for this is that veterinarians are unable to express their symptoms.",
        "Another challenge is getting to and from dangerous animals.",
        "There is also an animal hospital at the Dehiwala National Zoo. X-rays, echo tests, and blood samples are also taken to diagnose the animal."
      ],
      "title_ents": [
        {
          "text": "the Dehiwala Animal Hospital",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "Veterinarians",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "One",
            "label": "CARDINAL"
          }
        ],
        [],
        [
          {
            "text": "the Dehiwala National Zoo",
            "label": "ORG"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0dc4\u0dd0\u0da7\u0dd2 \u0d94\u0db6 \u0daf\u0dd0\u0d9a \u0dad\u0dd2\u0db6\u0dda\u0daf?",
      "author": "",
      "body_lines": [
        "\u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dbb\u0db1 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0da7 \u0dc0\u0da9\u0dcf \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dbb\u0db1 \u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4 \u0dc0\u0dd9\u0db1\u0dc3\u0dca \u0d85\u0dad\u0dca\u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0dca \u0dbd\u0db6\u0dad\u0dd2.",
        "\u0d8a\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0d9a\u0dca \u0dc0\u0db1\u0dca\u0db1\u0dda \u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0db1 \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0dad\u0db8\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0ddd\u0d9c \u0dbd\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd3\u0db8\u0dba\u0dd2.",
        "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0dcf\u0dba\u0d9a \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0dc5\u0d9f\u0dcf \u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0dad\u0dd4\u0db1\u0dca \u0dc5\u0d9f\u0da7 \u0d9c\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dad\u0dc0\u0dad\u0dca \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0d9a\u0dd2.",
        "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd6 \u0dbb\u0ddd\u0dc4\u0dbd\u0d9a\u0dca \u0daf \u0db4\u0dc0\u0dad\u0dd3. \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0ddd\u0d9c \u0dc0\u0dd2\u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0daf \u0d91\u0d9a\u0dca\u0dc3\u0dca\u0dbb\u0dda, \u0d91\u0d9a\u0ddd \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab, \u0dbb\u0dd4\u0db0\u0dd2\u0dbb \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dbd \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0d86\u0daf\u0dd2\u0dba \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dda."
      ],
      "title_ents": [
        {
          "text": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dc0 \u0dbb\u0ddd\u0dc4\u0dbd",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "\u0d91\u0d9a",
            "label": "CARDINAL"
          }
        ],
        [],
        [
          {
            "text": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba",
            "label": "ORG"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0ba4\u0bc6\u0bb9\u0bbf\u0bb5\u0bb3\u0bc8 \u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8 \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bbe\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b9a\u0bbf\u0b95\u0bbf\u0b9a\u0bcd\u0b9a\u0bc8\u0baf\u0bc8 \u0baa\u0bbe\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bc0\u0bb0\u0bcd\u0b95\u0bb3\u0bbe?",
      "author": "",
      "body_lines": [
        "\u0bae\u0ba9\u0bbf\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b9a\u0bbf\u0b95\u0bbf\u0b9a\u0bcd\u0b9a\u0bc8 \u0b85\u0bb3\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8 \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bc8 \u0bb5\u0bbf\u0b9f \u0bb5\u0bbf\u0bb2\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b9a\u0bbf\u0b95\u0bbf\u0b9a\u0bcd\u0b9a\u0bc8 \u0b85\u0bb3\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8 \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0b9a\u0bae\u0bbe\u0ba9 \u0b85\u0ba9\u0bc1\u0baa\u0bb5\u0bae\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0b87\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0bae\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0b95\u0bbe\u0bb0\u0ba3\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b92\u0ba9\u0bcd\u0bb1\u0bc1, \u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8 \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bb1\u0bbf\u0b95\u0bc1\u0bb1\u0bbf\u0b95\u0bb3\u0bc8 \u0bb5\u0bc6\u0bb3\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0bae\u0bc1\u0b9f\u0bbf\u0baf\u0bbe\u0ba4\u0bc1.",
        "\u0bae\u0bb1\u0bcd\u0bb1\u0bca\u0bb0\u0bc1 \u0b9a\u0bb5\u0bbe\u0bb2\u0bcd \u0b86\u0baa\u0ba4\u0bcd\u0ba4\u0bbe\u0ba9 \u0bb5\u0bbf\u0bb2\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b9a\u0bcd \u0b9a\u0bc6\u0bb2\u0bcd\u0bb5\u0ba4\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba4\u0bbf\u0bb0\u0bc1\u0bae\u0bcd\u0baa\u0bc1\u0bb5\u0ba4\u0bc1.",
        "\u0ba4\u0bc6\u0bb9\u0bbf\u0bb5\u0bb3\u0bc8 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0bae\u0bbf\u0bb0\u0bc1\u0b95\u0b95\u0bcd\u0b95\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0b9a\u0bbe\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b92\u0bb0\u0bc1 \u0bb5\u0bbf\u0bb2\u0b99\u0bcd\u0b95\u0bc1 \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bbe\u0bb2\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. X- \u0b95\u0ba4\u0bbf\u0bb0\u0bcd\u0b95\u0bb3\u0bcd, \u0b8e\u0ba4\u0bbf\u0bb0\u0bca\u0bb2\u0bbf \u0b9a\u0bcb\u0ba4\u0ba9\u0bc8\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b87\u0bb0\u0ba4\u0bcd\u0ba4 \u0bae\u0bbe\u0ba4\u0bbf\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bb5\u0bc8 \u0bb5\u0bbf\u0bb2\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bc8\u0b95\u0bcd \u0b95\u0ba3\u0bcd\u0b9f\u0bb1\u0bbf\u0baf \u0b8e\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9."
      ],
      "title_ents": [
        {
          "text": "\u0ba4\u0bc6\u0bb9\u0bbf\u0bb5\u0bb3\u0bc8 \u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8 \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bbe\u0bb2\u0bc8",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8 \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "\u0b92\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "CARDINAL"
          }
        ],
        [],
        [
          {
            "text": "\u0ba4\u0bc6\u0bb9\u0bbf\u0bb5\u0bb3\u0bc8 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0bae\u0bbf\u0bb0\u0bc1\u0b95\u0b95\u0bcd\u0b95\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0b9a\u0bbe\u0bb2\u0bc8",
            "label": "ORG"
          }
        ]
      ]
    }
  },
  "title": "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0dc4\u0dd0\u0da7\u0dd2 \u0d94\u0db6 \u0daf\u0dd0\u0d9a \u0dad\u0dd2\u0db6\u0dda\u0daf?",
  "body_lines": [
    "\u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dbb\u0db1 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0da7 \u0dc0\u0da9\u0dcf \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dbb\u0db1 \u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4 \u0dc0\u0dd9\u0db1\u0dc3\u0dca \u0d85\u0dad\u0dca\u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0dca \u0dbd\u0db6\u0dad\u0dd2.",
    "\u0d8a\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0d9a\u0dca \u0dc0\u0db1\u0dca\u0db1\u0dda \u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0db1 \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0dad\u0db8\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0ddd\u0d9c \u0dbd\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd3\u0db8\u0dba\u0dd2.",
    "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0dcf\u0dba\u0d9a \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0dc5\u0d9f\u0dcf \u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0dad\u0dd4\u0db1\u0dca \u0dc5\u0d9f\u0da7 \u0d9c\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dad\u0dc0\u0dad\u0dca \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0d9a\u0dd2.",
    "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd6 \u0dbb\u0ddd\u0dc4\u0dbd\u0d9a\u0dca \u0daf \u0db4\u0dc0\u0dad\u0dd3. \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc3\u0dad\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0ddd\u0d9c \u0dc0\u0dd2\u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0daf \u0d91\u0d9a\u0dca\u0dc3\u0dca\u0dbb\u0dda, \u0d91\u0d9a\u0ddd \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab, \u0dbb\u0dd4\u0db0\u0dd2\u0dbb \u0dc3\u0dcf\u0db8\u0dca\u0db4\u0dbd \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0d86\u0daf\u0dd2\u0dba \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dda."
  ],
