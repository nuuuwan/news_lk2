          },
          {
            "text": "\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bbe\u0bb5\u0ba4\u0bc1",
            "label": "ORDINAL"
          },
          {
            "text": "\u0bb0\u0bc2\u0baa\u0bb5\u0bbe\u0bb9\u0bbf\u0ba9\u0bbf \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0baa\u0ba9\u0bae\u0bcd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "Jehan Abuhami",
            "label": "PERSON"
          },
          {
            "text": "\u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0bae\u0bbe\u0b9c\u0bbf\u0bb8\u0bcd\u0ba4\u0bbf\u0bb0\u0bc7\u0b9f\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
          }
