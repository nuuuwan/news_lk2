    "si": {
      "title": "\u0d94\u0dc4\u0dd4 \u0dc3\u0dc4 \u0da0\u0dbb\u0db1\u0dca: \u0d91\u0dba\u0dad\u0dca \u0da0\u0dbb\u0db1\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0d85\u0db1\u0dc0\u0dc3\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd3 \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1 \u0d9a\u0da9\u0dcf\u0d9a\u0db4\u0dca\u0db4\u0dbd\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0da0\u0ddd\u0daf\u0db1\u0dcf\u0dc0 \u0db8\u0dad \u0dad\u0dc0\u0dad\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4 \u0d9a\u0dbb\u0dd4\u0dc0\u0dcf\u0dad\u0ddc\u0da7 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0db7\u0dcf\u0dbb \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0dc3\u0db8\u0dd2\u0db1\u0dca\u0dad\u0dcf \u0d9a\u0dd0\u0dbd\u0dd4\u0db8\u0dca\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba \u0d85\u0db8\u0dbb\u0dc3\u0dd2\u0d82\u0dc4 (\u0d85\u0dc0\u0dd4. 45) \u0db8\u0dd9\u0dc3\u0dda \u0db7\u0dcf\u0dbb\u0dc0\u0dd3 \u0d87\u0dad. \u0d94\u0dc4\u0dd4 \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0dc0\u0dd6 \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dcf\u0dba\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db8\u0dd0\u0daf\u0dd4\u0dbb\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd6 \u0db1\u0dc5\u0dd4 \u0da2\u0dd9\u0dc4\u0dcf\u0db1\u0dca \u0d85\u0db6\u0dd4\u0dc4\u0dcf\u0db8\u0dd2 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0da7 \u0db7\u0dcf\u0dbb \u0dc0\u0dd2\u0dba. \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0d94\u0dc4\u0dd4 \u0d87\u0db4 \u0db8\u0dad \u0db8\u0dd4\u0daf\u0dcf \u0dc4\u0dd0\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [
        {
          "text": "\u0da0\u0dbb\u0db1\u0dca",
          "label": "GPE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0dbb\u0dd4\u0dc0\u0dcf\u0dad\u0ddc\u0da7",
