    "si": {
      "title": "\u0db8\u0dcf\u0dc3 \u0dad\u0dd4\u0db1\u0d9a\u0da7 \u0db8\u0dd2\u0db1\u0dd3\u0db8\u0dd0\u0dbb\u0dd4\u0db8\u0dca 15\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda \u0da2\u0dd6\u0db1\u0dd2 01 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 31 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db8\u0dcf\u0dc3 \u0dad\u0dd4\u0db1\u0d9a \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0d9d\u0dcf\u0dad\u0db1 15\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dd9\u0d9a\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dd9\u0db8 \u0d9d\u0dcf\u0dad\u0db1\u0dc0\u0dbd\u0dd2\u0db1\u0dca 12\u0d9a\u0dca \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0dca \u0db6\u0dc0\u0dad\u0dca, \u0dc4\u0dad\u0d9a\u0dca \u0d85\u0db8\u0dca\u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3\u0dad\u0dca, \u0d85\u0db1\u0dd9\u0d9a\u0dca \u0d9d\u0dcf\u0dad\u0db1 \u0dad\u0dd4\u0db1 \u0dad\u0dd2\u0dba\u0dd4\u0dab\u0dd4 \u0d86\u0dba\u0dd4\u0db0\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0d9d\u0dcf\u0dad\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4\u0dba."
      ],
