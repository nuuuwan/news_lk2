        ],
        [
          {
            "text": "\u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0da7\u0dcf\u0dbb\u0dca \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd",
