    "si": {
      "title": "\u2018\u0dc3\u0dd4\u0db4\u0dbb\u0dca \u0da9\u0dd3\u0dc3\u0dbd\u0dca\u2019 \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8 \u0d85\u0dbb\u0db9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4\u0dc0\u0dbd \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1\u0dba\u0d9a\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d8a\u0dba\u0dda \u0daf\u0dd2\u0db1\u0dba\u0dda \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u2018\u0dc3\u0dd4\u0db4\u0dbb\u0dca \u0da9\u0dd3\u0dc3\u0dbd\u0dca\u2019 \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0dda \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0dd3 \u0d85\u0daf \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5 \u0db6\u0dc0\u0dad\u0dca \u0d92 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd6 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf\u0dba \u0d86\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dba\u0dda \u0daf \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (25) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dad\u0dc0\u0dad\u0dca \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0d85\u0daf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0ddc\u0dc5\u0db9\u0da7 \u0dc5\u0d9f\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0\u0dad\u0dca \u0d91\u0dc4\u0dd2 \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dad\u0ddc\u0d9c\u0dba \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dc4\u0dd9\u0da7 \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
