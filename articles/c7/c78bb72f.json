    "ta": {
      "title": "CCWG 2022 \u0b87\u0bb2\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0b95 \u0b87\u0b9a\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0bb5\u0bc6\u0ba3\u0bcd\u0b95\u0bb2\u0bae\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0bb0\u0bcd\u0bae\u0bbf\u0b99\u0bcd\u0b95\u0bbe\u0bae\u0bcd 2022 \u0baa\u0bca\u0ba4\u0bc1\u0ba8\u0bb2\u0bb5\u0bbe\u0baf \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, \u0b86\u0ba3\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 55 \u0b95\u0bbf\u0bb2\u0bcb \u0b8e\u0b9f\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0bb2\u0bcd \u0baa\u0bb3\u0bc1\u0ba4\u0bc2\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0b87\u0b9a\u0bc1\u0bb0\u0bc1 \u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bc8 \u0b9a\u0ba9\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8 \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1\u0bbe\u0bb0\u0bcd.",
        "\u0b85\u0bb5\u0bb0\u0bcd \u0ba4\u0b99\u0bcd\u0b95\u0bae\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1 \u0bae\u0bb2\u0bc7\u0b9a\u0bbf\u0baf\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0b95\u0bae\u0ba4\u0bc1 \u0b85\u0ba9\u0bbf\u0b95\u0bcd \u0baa\u0bbf\u0ba9\u0bcd \u0b95\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0bc6\u0bb3\u0bcd\u0bb3\u0bbf\u0baa\u0bcd \u0baa\u0ba4\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1 \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0bc7\u0ba4\u0bcd \u0b9a\u0bb0\u0bcd\u0b95\u0bbe\u0bb0\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bbe\u0bb2\u0bcd \u0bae\u0bc1\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bbe \u0bb8\u0bcd\u0ba8\u0bbe\u0b9f\u0bcd\u0b9a\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0bb2\u0bcd 105 \u0b95\u0bbf\u0bb2\u0bcb\u0bb5\u0bc1\u0bae\u0bcd, \u0b95\u0bbf\u0bb3\u0bc0\u0ba9\u0bcd & \u0b9c\u0bc6\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd 120 \u0b95\u0bbf\u0bb2\u0bcb\u0bb5\u0bc1\u0bae\u0bcd \u0ba4\u0bc2\u0b95\u0bcd\u0b95\u0bbf \u0bae\u0bca\u0ba4\u0bcd\u0ba4\u0bae\u0bcd 225 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0b95\u0bb8\u0bcd\u0b9f\u0ba9\u0bcd \u0bb8\u0bcd\u0ba8\u0bbe\u0b9f\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0bb2\u0bcd 107 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b95\u0bcd\u0bb3\u0bc0\u0ba9\u0bcd & \u0b9c\u0bc6\u0bb0\u0bcd\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd 142 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0b89\u0baf\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd, \u0baa\u0bbf\u0ba8\u0bcd\u0ba4\u0bc8\u0baf\u0ba4\u0bc1 \u0b92\u0bb0\u0bc1 \u0b95\u0bc7\u0bae\u0bcd\u0bb8\u0bcd \u0b9a\u0bbe\u0ba4\u0ba9\u0bc8\u0baf\u0bbe\u0b95 \u0bae\u0bca\u0ba4\u0bcd\u0ba4\u0bae\u0bcd 249 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0b9a\u0bb0\u0bcd\u0b95\u0bbe\u0bb0\u0bcd 113 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd 135 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0b89\u0baf\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0baa\u0bbf\u0bb1\u0b95\u0bc1 248 \u0b87\u0bb2\u0bcd \u0b92\u0bb0\u0bc1 \u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bbf \u0baa\u0bbf\u0ba9\u0bcd\u0ba4\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0bae\u0bb1\u0bcd\u0bb1 \u0b87\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd, \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0b99\u0bcd\u0b95\u0bbe \u0b9a\u0bc6\u0ba9\u0bb5\u0bbf\u0bb0\u0ba4\u0bcd\u0ba9\u0bc7 \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 100\u0bae\u0bc0 \u0baa\u0bc7\u0b95\u0bcd\u0bb8\u0bcd\u0b9f\u0bcd\u0bb0\u0bcb\u0b95\u0bcd \u0bb9\u0bc0\u0b9f\u0bcd 4 \u0b87\u0bb2\u0bcd 1:06.17 \u0bb5\u0bbf\u0ba9\u0bbe\u0b9f\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b95\u0b9f\u0ba8\u0bcd\u0ba4\u0bc1 \u0b8f\u0bb4\u0bbe\u0bb5\u0ba4\u0bc1 \u0b87\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8\u0baa\u0bcd \u0baa\u0bbf\u0b9f\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0b85\u0bb5\u0bc1\u0bb8\u0bcd\u0ba4\u0bbf\u0bb0\u0bc7\u0bb2\u0bbf\u0baf\u0bbe\u0bb5\u0bbf\u0ba9\u0bcd \u0b95\u0bc6\u0baf\u0bcd\u0bb2\u0bbf \u0bae\u0bc6\u0b95\u0bcd\u0b95\u0bcc\u0ba9\u0bcd 59.58 \u0bb5\u0bbf\u0ba9\u0bbe\u0b9f\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0bc1, \u0b9a\u0bc6\u0ba9\u0bb5\u0bbf\u0bb0\u0ba4\u0bcd\u0ba9\u0bc7 \u0b85\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0b9a\u0bc1\u0bb1\u0bcd\u0bb1\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0ba4\u0bcd \u0ba4\u0b95\u0bc1\u0ba4\u0bbf\u0baa\u0bc6\u0bb1 \u0bae\u0bc1\u0b9f\u0bbf\u0baf\u0bbe\u0bae\u0bb2\u0bcd \u0baa\u0bcb\u0ba9\u0bbe\u0bb0\u0bcd."
      ],
