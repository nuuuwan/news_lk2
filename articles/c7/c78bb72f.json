    "si": {
      "title": "CCWG 2022 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d89\u0dc3\u0dd4\u0dbb\u0dd4 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dbd\u0ddd\u0d9a\u0da9 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0db1\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db6\u0dbb \u0d89\u0dc3\u0dd2\u0dbd\u0dd3\u0db8\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d89\u0dc3\u0dd4\u0dbb\u0dd4 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0db6\u0dbb\u0dca\u0db8\u0dd2\u0db1\u0dca\u0dc4\u0dd0\u0db8\u0dca 2022 \u0db4\u0ddc\u0daf\u0dd4\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dd3\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d8b\u0dc5\u0dd9\u0dbd\u0dda \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 55 \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba\u0dd9\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0dc5\u0db8\u0dd4 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba.",
        "\u0d94\u0dc4\u0dd4 \u0dbb\u0db1\u0dca \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0dad\u0dca \u0db8\u0dd0\u0dbd\u0dda\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0d85\u0db1\u0dd2\u0d9a\u0dca \u0db6\u0dd2\u0db1\u0dca \u0d9a\u0dc3\u0dca\u0daf\u0dcf\u0db1\u0dca \u0dc3\u0dc4 \u0dbb\u0dd2\u0daf\u0dd3 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0dad\u0dca \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0dc3\u0d82\u0d9a\u0dda\u0dad\u0dca \u0dc3\u0dbb\u0dca\u0d9c\u0dcf\u0dbb\u0dca \u0db4\u0dc3\u0dd4\u0db4\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc3\u0dca\u0db1\u0dd0\u0da0\u0dca \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba\u0da7 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 105\u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0dca\u0dbd\u0dd3\u0db1\u0dca \u0d87\u0db1\u0dca\u0da9\u0dca \u0da2\u0dbb\u0dca\u0d9a\u0dca \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba\u0dda\u0daf\u0dd3 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 120\u0d9a\u0dca \u0d94\u0dc3\u0dc0\u0db8\u0dd2\u0db1\u0dca \u0db8\u0dd4\u0dc5\u0dd4 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 225\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba.",
        "\u0d9a\u0dc3\u0dca\u0da9\u0db1\u0dca Snatch \u0dc4\u0dd2 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 107\u0d9a\u0dca \u0dc3\u0dc4 Clean & Jerk \u0dc4\u0dd2 142\u0d9a\u0dca \u0d94\u0dc3\u0dc0\u0db1 \u0dbd\u0daf \u0d85\u0dad\u0dbb, \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0 \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0d91\u0dba \u0db8\u0dd4\u0dc5\u0dd4 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 249 \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd6 \u0d85\u0dad\u0dbb, Sargar \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 113\u0d9a\u0dca \u0dc3\u0dc4 135\u0d9a\u0dca \u0d91\u0dc3\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 248\u0d9a\u0da7 \u0dbd\u0d9a\u0dd4\u0dab\u0d9a\u0dca \u0db4\u0dc3\u0dd4\u0db4\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dc3\u0dd9\u0dc3\u0dd4 \u0dad\u0dbb\u0d9c\u0dc0\u0dbd\u0daf\u0dd3, \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d9c\u0d82\u0d9c\u0dcf \u0dc3\u0dd9\u0db1\u0dc0\u0dd2\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0db4\u0dc3\u0dd4\u0db4\u0dc3 \u0d86\u0dbb 4 \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf \u0d89\u0dc3\u0dc0\u0dca\u0dc0 \u0dad\u0dad\u0dca\u0db4\u0dbb 1:06.17 \u0d9a\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0db8 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc4\u0dad\u0dca\u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd2\u0dba.",
        "\u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0dda Kaylee McKeown \u0dad\u0dad\u0dca\u0db4\u0dbb 59.58\u0d9a\u0dd2\u0db1\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0dda \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8 \u0da2\u0dba\u0d9c\u0dad\u0dca \u0d85\u0dad\u0dbb \u0dc3\u0dd9\u0db1\u0dc0\u0dd2\u0dbb\u0dad\u0dca\u0db1\u0da7 \u0db8\u0dd3\u0dc5\u0d9f \u0dc0\u0da7\u0dba\u0da7 \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba."
      ],
