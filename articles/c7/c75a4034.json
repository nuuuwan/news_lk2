  "title": "\u0dbb\u0dd0\u0da7\u0dca\u0da7\u0dcf \u0d87\u0dad\u0dd4\u0dc5\u0dd4\u00a0\u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0db7\u0dcf\u0dbb\u0dc0\u0dd9\u0dba\u0dd2",
  "body_lines": [
    "\u0d9c\u0ddd\u0dbd\u0dca\u0dc6\u0dda\u0dc3\u0dca \u0d85\u0dbb\u0d9c\u0dbd\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dbb\u0dd9\u0db1\u0dca\u0dad\u0dd4 \u0dbd\u0db6\u0dcf\u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db8\u0dbb\u0daf\u0dcf\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0db1\u0dd3\u0dad\u0dd2\u0da5\u0dcf\u0dba\u0db1\u0dca \u0dc4\u0dbb\u0dc4\u0dcf \u0d85\u0daf (22) \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db7\u0dcf\u0dbb\u0dc0\u0dd6\u0dc4.",
    "\u0d91\u0db8 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0dc3\u0db8\u0d9f \u0d85\u0dbb\u0d9c\u0dbd\u0dba\u0dda \u0dba\u0dd9\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0daf \u0d9c\u0dd2\u0dba \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0db8\u0dbb\u0daf\u0dd2\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0db4\u0daf\u0dd2\u0d9a\u0dc0\u0dda\u0daf\u0dd2\u0d9a\u0dcf\u0dc0\u0dda \u0d8b\u0daf\u0dca\u0d9d\u0ddd\u0dc2\u0dab\u0dba\u0dda \u0db1\u0dd2\u0dbb\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dc4.",
    "\u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0d91\u0db8 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0da7 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0da2\u0dbd \u0db6\u0ddd\u0dad\u0dbd\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd4\u0db1\u0dca \u0d85\u0dad\u0dbb \u0db6\u0dd4\u0daf\u0dca\u0db0 \u0db6\u0dd6\u0da2\u0dcf\u0dc0 \u0daf \u0d85\u0dad\u0d9c\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8 \u0d9a\u0dd0\u0db4\u0dd3 \u0db4\u0dd9\u0db1\u0dd4\u0dab\u0dd2."
