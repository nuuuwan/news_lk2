    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd3\u0db8\u0dda \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0d88\u0dad\u0d9a....",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dc0\u0dc3\u0dbb\u0db4\u0dad\u0dca\u200d\u0dbb (NFP) \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0dba\u0da7\u0dad\u0dda QR \u0d9a\u0dda\u0dad \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0daf \u0dad\u0dc0\u0db8\u0dad\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a \u0dc0\u0dcf\u0dc4\u0db1 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0d9c\u0dd0\u0dc3\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dd4 \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dda. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2"
      ],
      "title_ents": [],
