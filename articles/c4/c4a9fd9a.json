    "si": {
      "title": "\u0db6\u0dcf\u0dbb\u0dca \u0db8\u0dbd\u0dca\u0db8\u0dcf\u0dbd\u0dcf \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0d85\u0d9c\u0dd4\u0dc5\u0dd4 \u0daf\u0db8\u0dcf \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf (09) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 5 \u0dc3\u0dd2\u0da7 \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0dcf \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0db8\u0dad\u0dca\u0db4\u0dd0\u0db1\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc0\u0dc3\u0dcf \u0dad\u0db6\u0db1 \u0db6\u0dc0 \u0db8\u0dad\u0dca\u0db4\u0dd0\u0db1\u0dca \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db8\u0dad\u0dca\u0db4\u0dd0\u0db1\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
