    "si": {
      "title": "\u0dad\u0dcf\u0dad\u0dca\u0dad\u0dcf \u0d9a\u0da9\u0db4\u0dd4 \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba \u0db4\u0dd4\u0dad\u0dcf\u0d9c\u0dda \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba \u0db6\u0dd2\u0dbd\u0dd2\u0d9c\u0dad\u0dca\u0dad\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db1\u0db8\u0dd4\u0dab\u0dd4\u0d9a\u0dd4\u0dbd - \u0db1\u0db8\u0dd4\u0dab\u0dd4\u0d9a\u0dd4\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db4\u0dd4\u0dad\u0dcf\u0d9c\u0dda \u0dc4\u0dd2\u0dc3\u0da7 \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba\u0d9a\u0dca \u0dc0\u0dd0\u0da7\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd4\u0dad\u0dcf \u0db8\u0dd2\u0dba \u0d9c\u0dd2\u0dba \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db8\u0dd2\u0dba\u0d9a\u0db1\u0db3\u0dd4\u0dbb \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda 10 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0dd0\u0db6\u0dd6 \u0db8\u0dd2\u0dba\u0d9a\u0db1\u0db3\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d91\u0da0\u0dca.\u0d91\u0db8\u0dca.\u0dc3\u0db8\u0dd3\u0dbb \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0db8\u0dd2\u0dba \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "29 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dc0\u0dc3 6.30\u0da7 \u0db4\u0dd2\u0dba\u0dcf \u0dc0\u0dad\u0dca\u0dad\u0dda \u0d85\u0da9\u0dd2 50\u0d9a\u0dca \u0db4\u0db8\u0dab \u0d8b\u0dc3 \u0d9c\u0dc3\u0d9a\u0da7 \u0db1\u0dd0\u0d9f \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba\u0d9a\u0dca \u0d9a\u0da9\u0dcf\u0d9c\u0dd9\u0db1 \u0d91\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dd4\u0dad\u0dcf \u0db1\u0dd2\u0dc0\u0dc3\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0db6\u0dc0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u200d\u0dc2\u0dab\u0dc0\u0dbd\u0daf\u0dd3 \u0dc4\u0dd9\u0dc5\u0dd2 \u0dc0\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0d92 \u0d85\u0dc0\u0dc3\u0dca\u200c\u0dae\u0dcf\u0dc0\u0dda \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba \u0d9a\u0da9\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db6\u0dbb\u0db4\u0dad\u0dc5 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0dd0\u0db6\u0dd6 \u0d94\u0dc4\u0dd4 \u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d8a\u0dba\u0dda (31) \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db1\u0ddc\u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0ddc\u0dbd\u0dca \u0d9a\u0dd0\u0da9\u0dd3\u0db8\u0dda \u0da0\u0ddd\u0daf\u0db1\u0dcf\u0dc0 \u0db8\u0dad 55 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd2\u0dba\u0dcf\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0db1\u0dd3\u0dad\u0dd2\u0db8\u0dba \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb \u0d87\u0dad. (\u0d86)"
      ],
