    "si": {
      "title": "\u0d8b\u0daf\u0dba\u0d82\u0d9c \u0dc3\u0dd3.\u0d85\u0dba\u0dd2.\u0da9\u0dd3 \u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2\u00a0\u0d8b\u0daf\u0dba\u0d82\u0d9c \u0dc0\u0dd3\u0dbb\u0dad\u0dd4\u0d82\u0d9c\u00a0 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u00a0 \u0daf\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0daf (17\u0daf\u0dcf)\u00a0\u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [
        {
          "text": "\u0d8b\u0daf\u0dba\u0d82\u0d9c \u0dc3\u0dd3.\u0d85\u0dba\u0dd2.\u0da9\u0dd3",
          "label": "ORG"
        }
      ],
