    "si": {
      "title": "\u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db8\u0dd4\u0dc2\u0dca\u0dc6\u0dd2\u0d9a\u0dbb\u0dca \u0dc0\u0dd2\u0dc3\u0dca\u0dc3\u0dba\u0dd220 \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0dd4\u0d9c\u0db1\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0dab \u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0db8\u0dd4\u0dc2\u0dca\u0dc6\u0dd2\u0d9a\u0dbb\u0dca \u0dbb\u0dc4\u0dd3\u0db8\u0dca \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dc0\u0dd2\u0dc3\u0dca\u0dc3\u0dba\u0dd220 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0dd4\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1\u0dba \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf 2022 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d91\u0db8 \u0dad\u0dbb\u0d9c\u0dba\u0dda \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0dc4\u0d9a\u0dba\u0db1\u0dca \u0dbd\u0dd9\u0dc3 2022 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc4\u0dad\u0dbb \u0d85\u0daf\u0dd2\u0dba\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0db6\u0d82\u0d9c\u0dca\u0dbd\u0dcf\u0daf\u0dda\u0dc1\u0dba \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0dca\u0daf\u0dd2\u0db1 \u0dc3\u0dc4 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dc0\u0dbd\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dbb\u0dc4\u0dd3\u0db8\u0dca \u0db4\u0dc0\u0dc3\u0dcf \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dcf."
      ],
