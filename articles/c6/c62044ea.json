          {
            "text": "\u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 \u0dc4\u0dad\u0dbb\u0d9a\u0dca",
            "label": "MONEY"
