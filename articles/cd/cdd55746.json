    "si": {
      "title": "\u0da9\u0dbd\u0dc3\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2\u0da7 \u0dc3\u0dd4\u0db7 \u0db4\u0dd0\u0dad\u0dd4\u0db8\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0db7\u0dd2\u0db1\u0dc0 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0da7 \u0dc4\u0daf\u0dc0\u0dad\u0dd2\u0db1\u0dca \u0dc3\u0dd4\u0db6 \u0db4\u0dad\u0db1 \u0db6\u0dc0 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dab\u0dba\u0da7 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0dc0\u0dd6 \u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0db8\u0dca \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db4\u0dd0\u0dbb\u0daf\u0dd6\u0db1\u0dd6 \u0db1\u0db8\u0dd6\u0daf\u0dd6 \u0dad\u0db8 \u0daf\u0dd9\u0dca\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0db8\u0dad\u0dc0\u0dcf\u0daf\u0dba \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0dc0\u0dd6\u0dba\u0dd9\u0dca \u0db1\u0dd0\u0dad\u0dd0\u0dba\u0dd2 \u0d9a\u0dd2\u0dba\u0db1 \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf\u00a0 \u0d91\u0dba\u0da7 \u0dc4\u0dd9\u0dca\u0dad\u0dd4\u0dc0 \u0dad\u0db8\u0dcf \u0daf\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1\u0dcf\u0dc0\u0dda \u0daf\u0dd6\u0db4\u0dad \u0dad\u0dd4\u0dbd \u0db4\u0dc0\u0dd6\u0dbd\u0dca 225 \u0dc0\u0dd9\u0db1\u0dd6\u0dc0\u0da7 \u0daf\u0dd6\u0db4\u0dad\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad \u0db4\u0dc0\u0dd6\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 58 \u0dc0\u0dd9\u0db1\u0dd6\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd9\u0db1\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0dba\u0dd0\u0dba\u0dd2 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0dad\u0db8\u0dcf \u0d9a\u0dd9\u0dbb\u0dd9\u0dc4\u0dd2 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dcf\u0dc3\u0dba \u0dad\u0dd0\u0db6\u0dd6 \u0dc3\u0dd2\u0dba\u0dc5\u0dd4\u0db8 \u0db4\u0d9a\u0dca\u0dc2 \u0dc3\u0dc4 \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0db1\u0dca \u0dc0\u0dd9\u0dad\u00a0 \u0d9c\u0dde\u0dbb\u0dc0\u0dcf\u0daf\u0dbb \u0dc3\u0dca\u0dad\u0dd4\u0dad\u0dd2\u0dba \u0db4\u0dd6\u0daf\u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0daf \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0dc3\u0dd2\u0dba \u0dc6\u0dda\u0dc3\u0dca\u0db6\u0dd4\u0d9a\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dda \u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0dad\u0db6\u0db8\u0dd2\u0db1\u0dca \u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dda \u0db6\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2."
      ],
