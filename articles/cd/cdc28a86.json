            "text": "\u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0dc0\u0dd2\u0dc1\u0dd2\u0db6\u0db8",
            "label": "NORP"
          },
          {
            "text": "\u0dc0\u0dc3\u0db1\u0dca\u0dad \u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0ddd\u0dc3\u0db4\u0dca \u0dc3\u0dca\u0da7\u0dcf\u0dbd\u0dd2\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dbd\u0dc4\u0dd2\u0dbb\u0dd4 \u0dc0\u0dd3\u0dbb\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dbb\u0d82\u0d9c \u0d9c\u0dd4\u0dab\u0dc3\u0dda\u0d9a\u0dbb \u0dc3\u0dc4 \u0d9c\u0dbb\u0dd4 \u0db4\u0dd2\u0dba\u0dad\u0dd4\u0db8\u0dcf",
            "label": "ORG"
