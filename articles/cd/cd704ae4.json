    "si": {
      "title": "\u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0d9a\u0dd0\u0dc3\u0dca\u0db6\u0dd1\u0dc0\u0dcf \u0dba\u0dc5\u0dd2\u0dad\u0dca  \u0daf\u0dd2\u0dba\u0db9 \u0db6\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dd2\u0dbb\u0dd2\u0dc3\u0dca\u0dc3 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dda\u0daf\u0dd3 \u0db8\u0dcf\u0dc5\u0dd4 \u0daf\u0dd0\u0dbd\u0d9a\u0da7 \u0dc4\u0dc3\u0dd4\u0dc0 \u0d9c\u0dd9\u0dbd \u0db4\u0daf\u0dda\u0dc1\u0dba \u0d9a\u0dd0\u0db4\u0dd3 \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0dc3\u0dd2\u0da7\u0dd2 \u0dc4\u0dd2\u0d9a\u0dca\u0d9a\u0da9\u0dd4\u0dc0 \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd3 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db7\u0dcf\u0dbb\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0dcf \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u0dbb\u0dd1\u0db8\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0d9a\u0dca \u0db4\u0db8\u0dab \u0db6\u0dbb \u0d9a\u0dd0\u0dc3\u0dca\u0db6\u0dd1\u0dc0\u0dd9\u0d9a\u0dd4 \u0dba\u0dbd\u0dd2 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0da7 \u0daf\u0dd0\u0db8\u0dd3\u0db8 \u0d85\u0daf (15\u0daf\u0dcf) \u0d8b\u0daf\u0dda \u0d85\u0db8\u0dca\u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0dc0\u0dd9\u0dbb\u0dc5 \u0dad\u0dd3\u0dbb\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd2\u0dab.",
        "\u0d85\u0db8\u0dca\u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0d9a\u0dd0\u0dc3\u0dca\u0db6\u0dd1 \u0dc3\u0d82\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0d9a \u0db8\u0dda \u0d9a\u0dd0\u0dc3\u0dca\u0db6\u0dd1\u0dc0\u0dd2\u0dba \u0daf\u0dd2\u0db1 \u0d9c\u0dab\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dcf\u0dba.",
        "\u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd3 \u0dc0\u0ddb\u0daf\u0dba\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4 \u0dc4\u0dd2\u0d9a\u0dca\u0d9a\u0da9\u0dd4\u0dc0 \u0dc0\u0db1 \u0da2\u0dd3\u0dc0\u0dd3 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0d9c\u0dda\u00a0 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0d89\u0d9a\u0dca\u0db8\u0db1\u0dca \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0db8\u0dda \u0d9a\u0dd0\u0dc3\u0dca\u0db6\u0dd1\u0dc0\u0dd2\u0dba \u0dba\u0dc5\u0dd2 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0da7 \u0daf\u0dd0\u0db8\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0dba\u0dd0\u0dba\u0dd2 \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd3 \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dc4\u0dd4 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dc4.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dda \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0d9a\u0dd0\u0dc3\u0dca\u0db6\u0dd1\u0dc0\u0dcf \u0d85\u0daf (15)\u0d8b\u0daf\u0dda \u0d85\u0db8\u0dca\u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0dc0\u0dd9\u0dbb\u0dc5 \u0dad\u0dd2\u0dbb\u0dba\u0dda\u0daf\u0dd3 \u0dc4\u0dd2\u0d9a\u0dca\u0d9a\u0da9\u0dd4\u0dc0 \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd3 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0d85\u0db0\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dba\u0da7\u0dad\u0dda \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0da7 \u0daf\u0dd0\u0db8\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd2\u0dab."
      ],
