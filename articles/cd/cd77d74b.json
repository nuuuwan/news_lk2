      "body_line_ents_list": [
        [
          {
            "text": "\u0db6\u0dd3\u0da2\u0dd2\u0d82",
            "label": "GPE"
          },
          {
            "text": "\u0da0\u0dd3\u0db1\u0dba - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd9\u0dc5\u0dd9\u0db3 \u0dc3\u0dc4 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dd3\u0dad\u0dcf\u0dc0 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dc3\u0d82\u0d9c\u0db8\u0dba \u0dc3\u0dc4 \u0da9\u0dd6\u0dba\u0dd2\u0db1\u0dca (\u0da7\u0dd2\u0d9a\u0dca\u0da7\u0ddc\u0d9a\u0dca) \u0dc3\u0db8\u0dcf\u0da2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dda\u0daf\u0dd2\u0d9a\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0dab\u0dca\u0da9\u0db4\u0dba",
            "label": "ORG"
          },
          {
            "text": "2022 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 30",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
