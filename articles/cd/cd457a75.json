    "si": {
      "title": "\u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0dc3\u0dc4 \u0db8\u0dbb\u0daf\u0dcf\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd \u0d89\u0dc0\u0dad\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dc5\u0db9 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0dc3\u0dc4 \u0db8\u0dbb\u0daf\u0dcf\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0d89\u0dc0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0daf\u0dd0\u0da9\u0dd2 \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db0\u0dcf\u0dc0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dc0\u0dbd \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d87\u0dad\u0dd4\u0dc5\u0dd4\u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dc4 \u0db4\u0dd2\u0da7\u0dad\u0da7 \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0db1\u0dad\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0d9a\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d85\u0da9\u0dcf\u0dbd \u0dc0\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0d9a\u0ddc\u0dc5\u0db9 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0dc3\u0dc4 \u0db8\u0dbb\u0daf\u0dcf\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0d89\u0dc0\u0dad\u0dca \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda."
      ],
