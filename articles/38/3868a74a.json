      "body_line_ents_list": [
        [
          {
            "text": "\u0b95\u0bc7\u0b95\u0bbe\u0bb2\u0bc8 SSP \u0b95\u0bc7.\u0bb5\u0bbf\u0b9c\u0bc7\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9",
            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bc7\u0bb2\u0bcd\u0bae\u0bc1\u0bb1\u0bc8\u0baf\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "27",
            "label": "CARDINAL"
          },
          {
            "text": "\u0b95\u0bc0\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0ba4\u0bcd\u0ba9",
            "label": "ORG"
          },
          {
            "text": "\u0ba8\u0bbe\u0ba9\u0bcd\u0b95\u0bc1",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0b9c\u0ba9\u0b95 \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0",
            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bc7\u0bb2\u0bcd\u0bae\u0bc1\u0bb1\u0bc8\u0baf\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
