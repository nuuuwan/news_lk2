            "label": "PERSON"
          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "25 \u0b86\u0bae\u0bcd \u0ba4\u0bc7\u0ba4\u0bbf",
            "label": "ORDINAL"
          },
          {
            "text": "\u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0bb5\u0b99\u0bcd\u0b95\u0bbf",
            "label": "ORG"
          },
          {
