    "si": {
      "title": "\u0d9a\u0db6\u0dca\u0dbb\u0dcf\u0dbd\u0dca\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0d9c\u0db8\u0db1\u0dca \u0dad\u0dc4\u0db1\u0db8 \u0daf\u0dd2\u0dbb\u0dca\u0d9d\u00a0\u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d85\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d85\u0da2\u0dd2\u0dad\u0dca \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dca \u0d9a\u0db6\u0dca\u0dbb\u0dcf\u0dbd\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0db4\u0db1\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0d9c\u0db8\u0db1\u0dca \u0dad\u0dc4\u0db1\u0db8 \u0dbd\u0db6\u0db1 \u0d94\u0d9a\u0dca\u0dad\u0ddd\u0db6\u0dbb\u0dca \u0db8\u0dc3 26 \u0daf\u0dcf \u0dad\u0dd9\u0d9a\u0dca \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0ddc\u0dc5\u0db9 \u0d85\u0dad\u0dd2\u0dbb\u0dda\u0d9a \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0dc4\u0dbb\u0dca\u0dc2\u0dab \u0d9a\u0dd0\u0d9a\u0dd4\u0dab\u0dc0\u0dd9\u0dbd \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (25\u0daf\u0dcf) \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dd9\u0dc5\u0dda\u0dba.",
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d85\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc0\u0db1 \u0d85\u0da2\u0dd2\u0dad\u0dca \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dca \u0d9a\u0db6\u0dca\u0dbb\u0dcf\u0dbd\u0dca \u0dba\u0db1 \u0d85\u0dba \u0dc3\u0dcf\u0db4\u0dbb\u0dcf\u0db0\u0dd2 \u0dc0\u0dd2\u0dc3\u0dca\u0dc0\u0dcf\u0dc3\u0dba \u0d9a\u0da9 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0dab\u0dd4 \u0dbd\u0db6\u0db1 \u0dc3\u0dcf\u0db4\u0dbb\u0dcf\u0db0\u0dd2 \u0dc0\u0dd2\u0dc3\u0dca\u0dc0\u0dcf\u0dc3\u0dba \u0d9a\u0da9 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc0\u0d82\u0d9a \u0dbd\u0dd9\u0dc3 \u0dc4\u0dcf \u0dc3\u0dcf\u0dc0\u0daf\u0dca\u200d\u0dba \u0dbd\u0dd9\u0dc3 \u0db4\u0dbb\u0dd2\u0dc4\u0dbb\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8, 1937 \u0d85\u0d82\u0d9a 07 \u0daf\u0dbb\u0dab (\u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad) \u0d86\u0da5\u0dcf \u0db4\u0db1\u0dad\u0dda \u0d85\u0d82\u0d9a 56 (\u0d85) (1) (\u0d85) \u0dba\u0da7\u0dad\u0dda \u0dc0\u0dbb\u0daf\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0dbb\u0da2\u0dd2\u0dad\u0dca \u0d9a\u0dd3\u0dbb\u0dca\u0dad\u0dd2 \u0dad\u0dd9\u0db1\u0dca\u0db1\u0d9a\u0ddd\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0d9c\u0ddc\u0db1\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0da7 \u0d85\u0daf\u0dcf\u0dc5\u0dc0 \u0db8\u0dd9\u0db8 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0d9c\u0db8\u0db1\u0dca \u0dad\u0dc4\u0db1\u0db8 \u0db4\u0dd0\u0db1\u0dc0\u0dd3\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
