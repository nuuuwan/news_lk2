    "si": {
      "title": "\u0d9a\u0dd8\u0dc2\u0dd2 \u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 163\u0d9a \u0db4\u0dcf\u0da9\u0dd4\u0dc0\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0dc4\u0dcf \u0d9c\u0ddc\u0dc0\u0dd2\u0da2\u0db1 \u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbb\u0d9a\u0dca\u0dc2\u0dab\u0db7\u0dcf\u0dbb \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd \u0dc3\u0db8\u0d9c \u0d87\u0dad\u0dd2\u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8 \u0d85\u0dc4\u0ddd\u0dc3\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0d9a\u0dd8\u0dc2\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 163.6\u0d9a \u0db4\u0dcf\u0da9\u0dd4\u0dc0\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca\u0dba.",
        "\u0db8\u0dda \u0db6\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0db1\u0dca\u0db1\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd2\u0d9c\u0dab\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0dc4\u0dcf \u0d9c\u0ddc\u0dc0\u0dd2\u0da2\u0db1 \u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca 2020 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0da7 \u0d85\u0daf\u0dcf\u0dc5\u0dc0 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0dc0\u0dd2\u0d9c\u0dab\u0db1 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0dda\u0dba.",
        "\u0dbb\u0d9a\u0dca\u0dc2\u0dab\u0db7\u0dcf\u0dbb \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd \u0dc3\u0db8\u0d9c \u0d87\u0dad\u0dd2\u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8 \u0d85\u0db1\u0dd4\u0dc0 2019 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0dda \u0dba\u0dbd \u0d9a\u0db1\u0dca\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0d91\u0d9a\u0dca \u0d9c\u0ddc\u0dc0\u0dd2\u0dba\u0dd9\u0d9a\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9c\u0dad\u0dc0\u0dd2\u0dba\u0dc4\u0dd0\u0d9a\u0dd2 \u0db8\u0dd4\u0dc5\u0dd4 \u0dc0\u0db1\u0dca\u0daf\u0dd2 \u0dc0\u0da7\u0dd2\u0db1\u0dcf\u0d9a\u0db8\u0dd2\u0db1\u0dca\u0db8\u0dd4\u0dbd\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,000\u0d9a \u0db8\u0dd4\u0daf\u0dbd \u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 312\u0d9a \u0dc4\u0dd2\u0d9f \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad \u0dba\u0dd4\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0d91\u0dc4\u0dd9\u0dad\u0dca \u0d9a\u0dd8\u0dc2\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d91\u0db8 \u0dc4\u0dd2\u0d9f \u0db8\u0dd4\u0daf\u0dbd \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0da7\u00a0 2020 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0dda\u0daf\u0dd3 \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8 \u0d85\u0dc4\u0ddd\u0dc3\u0dd2\u0d9a\u0dbb \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 148.3\u0d9a \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0d9a\u0dd8\u0dc2\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 163.6\u0d9a \u0d85\u0dbd\u0dcf\u0db7\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd2\u0d9c\u0dab\u0db1\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0d86\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0db1\u0ddc\u0dc0\u0dd6 \u0db1\u0dd2\u0dc3\u0dcf \u0db8\u0dd9\u0d9a\u0dd3 \u0db8\u0dd4\u0daf\u0dbd \u0dbd\u0dd0\u0db6\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d9c\u0dab\u0db1\u0dca \u0db6\u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0d85\u0dad\u0dbb, \u0db8\u0dd9\u0db8 \u0db8\u0dd4\u0daf\u0dbd \u0d9a\u0dd8\u0dc2\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc0\u0dd9\u0dad \u0dbd\u0dd0\u0db6\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0d9a\u0dd8\u0dc2\u0dd2\u0dbb\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0dad\u0dca\u0dc0\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0d9c\u0dab\u0db1\u0dba\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd3\u0dad\u0dd2\u0db6\u0dda."
      ],
