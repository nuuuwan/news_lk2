        ],
        [
          {
            "text": "\u0da9\u0dd3.\u0d91\u0db8\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0db8\u0db0\u0dd4\u0dc2\u0dcf\u0db1\u0dca",
