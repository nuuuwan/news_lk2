          },
          {
            "text": "\u0d9c\u0dbd\u0dca\u0da7\u0db8\u0dca\u0db8\u0dab\u0dca\u0da9\u0dd2\u0dba \u0d9a\u0db1\u0dd2\u0dc2\u0dca\u0da8 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d94\u0d9a\u0dca\u0d9a\u0db8\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba",
