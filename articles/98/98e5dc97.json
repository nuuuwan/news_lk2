    "si": {
      "title": "\u0d9a\u0ddd\u0db1\u0dca \u0d87\u0da7\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0dbb\u0dc0\u0dd3 9 \u0dc4\u0dd0\u0dc0\u0dd0\u0dbb\u0dd2\u0daf\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dca \u0db8\u0dbb\u0dd4\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddd\u0db1\u0dca\u0d9c\u0dd9\u0da9\u0dd2 \u0d9a\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0d9a\u0ddd\u0db1\u0dca\u0d87\u0da7\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0dbb\u0dc0\u0dd3 \u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0db1\u0dc0 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0d85\u0daf (05\u0daf\u0dcf) \u0d85\u0dbd\u0dd4\u0dba\u0db8 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca\u0dad\u0dda \u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd \u0dc3\u0dd4\u0daf\u0dd4\u0dc0\u0dad\u0dd4\u0dbb\u0d86\u0dbb \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d94\u0d9a\u0dca\u0d9a\u0db8\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0d9c\u0dbd\u0dca\u0da7\u0dd0\u0db8\u0dca\u0db8\u0dab\u0dca\u0da9\u0dd2\u0dba \u0d9a\u0db1\u0dd2\u0dc2\u0dca\u0da8 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dad\u0dd4\u0db1\u0dc0\u0dc3\u0dbb\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0db6\u0db1 \u0da9\u0dd3.\u0d91\u0db8\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0db8\u0db0\u0dd4\u0dc1\u0dcf\u0db1\u0dca (09) \u0db1\u0dd0\u0db8\u0dad\u0dd2 \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba\u0dba\u0dd9\u0d9a\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0d89\u0d9a\u0dd4\u0dad\u0dca 28 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf \u0db1\u0dd2\u0dc0\u0dc3 \u0d85\u0dc3\u0dbd \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0d9a\u0ddd\u0db1\u0dca\u0d9c\u0dc3\u0d9a\u0dd2\u0db1\u0dca \u0d9a\u0ddd\u0db1\u0dca\u0d9c\u0dd9\u0da9\u0dd2 \u0d9a\u0da9\u0dcf \u0db1\u0dd2\u0dc0\u0dc3\u0da7 \u0d9c\u0dd9\u0db1\u0dc0\u0dd2\u0dad\u0dca \u0d9a\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0d9a\u0ddd\u0db1\u0dca\u0d87\u0da7\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0dbb\u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db4\u0dc3\u0dd4\u0dc0 \u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca\u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0daf\u0dd0\u0da9\u0dd2 \u0dc3\u0dad\u0dca\u0d9a\u0dcf\u0dbb \u0d92\u0d9a\u0d9a\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad. \u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dba\u0dd2."
      ],
      "title_ents": [
        {
          "text": "9 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2",
