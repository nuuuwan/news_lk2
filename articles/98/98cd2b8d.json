    "si": {
      "title": "\u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba \u0dc3\u0db8\u0dca\u0db8\u0dad \u0dc0\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db1\u0dc0 \u0dbb\u0da2\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0dba \u0dad\u0dc0\u0dad\u0dca \u0db8\u0dc3\u0d9a\u0dd2\u0db1\u0dca \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2 \u0da1\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0d85\u0daf (27) \u0dc3\u0db8\u0dca\u0db8\u0dad \u0dc0\u0dd2\u0dba.",
        "\u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0da7 \u0db4\u0d9a\u0dca\u0dc2\u0dc0 \u0da1\u0db1\u0dca\u0daf 120 \u0d9a\u0dca \u0dc3\u0dc4 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dc0 \u0da1\u0db1\u0dca\u0daf 63 \u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd2\u0dab\u0dd2. \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0dad\u0dd2\u0dbb\u0dda\u0d9a \u0da1\u0db1\u0dca\u0daf 57\u0d9a\u0dd2\u0db1\u0dca \u0d91\u0db8 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0 \u0dc3\u0db8\u0dca\u0db8\u0dad \u0dc0\u0dd2\u0dba."
      ],
