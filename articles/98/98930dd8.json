    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0dc5\u0db8\u0dd4 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "2022 \u0dc0\u0dc3\u0dbb\u0dda \u0d91\u0d82\u0d9c\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0db6\u0dbb\u0dca\u0db8\u0dd2\u0d82\u0dc4\u0dd0\u0db8\u0dca \u0dc4\u0dd2 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db4\u0ddc\u0daf\u0dd4\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dd3\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d8b\u0dc5\u0dd9\u0dbd\u0dda\u0daf\u0dd3 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 55 \u0db6\u0dbb \u0d89\u0dc3\u0dd2\u0dbd\u0dd3\u0db8\u0dda \u0d89\u0dc3\u0dc0\u0dca\u0dc0\u0dd9\u0db1\u0dca \u0dbd\u0ddd\u0d9a\u0da9 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dad\u0dd2\u0dbd\u0d82\u0d9c \u0d89\u0dc3\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd9\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dbd\u0dd0\u0db6\u0dd6 \u0db4\u0dc5\u0db8\u0dd4 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d94\u0dc4\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 225 \u0db6\u0dbb \u0d89\u0dc3\u0dd2\u0dbd\u0dd3\u0db8\u0dda \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0ddd\u0d9a\u0da9 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8\u0d9a\u0dca \u0daf\u0dd2\u0db1\u0dcf\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2."
      ],
