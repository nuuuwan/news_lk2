    "si": {
      "title": "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca 96 \u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca\u2019 \u0dc0\u0dba\u0dd2\u0dbb\u0dc3\u0dba \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 96 \u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0d85\u0daf (14) \u0d85\u0dbd\u0dd4\u0dad\u0dd2\u0db1\u0dca \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd9\u0dbb\u0da7\u0dd2\u0db1\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0db8\u0dd4\u0dc5\u0dd4 \u2018\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca\u2019 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 668,012 \u0d9a\u0dca \u0db6\u0dc0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf\u0d9c\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0dda \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dda."
      ],
