    "si": {
      "title": "\u0daf\u0d9a\u0dd4\u0dab\u0dd4\u0daf\u0dd2\u0d9c \u0d89\u0dbb\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d89\u0dbb\u0dcf\u0db1\u0dba\u0da7 \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db4\u0dbb\u0dd2\u0db8\u0dcf\u0dab 5.7\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd \u0db7\u0dd6\u00a0\u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2\u0dc0\u0dd3\u00a0\u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d85\u0daf (24\u0daf\u0dcf) \u0d85\u0dbd\u0dd4\u0dba\u0db8\u0dca \u0d9a\u0dcf\u0dbd\u0dba\u0dda\u0daf\u0dd3\u00a0\u0db8\u0dd9\u0db8 \u0db7\u0dd6\u00a0\u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb,\u00a0\u0db7\u0dd6\u00a0\u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd6 \u0d85\u0dbd\u0dcf\u0db7\u0dcf\u0db1\u0dd2 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db1\u0dd2\u0dbd \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0 \u0d91\u0db8 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
      "title_ents": [
        {
          "text": "\u0d89\u0dbb\u0dcf\u0db1\u0dba",
