{
  "newspaper_id": "lankadeepa-lk",
  "url": "https://www.lankadeepa.lk/news/\u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9-\u0db1\u0da9\u0dd4\u0dc0:-\u0dba\u0dd4\u0daf-\u0dc4\u0db8\u0dd4\u0daf\u0dcf-\u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca-\u0d87\u0dad\u0dd4\u0db5-\u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2-\u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7-\u0d87\u0db4/101-615287",
  "time_ut": 1655988676,
  "original_lang": "si",
  "original_title": "\u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0da9\u0dd4\u0dc0: \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d87\u0dad\u0dd4\u0db5 \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d87\u0db4",
  "text_idx": {
    "si": {
      "title": "\u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0da9\u0dd4\u0dc0: \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d87\u0dad\u0dd4\u0db5 \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d87\u0db4",
      "body_lines": [
        "\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dd9\u0dc0\u0dca\u0daf\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dd3\u0dad\u0dca \u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dd1\u0db8\u0da7 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0da7 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0dbd\u0dd0\u0db6 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dbd\u0dd4\u0dad\u0dd2\u0db1\u0db1\u0dca \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca 07 \u0daf\u0dd9\u0db1\u0dcf \u0db4\u0dd9\u0dbb \u0d87\u0db4 \u0db8\u0dad \u0db8\u0dd4\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5 \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0dbd\u0db6\u0db1 27 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca \u0db6\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0d9a\u0ddc\u0dc5\u0db9 \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0d8a\u0dba\u0dda (23) \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db1\u0da9\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd4 \u0dc3\u0dd4\u0db8\u0dad\u0dd2\u0db4\u0dcf\u0dbd \u0dc3\u0dd4\u0dbb\u0dda\u0dc2\u0dca \u0db1\u0dd0\u0db8\u0dd0\u0dad\u0dd2 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0d85\u0dc3\u0dad\u0dca\u200d\u0dba \u0dc3\u0dcf\u0d9a\u0dca\u0d9a\u0dd2\u0daf\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd6\u0dc0\u0dd9\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca \u0db6\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dd9\u0dbb\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0db1 \u0dc3\u0d82\u0da2\u0dd3\u0dc0 \u0db8\u0ddc\u0dbb\u0dcf\u0dba\u0dc3\u0dca (\u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2), \u0daf\u0db8\u0dd2\u0dad\u0dca \u0dad\u0ddc\u0da7\u0dc0\u0dad\u0dca\u0dad \u0dc3\u0dc4 \u0db8\u0dc4\u0dd9\u0db1\u0dca \u0dc0\u0dd3\u0dbb\u0db8\u0db1\u0dca \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0 \u0d9a\u0dd0\u0db3\u0dc0\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd2\u0dab.",
        "2010 \u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd3 \u0db8\u0dc3 24 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dad\u0dca 27 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dad\u0dca \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0d9c\u0dd2\u0dbb\u0dd2\u0dad\u0dbd\u0dda, \u0d9a\u0ddc\u0dc3\u0dca\u0dc0\u0dad\u0dca\u0dad, \u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd, \u0d85\u0da9\u0dbd\u0da0\u0dca\u0da0\u0dda\u0db1 \u0dc4\u0dcf \u0d85\u0d9a\u0dca\u0d9a\u0dbb\u0db4\u0dad\u0dca\u0dad\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0daf\u0dd3 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd \u0db1\u0ddc\u0daf\u0dad\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dd3\u0dad\u0dca \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0db8\u0dd0\u0dad\u0dca\u0dad\u0dcf \u0d85\u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0dda \u0d85\u0daf\u0dc4\u0dc3\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dd1\u0db8\u0da7 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0daf \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db1\u0dd3\u0dad\u0dd3\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1\u0dca \u0d9c\u0ddc\u0dc3\u0dca \u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db8\u0dbb\u0dab\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0db6\u0dc0\u0da7\u0daf \u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0db1\u0d9f\u0dcf \u0d87\u0dad."
      ]
    },
    "ta": {
      "title": "\u0b8e\u0b95\u0bcd\u0ba9\u0bc6\u0bb2\u0bbf\u0b95\u0bca\u0b9f \u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bc1: \u0b87\u0bb0\u0bbe\u0ba3\u0bc1\u0bb5 \u0b95\u0bb0\u0bcd\u0ba9\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0bbf\u0b9f\u0bcd\u0b9f \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0bbf\u0ba3\u0bc8",
      "body_lines": [
        "\u0baa\u0bbf\u0bb0\u0b95\u0bc0\u0ba4\u0bcd \u0b8e\u0b95\u0bcd\u0ba9\u0bc6\u0bb2\u0bbf\u0b95\u0bca\u0b9f\u0bb5\u0bc8 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0b9a\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0ba4\u0bbe\u0b95 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bae\u0bcd \u0b9a\u0bbe\u0b9f\u0bcd\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb2\u0bc6\u0baa\u0bcd\u0b9f\u0bbf\u0ba9\u0ba9\u0bcd\u0b9f\u0bcd \u0b95\u0bb0\u0bcd\u0ba9\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b89\u0b9f\u0bcd\u0baa\u0b9f \u0b8f\u0bb4\u0bc1 \u0b87\u0bb0\u0bbe\u0ba3\u0bc1\u0bb5 \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bc8 \u0baa\u0bbf\u0ba3\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0bb5\u0bbf\u0b95\u0bcd\u0b95 \u0b89\u0b9a\u0bcd\u0b9a \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0ba8\u0bbf\u0bb0\u0ba8\u0bcd\u0ba4\u0bb0 \u0bae\u0bc2\u0bb5\u0bb0\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0baa\u0bc6\u0b9e\u0bcd\u0b9a\u0bcd \u0ba8\u0bc7\u0bb1\u0bcd\u0bb1\u0bc1 \u0ba4\u0bbf\u0b99\u0bcd\u0b95\u0b9f\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.\u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb5\u0bb0\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb4\u0bbe\u0bae\u0bcd \u0ba8\u0bc7\u0bb1\u0bcd\u0bb1\u0bc1 ( 23) \u0b85\u0bb5\u0bb0\u0bc8 \u0ba8\u0bbe\u0b9f\u0bc1 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
        "\u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd \u0b9a\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0baf\u0bbe\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bb2\u0bc8\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbe\u0bb3\u0bcd \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd \u0b9a\u0bc1\u0bae\u0ba4\u0bbf\u0baa\u0bbe\u0bb2 \u0b9a\u0bc1\u0bb0\u0bc7\u0bb7\u0bcd \u0baa\u0bca\u0baf\u0bcd\u0b9a\u0bcd \u0b9a\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0bb3\u0b95\u0bcd\u0b95\u0bae\u0bb1\u0bbf\u0baf\u0bb2\u0bbf\u0bb2\u0bcd \u0bb5\u0bc8\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b9a\u0b9e\u0bcd\u0b9a\u0bc0\u0bb5 \u0bae\u0bca\u0bb0\u0bc7\u0bb8\u0bcd (\u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd), \u0ba4\u0bae\u0bbf\u0ba4\u0bcd \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f\u0bb5\u0ba4\u0bcd\u0ba4 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bb9\u0bc7\u0ba9\u0bcd \u0bb5\u0bc0\u0bb0\u0bae\u0ba9\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b85\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bbf\u0bb0\u0ba8\u0bcd\u0ba4\u0bb0 \u0bae\u0bc2\u0bb5\u0bb0\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb4\u0bbe\u0bae\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bbe\u0bb0\u0ba3\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
        "\u0baa\u0bbf\u0bb0\u0b95\u0bc0\u0ba4\u0bcd \u0bb0\u0b9e\u0bcd\u0b9a\u0ba9\u0bcd \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0 \u0b8e\u0b95\u0bcd\u0ba9\u0bc6\u0bb2\u0bbf\u0b95\u0bca\u0b9f\u0bb5\u0bc8 2010 \u0b9c\u0ba9\u0bb5\u0bb0\u0bbf 24 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd 27 \u0bb5\u0bb0\u0bc8 \u0b95\u0bbf\u0bb0\u0bbf\u0ba4\u0bb2\u0bc7, \u0b95\u0bca\u0bb8\u0bcd\u0bb5\u0ba4\u0bcd\u0ba4\u0bc8, \u0baa\u0ba4\u0bcd\u0ba4\u0bb0\u0bae\u0bc1\u0bb2\u0bcd\u0bb2, \u0b85\u0b9f\u0bcd\u0b9f\u0bbe\u0bb3\u0bc8\u0b9a\u0bcd\u0b9a\u0bc7\u0ba9\u0bc8, \u0b85\u0b95\u0bcd\u0b95\u0bb0\u0bc8\u0baa\u0bcd\u0baa\u0bb1\u0bcd\u0bb1\u0bc1 \u0b86\u0b95\u0bbf\u0baf \u0b87\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0b9a\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ]
    },
    "en": {
      "title": "Ekneligoda case: Bail for intelligence officers including Army colonels",
      "body_lines": [
        "The permanent three-member bench of the Supreme Court on Monday ordered the release on bail of seven Army intelligence officers, including two lieutenant colonels, who were accused of plotting to abduct Prageeth Ekneligoda. A three-judge bench of the Colombo High Court yesterday (23) ordered his extradition.",
        "Sumathipala Suresh, a former LTTE member who was a witness in the case, was remanded on the basis of perjury.",
        "The case was taken up before a permanent three-judge bench comprising Justices Sanjeewa Moraes (Chairman), Damith Thotawatte and Mahen Weeraman.",
        "He also conspired to abduct Prageeth Ranjan Bandara Ekneligoda between January 24 and 27, 2010 in Giritale, Koswatta, Battaramulla, Adalachchenai and Akkaraipattu with the intention of illegally detaining him. Defendants have also been charged with murder."
      ]
    }
  },
  "title": "\u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0da9\u0dd4\u0dc0: \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d87\u0dad\u0dd4\u0db5 \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d87\u0db4",
  "body_lines": [
    "\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dd9\u0dc0\u0dca\u0daf\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dd3\u0dad\u0dca \u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dd1\u0db8\u0da7 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0da7 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0dbd\u0dd0\u0db6 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dbd\u0dd4\u0dad\u0dd2\u0db1\u0db1\u0dca \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca 07 \u0daf\u0dd9\u0db1\u0dcf \u0db4\u0dd9\u0dbb \u0d87\u0db4 \u0db8\u0dad \u0db8\u0dd4\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5 \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0dbd\u0db6\u0db1 27 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca \u0db6\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0d9a\u0ddc\u0dc5\u0db9 \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0d8a\u0dba\u0dda (23) \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dc5\u0dda\u0dba.",
    "\u0db1\u0da9\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd4 \u0dc3\u0dd4\u0db8\u0dad\u0dd2\u0db4\u0dcf\u0dbd \u0dc3\u0dd4\u0dbb\u0dda\u0dc2\u0dca \u0db1\u0dd0\u0db8\u0dd0\u0dad\u0dd2 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0d85\u0dc3\u0dad\u0dca\u200d\u0dba \u0dc3\u0dcf\u0d9a\u0dca\u0d9a\u0dd2\u0daf\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd6\u0dc0\u0dd9\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca \u0db6\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dd9\u0dbb\u0dd2\u0dab\u0dd2.",
    "\u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0db1 \u0dc3\u0d82\u0da2\u0dd3\u0dc0 \u0db8\u0ddc\u0dbb\u0dcf\u0dba\u0dc3\u0dca (\u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2), \u0daf\u0db8\u0dd2\u0dad\u0dca \u0dad\u0ddc\u0da7\u0dc0\u0dad\u0dca\u0dad \u0dc3\u0dc4 \u0db8\u0dc4\u0dd9\u0db1\u0dca \u0dc0\u0dd3\u0dbb\u0db8\u0db1\u0dca \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0 \u0d9a\u0dd0\u0db3\u0dc0\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd2\u0dab.",
    "2010 \u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd3 \u0db8\u0dc3 24 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dad\u0dca 27 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dad\u0dca \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0d9c\u0dd2\u0dbb\u0dd2\u0dad\u0dbd\u0dda, \u0d9a\u0ddc\u0dc3\u0dca\u0dc0\u0dad\u0dca\u0dad, \u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd, \u0d85\u0da9\u0dbd\u0da0\u0dca\u0da0\u0dda\u0db1 \u0dc4\u0dcf \u0d85\u0d9a\u0dca\u0d9a\u0dbb\u0db4\u0dad\u0dca\u0dad\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0daf\u0dd3 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd \u0db1\u0ddc\u0daf\u0dad\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dd3\u0dad\u0dca \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0db8\u0dd0\u0dad\u0dca\u0dad\u0dcf \u0d85\u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0dda \u0d85\u0daf\u0dc4\u0dc3\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dd1\u0db8\u0da7 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0daf \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db1\u0dd3\u0dad\u0dd3\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1\u0dca \u0d9c\u0ddc\u0dc3\u0dca \u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db8\u0dbb\u0dab\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0db6\u0dc0\u0da7\u0daf \u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0db1\u0d9f\u0dcf \u0d87\u0dad."
  ],
  "translate": {
    "si": {
      "title": "\u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0da9\u0dd4\u0dc0: \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0d87\u0dad\u0dd4\u0db5 \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d87\u0db4",
      "body_lines": [
        "\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dd9\u0dc0\u0dca\u0daf\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dd3\u0dad\u0dca \u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dd1\u0db8\u0da7 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0da7 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0dbd\u0dd0\u0db6 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dbd\u0dd4\u0dad\u0dd2\u0db1\u0db1\u0dca \u0d9a\u0dbb\u0dca\u0db1\u0dbd\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca 07 \u0daf\u0dd9\u0db1\u0dcf \u0db4\u0dd9\u0dbb \u0d87\u0db4 \u0db8\u0dad \u0db8\u0dd4\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5 \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0dbd\u0db6\u0db1 27 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca \u0db6\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0d9a\u0ddc\u0dc5\u0db9 \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0d8a\u0dba\u0dda (23) \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db1\u0da9\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0dda \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0dc0\u0dd4 \u0dc3\u0dd4\u0db8\u0dad\u0dd2\u0db4\u0dcf\u0dbd \u0dc3\u0dd4\u0dbb\u0dda\u0dc2\u0dca \u0db1\u0dd0\u0db8\u0dd0\u0dad\u0dd2 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0d85\u0dc3\u0dad\u0dca\u200d\u0dba \u0dc3\u0dcf\u0d9a\u0dca\u0d9a\u0dd2\u0daf\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd6\u0dc0\u0dd9\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0dbb\u0dd2\u0db8\u0dcf\u0db1\u0dca\u0da9\u0dca \u0db6\u0dcf\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dd9\u0dbb\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0db1 \u0dc3\u0d82\u0da2\u0dd3\u0dc0 \u0db8\u0ddc\u0dbb\u0dcf\u0dba\u0dc3\u0dca (\u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2), \u0daf\u0db8\u0dd2\u0dad\u0dca \u0dad\u0ddc\u0da7\u0dc0\u0dad\u0dca\u0dad \u0dc3\u0dc4 \u0db8\u0dc4\u0dd9\u0db1\u0dca \u0dc0\u0dd3\u0dbb\u0db8\u0db1\u0dca \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dad\u0dca\u200d\u0dbb\u0dd2\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0 \u0d9a\u0dd0\u0db3\u0dc0\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd2\u0dab.",
        "2010 \u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd3 \u0db8\u0dc3 24 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dad\u0dca 27 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dad\u0dca \u0d85\u0dad\u0dbb \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0d9c\u0dd2\u0dbb\u0dd2\u0dad\u0dbd\u0dda, \u0d9a\u0ddc\u0dc3\u0dca\u0dc0\u0dad\u0dca\u0dad, \u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd, \u0d85\u0da9\u0dbd\u0da0\u0dca\u0da0\u0dda\u0db1 \u0dc4\u0dcf \u0d85\u0d9a\u0dca\u0d9a\u0dbb\u0db4\u0dad\u0dca\u0dad\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0daf\u0dd3 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd \u0db1\u0ddc\u0daf\u0dad\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dd3\u0dad\u0dca \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0d91\u0d9a\u0dca\u0db1\u0dd0\u0dc5\u0dd2\u0d9c\u0ddc\u0da9 \u0db1\u0db8\u0dd0\u0dad\u0dca\u0dad\u0dcf \u0d85\u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0dda \u0d85\u0daf\u0dc4\u0dc3\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dd1\u0db8\u0da7 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0daf \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db1\u0dd3\u0dad\u0dd3\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1\u0dca \u0d9c\u0ddc\u0dc3\u0dca \u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db8\u0dbb\u0dab\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0db6\u0dc0\u0da7\u0daf \u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0db1\u0d9f\u0dcf \u0d87\u0dad."
      ]
    },
    "ta": {
      "title": "\u0b8e\u0b95\u0bcd\u0ba9\u0bc6\u0bb2\u0bbf\u0b95\u0bca\u0b9f \u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bc1: \u0b87\u0bb0\u0bbe\u0ba3\u0bc1\u0bb5 \u0b95\u0bb0\u0bcd\u0ba9\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0bbf\u0b9f\u0bcd\u0b9f \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0bbf\u0ba3\u0bc8",
      "body_lines": [
        "\u0baa\u0bbf\u0bb0\u0b95\u0bc0\u0ba4\u0bcd \u0b8e\u0b95\u0bcd\u0ba9\u0bc6\u0bb2\u0bbf\u0b95\u0bca\u0b9f\u0bb5\u0bc8 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0b9a\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0ba4\u0bbe\u0b95 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bae\u0bcd \u0b9a\u0bbe\u0b9f\u0bcd\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0bb2\u0bc6\u0baa\u0bcd\u0b9f\u0bbf\u0ba9\u0ba9\u0bcd\u0b9f\u0bcd \u0b95\u0bb0\u0bcd\u0ba9\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b89\u0b9f\u0bcd\u0baa\u0b9f \u0b8f\u0bb4\u0bc1 \u0b87\u0bb0\u0bbe\u0ba3\u0bc1\u0bb5 \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bc8 \u0baa\u0bbf\u0ba3\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0bb5\u0bbf\u0b95\u0bcd\u0b95 \u0b89\u0b9a\u0bcd\u0b9a \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0ba8\u0bbf\u0bb0\u0ba8\u0bcd\u0ba4\u0bb0 \u0bae\u0bc2\u0bb5\u0bb0\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0baa\u0bc6\u0b9e\u0bcd\u0b9a\u0bcd \u0ba8\u0bc7\u0bb1\u0bcd\u0bb1\u0bc1 \u0ba4\u0bbf\u0b99\u0bcd\u0b95\u0b9f\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.\u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb5\u0bb0\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb4\u0bbe\u0bae\u0bcd \u0ba8\u0bc7\u0bb1\u0bcd\u0bb1\u0bc1 ( 23) \u0b85\u0bb5\u0bb0\u0bc8 \u0ba8\u0bbe\u0b9f\u0bc1 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
        "\u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd \u0b9a\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0baf\u0bbe\u0b95 \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bb2\u0bc8\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbe\u0bb3\u0bcd \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd \u0b9a\u0bc1\u0bae\u0ba4\u0bbf\u0baa\u0bbe\u0bb2 \u0b9a\u0bc1\u0bb0\u0bc7\u0bb7\u0bcd \u0baa\u0bca\u0baf\u0bcd\u0b9a\u0bcd \u0b9a\u0bbe\u0b9f\u0bcd\u0b9a\u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0bb3\u0b95\u0bcd\u0b95\u0bae\u0bb1\u0bbf\u0baf\u0bb2\u0bbf\u0bb2\u0bcd \u0bb5\u0bc8\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0bb5\u0bb4\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b9a\u0b9e\u0bcd\u0b9a\u0bc0\u0bb5 \u0bae\u0bca\u0bb0\u0bc7\u0bb8\u0bcd (\u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd), \u0ba4\u0bae\u0bbf\u0ba4\u0bcd \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f\u0bb5\u0ba4\u0bcd\u0ba4 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bb9\u0bc7\u0ba9\u0bcd \u0bb5\u0bc0\u0bb0\u0bae\u0ba9\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b85\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bbf\u0bb0\u0ba8\u0bcd\u0ba4\u0bb0 \u0bae\u0bc2\u0bb5\u0bb0\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bc0\u0ba4\u0bbf\u0baa\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb4\u0bbe\u0bae\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9a\u0bbe\u0bb0\u0ba3\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
        "\u0baa\u0bbf\u0bb0\u0b95\u0bc0\u0ba4\u0bcd \u0bb0\u0b9e\u0bcd\u0b9a\u0ba9\u0bcd \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0 \u0b8e\u0b95\u0bcd\u0ba9\u0bc6\u0bb2\u0bbf\u0b95\u0bca\u0b9f\u0bb5\u0bc8 2010 \u0b9c\u0ba9\u0bb5\u0bb0\u0bbf 24 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd 27 \u0bb5\u0bb0\u0bc8 \u0b95\u0bbf\u0bb0\u0bbf\u0ba4\u0bb2\u0bc7, \u0b95\u0bca\u0bb8\u0bcd\u0bb5\u0ba4\u0bcd\u0ba4\u0bc8, \u0baa\u0ba4\u0bcd\u0ba4\u0bb0\u0bae\u0bc1\u0bb2\u0bcd\u0bb2, \u0b85\u0b9f\u0bcd\u0b9f\u0bbe\u0bb3\u0bc8\u0b9a\u0bcd\u0b9a\u0bc7\u0ba9\u0bc8, \u0b85\u0b95\u0bcd\u0b95\u0bb0\u0bc8\u0baa\u0bcd\u0baa\u0bb1\u0bcd\u0bb1\u0bc1 \u0b86\u0b95\u0bbf\u0baf \u0b87\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0b95\u0b9f\u0ba4\u0bcd\u0ba4 \u0b9a\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ]
    },
    "en": {
      "title": "Ekneligoda case: Bail for intelligence officers including Army colonels",
      "body_lines": [
        "The permanent three-member bench of the Supreme Court on Monday ordered the release on bail of seven Army intelligence officers, including two lieutenant colonels, who were accused of plotting to abduct Prageeth Ekneligoda. A three-judge bench of the Colombo High Court yesterday (23) ordered his extradition.",
        "Sumathipala Suresh, a former LTTE member who was a witness in the case, was remanded on the basis of perjury.",
        "The case was taken up before a permanent three-judge bench comprising Justices Sanjeewa Moraes (Chairman), Damith Thotawatte and Mahen Weeraman.",
        "He also conspired to abduct Prageeth Ranjan Bandara Ekneligoda between January 24 and 27, 2010 in Giritale, Koswatta, Battaramulla, Adalachchenai and Akkaraipattu with the intention of illegally detaining him. Defendants have also been charged with murder."
      ]
    }
  }
}