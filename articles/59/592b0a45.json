    "si": {
      "title": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd LP \u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0d85\u0daf \u0d87\u0dbb\u0db9\u0dda; \u0db1\u0dc0 MRP \u0d9a\u0dd2\u0dbd\u0ddd 12.5 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dd4. 4,910/-\u0d9a\u0dd2.",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 12.5\u0d9a \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d89\u0dc0\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc4\u0dd4\u0db8\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0db8\u0dd2\u0dbd \u0dbb\u0dd4. 50/- \u0dc3\u0dd2\u0da7 \u0dbb\u0dd4. 4,910/-\u0d9a\u0dd2.",
        "\u0d9a\u0ddc\u0dc5\u0db9 \u0dc3\u0dc4 \u0dad\u0daf\u0dcf\u0dc3\u0db1\u0dca\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0dc3\u0db3\u0dc4\u0dcf \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d89\u0dc0\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc4\u0dd4\u0db8\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dca \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dd4\u0daf\u0dcf (11) \u0dc3\u0dd2\u0da7 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d85\u0db1\u0dd9\u0d9a\u0dd4\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0dc3\u0db3\u0dc4\u0dcf \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 2022 \u0da2\u0dd6\u0dbd\u0dd2 13 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d85\u0db1\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dbd\u0dd9\u0dc3 \u0d9c\u0ddc\u0da9\u0d9c\u0dd0\u0dc3\u0dd3\u0db8 \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf 2022 \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0db6\u0dd2\u0dbd\u0dca\u0db4\u0dad \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0 \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d85\u0daf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0d91\u0dbd\u0dca\u0db4\u0dd3 \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3,700 \u0d9a \u0dad\u0ddc\u0d9c\u0dba\u0dda \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dad \u0d89\u0dc0\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc4\u0dd4\u0db8\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dd4\u0daf\u0dcf (11) \u0daf\u0dc4\u0dc0\u0dbd\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0db1 \u0db6\u0dc0 \u0d91\u0dc4\u0dd2 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0dda.",
        "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db8\u0dd4\u0daf\u0dd2\u0dad \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca News 1st \u0dc0\u0dd9\u0dad \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0d9c\u0dd1\u0dc3\u0dca \u0dad\u0ddc\u0d9c\u0dba\u0dd9\u0db1\u0dca 70%\u0d9a\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0dc3\u0dc4 \u0dad\u0daf\u0dcf\u0dc3\u0db1\u0dca\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "LP \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3700\u0d9a \u0dad\u0dc0\u0dad\u0dca \u0db1\u0dd0\u0dc0\u0dca\u0d9c\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0d85\u0daf (11) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d91\u0db8 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0dad\u0ddc\u0d9c\u0dba\u0dd9\u0db1\u0dca 30%\u0d9a\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d89\u0dad\u0dd2\u0dbb\u0dd2 70% \u0d85\u0db1\u0dd9\u0d9a\u0dd4\u0dad\u0dca \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0db6\u0dc0 \u0dbd\u0dd2\u0da7\u0dca\u0dbb\u0ddd \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
