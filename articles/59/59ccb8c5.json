    "si": {
      "title": "\u0daf\u0dd4\u0dbb\u0d9a\u0dad\u0db1, \u0db6\u0dca\u200d\u0dbb\u0ddd\u0da9\u0dca\u0db6\u0dd1\u0db1\u0dca\u0da9\u0dca \u0dc4\u0dcf \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0da2\u0d82\u0d9c\u0db8 \u0dc3\u0dc4 \u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dbb \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0dc3\u0dda\u0dc0\u0dcf \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4, \u0db6\u0dca\u200d\u0dbb\u0ddd\u0da9\u0dca\u0db6\u0dd1\u0db1\u0dca\u0da9\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4, \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd9\u0dc0\u0dcf \u0db1\u0dbb\u0db9\u0db1 \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0dda\u0dc0\u0dcf \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc3\u0d82\u0daf\u0dda\u0dc1 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1 \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0 \u0d85\u0dc0\u0dc3\u0dbb \u0daf\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5 \u0db1\u0dd0\u0d82\u0dc0\u0dd3\u0db8 \u0dbd\u0db6\u0db1 5 \u0dc0\u0db1\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba. \u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0da2\u0d82\u0d9c\u0db8 \u0dc4\u0dcf \u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dbb \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0dc3\u0dda\u0dc0\u0dcf \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dc3\u0dc4 \u0db6\u0dca\u200d\u0dbb\u0ddd\u0da9\u0dca\u0db6\u0dd1\u0db1\u0dca\u0da9\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 20%\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0d85\u0dad\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd9\u0dc0\u0dcf \u0db1\u0dbb\u0db9\u0db1 \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0dda\u0dc0\u0dcf \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 25%\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba\u0dad",
        "\u0d8a\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0d85\u0dad\u0dd4\u0dbb\u0dd4 \u0d85\u0dba\u0dc0\u0dd0\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0d9a\u0dc5 \u0dc0\u0dd0\u0da7\u0dca \u0db6\u0daf\u0dca\u0daf\u0daf \u200c\u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0d85\u0dba \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc3\u0d82\u0daf\u0dda\u0dc1 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1 \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
