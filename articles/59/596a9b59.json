          {
            "text": "\u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 18 \u0dba\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 18 \u0da7 \u0d85\u0da9\u0dd4 04 \u0dba\u0dd2",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba, \u0dc0\u0dc0\u0dd4\u0db1\u0dd2\u0dba\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0dca\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba",
            "label": "NORP"
          },
          {
            "text": "\u0d9a\u0dbd\u0dca\u0db8\u0dd4\u0dab\u0dda, \u0db8\u0da9\u0d9a\u0dbd\u0db4\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8",
            "label": "GPE"
          },
          {
            "text": "\u0dc4\u0dbd\u0dc0\u0dad",
