            "label": "ORDINAL"
          },
          {
            "text": "\u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bbe\u0bb5\u0ba4\u0bc1 \u0bb5\u0bb0\u0bbf\u0b9a\u0bc8",
