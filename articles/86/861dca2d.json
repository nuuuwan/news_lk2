    "si": {
      "title": "\u0dc4\u0dd4\u0da7\u0db1\u0dca \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0db1\u0ddc\u0dc3\u0db1\u0dca\u0dc3\u0dd4\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca: \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dcf\u0dbb \u0dc0\u0dc3\u0dcf \u0daf\u0db8\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0da7\u0db1\u0dca \u0da0\u0dd2\u0db4\u0dd9\u0da7\u0dca\u0d9a\u0ddd \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dda \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0db1\u0dca 2000\u0d9a\u0dca \u0db4\u0db8\u0dab \u0db4\u0dd9\u0dc5 \u0d9c\u0dd0\u0dc3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dad\u0dbb, \u0dc4\u0da7\u0db1\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7\u0dd2\u0db1\u0dca \u0d85\u0dc0\u0dc4\u0dd2\u0dbb \u0dc0\u0dd2\u0dba.",
        "\u0dc4\u0da7\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0dda \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0db1 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dc3\u0db1\u0dca\u0db1\u0dda \u0dad\u0db8\u0db1\u0dca \u0dc3\u0dad\u0dd4\u0dc0 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba (09) \u0dc3\u0dd2\u0da7 \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca, \u0daf\u0dd2\u0db1\u0db4\u0dad\u0dcf \u0db4\u0dd0\u0dba \u0d9c\u0dab\u0db1\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dc3\u0dd2\u0da7 \u0dc4\u0dd2\u0dc3\u0dca \u0d85\u0dad\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0dc0\u0dd9\u0dc3\u0dca \u0db6\u0dbd\u0dcf \u0dba\u0db1 \u0db6\u0dc0\u0dad\u0dca\u0dba.",
        "\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0dd4\u0da7\u0db1\u0dca - \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0dbb\u0dae \u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0db8\u0db1\u0dcf\u0d9c\u0db8\u0db1\u0dba\u0da7 \u0dc4\u0dbb\u0dc0\u0dcf \u0dba\u0dd0\u0dc0\u0dd3\u0db8\u0da7 \u0dc4\u0dd4\u0da7\u0db1\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf."
      ],
