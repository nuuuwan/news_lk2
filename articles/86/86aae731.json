          },
          {
            "text": "\u0dc3\u0dd3\u0db8\u0dcf\u0dc3\u0dc4\u0dd2\u0dad \u0d9a\u0dc5\u0dd4\u0db6\u0ddd\u0dc0\u0dd2\u0da7\u0dd2\u0dba\u0db1 \u0dad\u0dda \u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad \u0dc1\u0dcf\u0dbd\u0dcf\u0dc0",
