    "si": {
      "title": "\u0dc4\u0dd9\u0da7 \u0d85\u0dc5\u0dd4\u0dba\u0db8 5.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0da7\u0da7\u0db8 \u0d87\u0db3\u0dd2\u0dbb\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0dba \u0db4\u0db1\u0dc0\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbb\u0da7 \u0db6\u0dbd\u0db4\u0dcf\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d85\u0daf (13) \u0db8\u0db0\u0dca\u200d\u0dba\u0dc4\u0db1 12.00 \u0dc3\u0dd2\u0da7 \u0d87\u0db3\u0dd2\u0dbb\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0dba \u0db4\u0db1\u0dc0\u0dcf \u0dc4\u0dd9\u0da7 (14) \u0d85\u0dc5\u0dd4\u0dba\u0db8 5.00 \u0da7 \u0d89\u0dc0\u0dad\u0dca\u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0db6\u0dbd\u0db1 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
