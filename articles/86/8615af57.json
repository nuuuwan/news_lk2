            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0da2\u0dba\u0db1\u0dca\u0dad \u0da2\u0dba\u0dc3\u0dd6\u0dbb\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0dbd\u0dd4\u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0dad \u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dbd\u0dbd\u0dca\u0d9c\u0ddc\u0da9",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dbd\u0dca.\u0da9\u0dd3.\u0db6\u0dd3.\u0daf\u0dd9\u0dc4\u0dd2\u0daf\u0dd9\u0dab\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dc4",
