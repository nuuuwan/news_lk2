          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2\u0dba\u0db1\u0dca \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8",
            "label": "PERSON"
