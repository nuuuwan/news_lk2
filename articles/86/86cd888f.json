    "si": {
      "title": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dad\u0dd4 \u0dc3\u0dda\u0dc0\u0d9a \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dad\u0dd4 \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad.",
        "\u2018\u2018\u0dc3\u0dd2\u0dba\u0dc0\u0dc3\u0d9a \u0d85\u0db7\u0dd2\u0db8\u0dcf\u0db1\u0dba \u0dc3\u0db8\u0d9f \u0da2\u0dba \u0da7\u0dd0\u0db9 \u0d9a\u0dbb\u0dcf\u201d \u0dba\u0db1 \u0dad\u0dda\u0db8\u0dcf \u0db4\u0dcf\u0da8\u0dba \u0dba\u0da7\u0dad\u0dda \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0dde\u0db1\u0dca\u0daf\u0dbb\u0dca\u0dba \u0db1\u0dd2\u0d9a\u0dda\u0dad\u0db1\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd4 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dad\u0dd4 \u0dc3\u0dda\u0dc0\u0d9a \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda 24 \u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dca\u0dc0\u0dd2\u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba\u0dda \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad \u0da1\u0db1\u0dca\u0daf \u0dc0\u0dd2\u0db8\u0dc3\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dad\u0dca \u0dc0\u0dd4 \u0d85\u0dad\u0dbb \u0d8b\u0db4 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd9\u0db1\u0dca\u0db1\u0db1\u0dca \u0d89\u0dbd\u0dd9\u0dba\u0dbb\u0dcf\u0da2\u0dca \u0dc4\u0dcf \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0d9a\u0dc4\u0db3\u0dc0\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2 \u0db7\u0dcf\u0db1\u0dca\u0da9\u0dcf\u0d9c\u0dcf\u0dbb\u0dd2\u0d9a \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dcf\u0dbb\u0dd2\u0db8\u0dd4\u0dad\u0dca\u0dad\u0dd4 \u0dc3\u0dd4\u0daf\u0dcf\u0dc4\u0dbb\u0dca \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4 \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca\u0dc0\u0dd4\u0dc4.",
        "\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0ddc\u0db6\u0da7\u0dca \u0dc6\u0dd0\u0db1\u0dca\u0dc3\u0dd2\u0dc3\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0db8\u0dc4\u0dcf \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d91\u0dc3. \u0d91\u0dbd\u0dca. \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db4\u0dcf\u0dbd, \u0da0\u0dcf\u0db8\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0dbb\u0dad\u0dca\u0db1, \u0dc4\u0dda\u0db8\u0db1\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1, \u0d91\u0dc3\u0dca. \u0da2\u0ddd\u0db1\u0dca. \u0db8\u0dc4\u0dda\u0dc2\u0dca \u0dbb\u0dab\u0dc3\u0dd2\u0d82\u0dc4 \u0dc3\u0dc4 \u0d91\u0dc3\u0dca. \u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db8\u0dcf\u0dbb\u0db1\u0dca \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4 \u0db1\u0dd2\u0dad\u0dbb\u0d9f\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dad\u0dca\u0dc0\u0dd4\u0dc4."
      ],
      "title_ents": [
        {
          "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dad\u0dd4 \u0dc3\u0dda\u0dc0\u0d9a \u0dc3\u0d82\u0d9c\u0db8\u0dba",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dad\u0dd4 \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dcf\u0dbb\u0dd2\u0db8\u0dd4\u0dad\u0dca\u0dad\u0dd4 \u0dc3\u0dd4\u0daf\u0dcf\u0dc4\u0dbb\u0dca",
            "label": "PERSON"
          },
          {
            "text": "24 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dad\u0dd4 \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0daf\u0dca\u0dc0\u0dd2\u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0dc3\u0db8\u0dd4\u0dc5\u0dd4\u0dc0",
            "label": "EVENT"
          },
          {
            "text": "\u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dbb\u0dd6\u0db4\u0dbd\u0dcf\u0dc0\u0db1\u0dca\u200d\u0dba \u0db1\u0dd2\u0d9a\u0dda\u0dad\u0db1\u0dba",
            "label": "LOC"
          },
          {
            "text": "\u0d85\u0db7\u0dd2\u0db8\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0dba\u0dc0\u0dc3\u0d9a\u0dca",
            "label": "WORK_OF_ART"
          }
        ],
        [
          {
            "text": "\u0dbb\u0ddc\u0db6\u0da7\u0dca \u0dc6\u0dd0\u0db1\u0dca\u0dc3\u0dd2\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4\u0dcf \u0dc3\u0db7\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0d91\u0dc3\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dbd\u0dca \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db4\u0dcf\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0da0\u0dcf\u0db8\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dda\u0db8\u0db1\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4\u0dda\u0dc2\u0dca \u0dbb\u0dab\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dc3\u0dca.",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db8\u0dcf\u0dbb\u0db1\u0dca",
            "label": "PERSON"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0ba8\u0bbf\u0bb7\u0bbe\u0ba8\u0bcd\u0ba4, \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bb3\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bbe\u0b95 \u0ba4\u0bbf\u0bb0\u0bc1.\u0ba8\u0bbf\u0bb7\u0bbe\u0ba8\u0bcd\u0ba4 \u0bb5\u0ba9\u0bcd\u0ba9\u0bbf\u0baf\u0bbe\u0bb0\u0bbe\u0b9a\u0bcd\u0b9a\u0bbf \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd.",
        "'\u0baa\u0bc6\u0bb0\u0bc1\u0bae\u0bc8\u0baf\u0bc1\u0b9f\u0ba9\u0bcd \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf\u0baf\u0bc8 \u0ba8\u0bcb\u0b95\u0bcd\u0b95\u0bbf' \u0b8e\u0ba9\u0bcd\u0bb1 \u0ba4\u0bca\u0ba9\u0bbf\u0baa\u0bcd\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bbf\u0bb2\u0bcd \u0bae\u0bc7\u0bb2\u0bcd\u0bae\u0bbe\u0b95\u0bbe\u0ba3 \u0b85\u0bb4\u0b95\u0bbf\u0baf\u0bb2\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0ba4\u0bcb\u0b9f\u0bcd\u0b9f \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd 24\u0bb5\u0ba4\u0bc1 \u0b87\u0bb0\u0bc1 \u0bb5\u0bb0\u0bc1\u0b9f \u0bae\u0bbe\u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bbe\u0b95 \u0ba8\u0bbf\u0bb7\u0bbe\u0ba8\u0bcd\u0ba4 \u0bb5\u0ba9\u0bcd\u0ba9\u0bbf\u0baf\u0bbe\u0bb0\u0bbe\u0b9a\u0bcd\u0b9a\u0bbf \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd.",
        "\u0ba4\u0bbf\u0bb0\u0bc1. \u0bb0\u0bbe\u0baa\u0bb0\u0bcd\u0b9f\u0bcd \u0b83\u0baa\u0bbe\u0ba9\u0bcd\u0b9a\u0bbf\u0bb8\u0bcd \u0baa\u0bca\u0ba4\u0bc1\u0b9a\u0bcd \u0b9a\u0bc6\u0baf\u0bb2\u0bbe\u0bb3\u0bb0\u0bbe\u0b95\u0bb5\u0bc1\u0bae\u0bcd, \u0baa\u0bca\u0ba4\u0bc1\u0b9a\u0bcd \u0b9a\u0baa\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0bb8\u0bcd. \u0b8e\u0bb2\u0bcd. \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0baa\u0bbe\u0bb2, \u0b9a\u0bbe\u0bae\u0bb0 \u0baa\u0bbf\u0bb0\u0bc7\u0bae\u0bb0\u0ba4\u0bcd\u0ba9, \u0bb9\u0bc7\u0bae\u0ba8\u0bcd\u0ba4 \u0baa\u0bbf\u0bb0\u0b9a\u0ba9\u0bcd\u0ba9, \u0b8e\u0bb8\u0bcd. \u0b9c\u0bbe\u0ba9\u0bcd. \u0bae\u0b95\u0bc7\u0bb7\u0bcd \u0bb0\u0ba3\u0b9a\u0bbf\u0b99\u0bcd\u0b95 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b8e\u0bb8\u0bcd. \u0ba4\u0bae\u0bbf\u0bb4\u0bcd\u0bae\u0bbe\u0bb1\u0ba9\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0ba9\u0bcd\u0bb1\u0bbf \u0ba4\u0bc7\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc6\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd."
      ],
      "title_ents": [
        {
