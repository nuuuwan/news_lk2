    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0 \u0db4\u0dbb\u0daf\u0dc0\u0dcf \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dc3\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0d9c\u0dcf\u0dbd\u0dca\u0dbd\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9c \u0daf\u0dd9\u0d9a\u0dda \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dc3\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d85\u0daf \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0dbd\u0d9a\u0dd4\u0dab\u0dd4 190\u0d9a\u0dca \u0db4\u0dc3\u0dd4\u0db4\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 151\u0d9a\u0da7 \u0daf\u0dd0\u0dc0\u0dd3 \u0d9c\u0dd2\u0dba\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0d89\u0db1\u0dd2\u0db8\u0d9a \u0dc3\u0dc4 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 39\u0d9a \u0da2\u0dba\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d9a\u0dbb \u0daf\u0dd9\u0db8\u0dd2\u0db1\u0dd2.",
        "\u0d86\u0dbb\u0db8\u0dca\u0db7\u0d9a \u0db4\u0dd2\u0dad\u0dd2\u0d9a\u0dbb\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dcf\u0dad\u0dca \u0da2\u0dba\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 59\u0d9a\u0da7 \u0d9a\u0da9\u0dd4\u0dbd\u0dd4 6\u0d9a\u0dca \u0daf\u0dc0\u0dcf \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dbb\u0d9c\u0dba \u0db1\u0dd2\u0db8\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 177\u0d9a\u0da7 \u0d9a\u0da9\u0dd4\u0dbd\u0dd4 12\u0d9a\u0dca \u0daf\u0dc0\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba. \u0d91\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dc0\u0db1\u0dca\u0db1\u0d9a\u0dd4 \u0db8\u0d82\u0d9c\u0dbd \u0dad\u0dbb\u0d9c\u0dba\u0d9a\u0daf\u0dd3 \u0d9a\u0dc5 \u0dc4\u0ddc\u0db3\u0db8 \u0daf\u0d9a\u0dca\u200d\u0dc2\u0dad\u0dcf\u0dc0 \u0dc0\u0dd6 \u0d85\u0dad\u0dbb\u00a0 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0db8\u0d82\u0d9c\u0dbd \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0d9a\u0daf\u0dd3 \u0dc4\u0ddc\u0db3\u0db8 \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8\u0dda \u0dc3\u0dd2\u0dc0\u0dca\u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8\u0dcf\u0dbd\u0dca \u0db4\u0db1\u0dca\u0daf\u0dd4 326\u0d9a\u0daf\u0dd3 \u0dc4\u0dad\u0dbb\u0dda \u0db4\u0dc4\u0dbb 16\u0d9a\u0dca \u0dc3\u0dc4 \u0dc4\u0dba\u0dda \u0db4\u0dc4\u0dbb 5\u0d9a\u0dca \u0dc3\u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 206\u0d9a\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0dc4\u0dd3 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 554\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2\u0dc0\u0dd2\u0dba."
      ],
