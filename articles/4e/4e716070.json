    "si": {
      "title": "\u0dad\u0dc0\u0dad\u0dca 6 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a\u0ddc\u0da9\u0dd2 \u0dc0\u0dd9\u0dad \u0dc5\u0d9f\u0dcf \u0dc0\u0dd6\u0dc4",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc3\u0dc4 \u0d85\u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dad\u0dc0\u0dad\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a\u0dba\u0db1\u0dca 6 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0dbb\u0dab\u0dcf\u0d9c\u0dad\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a\u0ddc\u0da9\u0dd2 \u0d85\u0dc3\u0dbd \u0d9a\u0db8\u0dca\u0db4\u0dd2\u0db4\u0dcf\u0da9\u0dd4 \u0dc0\u0dd9\u0dbb\u0dc5\u0da7 \u0dc5\u0d9f\u0dcf \u0dc0\u0dd2\u0dba.",
        "\u0dbb\u0dcf\u0db8\u0dda\u0dc2\u0dca\u0dc0\u0dbb\u0db8\u0dca \u0dc3\u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0db8\u0dab\u0dca\u0da9\u0db4\u0db8\u0dca \u0dc3\u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u200d\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0, \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dbb\u0dab\u0dcf\u0d9c\u0dad\u0dba\u0dd2\u0db1\u0dca \u0dbd\u0dd9\u0dc3 \u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db1\u0dcf\u0da9\u0dd4\u0dc0\u0da7 \u0dba\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a \u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0dcf\u0dad\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 129 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda."
      ],
