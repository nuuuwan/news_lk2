    "si": {
      "title": "\u0d9a\u0dca\u200d\u0dbb\u0dd9\u0da9\u0dd2\u0da7\u0dca \u0d9a\u0dcf\u0da9\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dbd\u0dd3 \u0d85\u0db1\u0dd4\u0db4\u0dcf\u0dad \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db6\u0ddc\u0dc4\u0ddd \u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd9\u0da9\u0dd2\u0da7\u0dca \u0d9a\u0dcf\u0da9\u0dca\u0db4\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0db4\u0ddc\u0dbd\u0dd3 \u0d85\u0db1\u0dd4\u0db4\u0dcf\u0dad\u0dba \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0dcf \u0d87\u0dad.",
        "\u0d9a\u0dca\u200d\u0dbb\u0dd9\u0da9\u0dd2\u0da7\u0dca \u0d9a\u0dcf\u0da9\u0dca\u0db4\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0db4\u0ddc\u0dbd\u0dd3 \u0d85\u0db1\u0dd4\u0db4\u0dcf\u0dad\u0dba \u0dc3\u0dd2\u0dba\u0dba\u0da7 36 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0daf\u0db1\u0dca\u0dc0\u0dcf \u0dc3\u0dd2\u0da7\u0dd3.",
        "\u0d9a\u0dca\u200d\u0dbb\u0dd9\u0da9\u0dd2\u0da7\u0dca \u0d9a\u0dcf\u0da9\u0dca\u0db4\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0db1 \u0db4\u0ddc\u0dbd\u0dd3 \u0d85\u0db1\u0dd4\u0db4\u0dcf\u0dad \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db1\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dda \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca 08 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d91\u0dad\u0dd0\u0db1\u0dca \u0dc3\u0dd2\u0da7, \u0db4\u0ddc\u0dbd\u0dd3 \u0d85\u0db1\u0dd4\u0db4\u0dcf\u0dad \u0db4\u0dd9\u0dbb \u0db4\u0dd0\u0dc0\u0dad\u0dd2 18% \u0dc3\u0dd2\u0da7 24% \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca, \u0db4\u0dc3\u0dd4\u0dc0 30% \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca, \u0daf\u0dd0\u0db1\u0dca \u0db1\u0dd0\u0dc0\u0dad\u0dad\u0dca 36% \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dbb \u0d87\u0dad."
      ],
