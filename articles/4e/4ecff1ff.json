    "si": {
      "title": "\u0dbb\u0da2\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0. \u0d85\u0dbb\u0d9c\u0dbd\u0dba \u0db8\u0dbb\u0dca\u0daf\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db4\u0dd2\u0dba\u0dc0\u0dbb",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9c\u0dcf\u0dbd\u0dd4\u0db8\u0dd4\u0dc0\u0daf\u0ddc\u0dbb \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0dda \u0db1\u0dd2\u0dbb\u0dad \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db8\u0dbb\u0dca\u0daf\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dbb\u0da2\u0dba \u0d9c\u0dd9\u0db1 \u0dba\u0db1 \u0dc0\u0dd0\u0da9\u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dc5\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2 \u0dc3\u0dc4 \u0dc3\u0dcf\u0db8\u0dd6\u0dc4\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0d85\u0daf \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba\u0db4\u0ddc\u0dc5 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd4\u0dab\u0dcf. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db1\u0dd2\u0db8\u0dbd\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0d91\u0daf\u0dd2\u0dbb\u0dd2\u0dc3\u0dd2\u0d82\u0dc4"
      ],
      "title_ents": [],
