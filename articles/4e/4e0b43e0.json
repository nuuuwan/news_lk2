      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0db1\u0dd2\u0db4\u0dd4\u0db1'",
            "label": "GPE"
          },
          {
            "text": "\u0d9c\u0dca\u0dbb\u0dd1\u0db8\u0dca 20 \u0dba\u0dd2",
