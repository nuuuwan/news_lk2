          }
        ],
        [
          {
            "text": "2,150,000 \u0d9a\u0dd2",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db1\u0dcf\u0dc1\u0d9a \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf\u0dba\u0dda \u0d85\u0dab\u0daf\u0dd9\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dbb\u0dd4\u0dab \u0da2\u0dba\u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf \u0d9c\u0ddd\u0db1\u0dc4\u0dda\u0db1 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dd9\u0dc3\u0dca\u0da7\u0dbb\u0dca \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dda\u0dc1\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dd0\u0db4\u0dd2\u0dbd\u0dd2\u0dba\u0dcf\u0db1 \u0dc4\u0db1\u0dca\u0daf\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "33 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
