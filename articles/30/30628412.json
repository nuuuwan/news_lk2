          },
          {
            "text": "\u0db8\u0dc4\u0d9c\u0db8 \u0dc3\u0dd4\u0db7\u0daf\u0dca\u200d\u0dbb\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
