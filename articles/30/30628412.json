          },
          {
            "text": "\u0db8\u0dc4\u0d9c\u0db8 \u0d8b\u0dbb\u0dd4\u0dc3\u0dd2\u0da7\u0dc0\u0dd0\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0dd9\u0dc0\u0db1\u0d9c\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0dc3\u0dd4\u0db1\u0dca \u0d89\u0db3\u0dd4\u0dc0\u0dbb \u0dc3\u0db8\u0dbb\u0dc0\u0dd3\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd0\u0dbd\u0d9c\u0dc4\u0dc0\u0dad\u0dca\u0dad \u0db6\u0da7\u0dc4\u0dd2\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0dc4\u0d9a\u0dca\u0db8\u0db1 \u0db1\u0dbb\u0dc0\u0dbd\u0dca\u0db4\u0dd2\u0da7",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0da4\u0dcf\u0dab\u0dcf\u0dbd\u0ddd\u0d9a \u0db4\u0dd2\u0dbb\u0dd2\u0dc0\u0dd9\u0db1",
