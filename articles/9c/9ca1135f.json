        [],
        [
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0dba",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 18/2022",
