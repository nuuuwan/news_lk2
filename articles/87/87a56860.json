      ]
    },
    "si": {
      "title": "\u0d9a\u0ddc\u0dca\u0dc0\u0dd2\u0da9\u0dca \u0dbd\u0d9a\u0dca\u200d\u0dc2\u0dab \u0d87\u0dad\u0dca\u0db1\u0db8\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dba\u0dc0\u0db1\u0dca\u0db1 \u0d91\u0db4\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u2018\u0d9a\u0ddc\u0dca\u0dc0\u0dd2\u0da9\u0dca\u2019 \u0dbb\u0ddd\u0d9c \u0dbd\u0d9a\u0dca\u200d\u0dc2\u0dab \u0d87\u0dad\u0dd2 \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd9\u0dad \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dc0\u0dc5\u0d9a\u0dd2\u0db1\u0dca\u0db1\u0dd0\u0dba\u0dd2\u00a0 \u0dc5\u0db8\u0dcf \u0dbb\u0ddd\u0d9c \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dcf \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0daf\u0dd3\u0db4\u0dcf\u0dbd\u0dca \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d91\u0dc3\u0dda \u0db1\u0ddc\u0d9a\u0dc5\u0dc4\u0ddc\u0dad\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0dbb\u0ddd\u0d9c \u0dc0\u0dd0\u0dc5\u0daf\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0db0\u0dcf\u0db1\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc5\u0db8\u0dcf \u0dbb\u0ddd\u0d9c \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dba\u0dcf",
            "label": "ORG"
