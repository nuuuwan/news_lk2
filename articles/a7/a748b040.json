{
  "newspaper_id": "lankadeepa-lk",
  "url": "https://www.lankadeepa.lk/news/\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0d9c\u0dda-\u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7-\u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0-\u0dbb\u0dad\u0db1-\u0dc4\u0dd2\u0db8\u0dd2\u0d9c\u0dd9\u0db1\u0dca-\u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca/101-615261",
  "time_ut": 1655965814,
  "original_lang": "si",
  "original_title": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca",
  "text_idx": {
    "si": {
      "title": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca",
      "body_lines": [
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d85\u0dad\u0dd4\u0dbb\u0dbd\u0dd2\u0dba\u0dda \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dc4.",
        "\u0dbb\u0ddd\u0dba\u0dbd\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0da7 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0db8\u0dcf\u0dc0\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dad\u0db8\u0dcf \u0daf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0d9a\u0dbb\u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0db8\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db6\u0dc0 \u0d8b\u0db1\u0dca\u0dc0\u0dc4\u0db1\u0dca\u0dc3\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd6\u0dc4."
      ]
    },
    "ta": {
      "title": "\u0bae\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bbe\u0b95 \u0bb5\u0ba3.\u0bb0\u0ba4\u0ba9 \u0ba4\u0bc7\u0bb0\u0bb0\u0bbf\u0b9f\u0bae\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc1\u0bb1\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bc1",
      "body_lines": [
        "\u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd \u0b85\u0ba4\u0bcd\u0ba4\u0bc1\u0bb0\u0bb2\u0bbf\u0baf\u0bc7 \u0bb0\u0ba4\u0bcd\u0ba4\u0ba9 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0bb1\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf \u0bb5\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd.",
        "\u0bb0\u0bcb\u0baf\u0bb2\u0bcd \u0baa\u0bbe\u0bb0\u0bcd\u0b95\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbe\u0bb3\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0bae\u0ba9\u0bcd\u0ba9\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bb5\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbe\u0bb3\u0bcd \u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0bae\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bbf\u0baa\u0bbe\u0bb2 \u0b9a\u0bbf\u0bb1\u0bbf\u0b9a\u0bc7\u0ba9 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4 \u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0bb1\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf \u0bb5\u0ba8\u0bcd\u0ba4\u0ba4\u0bbe\u0b95 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ]
    },
    "en": {
      "title": "Complaint from Ven. Rathana Thera against Maithri's statement",
      "body_lines": [
        "Parliamentarian Athuraliye Rathana Thera came to the CID to lodge a complaint.",
        "He said that he had come to lodge a complaint regarding the statement made by former President Maithripala Sirisena regarding the Presidential pardon for the accused in the Royal Park incident."
      ]
    }
  },
  "title": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca",
  "body_lines": [
    "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d85\u0dad\u0dd4\u0dbb\u0dbd\u0dd2\u0dba\u0dda \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dc4.",
    "\u0dbb\u0ddd\u0dba\u0dbd\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0da7 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0db8\u0dcf\u0dc0\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dad\u0db8\u0dcf \u0daf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0d9a\u0dbb\u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0db8\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db6\u0dc0 \u0d8b\u0db1\u0dca\u0dc0\u0dc4\u0db1\u0dca\u0dc3\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd6\u0dc4."
  ],
  "translate": {
    "si": {
      "title": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca",
      "body_lines": [
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d85\u0dad\u0dd4\u0dbb\u0dbd\u0dd2\u0dba\u0dda \u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dc4.",
        "\u0dbb\u0ddd\u0dba\u0dbd\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0da7 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0db8\u0dcf\u0dc0\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dad\u0db8\u0dcf \u0daf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0d9a\u0dbb\u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0db8\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db6\u0dc0 \u0d8b\u0db1\u0dca\u0dc0\u0dc4\u0db1\u0dca\u0dc3\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd6\u0dc4."
      ]
    },
    "ta": {
      "title": "\u0bae\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bbe\u0b95 \u0bb5\u0ba3.\u0bb0\u0ba4\u0ba9 \u0ba4\u0bc7\u0bb0\u0bb0\u0bbf\u0b9f\u0bae\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc1\u0bb1\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bc1",
      "body_lines": [
        "\u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd \u0b85\u0ba4\u0bcd\u0ba4\u0bc1\u0bb0\u0bb2\u0bbf\u0baf\u0bc7 \u0bb0\u0ba4\u0bcd\u0ba4\u0ba9 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0bb1\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf \u0bb5\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd.",
        "\u0bb0\u0bcb\u0baf\u0bb2\u0bcd \u0baa\u0bbe\u0bb0\u0bcd\u0b95\u0bcd \u0b9a\u0bae\u0bcd\u0baa\u0bb5\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0bb5\u0bbe\u0bb3\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0bae\u0ba9\u0bcd\u0ba9\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bb5\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bbe\u0bb3\u0bcd \u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0bae\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bbf\u0baa\u0bbe\u0bb2 \u0b9a\u0bbf\u0bb1\u0bbf\u0b9a\u0bc7\u0ba9 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4 \u0b95\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0bb1\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf \u0bb5\u0ba8\u0bcd\u0ba4\u0ba4\u0bbe\u0b95 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ]
    },
    "en": {
      "title": "Complaint from Ven. Rathana Thera against Maithri's statement",
