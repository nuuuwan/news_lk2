    "si": {
      "title": "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dad\u0dd4\u0db8\u0dcf \u0db4\u0dc5\u0db8\u0dd4 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae\u0dba \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba\u0dda\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf (26) \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0db8\u0dad\u0dca \u0da2\u0ddd\u0db1\u0dca \u0d9a\u0ddc\u0dad\u0dbd\u0dcf\u0dc0\u0dbd \u0d9a\u0dde\u0dad\u0dd4\u0d9a\u0dcf\u0d9c\u0dcf\u0dbb\u0dba \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d91\u0dc4\u0dd2 \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0db8\u0dad\u0dca \u0da2\u0ddd\u0db1\u0dca \u0d9a\u0ddc\u0dad\u0dbd\u0dcf\u0dc0\u0dbd \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae\u0dba \u0daf \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "Accor \u0dba\u0db1\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dc5 \u0db4\u0dc5\u0db8\u0dd4 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae\u0dba\u0dba\u0dd2. (1 \u0dc1\u0dca\u200d\u0dbb\u0dd3 1)"
      ],
