          },
          {
            "text": "\u0d89\u0dc4\u0dc5 \u0db4\u0dc5\u0dcf\u0dad",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0d89\u0dc4\u0dc5 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba",
