            "label": "ORG"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0d9c\u0ddc\u0dc0\u0dd2 \u0dab\u0dba \u0d9a\u0db4\u0dcf\u0dc4\u0dbb\u0dd2\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc4\u0dd9\u0d9a\u0dca\u0da7\u0dba\u0dcf\u0dbb\u0dca 2\u0da7 \u0d85\u0da9\u0dd4 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0dab\u0dba \u0d9a\u0db4\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0da2\u0db1\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba. \u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0dab\u0dba \u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dbd\u0dcf\u0db7 \u0dbd\u0db6\u0db1 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 28000\u0d9a\u0dca \u0db6\u0dc0\u0dad\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dbd\u0da7 \u0d85\u0dba\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0dc4\u0dcf \u0db7\u0dcf\u0dab\u0dca\u0da9\u0dcf\u0d9c\u0dcf\u0dbb\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0daf\u0dcf\u0dc5 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dbd\u0da7 \u0db6\u0dd0\u0dbb \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
