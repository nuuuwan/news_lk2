    "si": {
      "title": "\u0db4\u0dab \u0d85\u0daf\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0d87\u0dad\u0dcf\u0d9c\u0dda \u0daf\u0dc5 \u0db4\u0ddc\u0dbb\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0d9c\u0dc3\u0dcf \u0d9a\u0db4\u0dcf\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dc4\u0dd2\u0db1\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d87\u0dad\u0d9a\u0dd4 \u0dc3\u0db8\u0d9c \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0daf\u0dca\u0dc0\u0db1\u0dca\u0daf \u0dc3\u0da7\u0db1\u0d9a\u0dd2\u0db1\u0dca \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0db8\u0dbb\u0dab\u0dcf\u0dc3\u0db1\u0dca\u0db1\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2 \u0d87\u0dad\u0d9a\u0dd4\u0d9c\u0dda \u0d91\u0d9a\u0dca \u0daf\u0dc5\u0d9a\u0dca \u0d9a\u0dd2\u0dc3\u0dd2\u0dba\u0db8\u0dca \u0dc3\u0dc4\u0dcf\u0dc3\u0dd2\u0d9a\u0dba\u0d9a\u0dd4 \u0db4\u0ddc\u0dbb\u0ddc\u0dc0\u0d9a\u0dca \u0d86\u0db0\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0db4\u0dcf\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d85\u0db1\u0dd4\u0dbb\u0dcf\u0db0\u0db4\u0dd4\u0dbb\u00a0 \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd2 \u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3 \u0da0\u0db1\u0dca\u0daf\u0db1 \u0da2\u0dba\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d9a\u0dd0\u0db6\u0dd2\u0dad\u0dd2\u0d9c\u0ddc\u0dbd\u0dca\u0dbd\u0dd1\u0dc0 \u0dad\u0dd2\u0dad\u0dca\u0dad\u0d9c\u0ddd\u0db1\u0dd1\u0dc0 \u0db8\u0ddc\u0dbb\u0d94\u0dba \u0d9a\u0dd4\u0db9\u0dd4\u0dbb\u0d9a\u0dc0\u0dd0\u0da7\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0daf\u0dca\u0db0\u0db1\u0dca\u0dad\u0dba\u0d9a\u0dd4\u0d9c\u0dda \u0daf\u0dc5\u0d9a\u0dca \u0db8\u0dd9\u0dc3\u0dda \u0d9a\u0db4\u0dcf\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad.",
        "\u0d9a\u0dd0\u0db6\u0dd2\u0dad\u0dd2\u0d9c\u0ddc\u0dbd\u0dca\u0dbd\u0dd1\u0dc0 \u0db1\u0db6\u0da9\u0dc0\u0dd0\u0dc0 \u0d85\u0dc3\u0dbd \u0dc0\u0db1\u0dba\u0d9a\u0daf\u0dd3\u00a0 \u0dad\u0dc0\u0dad\u0dca \u0d87\u0dad\u0d9a\u0dd4 \u0dc3\u0db8\u0d9c \u0d87\u0dad\u0dd2\u0dc0\u0dd6 \u0daf\u0dca\u0dc0\u0db1\u0dca\u0db0 \u0dc3\u0da7\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db8\u0dd9\u0db8 \u0d87\u0dad\u0dcf \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0d8a\u0dbb\u0dd2\u0db4\u0dd2\u0db1\u0dd2\u0dc0\u0dd0\u0dc0 \u0dc0\u0dad\u0dd4\u0dbb \u0d85\u0daf\u0dca\u0daf\u0dbb\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0db4\u0db1 \u0d85\u0daf\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd2 \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d87\u0dad\u0dcf\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0dbb\u0db9\u0dcf \u0d87\u0dad.",
        "\u0dc3\u0dad\u0dd2 \u0dad\u0dd4\u0db1\u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d87\u0dad\u0dcf\u0da7 \u0db1\u0ddc\u0d9a\u0da9\u0dc0\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dc5 \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0da0\u0db1\u0dca\u0daf\u0db1 \u0da2\u0dba\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
