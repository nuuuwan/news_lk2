    "ta": {
      "title": "65\u0bb5\u0ba4\u0bc1 \u0bae\u0bb2\u0bc7\u0b9a\u0bbf\u0baf \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0ba4\u0bbf\u0ba9\u0bae\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbe\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0bae\u0bb2\u0bc7\u0b9a\u0bbf\u0baf \u0b89\u0baf\u0bb0\u0bcd\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0b95\u0bb0\u0bcd Tan Yang Thai \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bbf\u0bb0\u0b9a\u0ba9\u0bcd\u0ba9\u0ba4\u0bcd\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bb5\u0bbe\u0bb4\u0bcd \u0bae\u0bb2\u0bc7\u0b9a\u0bbf\u0baf \u0baa\u0bbf\u0bb0\u0b9c\u0bc8\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0b99\u0bcd\u0b95\u0bc1\u0baa\u0bb1\u0bcd\u0bb1\u0bc1\u0ba4\u0bb2\u0bc1\u0b9f\u0ba9\u0bcd 65\u0bb5\u0ba4\u0bc1 \u0bae\u0bb2\u0bc7\u0b9a\u0bbf\u0baf \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0ba4\u0bbf\u0ba9\u0bae\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbe\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1. \u0baa\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bc0\u0baa\u0bcd \u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0ba9."
      ],
