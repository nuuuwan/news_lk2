    "en": {
      "title": "Oil distribution from Kolonnawa halted",
      "author": "unknown",
      "body_lines": [
        "The supply of fuel from the Ceylon Petroleum Corporation's Kolonnawa warehouse has been suspended from this morning (28), a senior official of the corporation said.",
        "He said that stocks of fuel for essential services would be issued from the Muthurajawela terminal and that filling stations had been informed to suspend the supply of fuel to the general public."
      ],
      "title_ents": [
        {
          "text": "Kolonnawa",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "the Ceylon Petroleum Corporation's",
            "label": "ORG"
          },
          {
            "text": "Kolonnawa",
            "label": "ORG"
          },
          {
            "text": "this morning",
            "label": "TIME"
          },
          {
            "text": "28",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "Muthurajawela",
            "label": "PERSON"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0d9a\u0ddc\u0dbd\u0ddc\u0db1\u0dca\u0db1\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dad\u0dd9\u0dbd\u0dca \u0db6\u0dd9\u0daf\u0dd3\u0db8 \u0db1\u0dc0\u0dad\u0dd3",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0d9a\u0ddc\u0dc5\u0ddc\u0db1\u0dca\u0db1\u0dcf\u0dc0 \u0dad\u0ddc\u0d9c \u0d9c\u0db6\u0da9\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0daf (28) \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dd9\u0d9a\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dd4\u0dad\u0dd4\u0dbb\u0dcf\u0da2\u0dc0\u0dd9\u0dc5 \u0db4\u0dbb\u0dca\u0dba\u0db1\u0dca\u0dad\u0dba\u0dd9\u0db1\u0dca \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db3\u0dc4\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dad\u0ddc\u0d9c \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d9a\u0dd3 \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0 \u0dbd\u0dd9\u0dc3 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca\u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca\u0dba."
      ],
      "title_ents": [
        {
