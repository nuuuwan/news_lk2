  "text_idx": {
    "en": {
      "title": "Litro gas price will decrease on 5th",
      "author": "unknown",
      "body_lines": [
        "Mr. Muditha Peiris, President and Chief Executive Officer of Litro Gas Company said that Litro domestic gas price will be reduced on the 5th of this month.",
        "The chairman further said that Litro Company hopes to reduce the price of domestic gas by a greater amount than the previous price increase."
      ],
