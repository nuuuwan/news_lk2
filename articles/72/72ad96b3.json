            "text": "\u0dc3\u0dd1\u0db8 \u0dc0\u0dc3\u0dbb\u0d9a\u0db8",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dd1\u0db8 \u0dc0\u0dc3\u0dbb\u0d9a\u0db8",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc3\u0daf\u0dba",
            "label": "WORK_OF_ART"
          },
          {
            "text": "\u0d9c\u0dd2\u0dba \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dca\u0daf\u0dda",
            "label": "DATE"
          },
          {
            "text": "\u0dc3\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0da2\u0dba\u0dc3\u0dd2\u0dbb\u0dd2",
            "label": "PERSON"
