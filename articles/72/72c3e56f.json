          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0d9a\u0dbb\u0dcf\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dc1\u0dd2\u0d9a\u0dca\u0dc2\u0dab \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "FAC"
          },
          {
            "text": "\u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc3\u0dda\u0db1 \u0dbd\u0ddc\u0d9a\u0dd4\u0d9c\u0dda",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dad\u0dd2 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0da7 \u0db4\u0dd9\u0dbb",
            "label": "DATE"
          },
          {
            "text": "\u0daf\u0dd2\u0db1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0db8\u0ddd",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dbb\u0dcf\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "11 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0db8\u0dda \u0d8b\u0daf\u0dd1\u0dc3\u0db1",
            "label": "TIME"
