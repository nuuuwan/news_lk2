          {
            "text": "\u0da2\u0dcf\u0db1\u0d9a\u0dd3 \u0dc0\u0dbb\u0dd4\u0dc3\u0dc4\u0db1\u0dca\u0db1\u0daf\u0dd3",
            "label": "PERSON"
