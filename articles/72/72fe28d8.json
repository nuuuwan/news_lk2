          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a",
            "label": "NORP"
          },
          {
            "text": "\u0d9a\u0dd0\u0db1\u0dda\u0da9\u0dd2\u0dba\u0dcf\u0db1\u0dd4\u0dc0\u0db1\u0dca",
            "label": "NORP"
          },
          {
            "text": "Janaka Ruwanpura",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd2\u0dc0\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dca \u0d9c\u0dd4\u0dbd\u0dc3\u0dd2\u0d82\u0dc4\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "25",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d9a\u0dd0\u0db1\u0dda\u0da9\u0dd2\u0dba\u0dcf\u0db1\u0dd4",
            "label": "NORP"
          },
          {
            "text": "\u0dc3\u0d82\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dab\u0dd2\u0d9a\u0dba\u0db1\u0dca",
            "label": "ORG"
          },
          {
            "text": "2022",
            "label": "DATE"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4 \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "Ruwanpura",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd0\u0dbd\u0dca\u0d9c\u0dbb\u0dd2 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "Ruwanpura",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d87\u0dbb\u0dd2\u0dc3\u0ddd\u0db1\u0dcf \u0dbb\u0dcf\u0da2\u0dca\u0dba \u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "Life Time Achievement Award",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0daf\u0db1\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0ddc\u0dc3\u0dca \u0d87\u0db1\u0dca\u0da2\u0dbd\u0dd3\u0dc3\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0dd0\u0dbd\u0dca\u0d9c\u0dbb\u0dd2",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dd2\u0dc0\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dca \u0d9c\u0dd4\u0dbd\u0dc3\u0dd2\u0d82\u0dc4\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0da2\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0da7\u0ddc\u0dbb\u0ddc\u0db1\u0dca\u0da7\u0ddd \u0db4\u0dd4\u0db1\u0dbb\u0dd4\u0dad\u0dca\u0dae\u0dcf\u0db4\u0db1 \u0d86\u0dba\u0dad\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0da7\u0ddc\u0dbb\u0ddc\u0db1\u0dca\u0da7\u0ddd \u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d9c\u0dd4\u0dbd\u0dc3\u0dd2\u0d82\u0dc4\u0db8\u0dca \u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0dd4\u0db1\u0dbb\u0dd4\u0dad\u0dca\u0dae\u0dcf\u0db4\u0db1 \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db8\u0dbd\u0dbd \u0d9a\u0dca\u0dbb\u0dd3\u0da9\u0dcf \u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0db4\u0dd0\u0dbb\u0dcf\u0dbd\u0dd2\u0db8\u0dca\u0db4\u0dd2\u0d9a\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0db4\u0dd0\u0dbb\u0dcf \u0db8\u0dbd\u0dbd \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0db4\u0dd0\u0dbb\u0dcf-\u0db1\u0dd0\u0da7\u0dd4\u0db8\u0dca \u0d9a\u0dca\u0dbb\u0dd3\u0da9\u0dcf",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9c\u0dd4\u0dbd\u0dc3\u0dd2\u0d82\u0dc4\u0db8\u0dca \u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dba\u0dd2\u0d9a\u0dbd\u0dca \u0d9c\u0ddd\u0dbb\u0dca\u0da9\u0db1\u0dca \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0da7\u0ddc\u0dbb\u0ddc\u0db1\u0dca\u0da7\u0ddd \u0dc0\u0dd2\u0dc1\u0dca\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dca\u0dc0\u0dda\u0da0\u0dca\u0da1\u0dcf \u0dc3\u0dda\u0dc0\u0dcf",
            "label": "ORG"
