          {
            "text": "\u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0db1\u0dc0\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dd0\u0db1\u0dda\u0da9\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dc3\u0d82\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dab \u0dc3\u0d9f\u0dbb\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "Toronto",
            "label": "GPE"
          },
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a\u0dba\u0db1\u0dca",
            "label": "NORP"
