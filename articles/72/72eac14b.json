    "si": {
      "title": "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0daf\u0dd9\u0db1 \u0dad\u0dd9\u0dbd\u0dca \u0d9c\u0db1\u0dca\u0db1 \u0da7\u0ddd\u0d9a\u0db1\u0dca \u0daf\u0dd4\u0db1\u0dca \u0d85\u0dba\u0dad\u0dca \u0d87\u0dc0\u0dd2\u0dad\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0dc3\u0db8\u0dd6\u0db4\u0d9a\u0dcf\u0dbb \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0da7 \u0dbd\u0dd0\u0db6\u0dd3 \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca 6600 \u0d9a \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0d85\u0daf (1) \u0daf\u0dd2\u0db1\u0dba\u0dda \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0dba\u0dcf\u0db8\u0dda\u0daf\u0dd3 \u0da7\u0ddd\u0d9a\u0db1\u0dca\u0db4\u0dad\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0dad\u0dd2\u0db6\u0dd6 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca\u0daf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d91\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0d8b\u0daf\u0dca\u0d9c\u0dad \u0dc0\u0dd2\u0dba.",
        "\u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dba \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc3\u0daf\u0dc4\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0dc0\u0dd9\u0db1\u0dca\u0d9a\u0ddc\u0da7 \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0db8\u0dad \u0d8a\u0dba\u0dda\u00a0 (30) \u0dc3\u0dc0\u0dc3 3 \u0db4\u0db8\u0dab \u0dc3\u0dd2\u0da7 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc3\u0db8\u0dd6\u0db4\u0d9a\u0dcf\u0dbb \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd \u0d85\u0dc3\u0dbd \u0dbb\u0dd0\u0db3\u0dd3 \u0dc3\u0dd2\u0da7 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d85\u0daf \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0dc3\u0dd6\u0daf\u0dcf\u0db1\u0db8\u0dca \u0dc0\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0db8\u0dd9\u0db8\u00a0 \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0dc0\u0dd2\u0dba.",
        "\u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd \u0d85\u0dc3\u0dbd \u0dc3\u0dd2\u0da7 \u0d94\u0dbb\u0dd4\u0dad\u0ddc\u0da7 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd \u0db8\u0dd3\u0da7\u0dbb\u0dca \u0dad\u0dd4\u0db1\u0d9a \u0db4\u0db8\u0dab \u0daf\u0dd4\u0dbb\u0d9a\u0dca \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0dbb\u0dae \u0dc0\u0dcf\u0dc4\u0db1 \u0dad\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dad\u0dbb \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0db1\u0ddc\u0daf\u0dd3\u0db8 \u0db8\u0dad \u0daf\u0dd9\u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0d85\u0dad\u0dbb \u0d87\u0dad\u0dd2\u0dc0\u0dd6 \u0db4\u0dca\u200d\u0dbb\u0dc1\u0dca\u0db1\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca\u00a0 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0daf \u0d85\u0dc0\u0dc4\u0dd2\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0db8\u0dad \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0dc3\u0dc4 \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0daf \u0d9a\u0dd0\u0db3\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0dd0\u0dab\u0dd2\u0db1.",
        "\u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0dc3\u0dc4\u0d9a\u0dcf\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dd4\u0dc3\u0dd2\u0dad \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca\u0dc0 , \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dba \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8 \u0db4\u0dd2\u0db1\u0dd2\u0dc3 \u0dc0\u0dd9\u0db1\u0dca\u0d9a\u0ddc\u0da7 \u0d87\u0dad\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0daf\u0dd3\u0db8 \u0db8\u0dad \u0d85\u0daf \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 3 \u0da7 \u0db4\u0db8\u0dab \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0dba."
      ],
