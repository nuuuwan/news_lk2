    "si": {
      "title": "\u0da9\u0dbd\u0dc3\u0dca\u0da7 \u0db4\u0dd2\u0da7\u0dd4\u0db6\u0dbd\u0dba \u0daf\u0dd3\u0db8\u0da7 TPA, ACMC, SLMC",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0daf\u0dd9\u0db8\u0dc5 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dad\u0dd2\u0dc1\u0dd3\u0dbd\u0dd3 \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba (TPA), \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0d9a\u0dca\u0d9a\u0dbd\u0dca \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba (ACMC) \u0dc3\u0dc4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba (SLMC) \u0d85\u0daf \u0db1\u0dc0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dad\u0ddd\u0dbb\u0dcf \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0da1\u0db1\u0dca\u0daf \u0dc0\u0dd2\u0db8\u0dc3\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0dc3\u0dc4\u0dcf\u0dba \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0da9\u0dbd\u0dc3\u0dca \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0dc3\u0dc4\u0dba \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0daf\u0dd9\u0db8\u0dc5 \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dad\u0dd2\u0dc1\u0dd3\u0dbd\u0dd3 \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba \u0d92\u0d9a\u0db8\u0dad\u0dd2\u0d9a\u0dc0 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dda\u0dba. \u0d91\u0dc4\u0dd2 \u0db1\u0dcf\u0dba\u0d9a \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db8\u0db1\u0ddd \u0d9c\u0db1\u0dda\u0dc2\u0db1\u0dca \u0db8\u0dda \u0db6\u0dc0 \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0db1\u0dd4\u0d9c\u0dda\u0d9c\u0ddc\u0da9 \u0db4\u0d9a\u0dca\u0dc2 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dd9\u0dad \u0d85\u0daf\u0dc4\u0dc3\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0db8\u0dd2\u0db1\u0dca.",
        "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 ACMC \u0dc3\u0dc4 SLMC \u0daf \u0d85\u0dbd\u0dc4\u0db4\u0dca\u0db4\u0dd9\u0dbb\u0dd4\u0db8 \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0dc3\u0dc4\u0dcf\u0dba \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dda\u0dba. (\u0dba\u0ddc\u0dc4\u0dcf\u0db1\u0dca \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf)"
      ],
