    "si": {
      "title": "\u0dbd\u0d82\u0d9c\u0db8 \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0db0\u0dcf\u0dbb\u0dd2\u0dad\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0d9c\u0db8\u0db1\u0dcf \u0d9c\u0db8\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba (\u0dbd\u0d82\u0d9c\u0db8) \u0db8\u0dd4\u0dc4\u0dd4\u0dab\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0da7\u0dba\u0dbb\u0dca \u0dc3\u0dc4 \u0db6\u0dd0\u0da7\u0dbb\u0dd2 \u0dc4\u0dd2\u0d9f\u0dba \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dbd\u0db6\u0db1 \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d8b\u0db4\u0dbb\u0dd2\u0db8 \u0db0\u0dcf\u0dbb\u0dd2\u0dad\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db6\u0dc3\u0dca \u0db0\u0dcf\u0dc0\u0dba\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dbd\u0d82\u0d9a\u0dcf \u0d9c\u0db8\u0db1\u0dcf \u0d9c\u0db8\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dbd\u0d82\u0d9c\u0db8 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0da7\u0dba\u0dbb\u0dca \u0dc3\u0dc4 \u0db6\u0dd0\u0da7\u0dbb\u0dd2 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db6\u0dc3\u0dca \u0dbb\u0dae 5,000 \u0db1\u0dca \u0db6\u0dc3\u0dca \u0dbb\u0dae 2000 \u0d9a\u0dca \u0db4\u0db8\u0dab \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0daf\u0dd4\u0dbb\u0d9c\u0db8\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0dd2\u0dba\u0dba\u0da7 80 \u0d9a\u0dca \u0db4\u0db8\u0dab \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0d9a\u0dd3\u0dba.",
        "\u0da7\u0dba\u0dbb\u0dca \u0dc3\u0dc4 \u0db6\u0dd0\u0da7\u0dbb\u0dd2 \u0db8\u0dd2\u0dbd\u0daf\u0dd3\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc3\u0d82\u0db4\u0dcf\u0daf\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u0dc0\u0d9a\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0dd6 \u0db6\u0dc0 \u0daf \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
