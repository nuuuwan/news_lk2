        ],
        [
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dad\u0dd2\u0dbd\u0d82\u0d9a \u0dbb\u0dad\u0dca\u0db1\u0db4\u0dcf\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0da2\u0dca\u200d\u0dba\u0ddd\u0dad\u0dd2",
            "label": "PERSON"
          }
        ],
        [],
        [
          {
            "text": "\u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0daf\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dba\u0dcf\u0dbb\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0dc2\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dad\u0dd2\u0dbb\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d85\u0dab\u0daf\u0dd9\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0da7\u0dd2\u0db1\u0ddd",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dcf \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 \u0d92\u0d9a\u0d9a\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d89\u0d82\u0da2\u0dd2\u0db1\u0dda\u0dbb\u0dd4 \u0db6\u0dbd\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d96\u0dc2\u0db0 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0ddc\u0dbb\u0da7\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "15",
            "label": "CARDINAL"
          },
          {
            "text": "03",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "50",
            "label": "CARDINAL"
          }
