    "si": {
      "title": "\u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a\u0dba 1.6% \u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3 \u0d9c\u0dd2\u0dba\u0dda\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "DCS \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba, \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0d85\u0dc0\u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0dc4\u0dd2\u0d9f\u0dba \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc4\u0dda\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d87\u0dad",
        "\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0dba\u0db1 \u0d85\u0d82\u0dc1 \u0daf\u0dd9\u0d9a\u0db8 \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3\u0db8\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb\u0dba\u0dd2; \u0dc3\u0dda\u0dc0\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9c\u0dad \u0d86\u0db1\u0dca\u0dad\u0dd2\u0d9a \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba\u0d9a\u0dca",
        "\u0dbb\u0dc3\u0dcf\u0dba\u0db1\u0dd2\u0d9a \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dc3\u0dc4 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dd2\u0d9f\u0dba \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad\u0dba\u0da7 \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0d85\u0d82\u0dc1\u0dba\u0da7 \u0d85\u0dc4\u0dd2\u0dad\u0d9a\u0dbb \u0dbd\u0dd9\u0dc3 \u0db6\u0dbd\u0db4\u0dcf\u0dba\u0dd2",
        "2020 \u0dc3\u0dc4 2021 \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba\u0dda \u0dc0\u0dc3\u0dbb \u0daf\u0dd9\u0d9a\u0d9a\u0da7 \u0db4\u0dc3\u0dd4 \u0dba\u0dae\u0dcf \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf\u0dc0\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3\u0dad\u0dca, \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dda \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db8\u0db1\u0dca\u0daf\u0d9c\u0dcf\u0db8\u0dd3 \u0dc0\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca 2022 \u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0daf\u0dc5 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0dd2\u0dad\u0dba (GDP) \u0dc3\u0dd2\u0dba\u0dba\u0da7 1.6 \u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3 \u0d9c\u0dd2\u0dba\u0dda\u0dba. \u0da2\u0db1\u0dbd\u0dda\u0d9b\u0db1 \u0dc4\u0dcf \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dda\u0d9b\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 (DCS) \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u201c\u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba, \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0d85\u0dc0\u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0dc4\u0dd2\u0d9f\u0dba \u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dcf\u0db0\u0d9a\u201d \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dd2.",
        "\u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0dc0 \u0dad\u0dd4\u0dc5 \u0dbb\u0dc3\u0dcf\u0dba\u0db1\u0dd2\u0d9a \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dc4\u0dd2\u0d9f\u0dba \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad\u0dba\u0da7 \u0daf\u0dd0\u0da9\u0dd2 \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc3\u0dc4\u0dbd\u0dca \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd4\u0dab\u0dd2. \u201c\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0, \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a\u0dba 2015 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0db8\u0dd9\u0db8 \u0d9a\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0d89\u0dc4\u0dc5\u0db8 \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd3\u0db8\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba,\u201d DCS \u0db4\u0dc0\u0dc3\u0dba\u0dd2. DCS \u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0d85\u0d82\u0dc1\u0dba\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d86\u0db1\u0dba\u0db1\u0dba \u0db8\u0dad \u0db4\u0db1\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0db1\u0dca \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc3\u0dd8\u0dab\u0dcf\u0dad\u0dca\u0db8\u0d9a\u0dc0 \u0db6\u0dbd\u0db4\u0dd1\u0dc0\u0dda\u0dba.",
        "\u0dbb\u0dc3\u0dcf\u0dba\u0db1\u0dd2\u0d9a \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dc4\u0dd2\u0d9f\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 '\u0dc3\u0dc4\u0dbd\u0dca \u0dc0\u0d9c\u0dcf\u0dc0' \u0dc3\u0dd2\u0dba\u0dba\u0da7 33.8\u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3 \u0d9c\u0dd2\u0dba \u0d85\u0dad\u0dbb '\u0dad\u0dda \u0dc0\u0d9c\u0dcf\u0dc0 \u0dc3\u0dd2\u0dba\u0dba\u0da7 15\u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3 \u0d9c\u0dd2\u0dba\u0dda\u0dba. \u2018\u0dbb\u0db6\u0dbb\u0dca \u0dc0\u0dd0\u0dc0\u0dd3\u0db8\u2019, \u2018\u0db0\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc0\u0dbb\u0dca\u0d9c \u0dc0\u0dd0\u0dc0\u0dd3\u0db8\u2019, \u2018\u0d91\u0dc5\u0dc0\u0dc5\u0dd4 \u0dc0\u0dd0\u0dc0\u0dd3\u0db8\u2019 \u0dc3\u0dc4 \u2018\u0db4\u0dc5\u0dad\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd0\u0dc0\u0dd3\u0db8\u2019 \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 13.1, \u0dc3\u0dd2\u0dba\u0dba\u0da7 9.5, \u0dc3\u0dd2\u0dba\u0dba\u0da7 8.4 \u0dc3\u0dc4 \u0dc3\u0dd2\u0dba\u0dba\u0da7 3.8 \u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb, \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 1Q22 \u0dc4\u0dd2 \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3\u0db8\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u2018\u0d9a\u0ddd\u0d9a\u0dca \u0dc3\u0dc4 \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4 \u0d9a\u0dc5 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0ddd\u0dbd\u0dd2\u0dba\u0db8\u0dca \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba\u2019 \u0dc3\u0dd2\u0dba\u0dba\u0da7 24.3\u0d9a \u0d89\u0dc4\u0dc5\u0db8 \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3\u0db8 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0d85\u0d82\u0dc1\u0dba\u0dda \u0daf\u0dc5 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0da7 \u0d89\u0dc4\u0dc5\u0db8 \u0daf\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0db4\u0dba\u0db1\u0dca\u0db1\u0db1\u0dca \u0dc0\u0db1 \u2018\u0d86\u0dc4\u0dcf\u0dbb, \u0db4\u0dcf\u0db1 \u0dc0\u0dbb\u0dca\u0d9c \u0dc3\u0dc4 \u0daf\u0dd4\u0db8\u0dca\u0d9a\u0ddc\u0dc5 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba\u2019 \u0dc3\u0dc4 \u2018\u0dbb\u0dd9\u0daf\u0dd2\u0db4\u0dd2\u0dc5\u0dd2 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba, \u0d87\u0d9f\u0dbd\u0dd4\u0db8\u0dca \u0d87\u0db3\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0db8\u0dca \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u2019 \u0dba\u0db1 \u0d85\u0d82\u0dc1\u0dba\u0db1\u0dca \u0daf \u0db8\u0dd9\u0db8 \u0d9a\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 9.1 \u0dc3\u0dc4 \u0dc3\u0dd2\u0dba\u0dba\u0da7 0.9 \u0d9a \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3\u0db8\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca \u0d85\u0dad\u0dbb\u0dd2\u0db1\u0dca \u0daf\u0dc5 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0da7 \u0dc3\u0dd2\u0dba\u0dba\u0da7 9.3 \u0d9a \u0d89\u0dc4\u0dc5\u0db8 \u0d9a\u0ddc\u0da7\u0dc3 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u2018\u0d89\u0daf\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad\u0dba\u2019 \u0dc3\u0dc4 \u2018\u0db4\u0dad\u0dbd\u0dca \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dca \u0dc3\u0dc4 \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dca\u2019 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca \u0dc3\u0db8\u0dcf\u0dbd\u0ddd\u0da0\u0dd2\u0dad \u0d9a\u0dcf\u0dbb\u0dca\u0dad\u0dd4\u0dc0 \u0dad\u0dd4\u0dc5 \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 2.2 \u0dc3\u0dc4 \u0dc3\u0dd2\u0dba\u0dba\u0da7 1.5 \u0d9a \u0dc4\u0dd0\u0d9a\u0dd2\u0dbd\u0dd3\u0db8\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0d82\u0dc1\u0dba\u0dda \u0d86\u0db1\u0dca\u0dad\u0dd2\u0d9a \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba\u0da7 \"'\u0db1\u0dc0\u0dcf\u0dad\u0dd0\u0db1\u0dca, \u0d86\u0dc4\u0dcf\u0dbb \u0db4\u0dcf\u0db1 \u0dc3\u0dda\u0dc0\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 25.2), '\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dbd\u0dda\u0d9b\u0db1 \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0db1 \u0dc3\u0dc4 \u0d92 \u0d86\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 12.3), '\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0dc3\u0d82\u0daf\u0dda\u0dc1' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 7.9), '\u0db1\u0dd2\u0dc1\u0dca\u0da0\u0dbd \u0daf\u0dda\u0db4\u0dbd \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca' \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db4\u0daf\u0db1\u0db8\u0dca \u0dc0\u0dd2\u0dba. , '\u0dc0\u0dcf\u0dc3\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0d85\u0dba\u0dd2\u0dad\u0dd2\u0dba' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 3.9), '\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0dbd\u0db1\u0dba \u0dc3\u0dc4 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a; \u0d85\u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dca\u0dba \u0dc3\u0db8\u0dcf\u0da2 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dab\u0dba' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 3.4), '\u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0dc3\u0dc4 \u0d9a\u0dd4\u0dbb\u0dd2\u0dba\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0d9a\u0db8\u0dca' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 3.3), '\u0dad\u0ddc\u0d9c \u0dc3\u0dc4 \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0dc0\u0dd9\u0dc5\u0db3\u0dcf\u0db8' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 1.0) \u0dc3\u0dc4 '\u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1\u0dba' (\u0dc3\u0dd2\u0dba\u0dba\u0da7 0.6),\" DCS \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
