          },
          {
            "text": "\u0bb9\u0bc6\u0bb2\u0bbe \u0b85\u0baa\u0bcd\u0baa\u0bc7\u0bb0\u0bb2\u0bcd \u0bb9\u0bcb\u0bb2\u0bcd\u0b9f\u0bbf\u0b99\u0bcd\u0bb8\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0bb5\u0bc7\u0b95\u0bae\u0bcd.",
            "label": "ORG"
