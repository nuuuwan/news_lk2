          }
        ],
        [
          {
            "text": "\u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d86\u0dba\u0dad\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0dbb\u0dca\u0da2\u0dd4\u0db1 \u0dbb\u0dab\u0dad\u0dd4\u0d82\u0d9c\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dad",
