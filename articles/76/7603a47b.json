            "text": "\u0b9a\u0bc6\u0bb0\u0bcd\u0b9c\u0bbf\u0baf\u0bcb \u0bae\u0bc7\u0b9f\u0bcd\u0b9f\u0bb0\u0bc6\u0bb2\u0bcd\u0bb2\u0bbe",
            "label": "PERSON"
