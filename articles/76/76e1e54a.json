    "si": {
      "title": "\u0dbd\u0dd9\u0dbd\u0dca\u0dc0\u0dbd \u0dc3\u0db8\u0dd6\u0db4 \u0da1\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0da2\u0db6\u0da7 \u0dc0\u0dd2\u0dc1\u0dd2\u0dc2\u0dca\u0da8 \u0da2\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd\u00a0 \u0d89\u0dc4\u0dc5 \u0dbd\u0dd9\u0dbd\u0dca\u0dc0\u0dbd \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0da1\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dc0\u0da7 \u0dc0\u0dd2\u0dc1\u0dd2\u0dc2\u0dca\u0da8 \u0da2\u0dba\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0dd2 \u0d87\u0dad. \u0d89\u0dc4\u0dc5 \u0dbd\u0dda\u0dbd\u0dca\u0dc0\u0dbd \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0dc3\u0db8\u0dd2\u0dad\u0dd2\u0dba\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0dad\u0dd9\u0dc0\u0dbb\u0dca\u0dc2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0db0\u0dba\u0d9a\u0dca\u0dc2\u0d9a \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0d9a\u0dca \u0dad\u0ddd\u0dbb\u0dcf \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u00a0\u0db8\u0dd9\u0db8 \u0da1\u0db1\u0dca\u0daf\u0dba \u0d85\u0daf (26\u0daf\u0dcf) \u0d91\u0db8 \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc1\u0dcf\u0dbd\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab.",
        "\u0d91\u0db8 \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0dc3\u0db8\u0dd2\u0dad\u0dd2\u0dba\u0da7 \u0d85\u0dba\u0dad\u0dca \u0dc3\u0db8\u0dd4\u0db4\u0d9a\u0dcf\u0dbb \u0db4\u0dcf\u0daf\u0dda\u0dc1\u0dd2\u0d9a 12\u0d9a\u0dca \u0d85\u0dad\u0dbb\u0dd2\u0db1\u0dca \u0db8\u0dc4\u0dcf \u0dc3\u0db7\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0dd2\u0db1\u0dca 83\u0d9a\u0dd4 \u0dad\u0ddd\u0dbb\u0dcf \u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0daf\u0dc4\u0dcf \u0da1\u0db1\u0dca\u0daf\u0dba \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba\u0dd2\u0db1\u0dca \u0db6\u0dc4\u0dd4\u0dad\u0dbb\u0dba\u0d9a\u0dca \u0db8\u0dc4\u0dcf \u0dc3\u0db7\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda \u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dd9\u0db1\u0dd2.",
        "\u0db8\u0dc4\u0dcf \u0dc3\u0db7\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dbb\u0dd2\u0db1\u0dca \u0d85\u0db0\u0dba\u0d9a\u0dca\u0dc2\u0d9a \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0dad\u0dca\u0daf\u0dd9\u0db1\u0dcf\u0db8 \u0dad\u0dda\u0dbb\u0dd3\u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda\u0daf \u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd3\u0db8\u0daf \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd2 \u0d9a\u0dd0\u0db4\u0dd3 \u0db4\u0dd9\u0db1\u0dda."
      ],
