          },
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0dc0\u0dc3\u0db1\u0dca\u0dad \u0db8\u0dd4\u0daf\u0dbd\u0dd2\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dad\u0dca\u0d9c\u0dbb\u0dd4\u0dc0\u0dda \u0da2\u0dd3\u0dbd\u0dbb\u0dad\u0db1 \u0dc4\u0dd2\u0db8\u0dd2",
            "label": "PERSON"
          }
        ],
        [
          {
