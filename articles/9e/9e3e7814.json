        ],
        [
          {
            "text": "\u0dc4\u0dba\u0dd2\u0db1\u0dca\u0d9a\u0db1\u0dca \u0dbd\u0d82\u0d9a\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0daf\u0dd4\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dad\u0dad\u0dca\u0dad\u0dca\u200d\u0dc0\u0dba\u0da7 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dbb\u0db1\u0dca\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd2\u0dc4\u0dd2\u0db1 \u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0da7 \u0db0\u0ddb\u0dbb\u0dca\u0dba\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd4\u0dbb\u0ddd\u0d9c\u0dcf\u0db8\u0dd2\u0dba\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0d9c\u0dca\u0dbb\u0dc4\u0dbd\u0ddd\u0d9a\u0dba \u0d9c\u0dd0\u0db1 \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0dd3\u0db8",
            "label": "WORK_OF_ART"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0db4\u0dd4\u0dbb \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
