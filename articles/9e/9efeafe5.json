    "si": {
      "title": "\u0da9\u0dd2\u0dc3\u0dca\u0db1\u0dd2 \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0da7 \u0db8\u0dd2\u0d9a\u0dd3 \u0db8\u0dc0\u0dd4\u0dc3\u0dca\u0d9c\u0dda \u0dad\u0db1\u0dd2 \u0d85\u0dba\u0dd2\u0dad\u0dd2\u0dba \u0d85\u0dc4\u0dd2\u0db8\u0dd2 \u0dc0\u0dd3\u0db8\u0da7 \u0d89\u0da9 \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dd2\u0db1\u0ddd\u0daf\u0dcf\u0dc3\u0dca\u0dc0\u0dcf\u0daf \u0daf\u0dd0\u0dc0\u0dd0\u0db1\u0dca\u0dad\u0dba\u0dcf \u0dc0\u0db1 Disney \u0dc4\u0da7 2024 \u0daf\u0dd3 \u0d91\u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0da7 \u0dc3\u0dc4 \u0dc0\u0da9\u0dcf\u0dad\u0dca\u0db8 \u0d86\u0daf\u0dbb\u0dab\u0dd3\u0dba \u0d9a\u0dcf\u0da7\u0dd6\u0db1\u0dca\u00a0\u0da0\u0dbb\u0dd2\u0dad\u0dba\u00a0\u2018Mickey Mouse\u2019 \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd6 \u0dad\u0db1\u0dd2 \u0d85\u0dba\u0dd2\u0dad\u0dd2\u0dba \u0d85\u0dc4\u0dd2\u0db8\u0dd2 \u0dc0\u0dd3\u0db8\u0da7 \u0d89\u0da9 \u0d87\u0dad.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8\u0dca \u0db1\u0dd3\u0dad\u0dd2\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0d9a\u0dbd\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dab\u0dc0\u0dbd \u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2\u0db8\u0dba \u0daf\u0dda\u0db4\u0dc5 \u0d91\u0dc4\u0dd2 \u0db4\u0dc5\u0db8\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0db1\u0dba\u0da7 \u0dc0\u0dc3\u0dbb 95\u0d9a\u0da7 \u0db4\u0dc3\u0dd4\u0dc0 \u0d9a\u0dbd\u0dca \u0d89\u0d9a\u0dd4\u0dad\u0dca \u0dc0\u0dda. Disney \u0dc3\u0db3\u0dc4\u0dcf, Mickey Mouse \u0dc4\u0dd2 \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u00a0\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 95\u0d9a \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0d9a\u0db8 \u0dbd\u0db6\u0db1 \u0dc0\u0dc3\u0dbb\u0dda \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dda. \u0da9\u0dd2\u0dc3\u0dca\u0db1\u0dd2 \u0db1\u0ddc\u0dc0\u0db1 \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0d9c\u0dad \u0dad\u0dd4\u0dc5 \u0d9a\u0dcf\u0da7\u0dd6\u0db1\u0dca \u0da0\u0dbb\u0dd2\u0dad\u0dba \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dca\u0dc0\u0dba\u0db1\u0dca\u0da7 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0dbd\u0dd0\u0db6\u0dd9\u0db1\u0dd4 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db8\u0dd9\u0dba\u0dd2\u0db1\u0dca \u0d85\u0daf\u0dc4\u0dc3\u0dca \u0dc0\u0dda.",
        "\u0db8\u0dd2\u0d9a\u0dd3 \u0db8\u0dc0\u0dd4\u0dc3\u0dca \u0db8\u0dd4\u0dbd\u0dd2\u0db1\u0dca\u0db8 \u0db4\u0dd9\u0db1\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda 1928 \u0daf\u0dd3 \u0dc0\u0ddd\u0dbd\u0dca\u0da7\u0dca \u0da9\u0dd2\u0dc3\u0dca\u0db1\u0dd2 \u0dc3\u0dc4 \u0dba\u0dd6\u0db6\u0dca \u0d85\u0dba\u0dd2\u0dc0\u0dbb\u0dca\u0d9a\u0dca\u0dc3\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 \u0d9a\u0dd9\u0da7\u0dd2 \u0d9a\u0dc5\u0dd4-\u0dc3\u0dd4\u0daf\u0dd4 \u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb\u0db4\u0da7\u0dba\u0d9a \u0dba."
      ],
