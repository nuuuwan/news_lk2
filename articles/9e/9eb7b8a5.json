          {
            "text": "\u0dc3\u0dd2\u0d82\u0dc4\u0dbd",
            "label": "NORP"
          },
          {
            "text": "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dcf\u0dc3\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0dd0\u0dc3\u0dd2\u0dbd\u0dca \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd4\u0dbd\u0dd2",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 9",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0db1",
            "label": "ORDINAL"
          },
          {
            "text": "\u0db8\u0dcf\u0dbd\u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd2\u0d82\u0d9c\u0db4\u0dca\u0db4\u0dd6\u0dbb\u0dd4\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d94\u0dad\u0dca\u0dad\u0dd4 \u0dc3\u0dda\u0dc0\u0dcf",
