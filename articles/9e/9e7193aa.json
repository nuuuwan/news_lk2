          },
          {
            "text": "\u0dbb\u0dd2\u0dc2\u0dcf\u0da9\u0dca \u0db6\u0daf\u0dd2\u0dba\u0dd4\u0daf\u0dd3\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db7\u0dd2\u0dba\u0dcf\u0da0\u0db1\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db7\u0dd2\u0dba\u0dcf\u0da0\u0db1\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd2\u0dbd\u0dca\u0db4\u0dad\u0dca\u0dad\u0dd4\u0dc0",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dda\u0dc2\u0dca\u0da8\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dcf\u0db8\u0dd2\u0dab\u0dd3 \u0d85\u0db8\u0dbb\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0da0\u0dbd \u0dc0\u0dd9\u0d82\u0d9c\u0db4\u0dca\u0db4\u0dd4\u0dbd\u0dd2",
            "label": "GPE"
