    "si": {
      "title": "\u0d9a\u0ddc\u0dc5\u0db9 \u0dad\u0dc4\u0db1\u0db8\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dd4\u0dbb\u0d9a\u0ddd\u0da7\u0dca\u0da7\u0dd9\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8\u0dda - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0db4\u0ddd\u0dad\u0dd2\u0dbb\u0dd4\u0d9a\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dba\u0dda \u0d95\u0dbd\u0dca\u0d9a\u0ddc\u0da7\u0dca \u0db8\u0dcf\u0dc0\u0dad \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0d9a\u0dd6\u0da9\u0dcf\u0dbb\u0db8\u0d9a\u0dca \u0d9c\u0dc3\u0dcf \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0dbb\u0dd0\u0db3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd3\u0db8\u0da7 \u0dc3\u0dd6\u0daf\u0dcf\u0db1\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0da7 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dcf\u0dc3 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dd4\u0d9a\u0da9\u0dd9\u0dba\u0dd2 \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0db8\u0dd9\u0db8 \u0dad\u0dc4\u0db1\u0db8\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0d9c\u0dba \u0db4\u0db1\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 '\u0dc3\u0dd4\u0dbb\u0d9a\u0dd2\u0db8\u0dd4 \u0dbd\u0d82\u0d9a\u0dcf' \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba\u0dda \u0d9a\u0dd0\u0daf\u0dc0\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0d91\u0da0\u0dca. \u0d9c\u0dd4\u0dbb\u0dd4-\u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dca\u0db4\u0dad\u0dd2 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d9c\u0dbb\u0dd4 \u0db6\u0dcf\u0dc4\u0dd2\u0dba\u0d82\u0d9c\u0dbd \u0d86\u0db1\u0db1\u0dca\u0daf \u0dc3\u0dcf\u0d9c\u0dbb \u0dc4\u0dd2\u0db8\u0dd2 \u0d8b\u0dbd\u0db4\u0db1\u0dda \u0dc3\u0dd4\u0db8\u0d82\u0d9c\u0dbd \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0da7 \u0dc3\u0dc4 \u0db7\u0dd6\u0db8\u0dd2 \u0db8\u0dcf\u0dad\u0dcf \u0db8\u0db1\u0dd4\u0dc3\u0dad\u0dca \u0db4\u0daf\u0db1\u0db8\u0dda \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dad\u0dd8 \u0d9a\u0dc5\u0dd4\u0db4\u0ddd\u0dc0\u0dd2\u0dbd \u0db4\u0daf\u0dd4\u0db8 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0da7 \u0d91\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8 \u0dad\u0dc4\u0db1\u0db8\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. (\u0d92)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0dd4\u0daf\u0dd4\u0d9a\u0da9\u0dd9\u0dba\u0dd2 \u0d8b\u0dc3\u0dcf\u0dc0\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d95\u0dbd\u0dca\u0d9a\u0ddc\u0da7\u0dca \u0db8\u0dcf\u0dc0\u0dad",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd4\u0dbb\u0d9a\u0ddd\u0da7\u0dca\u0da7\u0dd9\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8 - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0db4\u0ddd\u0dad\u0dd2\u0dbb\u0dd4\u0d9a\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dba",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9c\u0dbb\u0dd4",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0dc4\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dbd \u0d86\u0db1\u0db1\u0dca\u0daf",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dcf\u0d9c\u0dbb \u0dc4\u0dd2\u0db8\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d9c\u0dbb\u0dd4 \u0d9c\u0dd4\u0dbb\u0dd4-\u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dca\u0db4\u0dad\u0dd2 \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd4\u0db8\u0d82\u0d9c\u0dbd \u0dc4\u0dd2\u0db8\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db7\u0dd6\u0db8\u0dd2 \u0db8\u0dcf\u0dad\u0dcf \u0db8\u0db1\u0dd4\u0dc3\u0dad\u0dca \u0db4\u0daf\u0db1\u0db8 \u0d9a\u0dc5\u0dd4\u0db4\u0ddd\u0dc0\u0dd2\u0dbd \u0db4\u0daf\u0dd4\u0db8 \u0dc4\u0dd2\u0db8\u0dd2",
            "label": "ORG"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f \u0ba4\u0b9f\u0bc8",
      "author": "unknown",
      "body_lines": [
        "\u0baa\u0bc1\u0bb1\u0b95\u0bcd\u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0bb1\u0bcd\u0b95\u0bc1\u0b9f\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b92\u0bb2\u0bcd\u0b95\u0bca\u0b9f\u0bcd \u0bae\u0bbe\u0bb5\u0ba4\u0bcd\u0ba4\u0bc8 - \u0bb8\u0bcd\u0bb0\u0bc0 \u0baa\u0bcb\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bb0\u0bbe\u0bae \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0baa\u0bbe\u0b95 \u0b89\u0bb3\u0bcd\u0bb3 \u0bb5\u0bc0\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0b95\u0bcd\u0b95\u0bbe\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc2\u0b9f\u0bbe\u0bb0\u0bae\u0bcd \u0b85\u0bae\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1\u0bae\u0bcd\u00a0 \u0ba4\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0bbf\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0ba4\u0baf\u0bbe\u0bb0\u0bbe\u0b95 \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0b95 \u0ba8\u0bae\u0bcd\u0baa\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bb5\u0ba4\u0bbe\u0bb2\u0bcd \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0bb2\u0bc8\u0baf \u0baa\u0bca\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf \u0bb5\u0bbf\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4 \u0b95\u0bcb\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bae\u0bc8\u0baf, \u0baa\u0bc1\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0b9f\u0bc8 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0b87\u0ba8\u0bcd\u0ba4 \u0ba4\u0b9f\u0bc8 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bc8 \u0bb5\u0bbf\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0b87\u0ba4\u0ba9\u0bcd\u0baa\u0b9f\u0bbf, '\u0b9a\u0bc1\u0bb0\u0b95\u0bbf\u0bae\u0bc1 \u0bb2\u0b99\u0bcd\u0b95\u0bbe' \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b87\u0baf\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0b85\u0bb4\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0bb3\u0bb0\u0bcd \u0bb5\u0ba3. \u0baa\u0bbe\u0bb9\u0bbf\u0baf\u0b99\u0bcd\u0b95\u0bb2 \u0b86\u0ba9\u0ba8\u0bcd\u0ba4 \u0b9a\u0bbe\u0b95\u0bb0 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd, \u0b86\u0b9a\u0bbf\u0bb0\u0bbf\u0baf\u0bb0\u0bcd - \u0b85\u0ba4\u0bbf\u0baa\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0bca\u0bb4\u0bbf\u0bb1\u0bcd\u0b9a\u0b99\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0bb5\u0ba3. \u0b89\u0bb2\u0baa\u0bcd\u0baa\u0ba9\u0bc7 \u0b9a\u0bc1\u0bae\u0b99\u0bcd\u0b95\u0bb2 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd, \u0baa\u0bc2\u0bae\u0bbf \u0bae\u0bbe\u0ba4\u0bbe \u0bae\u0ba9\u0bc1\u0b9a\u0ba4\u0bcd \u0b85\u0bb1\u0b95\u0bcd\u0b95\u0b9f\u0bcd\u0b9f\u0bb3\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bb8\u0bcd\u0ba4\u0bbe\u0baa\u0b95\u0bb0\u0bcd \u0b95\u0bb3\u0bc1\u0baa\u0bcb\u0bb5\u0bbf\u0bb2 \u0baa\u0ba4\u0bc1\u0bae \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb1\u0bcd\u0baa\u0b9f\u0bbf \u0b87\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bb0\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0ba4\u0b9f\u0bc8 \u0bb5\u0bbf\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1. (a)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0baa\u0bc1\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0b9f\u0bc8 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b92\u0bb2\u0bcd\u0b95\u0bcb\u0b9f\u0bcd \u0bae\u0bbe\u0bb5\u0ba4\u0bcd\u0ba4\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bc1\u0bb1\u0b95\u0bcd\u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bc1 - \u0bb8\u0bcd\u0bb0\u0bc0 \u0baa\u0bcb\u0ba4\u0bcd\u0ba4\u0bbf\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bb0\u0bbe\u0bae \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b95\u0bcc\u0bb0\u0bb5",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bb9\u0bbf\u0baf\u0b99\u0bcd\u0b95\u0bb2 \u0b86\u0ba9\u0ba8\u0bcd\u0ba4",
            "label": "PERSON"
          },
          {
            "text": "\u0b9a\u0bbe\u0b95\u0bb0 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0b86\u0b9a\u0bbf\u0bb0\u0bbf\u0baf\u0bb0\u0bcd - \u0bae\u0bc1\u0ba4\u0bb2\u0bcd\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0b99\u0bcd\u0b95\u0bae\u0bcd \u0b95\u0bcc\u0bb0\u0bb5",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0bc1\u0bae\u0b99\u0bcd\u0b95\u0bb2 \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0bc2\u0bae\u0bbf \u0bae\u0bbe\u0ba4\u0bbe \u0bae\u0ba9\u0bc1\u0b9a\u0ba4\u0bcd \u0b85\u0bb1\u0b95\u0bcd\u0b95\u0b9f\u0bcd\u0b9f\u0bb3\u0bc8 \u0b95\u0bb3\u0bc1\u0baa\u0bcb\u0bb5\u0bbf\u0bb2 \u0baa\u0ba4\u0bc1\u0bae \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd",
            "label": "ORG"
          }
        ]
      ]
    }
  }
}