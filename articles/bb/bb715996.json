    "si": {
      "title": "\u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8, \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8 \u0dc3\u0dc4 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dc3\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd\u0dca\u0dc0\u0dbd\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0db1\u0dca \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0dbd\u0dd9\u0dc3 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8, \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc3\u0dc4 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8 \u0dc4\u0ddd \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0db1\u0dca \u0dc3\u0dc4 \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dc0 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc4\u0ddd \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d95\u0db1\u0dd1\u0db8 \u0dc0\u0dd2\u0dc3\u0dca\u0dad\u0dbb\u0dba\u0d9a\u0dca, \u0dc3\u0dc4 \u0db4\u0dd2\u0dc5\u0dd2\u0d9c\u0dd0\u0db1\u0dd3\u0db8, \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dc3\u0dda\u0dc0\u0dcf, \u0dc0\u0dd0\u0da9 \u0dc4\u0ddd \u0dc1\u0dca\u200d\u0dbb\u0db8\u0dba, \u0dbb\u0ddd\u0dc4\u0dbd\u0dca\u0dc0\u0dbd, \u0dc3\u0dcf\u0dad\u0dca\u0dad\u0dd4 \u0db1\u0dd2\u0dc0\u0dcf\u0dc3\u0dc0\u0dbd, \u0db6\u0dd9\u0dc4\u0dd9\u0dad\u0dca \u0dc1\u0dcf\u0dbd\u0dcf \u0dc3\u0dc4 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0dc3\u0db8\u0dcf\u0db1 \u0d86\u0dba\u0dad\u0db1\u0dc0\u0dbd \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0dd0\u0d9a\u0dc0\u0dbb\u0dab\u0dba \u0db4\u0ddd\u0dc2\u0dab\u0dba \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc3\u0dbd\u0d9a\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dda.",
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 - \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db8\u0dc4\u0da2\u0db1 \u0dc3\u0dda\u0dc0\u0dcf \u0db4\u0db1\u0dad, 1979 \u0d85\u0d82\u0d9a 61, Adaderana Online by Scribd"
      ],
