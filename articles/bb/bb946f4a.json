          {
            "text": "\u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 25,000 \u0d9a\u0dd2",
            "label": "QUANTITY"
          },
          {
