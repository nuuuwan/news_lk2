    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0db8\u0dad \u0dbd\u0db6\u0db1 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf (21) \u0dc3\u0dd2\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0d8a\u0dba\u0dda (18) \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dd3\u0dad\u0dd2\u0d9c\u0dad \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0dc3\u0dd2\u0da7\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dbd\u0d9a\u0dca \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dcf.",
        "\u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1\u0dca\u0db1\u0dda QR \u0d9a\u0dda\u0dad\u0dba \u0dc3\u0dc4 \u0dc0\u0dcf\u0dc4\u0db1 \u0d85\u0d82\u0d9a \u0dad\u0dc4\u0da9\u0dd4\u0dc0\u0dda \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0d85\u0d82\u0d9a\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0db8\u0dab\u0d9a\u0dca \u0db6\u0dc0\u0dad\u0dca, \u0daf\u0dd0\u0db1\u0da7 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0dc0\u0db1 \u0dbd\u0dd9\u0dc3\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0dba.",
        "\u0dc0\u0dcf\u0dc4\u0db1 \u0d85\u0d82\u0d9a \u0dad\u0dc4\u0da9\u0dd4\u0dc0\u0dda 0, 1 \u0dc3\u0dc4 2 \u0dba\u0db1 \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0db8\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0dc0\u0dcf\u0dc4\u0db1 \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0da7 \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dbd\u0db6\u0db1 21 \u0dc0\u0db1\u0daf\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0dc3\u0dc4 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0db8\u0dca 0, 1, 2, \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0db8\u0dca 3, 4, 5 \u0dc3\u0db3\u0dc4\u0dcf\u0dad\u0dca \u0db6\u0daf\u0dcf\u0daf\u0dcf, \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0d89\u0dbb\u0dd2\u0daf\u0dcf \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0d89\u0dbd\u0d9a\u0dca\u0d9a\u0db8\u0dca 6, 7, 8, 9 \u0dc3\u0db3\u0dc4\u0dcf\u0dad\u0dca \u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2."
      ],
