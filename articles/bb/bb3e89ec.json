          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "16",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0b8f\u0b9c\u0bc6\u0ba9\u0bcd\u0b9a\u0bbf",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0bb0\u0bcd\u0bb5\u0ba4\u0bc7\u0b9a \u0b85\u0baa\u0bbf\u0bb5\u0bbf\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9f\u0bc7\u0bb5\u0bbf\u0b9f\u0bcd \u0baa\u0bc0\u0bb0\u0bcd\u0bb8\u0bcd \u0bae\u0bcb\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bae\u0bcd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0ba9\u0bcd",
            "label": "NORP"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
            "label": "GPE"
          },
          {
            "text": "\u0b95\u0bbe\u0b9e\u0bcd\u0b9a\u0ba9\u0bbe \u0bb5\u0bbf\u0b9c\u0bc7\u0b9a\u0bc7\u0b95\u0bb0",
