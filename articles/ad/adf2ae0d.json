          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba",
            "label": "GPE"
          },
          {
            "text": "\u0dbb\u0da2\u0dba\u0dda",
            "label": "ORG"
          },
          {
            "text": "\u0d87\u0db1\u0dca\u0dad\u0db1\u0dd2 \u0db6\u0dca\u0dbd\u0dd2\u0db1\u0dca\u0d9a\u0db1\u0dca",
            "label": "PERSON"
