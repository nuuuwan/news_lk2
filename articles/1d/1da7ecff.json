          }
        ]
      ]
    },
    "si": {
      "title": "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dbb\u0db1 \u0d9a\u0dcf\u0dbd\u0dba \u0daf \u0daf\u0dd2\u0d9c\u0dd4 \u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0db1\u0dd2\u0db4\u0daf\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dc0\u0dad\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dc4 \u0da2\u0dbd\u0dba \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0d9a\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0dba \u0dad\u0dd4\u0db1\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1\u0dd4 \u0d87\u0dad\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0da7\u0dd2\u0db4\u0dcf\u0da7\u0dd2\u0dba \u0dc4\u0dd9\u0da7 (27) \u0dc3\u0dd2\u0da7 \u0da2\u0dd6\u0dbd\u0dd2 3 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0db6\u0dc0 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb \u0d87\u0dad."
      ],
      "title_ents": [],
