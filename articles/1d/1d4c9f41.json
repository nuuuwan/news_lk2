    "si": {
      "title": "\u0da0\u0dd3\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca Yaogan-33 2 \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0 \u0d9a\u0d9a\u0dca\u0dc2\u0d9c\u0dad \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0da0\u0dd3\u0db1\u0dba Yaogan-33 02 \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0 \u0dbd\u0ddd\u0db1\u0dca\u0d9c\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0da0\u0dca 4C \u0dc0\u0dcf\u0dc4\u0d9a \u0dbb\u0ddc\u0d9a\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0d9a\u0dca \u0db8\u0dad\u0dd2\u0db1\u0dca \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc0\u0dba\u0db9 \u0daf\u0dd2\u0d9c \u0da0\u0dd3\u0db1\u0dba\u0dda Jiuquan \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0db6\u0dd3\u0da2\u0dd2\u0d82 \u0dc0\u0dda\u0dbd\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd9.\u0dc0. 7:44 \u0da7 \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0,\u00a0\u0db8\u0dd9\u0db8 \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0 \u0d91\u0dc4\u0dd2 \u0db4\u0dd9\u0dbb \u0dc3\u0dd0\u0d9a\u0dc3\u0dd6 \u0d9a\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dcf\u0dbb\u0dca\u0dae\u0d9a \u0dc0\u0dd6 \u0db6\u0dc0 \u0dc3\u0d82\u0da5\u0dcf \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0da0\u0dd3\u0db1\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0d91\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0d85\u0dad\u0dca\u0dc4\u0daf\u0dcf \u0db6\u0dd0\u0dbd\u0dd3\u0db8\u0dca, \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0da9\u0db8\u0dca \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0dc3\u0d82\u0d9c\u0dab\u0db1\u0dba, \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dc0\u0dbd \u0d85\u0dc3\u0dca\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0d87\u0dc3\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dc4 \u0d86\u0db4\u0daf\u0dcf \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dba\u0ddc\u0daf\u0dcf \u0d9c\u0dd0\u0db1\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dbd\u0ddd\u0db1\u0dca\u0d9c\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0da0\u0dca \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0dda \u0dc0\u0dcf\u0dc4\u0d9a \u0dbb\u0ddc\u0d9a\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0dda 435 \u0dc0\u0dd0\u0db1\u0dd2 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0d9c\u0db8\u0db1 \u0dc3\u0db1\u0dd2\u0da7\u0dd4\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0dba."
      ],
