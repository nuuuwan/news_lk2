        [
          {
            "text": "\u0dc3\u0dd4\u0daf\u0dd2\u0dbd\u0dca \u0da2\u0dba\u0dbb\u0dd4\u0d9a\u0dca",
            "label": "PERSON"
          },
          {
            "text": "100",
