          },
          {
            "text": "\u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dd4- \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0dc4\u0dcf \u0d9a\u0dd4\u0da9\u0dcf \u0dc4\u0dcf \u0db8\u0db0\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0db8\u0dcf\u0dab \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0d82\u0da2\u0dba \u0dc0\u0dd2\u0da2\u0dda\u0db8\u0dcf\u0db1\u0dca\u0db1",
            "label": "PERSON"
