    "si": {
      "title": "Capital Alliance, CT CLSA \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d89\u0dc4\u0dc5\u0db8 CFA \u0db4\u0dca\u200d\u0dbb\u0dcf\u0d9c\u0dca\u0db0\u0db1 \u0dc0\u0dd9\u0dc5\u0dd9\u0db3\u0db4\u0ddc\u0dc5 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1 \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0db1\u0dd3",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dcf\u0d9c\u0dca\u0db0\u0db1 \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba \u0dc3\u0dc4 CTCLSA \u0dc3\u0dd4\u0dbb\u0dd0\u0d9a\u0dd4\u0db8\u0dca\u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dda \u0dc0\u0dbb\u0dbd\u0dad\u0dca \u0db8\u0dd6\u0dbd\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dc1\u0dca\u0dbd\u0dda\u0dc2\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0d9c\u0dda \u0db4\u0dbb\u0dd2\u0da0\u0dca\u0dd9\u0da1\u0dca\u0daf\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0db8\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d89\u0dc4\u0dc5\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0d9c\u0dca\u0db0\u0db1 \u0dc0\u0dd9\u0dc5\u0dd9\u0db3\u0db4\u0ddc\u0dc5 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1 \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "Capital Alliance Securities Private Ltd \u0dc4\u0ddc\u0db3\u0db8 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dad\u0dd0\u0dbb\u0dd0\u0dc0\u0dca\u0d9a\u0dcf\u0dbb \u0db4\u0dbb\u0dca\u0dba\u0dda\u0dc2\u0dab \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0db1\u0dca \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0daf\u0dd4\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd6 \u0db6\u0dc0 CFA \u0db4\u0dc0\u0dc3\u0dba\u0dd2. Asia Securities Private Ltd \u0dbb\u0dd2\u0daf\u0dd3 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0daf\u0dd4\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd6 \u0d85\u0dad\u0dbb CT CLSA Securities Private Ltd \u0dbd\u0ddd\u0d9a\u0da9 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0daf\u0dd4\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd3\u0dba.",
        "Capital Alliance \u0dc3\u0dc4 \u0dc4\u0ddc\u0db3\u0db8 \u0d85\u0d82\u0dc1\u0dba\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0da7 \u0dc4\u0dd2\u0db8\u0dd2 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0daf \u0dc4\u0dd2\u0db8\u0dd2 \u0dc0\u0dd2\u0dba. Asia Securities Private Ltd \u0dc3\u0dc4 Capital Alliance Securities Private Ltd \u0dba\u0db1 \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0dbd\u0ddd\u0d9a\u0da9 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0db6\u0dd9\u0daf\u0dcf \u0d9c\u0db1\u0dd3. \u0dbb\u0dd2\u0daf\u0dd3 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0dd0\u0db8\u0dd4\u0dab\u0dda \u0db1\u0dd0\u0dc4\u0dd0.",
        "CT CLSA Securities \u0dc4\u0ddc\u0db3\u0db8 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0db4\u0dbb\u0dca\u0dba\u0dda\u0dc2\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0db1\u0dca \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba. \u0dc3\u0dd3\u0db8\u0dcf\u0dc3\u0dc4\u0dd2\u0dad Capital Alliance Securities Private \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dbb\u0dd2\u0daf\u0dd3 \u0dc3\u0dc4 \u0dbd\u0ddd\u0d9a\u0da9 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1 \u0daf\u0dd9\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba.",
        "\u0dc3\u0db1\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0dc4\u0ddc\u0db3\u0db8 \u0d86\u0dba\u0ddd\u0da2\u0d9a \u0dc3\u0db6\u0db3\u0dad\u0dcf \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0db1\u0dca \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba. \u0dbb\u0dd2\u0daf\u0dd3 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dbd\u0daf\u0dd3. \u0da9\u0dba\u0dbd\u0ddc\u0d9c\u0dca \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0da7\u0dcf \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0dc3\u0dc4 \u0da2\u0ddd\u0db1\u0dca \u0d9a\u0dd3\u0dbd\u0dca\u0dc3\u0dca \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0dbd\u0ddd\u0d9a\u0da9 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0db6\u0dd9\u0daf\u0dcf \u0d9c\u0db1\u0dd3.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dca\u0db4\u0ddd\u0dbd\u0d82\u0d9a\u0dcf \u0dc4\u0ddd\u0dbd\u0dca\u0da9\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3 \u0dba\u0da7\u0dad\u0dda \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc0\u0dc3\u0dbb \u0dad\u0dd4\u0dc5 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd2\u0dba\u0dd4\u0dab\u0dd4 \u0d9a\u0dc5 \u0d86\u0dba\u0ddd\u0da2\u0d9a \u0dc3\u0db6\u0db3\u0dad\u0dcf \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba\u0db1\u0dca \u0d87\u0d9c\u0dba\u0dd3\u0db8\u0da7 \u0dbd\u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0dc3\u0dd9\u0db1\u0dca\u0dc6\u0dd2\u0db1\u0dca \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc0\u0dd9\u0dc5\u0dd9\u0db3\u0db4\u0ddc\u0dc5 \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd \u0dc4\u0ddc\u0db3\u0db8 \u0d92\u0d9a\u0d9a \u0db7\u0dcf\u0dbb \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd \u0dbd\u0dd9\u0dc3 \u0db1\u0db8\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3. JB Vantage \u0d9a\u0dd9\u0da7\u0dd2 \u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0d9c\u0dd2\u0dbd\u0dca\u0da7\u0dca \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd \u0dbb\u0dd2\u0daf\u0dd3 \u0db4\u0daf\u0d9a\u0dca\u0d9a\u0db8 \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba. \u0dbd\u0ddd\u0d9a\u0da9 \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0dd0\u0db8\u0dd4\u0dc0\u0dda \u0db1\u0dd0\u0dad."
