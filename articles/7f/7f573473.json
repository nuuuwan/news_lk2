          }
        ],
        [
          {
            "text": "\u0dc4\u0ddd\u0db8\u0dcf\u0d9c\u0db8 \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db8\u0dbb\u0dab \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a",
