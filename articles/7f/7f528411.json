    "si": {
      "title": "2021 \u0d85.\u0db4\u0ddc.\u0dc3 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda \u0dc4\u0ddc\u0db3\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0d9a\u0dd0\u0db1\u0dca\u0daf\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d89\u0dc2\u0dcf\u0dbb \u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca \u0dc4\u0dd3\u0db1\u0dca\u0d9a\u0dd9\u0db1\u0dca\u0daf \u0d85.\u0db4\u0ddc.\u0dc3. \u0d9a\u0dbd\u0dcf \u0dc0\u0dd2\u0dc2\u0dba \u0db0\u0dcf\u0dbb\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad. \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba 2021 (2022).",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab \u0dc0\u0dd2\u0dc2\u0dba \u0db0\u0dcf\u0dbb\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0db1\u0dcf\u0dbb\u0db8\u0dca\u0db8\u0dbd \u0db8\u0dba\u0dd4\u0dbb\u0db4\u0dcf\u0daf \u0db8\u0db0\u0dca\u200d\u0dba \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db1\u0dd9\u0dbb\u0db1\u0dca\u0daf \u0daf\u0dd2\u0dbd\u0dca\u0dc4\u0dcf\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dd2\u0d82\u0dc4 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0da2\u0dd3\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc0\u0dd2\u0dc2\u0dba \u0db0\u0dcf\u0dbb\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc4\u0dd2\u0db8\u0dd2\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db8\u0da9\u0d9a\u0dbd\u0db4\u0dd4\u0dc0 \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db8\u0dba\u0dd2\u0d9a\u0dbd\u0dca \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dad\u0db8\u0dd2\u0dbd\u0dca\u0dc0\u0db1\u0dca\u0db1\u0db1\u0dca \u0dad\u0dd4\u0dc0\u0dbb\u0d9c\u0dda\u0dc2\u0dca \u0dba.",
        "2021 G.C.E \u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba \u0d85\u0daf www.doenets.lk \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba \u0dc4\u0dbb\u0dc4\u0dcf \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0da2\u0dcf\u0dbd\u0dba\u0da7 \u0db8\u0dd4\u0daf\u0dcf \u0dc4\u0dd0\u0dbb \u0d87\u0dad www.results.exams.gov.lk",
        "2021 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba \u0db4\u0dd9\u0db6\u0dbb\u0dc0\u0dcf\u0dbb\u0dd2 07 \u0dc3\u0dd2\u0da7 \u0db8\u0dcf\u0dbb\u0dca\u0dad\u0dd4 05 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0dcf \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1 2,438\u0d9a\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2.",
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 236,035 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0dc4 \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 36,647 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd9\u0db1\u0dd3 \u0dc3\u0dd2\u0da7 \u0d87\u0dad.",
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 149,946 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dda\u0dc1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0d85\u0dba\u0daf\u0dd4\u0db8\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca 21,551 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db8\u0dd9\u0dc0\u0dbb \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf."
      ],
