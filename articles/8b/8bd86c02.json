    "si": {
      "title": "\u0dad\u0dd9\u0dbd\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0d85\u0dba \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dba\u0d9a",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0dbd\u0dd4\u0dad\u0dca\u0d9c\u0db8 \u0d85\u0dba\u0dd2.\u0d95.\u0dc3\u0dd3. \u0d89\u0db1\u0dca\u0db0\u0db1\u0dc4\u0dbd\u0da7\u00a0 \u0daf\u0dd2\u0db1 7 \u0d9a\u0dd2\u0db1\u0dca\u00a0 \u0d89\u0db1\u0dca\u0db0\u0db1\u00a0 \u0db1\u0ddc\u0dbd\u0dd0\u0db6\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0ddc\u0dca\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0dc3\u0dd2\u0da7\u0dd2 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d85\u0daf (4\u0daf\u0dcf)\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd6\u0dc4.",
        "\u0d85\u0dbd\u0dd4\u0dad\u0dca\u0d9c\u0db8\u00a0 \u0d89\u0db1\u0dca\u0db0\u0db1\u0dc4\u0dbd\u0da7\u00a0 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb\u0dca 2 \u0d9a \u0daf\u0dd4\u0dbb\u0dd2\u0db1\u0dca\u00a0 \u0d9a\u0dc5\u0dd4\u0dc0\u0dcf\u0db8\u0ddd\u0daf\u0dbb \u0db4\u0dcf\u0dbd\u0db8 \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u00a0 \u00a0\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dc3\u0dc4\u00a0 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc0\u0dcf\u0dc4\u0db1 \u0daf\u0dd2\u0db1 \u0d9c\u0db1\u0db1\u0dcf\u0dc0\u0d9a \u0dc3\u0dd2\u0da7\u00a0 \u0d9c\u0dcf\u0dbd\u0dd4 \u0db4\u0dcf\u0dbb\u0dda \u0db1\u0dc0\u0dad\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda\u00a0 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u00a0 \u0dad\u0db8\u0db1\u0dca\u0da7\u00a0 \u0d89\u0db1\u0dca\u0db0\u0db1\u00a0 \u0db1\u0ddc\u0dbd\u0dd0\u0db6\u0dd3\u0db8\u0dda \u0db4\u0dd3\u0da9\u0db1\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca\u00a0 \u0db8\u0dd9\u0dc3\u0dda \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dda \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd2\u0dba."
      ],
