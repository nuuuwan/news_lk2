          {
            "text": "\u0d85\u0dbb\u0dbd\u0dd2\u0dba\u0d9c\u0dc4 \u0db8\u0db1\u0dca\u0daf\u0dd2\u0dbb\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0dc0\u0dc3\u0dd2\u0db1\u0dca \u0daf\u0dc0\u0dc3",
            "label": "DATE"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d85\u0db0\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0d85\u0dbb\u0db8\u0dd4\u0daf\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0d86\u0dc4\u0dcf\u0dbb \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1",
