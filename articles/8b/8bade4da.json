          {
            "text": "\u0b89\u0bb2\u0b95 \u0b89\u0ba3\u0bb5\u0bc1 \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f\u0bae\u0bcd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "IMF",
            "label": "ORG"
