    "si": {
      "title": "\u0da2\u0dbb\u0dca\u0db8\u0db1\u0dd2\u0dba \u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1\u0dba\u0da7 \u0dbb\u0ddc\u0d9a\u0da7\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0d9a \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0dbb\u0dca\u0db8\u0db1\u0dd2\u0dba\u0dda Mars-II \u0db6\u0dc4\u0dd4 \u0daf\u0dd2\u0dba\u0dad\u0dca \u0dbb\u0ddc\u0d9a\u0da7\u0dca \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2 (MLRS) \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba\u0dda \u0dad\u0dd9\u0dc0\u0dd0\u0db1\u0dca\u0db1 \u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d91\u0dbb\u0da7 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d87\u0dbd\u0dd9\u0d9a\u0dca\u0dc3\u0dd2 \u0dbb\u0dd9\u0dc3\u0dca\u0db1\u0dd2\u0d9a\u0ddc\u0dc0\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u201c\u0dbd\u0ddd\u0db1\u0dca\u0d9c\u0dca \u0dc4\u0dd1\u0db1\u0dca\u0da9\u0dca \u0db4\u0dc0\u0dd4\u0dbd\u0dda \u0dad\u0dd4\u0db1\u0dca\u0dc0\u0db1 \u0dc3\u0dc4\u0ddd\u0daf\u0dbb\u0dba\u0dcf, \u0da2\u0dbb\u0dca\u0db8\u0db1\u0dd2\u0dba\u0dda MLRS MARS II \u0dba\u0dd4\u0d9a\u0dca\u0dbb\u0dda\u0db1\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. \u0db8\u0dd9\u0db8 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2 \u0dc3\u0db3\u0dc4\u0dcf \u0da2\u0dbb\u0dca\u0db8\u0db1\u0dd2\u0dba\u0da7 \u0dc3\u0dc4 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a\u0dc0 \u0db8\u0d9c\u0dda \u0dc3\u0d9c\u0dba\u0dcf \u0dc0\u0db1 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd9\u0dad \u0dc3\u0dca\u0dad\u0dd6\u0dad\u0dd2\u0dba \u0db4\u0dd4\u0daf \u0d9a\u0dbb\u0db1\u0dc0\u0dcf. \u0d85\u0db4\u0d9c\u0dda \u0d9a\u0dcf\u0dbd\u0dad\u0dd4\u0dc0\u0d9a\u0dca\u0d9a\u0dd4 \u0db7\u0da7\u0dba\u0dd2\u0db1\u0dca \u0d85\u0db4\u0d9c\u0dda \u0da2\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dd4 \u0dc4\u0dc0\u0dd4\u0dbd\u0dca\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0d86\u0da0\u0dcf\u0dbb \u0d9a\u0dbb\u0dcf\u0dc0\u0dd2, \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0da7\u0dca\u0dc0\u0dd3\u0da7\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "Mars-II \u0dba\u0db1\u0dd4 \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0dd2\u0dad MLRS M270 \u0db6\u0dc4\u0dd4 \u0dbb\u0ddc\u0d9a\u0da7\u0dca \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dba\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0da2\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dd4, \u0d89\u0dad\u0dcf\u0dbd\u0dd2 \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0d82\u0dc1-\u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0dd2\u0dad \u0dc0\u0dd9\u0db1\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dd2. \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba\u0dda \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0da2\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dd4 \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0d9a\u0dca \u0dc0\u0db1 KMW\u0da7 \u0d85\u0db1\u0dd4\u0dc0, Mars-II \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2\u0dba\u0d9a\u0da7 \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd 12\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb 70\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0d9a\u0dca \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0dda \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0d87\u0dad. \u0db8\u0dd9\u0db8 \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd GPS \u0dc4\u0ddd \u0db6\u0dd2\u0db8\u0dca \u0db6\u0ddd\u0db8\u0dca\u0db6 \u0d89\u0dc0\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a."
      ],
