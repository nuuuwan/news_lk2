          },
          {
            "text": "1993",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0dc0\u0dc3",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dab\u0dc3\u0dd2\u0d82\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dd3 \u0db6\u0dd3 \u0dc0\u0dd2\u0da2\u0dda\u0dad\u0dd4\u0d82\u0d9c",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dda\u0dad\u0dd4\u0d82\u0d9c",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
