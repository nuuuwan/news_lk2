    "en": {
      "title": "Selvaraja Gajendran did not vote",
      "author": "unknown",
      "body_lines": [
        "All Sri Lanka Tamil Congress National List Member of Parliament Selvarasa Gajendran did not participate in the ongoing voting to elect the President."
      ],
