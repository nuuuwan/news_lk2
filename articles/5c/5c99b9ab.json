  "text_idx": {
    "en": {
      "title": "2600 train ticket sold for 7600",
      "author": "unknown",
      "body_lines": [
        "The police said that a suspect was arrested for selling a train ticket at a higher price to a foreign couple at the Kandy railway station.",
        "The suspect has sold the 2600 rupees ticket for 7600 rupees, the police said.",
        "While the suspect was selling this ticket, he was arrested by the security personnel of the railway station and he was arrested and handed over to the police."
      ],
