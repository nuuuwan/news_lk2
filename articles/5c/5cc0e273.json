    "si": {
      "title": "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0dc0: \u0dbd\u0dd2\u0dba\u0d9a\u0dd2\u0dba\u0dc0\u0dd2\u0dbd\u0dd2 \u0da2\u0db1\u0db4\u0dad\u0dd2\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0db8\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dbd\u0dd2\u0db4\u0dd2 \u0dbd\u0dda\u0d9b\u0db1 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd9\u0dad \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0da5 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dc0\u0dd2\u0da2\u0dba\u0daf\u0dcf\u0dc3 \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d8a\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0dbd\u0dd2\u0db4\u0dd2 \u0dbd\u0dda\u0d9b\u0db1 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0dc0\u0dd9\u0dad \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dc5 \u0db6\u0dc0 \u0daf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "QR \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 1 \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dda : \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0ddc\u0db8\u0dca\u0db4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db4\u0dd9\u0dbb \u0daf\u0dd0\u0db1\u0d9c\u0dad \u0dba\u0dd4\u0dad\u0dd4 \u0dc0\u0dd0\u0daf\u0d9c\u0dad\u0dca \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 12 \u0d9a\u0dca"
