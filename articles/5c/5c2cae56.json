    "si": {
      "title": "\u0db6\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u200d\u0dba \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0db4\u0ddc\u0dbb\u0dba \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db6\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u200d\u0dba \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dbb\u0dd2\u0dc2\u0dd2 \u0dc3\u0dd4\u0db1\u0d9a\u0dca \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc0\u0da7\u0dba\u0dda \u0da1\u0db1\u0dca\u0daf \u0dc0\u0dd2\u0db8\u0dc3\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0da1\u0db1\u0dca\u0daf \u0dbd\u0db6\u0dcf \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0db6\u0ddc\u0dbb\u0dd2\u0dc3\u0dca \u0da2\u0ddc\u0db1\u0dca\u0dc3\u0db1\u0dca \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0da7 \u0d9a\u0ddc\u0db1\u0dca\u0dc3\u0dbb\u0dca\u0dc0\u0dda\u0da7\u0dd2\u0dc0\u0dca \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0dc4 \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0db0\u0dd4\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0dbb\u0d9c\u0dba\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd3.",
        "\u0dc3\u0dd4\u0db1\u0d9a\u0dca \u0da1\u0db1\u0dca\u0daf 101 \u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb, \u0d9a\u0db1\u0dd2\u0dc2\u0dca\u0da8 \u0dc0\u0dd9\u0dc5\u0db3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db4\u0dd9\u0db1\u0dd3 \u0db8\u0ddd\u0dbb\u0dca\u0da9\u0ddc\u0db1\u0dca\u0da7\u0dca \u0da1\u0db1\u0dca\u0daf 83 \u0d9a\u0dca \u0dc3\u0dc4 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0dbd\u0dd2\u0dc3\u0dca \u0da7\u0dca\u200d\u0dbb\u0dc3\u0dca \u0da1\u0db1\u0dca\u0daf 64 \u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd9\u0db1 \u0d87\u0dad. \u0db1\u0dd3\u0dad\u0dd2\u0db4\u0dad\u0dd2 \u0dc3\u0dd4\u0d91\u0dbd\u0dcf \u0db6\u0dca\u200d\u0dbb\u0dd0\u0dc0\u0dbb\u0dca\u0db8\u0db1\u0dca \u0da1\u0db1\u0dca\u0daf 27\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8,\u00a0\u0db1\u0dd3\u0dad\u0dd2 \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0d9a \u0da7\u0ddc\u0db8\u0dca \u0da7\u0dd4\u0d9c\u0dd9\u0db1\u0dca\u0da9\u0dca\u0dc4\u0da7\u0dca \u0da1\u0db1\u0dca\u0daf 32 \u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0dd9\u0db8\u0dd2 \u0db6\u0dd9\u0da9\u0dca\u0db1\u0ddd \u0da1\u0db1\u0dca\u0daf 49\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba."
      ],
