      "body_line_ents_list": [
        [
          {
            "text": "News 1st",
            "label": "DATE"
          },
          {
            "text": "\u0b86\u0b9a\u0bbf\u0baf \u0bae\u0bb2\u0bc8 \u0b9a\u0bc1\u0bb1\u0bcd\u0bb1\u0bc1\u0bb2\u0bbe \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0ba3\u0bbf",
            "label": "ORG"
