          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d91\u0db8\u0dca.\u0d92.",
            "label": "ORG"
          },
          {
            "text": "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dc3\u0dca \u0dc3\u0dd4\u0d9a\u0dd3\u0dbb\u0dca\u0dad\u0db1\u0dca",
            "label": "PERSON"
          },
          {
