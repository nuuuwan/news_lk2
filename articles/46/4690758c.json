    "si": {
      "title": "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba\u0dda \u0daf\u0dbb\u0dd4\u0dab\u0dd4 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0dad\u0dd4\u0db1\u0dca \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0db8\u0dd0\u0dbb\u0dd4\u0dc0\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba - \u0db8\u0dd4\u0dad\u0dd6\u0dbb\u0dca, \u0db6\u0da0\u0db1\u0dd4\u0dbb\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd3\u0dc3\u0dd1\u0db8 \u0dba\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dba\u0d9a\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0da7 \u0db4\u0dd0\u0db1\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd4\u0dab\u0dcf."
