    "si": {
      "title": "SLC SLvsAUS \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba \u0dad\u0ddd\u0dbb\u0dcf \u0d9c\u0db1\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dda\u0dbb\u0dd3\u0db8\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dad\u0dbb\u0d9f 02 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf 18 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0d9c\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba\u0d9a\u0dca \u0dad\u0ddd\u0dbb\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "ICC \u0dbd\u0ddd\u0d9a \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dba\u0da7\u0dad\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba 2022 \u0da2\u0dd4\u0db1\u0dd2 29 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0dab\u0dba\u0dda\u0daf\u0dd3 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dda.",
        "\u0d85\u0daf\u0dad\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf; \u0dc4\u0dd0\u0da7\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dcf\u0dc3\u0dd3\u0db1\u0dca \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0dda \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba 9 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2",
        "CEDAW \u0dc4\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dd2\u0dad\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dbb\u0d82\u0d9c\u0dd2\u0dad \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0daf \u0d85\u0dbd\u0dca\u0dc0\u0dd2\u0dc3\u0dca \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba"
      ],
