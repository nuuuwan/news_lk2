          }
        ],
        [
          {
            "text": "\u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "CARDINAL"
          },
          {
            "text": "\u0bae\u0bbe\u0bb2\u0baa\u0bc7 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bcd \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bae\u0bcd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0b92\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "CARDINAL"
          },
