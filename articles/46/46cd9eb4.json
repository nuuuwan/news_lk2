            "label": "CARDINAL"
          },
          {
            "text": "\u0bb5\u0bbf\u0ba4\u0bcd\u0baf\u0bbe\u0bb2\u0bbe \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc1",
            "label": "FAC"
          },
          {
            "text": "Kottawa",
