            "label": "PERSON"
          },
          {
            "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0d9a\u0dd2\u0dbd\u0dd2\u0db1\u0ddc\u0da0\u0dca\u0da0\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
