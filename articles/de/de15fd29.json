    "si": {
      "title": "\u0d9a\u0dc5\u0dd4 \u0d9c\u0d9f \u0daf\u0dd9\u0db4\u0dc3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dba\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0daf\u0dd3\u0db8\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dcf\u0dbb\u0dd2\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc4\u0dd9\u0da7 (01\u0daf\u0dcf) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 03.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dbd\u0d82\u0d9c\u0dd4 \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d9a\u0dc5\u0dd4 \u0d9c\u0d9f \u0daf\u0dca\u200d\u0dbb\u0ddd\u0dab\u0dd2\u0dba\u0da7 \u0d85\u0daf\u0dcf\u0dc5\u0dc0 \u0d9c\u0d82\u0dc0\u0dad\u0dd4\u0dbb \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0d87\u0d9f\u0dc0\u0dd3\u0db8\u0dda \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d91\u0db8 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0dda \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0db4\u0dd0\u0dba 24 \u0dad\u0dd4\u0dc5 \u0dbb\u0dad\u0dca\u0db1\u0db4\u0dd4\u0dbb \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0dda \u0db4\u0dd0\u0dbd\u0dca\u0db8\u0da9\u0dd4\u0dbd\u0dca\u0dbd, \u0db1\u0dd2\u0dc0\u0dd2\u0dad\u0dd2\u0d9c\u0dbd, \u0dbb\u0dad\u0dca\u0db1\u0db4\u0dd4\u0dbb, \u0d9a\u0dd4\u0dbb\u0dd4\u0dc0\u0dd2\u0da7, \u0d85\u0dba\u0d9c\u0db8 \u0dc3\u0dc4 \u0d87\u0dbd\u0db4\u0dcf\u0dad \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dc0\u0dbd \u0db4\u0dc4\u0dad \u0db6\u0dd2\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db8\u0da7\u0dca\u0da7\u0db8\u0dda \u0d9c\u0d82\u0dc0\u0dad\u0dd4\u0dbb \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d91\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc4\u0dcf \u0d91\u0db8 \u0db4\u0dca\u200d\u0dbb \u0daf\u0dda\u0dc1 \u0dc4\u0dbb\u0dc4\u0dcf \u0d9c\u0db8\u0db1\u0dca\u0d9c\u0db1\u0dca\u0db1\u0db1\u0dca \u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0daf\u0dd0\u0da9\u0dd2 \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dca\u0dbd\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0dbd\u0dd9\u0dc3\u0daf \u0dc0\u0dcf\u0dbb\u0dd2\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd3."
      ],
