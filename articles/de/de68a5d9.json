    "si": {
      "title": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0dc3\u0dbd \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca 429\u0d9a\u0dca \u0d8b\u0dc3\u0dca\u0dc3\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba (\u0db4\u0ddc\u0dbd\u0dca\u0daf\u0dd6\u0dc0 \u0dc0\u0da7\u0dbb\u0dc0\u0dd4\u0db8) \u0d85\u0dc3\u0dbd \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u00a0\u0d9a\u0dbd\u0dc4\u0d9a\u0dcf\u0dbb\u0dd3 \u0dbd\u0dd9\u0dc3 \u0dc4\u0dd0\u0dc3\u0dd2\u0dbb\u0dd4\u0dab\u0dd4 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0d9a\u0daf\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0d8b\u0dab\u0dca\u0da9 \u0dc4\u0dcf \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0ddd\u0db8\u0dca\u0db6 429\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dca\u0dad\u0dda \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0d8b\u0dab\u0dca\u0da9 340 \u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0ddd\u0db8\u0dca\u0db6 \u00a089 \u0d9a\u0dca \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u00a0 \u0dc0\u0dda.",
        "\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dd0\u0dc4\u0dd0\u0dbb\u0d9c\u0dad\u0dca \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0d8b\u0dab\u0dca\u0da9 50\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0dc3\u0d9f\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0ddc\u0dba\u0dcf\u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba. \u0d85\u0db1\u0dd9\u0d9a\u0dca \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0d8b\u0dab\u0dca\u0da9 \u0dc3\u0dc4 \u0d9a\u0db3\u0dd4\u0dc5\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0ddd\u0db8\u0dca\u0db6 \u0dc3\u0ddc\u0dba\u0dcf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda ."
      ],
