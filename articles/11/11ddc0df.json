    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: \u0d85\u0dbb\u0d9c\u0dbd\u0dba\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0dc0\u0dd9\u0dad \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba\u0d9a\u0daf\u0dd3 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dbb\u0d9c\u0dbd\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0d9a\u0dca \u0d85\u0daf \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dc5\u0dcf.",
        "\u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0db6\u0dbd\u0dcf \u0dba\u0dcf\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0d85\u0dbb\u0d9c\u0dbd\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0da9\u0db1\u0dd2\u0dc2\u0dca \u0d85\u0dbd\u0dd2 \u0db1\u0db8\u0dd0\u0dad\u0dd2 \u0d85\u0dba\u0dd9\u0d9a\u0dd4 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc3\u0db8\u0dcf\u0da2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dc0\u0dbd \u0daf\u0dbb\u0dca\u0dc1\u0db1 \u0dad\u0dbd\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9a\u0da9\u0dcf \u0dc0\u0dd0\u0daf\u0dd3\u0db8\u0dda \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0da7 \u0db8\u0ddc\u0dc4\u0dd4 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0db6\u0dbd\u0dcf \u0dba\u0dcf\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u2018\u0da9\u0dd0\u0db1\u0dd2\u0dc2\u0dca \u0d85\u0dbd\u0dd2\u2019 \u0db1\u0db8\u0dd0\u0dad\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad. \u0d94\u0dc4\u0dd4 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba\u0d9a\u0dca \u0dad\u0dd4\u0dc5\u0daf\u0dd3 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0da7 \u0d9a\u0da9\u0dcf \u0dc0\u0dd0\u0daf\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0d85\u0dba\u0dd9\u0d9a\u0dd2 - \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca#lka #SriLanka #SLnews #News1st #ProtestLK #SriLankaProtest #CID #Arrest #Inflight pic.twitter.com/28RYL6FPTI",
        "\u0dc3\u0db3\u0dd4\u0daf\u0dcf (25) \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0db8\u0dbb\u0dab \u0db4\u0dc4\u0d9a\u0dca, \u0d85\u0daf (26) \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 100 \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dba\u0dd2."
      ],
