      "body_line_ents_list": [
        [
          {
            "text": "\u0daf\u0dd2\u0db1 \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0db4\u0db8\u0dab\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0dbd\u0db6\u0db1 \u0db8\u0dc3 10 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
