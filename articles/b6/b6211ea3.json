    "si": {
      "title": "\u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dc3\u0dad\u0dd2\u0dba\u0da7 \u0daf\u0dd2\u0db1 3 \u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0da7\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dc0\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dda \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dbd\u0db6\u0db1 \u0db8\u0dc3 10 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc4\u0ddd \u0db1\u0dd0\u0dc0\u0dad \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0dad\u0dd9\u0d9a\u0dca \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0daf\u0dd2\u0db1 \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0daf\u0dd2\u0db1 \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0dc4\u0dd4\u0dc0\u0db8\u0dcf\u0dbb\u0dd4\u0dc0\u0dda \u0dc3\u0dc4 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dc0\u0dbd \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd3 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0db8 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd \u0d9a\u0dd0\u0db3\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca\u0db4\u0dad\u0dd2 \u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0d86\u0dbb\u0dd2\u0dba\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0da0\u0d9a\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9b\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d91\u0db8 \u0da0\u0d9a\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9b\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf, \u0db6\u0db3\u0daf\u0dcf \u0dc3\u0dc4 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dba\u0db1 \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0dc3\u0db3\u0dd4\u0daf\u0dcf, \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dba\u0db1 \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dc0\u0dc3\u0dcf \u0dad\u0db6\u0dba\u0dd2."
      ],
      "title_ents": [
