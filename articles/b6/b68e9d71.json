          },
          {
            "text": "\u0baa\u0bc6\u0bb0\u0bcd\u0baa\u0bc6\u0b9a\u0bcd\u0b9a\u0bc1\u0bb5\u0bb2\u0bcd \u0b9f\u0bcd\u0bb0\u0bb7\u0bb0\u0bc0\u0bb8\u0bcd",
