    "si": {
      "title": "\u0dba\u0dcf\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d9a\u0da9\u0dd4\u0dc0\u0d9a\u0dca \u0d9a\u0dd0\u0db4\u0dda: \u0dad\u0dbb\u0dd4\u0dab \u0dbb\u0ddd\u0dc4\u0dbd\u0d9a\u0daf\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0db1\u0dd2\u0db4\u0dcf\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8\u0da7 \u0d85\u0dba\u0dad\u0dca \u0db8\u0db1\u0dd2\u0db4\u0dcf\u0dba\u0dd2 \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0daf\u0dd3 \u0db4\u0dd2\u0dc4\u0dd2 \u0d87\u0db1\u0dd4\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dd9\u0d9a\u0dd4 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc0\u0dd9\u0dc5\u0dd9\u0db3 \u0db4\u0ddc\u0dc5\u0d9a \u0dc3\u0dda\u0dc0\u0dba \u0d9a\u0dbb\u0db1 21 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0da2\u0dba\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dca \u0dc3\u0da2\u0dd3\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db1\u0dca \u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0dc0\u0db8\u0dca \u0d85\u0dad \u0dba\u0dcf\u0db4\u0db1\u0dba, \u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0d87\u0dad. \u0d94\u0dc4\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0dc1\u0dd2\u0d9a\u0dca\u0dc2\u0dab \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad. (\u0d92)"
      ],
