    "si": {
      "title": "\u0db1\u0dcf\u0dc3\u0dcf \u0dc4\u0dd2 \u0db4\u0dc5\u0db8\u0dd4 \u0db4\u0dd6\u0dbb\u0dca\u0dab-\u0dc0\u0dbb\u0dca\u0dab \u0d85\u0db7\u0dca\u200d\u0dba\u0dc0\u0d9a\u0dcf\u0dc1 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dba",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca JWST \u0dc4\u0ddd Webb \u0dbd\u0dd9\u0dc3 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0db1 \u0da2\u0dda\u0db8\u0dca\u0dc3\u0dca \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0db7\u0dca\u200d\u0dba\u0dc0\u0d9a\u0dcf\u0dc1 \u0daf\u0dd4\u0dbb\u0dda\u0d9a\u0dca\u0dc2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db4\u0dc5\u0db8\u0dd4 \u0dc0\u0dd0\u0db1\u0dd2 \u0db4\u0dd6\u0dbb\u0dca\u0dab-\u0dc0\u0dbb\u0dca\u0dab \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dba \u0db4\u0dca\u200d\u0dbb\u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d85\u0dbd\u0dd4\u0dad\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db8\u0dd9\u0db8 \u0d85\u0db7\u0dca\u200d\u0dba\u0dc0\u0d9a\u0dcf\u0dc1\u00a0\u0daf\u0dd4\u0dbb\u0dda\u0d9a\u0dca\u0dc2\u0dba \u0d91\u0dc4\u0dd2 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dc3\u0d82\u0dbb\u0da0\u0d9a \u0daf\u0dd2\u0d9c \u0dc4\u0dd0\u0dbb\u0dd3\u0db8, \u0d91\u0dc4\u0dd2 \u0daf\u0dbb\u0dca\u0db4\u0dab \u0db4\u0dd9\u0dc5\u0d9c\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0d91\u0dc4\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dcf\u0d82\u0d9a\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db8\u0dcf\u0dc3 \u0dc4\u0dba\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dba \u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "Webb's Near-Infrared Camera \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dbd\u0daf, \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dba Webb's First Deep Field \u0dbd\u0dd9\u0dc3 \u0db1\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb\u0dca,\u00a0\u0d91\u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d89\u0dad\u0dcf \u0dc3\u0dc0\u0dd2\u0dc3\u0dca\u0dad\u0dbb\u0dcf\u0dad\u0dca\u0db8\u0d9a\u0dc0 \u0db8\u0db1\u0dca\u0daf\u0dcf\u0d9a\u0dd2\u0dab\u0dd2 \u0daf\u0dc4\u0dc3\u0dca \u0d9c\u0dab\u0db1\u0d9a\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db8\u0dd9\u0dc4\u0dd2 \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0d9c\u0dad \u0d9a\u0dca\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb\u0dba \u0dba\u0db1\u0dd4 \u0db1\u0dcf\u0dc3\u0dcf \u0d86\u0dba\u0dad\u0db1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd3\u0da7 \u0dc0\u0dc3\u0dbb \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 4.6\u0d9a\u0da7 \u0db4\u0dd9\u0dbb \u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0dc0\u0dd6 SMACS 0723 \u0db8\u0db1\u0dca\u0daf\u0dcf\u0d9a\u0dd2\u0dab\u0dd2 \u0db4\u0ddc\u0d9a\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0dad\u0dbb\u0d82\u0d9c \u0d86\u0dba\u0dcf\u0db8\u0dc0\u0dbd \u0dbb\u0dd6\u0db4\u0dc0\u0dbd \u0dc3\u0d82\u0dba\u0dd4\u0d9a\u0dca\u0dad\u0dba\u0d9a\u0dd2."
      ],
