    "si": {
      "title": "\u0d9c\u0dd1\u0dc3\u0dca, \u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0da7 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0dd2\u0dad\u0dd2\u0dba\u0db8\u0d9a\u0dca \u0dc4\u0daf\u0db1\u0dca\u0db1",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dd9\u0dbb\u0da7 \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dc4 \u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u00a0 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dc0\u0dd2\u0dc3\u0dca\u0dad\u0dbb\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca\u00a0 \u00a0\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0dd2\u0dad\u0dd2\u0dba\u0db8\u0d9a\u0dca \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0d9a\u0dc3\u0dca\u00a0 \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0dd0\u0dba\u0dd2\u00a0 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0 (\u0d9a\u0ddd\u0db4\u0dcf \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 ) \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba.",
        "\u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0 \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0dab \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dc3\u0d82\u0d9a\u0dd3\u0dbb\u0dca\u0dab\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd9\u0dbb\u0da7 \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca\u0d9a\u0dbb \u0d87\u0dad\u0dd2\u00a0 \u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0d9a \u0dc0\u0dcf\u0dba\u0dd4 \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dda \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 (LNG)\u00a0 \u0dc3\u0dc4 \u0d92\u0dca\u0dc0\u0dcf\u0dba\u0dda \u0dc0\u0dbb\u0dca\u0dad\u0db8\u0dcf\u0db1 \u0dad\u0dad\u0dca\u0dc0\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0\u00a0 \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dc4\u0dd4 \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3\u00a0 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0db4\u0dd0\u0dc4\u0dd0\u0daf\u0dd2\u0dbd\u0dd2\u00a0 \u0d9a\u0dc5\u0dc4.",
        "\u0db8\u0dd9\u0db8 \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dbb\u0da2\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dc0\u0db1\u0dca\u0db1\u0dda\u0daf\u0dd0\u0dba\u0dd2\u00a0 \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u00a0 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u00a0 \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0dc0\u0dd2\u0db8\u0dc3\u0dd6\u0dc4.",
        "\u0d8a\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0da0\u0dcf\u0dbb \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd6 \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd6 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda\u00a0 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0dbb\u0da2\u0dba\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca\u00a0 \u0d91\u0dc3\u0dda\u00a0 \u00a0\u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dca \u0d89\u0d9a\u0dca\u0db8\u0db1\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u00a0 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u00a0 \u0d9a\u0ddd\u0db4\u0dcf \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca\u00a0 \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba.",
        "\u0db8\u0dd9\u0db8 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0\u00a0 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7\u00a0 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0dc0\u0db1\u00a0 \u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0d85\u0dad\u0dca\u0dad\u0db1\u0dcf\u0dba\u0d9a,\u00a0 \u0dbd\u0dc3\u0db1\u0dca\u0dad \u0d85\u0dbd\u0d9c\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1,\u00a0 \u0daf\u0dba\u0dcf\u0dc3\u0dd2\u0dbb\u0dd2 \u0da2\u0dba\u0dc3\u0dda\u0d9a\u0dbb, \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u00a0 \u00a0\u0dc3\u0dd4\u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4\u0db4\u0dd4\u0dbd\u0dca\u0dbd\u0dda,\u00a0 \u0d8b\u0daf\u0dba \u0d9c\u0db8\u0dca\u0db8\u0db1\u0dca\u0db4\u0dd2\u0dbd,\u00a0 \u0dc4\u0dda\u0dc2\u0dcf \u0dc0\u0dd2\u0dad\u0dcf\u0db1\u0d9c\u0dda,\u00a0 \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba\u00a0 \u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb,\u00a0 \u0db1\u0dd2\u0dbb\u0ddd\u0dc2\u0db1\u0dca \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf,\u00a0 \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db8\u0dd4\u0dc3\u0db8\u0dca\u0db8\u0dd2\u0dbd\u0dca,\u00a0 \u0daf\u0dd4\u0db8\u0dd2\u0db1\u0dca\u0daf \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a,\u00a0 \u0dc0\u0dd3\u0dbb\u0dc3\u0dd4\u0db8\u0db1 \u0dc0\u0dd3\u0dbb\u0dc3\u0dd2\u0d82\u0dc4, (\u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba)\u00a0 \u00a0\u0d8b\u0db4\u0dd4\u0dbd\u0dca \u0d9c\u0dbd\u0db4\u0dca\u0db4\u0dad\u0dca\u0dad\u0dd2,\u00a0 \u0d91\u0dc3\u0dca. \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dad\u0dbb\u0db1\u0dca, \u0db6\u0dd3.\u0dc0\u0dba\u0dd2.\u0da2\u0dd3. \u0dbb\u0dad\u0dca\u0db1\u0dc3\u0dda\u0d9a\u0dbb,\u00a0 \u0d85\u0dc1\u0ddd\u0d9a\u0dca \u0d85\u0db6\u0dda\u0dc3\u0dd2\u0d82\u0dc4 \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1 \u0dbb\u0dab\u0dc0\u0dd3\u0dbb \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0db8 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd3\u0db1\u0dca\u00a0 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca\u0daf \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0dd6\u0dc4"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0d82\u0d9a\u0dd3\u0dbb\u0dca\u0dab",
            "label": "PRODUCT"
          }
        ],
        [
          {
            "text": "\u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0d9a \u0d9c\u0dd1\u0dc3\u0dca \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dca \u0dc0\u0dca\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dbd\u0dca\u0d91\u0db1\u0dca\u0da2\u0dd3",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [],
        [
          {
            "text": "COPA \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0d85\u0dad\u0dca\u0dad\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0dbd\u0dc3\u0db1\u0dca\u0dad \u0d85\u0dbd\u0d9c\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1",
            "label": "GPE"
          },
          {
            "text": "\u0daf\u0dba\u0dcf\u0dc3\u0dd2\u0dbb\u0dd2 \u0da2\u0dba\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "GPE"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd4\u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4\u0db4\u0dd4\u0dbd\u0dca\u0dbd\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0d8b\u0daf\u0dba \u0d9c\u0db8\u0dca\u0db8\u0db1\u0dca\u0db4\u0dd2\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dda\u0dc2\u0dcf \u0dc0\u0dd2\u0dad\u0dcf\u0db1\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0dbb\u0ddd\u0dc2\u0db1\u0dca \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db8\u0dd4\u0dc3\u0db8\u0dca\u0db8\u0dd2\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd3\u0dbb\u0dc3\u0dd4\u0db8\u0db1 \u0dc0\u0dd3\u0dbb\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0dc1\u0ddd\u0d9a\u0dca \u0d85\u0db6\u0dda\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1 \u0dbb\u0dab\u0dc0\u0dd3\u0dbb",
            "label": "PERSON"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b95\u0b9a\u0bcd\u0b9a\u0bbe \u0b8e\u0ba3\u0bcd\u0ba3\u0bc6\u0baf\u0bcd \u0ba4\u0bcb\u0ba3\u0bcd\u0b9f\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0b9a\u0bbe\u0bb2\u0bc8 \u0bb5\u0bb0\u0bc8\u0baa\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8 \u0b89\u0bb0\u0bc1\u0bb5\u0bbe\u0b95\u0bcd\u0b95\u0bb5\u0bc1\u0bae\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b95\u0b9a\u0bcd\u0b9a\u0bbe \u0b8e\u0ba3\u0bcd\u0ba3\u0bc6\u0baf\u0bc8 \u0b86\u0bb0\u0bbe\u0baf\u0bcd\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0bb5\u0bbf\u0bb0\u0bbf\u0bb5\u0bbe\u0ba9 \u0bb5\u0bb0\u0bc8\u0baa\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8 \u0ba4\u0baf\u0bbe\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0bc8 \u0bb5\u0bbf\u0bb0\u0bc8\u0bb5\u0bc1\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bbe\u0bb1\u0bc1 \u0baa\u0bca\u0ba4\u0bc1\u0b95\u0bcd \u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0b95\u0bcd \u0b95\u0bc1\u0bb4\u0bc1 (COPA) \u0b8e\u0bb0\u0bbf\u0b9a\u0b95\u0bcd\u0ba4\u0bbf \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0b85\u0bb1\u0bbf\u0bb5\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0baa\u0bca\u0ba4\u0bc1\u0b95\u0bcd \u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bcd \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbe\u0ba9 \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0b95\u0bcd \u0b95\u0bc1\u0bb4\u0bc1 \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd \u0baa\u0bc7\u0bb0\u0bbe\u0b9a\u0bbf\u0bb0\u0bbf\u0baf\u0bb0\u0bcd \u0ba4\u0bbf\u0bb8\u0bcd\u0bb8 \u0bb5\u0bbf\u0ba4\u0bbe\u0bb0\u0ba3 \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b85\u0ba3\u0bcd\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b95\u0b9f\u0bcd\u0b9f\u0b9f\u0ba4\u0bcd \u0ba4\u0bca\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b95\u0bc2\u0b9f\u0bbf\u0baf\u0ba4\u0bc1.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3 \u0b87\u0baf\u0bb1\u0bcd\u0b95\u0bc8 \u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1 \u0b85\u0b95\u0bb4\u0bcd\u0bb5\u0bc1\u0ba4\u0bcd \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bcd (LNG) \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b85\u0bb5\u0bb1\u0bcd\u0bb1\u0bbf\u0ba9\u0bcd \u0ba4\u0bb1\u0bcd\u0baa\u0bcb\u0ba4\u0bc8\u0baf \u0ba8\u0bbf\u0bb2\u0bc8 \u0b95\u0bc1\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0b8e\u0bb0\u0bbf\u0b9a\u0b95\u0bcd\u0ba4\u0bbf \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0bb3\u0b95\u0bcd\u0b95\u0bae\u0bb3\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd.",
        "\u0b85\u0b95\u0bb4\u0bcd\u0bb5\u0bbe\u0bb0\u0bbe\u0baf\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bc6\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0b85\u0bb0\u0b9a\u0bbe\u0b99\u0bcd\u0b95\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b86\u0bb2\u0bcb\u0b9a\u0ba9\u0bc8 \u0ba4\u0bc7\u0bb5\u0bc8\u0baf\u0bbe \u0b8e\u0ba9 \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc7\u0b9f\u0bcd\u0b9f\u0ba9\u0bb0\u0bcd.",
        "\u0b87\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0baa\u0ba4\u0bbf\u0bb2\u0bb3\u0bbf\u0ba4\u0bcd\u0ba4 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd, \u0bae\u0bb1\u0bcd\u0bb1 \u0b85\u0bb0\u0b9a\u0bc1\u0b95\u0bb3\u0bbf\u0b9f\u0bae\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b87\u0ba4\u0bc1\u0baa\u0bcb\u0ba9\u0bcd\u0bb1 \u0b86\u0bb2\u0bcb\u0b9a\u0ba9\u0bc8\u0b95\u0bb3\u0bcd \u0ba4\u0bc7\u0bb5\u0bc8\u0baf\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8 \u0b8e\u0ba9\u0bcd\u0bb1\u0bc1 \u0b95\u0bc1\u0bb1\u0bbf\u0baa\u0bcd\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd.",
        "\u0b85\u0ba4\u0ba9\u0bcd\u0baa\u0b9f\u0bbf, \u0b85\u0b95\u0bb4\u0bcd\u0bb5\u0bbe\u0bb0\u0bbe\u0baf\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf \u0baa\u0ba3\u0bbf\u0b95\u0bb3\u0bc8 \u0bb5\u0bbf\u0bb0\u0bc8\u0bb5\u0bbf\u0bb2\u0bcd \u0bae\u0bc1\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bbe\u0bb1\u0bc1 \u0b95\u0bcb\u0baa\u0bbe \u0b95\u0bc1\u0bb4\u0bc1 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0bc1\u0bae\u0bcd \u0b85\u0bb1\u0bbf\u0bb5\u0bc1\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0ba4\u0bc1.",
        "\u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd\u0b95\u0bb3\u0bbe\u0ba9 \u0ba4\u0bbf\u0bb8\u0bcd\u0bb8 \u0b85\u0ba4\u0bcd\u0ba4\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95, \u0bb2\u0b9a\u0ba8\u0bcd\u0ba4 \u0b85\u0bb4\u0b95\u0bbf\u0baf\u0bb5\u0ba3\u0bcd\u0ba3, \u0ba4\u0baf\u0bbe\u0b9a\u0bbf\u0bb1\u0bbf \u0b9c\u0baf\u0b9a\u0bc7\u0b95\u0bb0, \u0bb5\u0bbf\u0b9a\u0bc7\u0b9f \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0ba8\u0bbf\u0baa\u0bc1\u0ba3\u0bb0\u0bcd \u0b95\u0bb2\u0bbe\u0ba8\u0bbf\u0ba4\u0bbf \u0b9a\u0bc1\u0ba4\u0bb0\u0bcd\u0bb7\u0ba9\u0bbf \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb\u0baa\u0bc1\u0bb3\u0bcd\u0bb3\u0bc7, \u0b89\u0ba4\u0baf \u0b95\u0bae\u0bcd\u0bae\u0ba9\u0bcd\u0baa\u0bbf\u0bb2, \u0bb9\u0bc7\u0bb7\u0bbe \u0bb5\u0bbf\u0ba4\u0bbe\u0ba9\u0b95\u0bc7, \u0baa\u0bc7\u0bb0\u0bbe\u0b9a\u0bbf\u0bb0\u0bbf\u0baf\u0bb0\u0bcd \u0bb0\u0b9e\u0bcd\u0b9a\u0bbf\u0ba4\u0bcd \u0baa\u0ba3\u0bcd\u0b9f\u0bbe\u0bb0, \u0ba8\u0bbf\u0bb0\u0bcb\u0bb7\u0ba9\u0bcd \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe, \u0bae\u0bca\u0bb9\u0bae\u0b9f\u0bcd \u0bae\u0bc1\u0bb8\u0bae\u0bcd\u0bae\u0bbf\u0bb2\u0bcd, \u0ba4\u0bc1\u0bae\u0bbf\u0ba8\u0bcd\u0ba4 \u0ba4\u0bbf\u0bb8\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95, \u0bb5\u0bc0\u0bb0\u0b9a\u0bc1\u0bae\u0ba3 \u0bb5\u0bc0\u0bb0\u0bb8\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b87\u0ba8\u0bcd\u0ba4\u0b95\u0bcd \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0ba9\u0bb0\u0bcd. \u0bb8\u0bcd\u0bb0\u0bc0\u0ba4\u0bb0\u0ba9\u0bcd, \u0baa\u0bbf.\u0b92\u0baf\u0bcd.\u0b9c\u0bbf. \u0bb0\u0ba4\u0bcd\u0ba9\u0b9a\u0bc7\u0b95\u0bb0, \u0b85\u0b9a\u0bcb\u0b95\u0bcd \u0b85\u0baa\u0bc7\u0b9a\u0bbf\u0b99\u0bcd\u0b95 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0bbf\u0bb0\u0b9a\u0ba9\u0bcd\u0ba9 \u0bb0\u0ba3\u0bb5\u0bc0\u0bb0 \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc1\u0bae\u0bcd \u0b95\u0bb2\u0ba8\u0bcd\u0ba4\u0bc1\u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0ba9\u0bb0\u0bcd."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0baa\u0bca\u0ba4\u0bc1\u0b95\u0bcd \u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0ba8\u0bbe\u0b9f\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0b95\u0bcd \u0b95\u0bc1\u0bb4\u0bc1",
            "label": "ORG"
          },
          {
            "text": "\u0b8e\u0bb0\u0bbf\u0b9a\u0b95\u0bcd\u0ba4\u0bbf \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
            "label": "GPE"
          }
        ],
