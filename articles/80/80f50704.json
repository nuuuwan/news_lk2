        ],
        [
          {
            "text": "\u0db4\u0dd2\u0dc5\u0dd2\u0dba\u0db1\u0dca\u0daf\u0dbd",
            "label": "NORP"
          },
          {
            "text": "\u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd2 17 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0d85\u0dbd\u0dd4\u0dad\u0dca\u0d9a\u0da9\u0dda \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
            "label": "ORG"
          },
          {
            "text": "55 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0db1\u0dca\u0db1\u0dcf",
            "label": "NORP"
          },
          {
            "text": "\u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd2 20 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0d85\u0dbd\u0dd4\u0dad\u0dca\u0d9a\u0da9\u0dda \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
