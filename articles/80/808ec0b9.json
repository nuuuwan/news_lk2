          "text": "\u0da2\u0dd0\u0d9a\u0dbd\u0dd2\u0db1\u0dca \u0dc6\u0dbb\u0dca\u0db1\u0dd0\u0db1\u0dca\u0da9\u0dc3\u0dca",
