    "si": {
      "title": "\u0dc3\u0db4\u0dd4\u0d9c\u0dc3\u0dca\u0d9a\u0db1\u0dca\u0daf \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4\u0dc0 \u0dba\u0dc5\u0dd2 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0d85\u0dbb\u0db9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dd3\u0dad\u0dd2\u0d9c\u0dad \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0 (CPC) \u0dc3\u0db4\u0dd4\u0d9c\u0dc3\u0dca\u0d9a\u0db1\u0dca\u0daf \u0dad\u0dd9\u0dbd\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0d85\u0daf (\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 20) \u0dba\u0dc5\u0dd2 \u0dc3\u0dd2\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5 \u0db6\u0dc0 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0dcf\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4\u0dc0 \u0db8\u0dcf\u0dc3 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dc0\u0dc3\u0dcf \u0daf\u0db8\u0dcf \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0db1\u0dd3\u0dad\u0dd2 \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0dd2\u0dba \u0db1\u0dd2\u0dbd \u0da7\u0dca\u0dc0\u0dd2\u0da7\u0dbb\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0da7 \u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0dad\u0db6\u0db8\u0dd2\u0db1\u0dca \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 100,000\u0d9a\u0dca \u0db8\u0dd4\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0dbd\u0db6\u0db1 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0daf\u0dd9\u0dc0\u0db1 \u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 120,000\u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd3\u0db8\u0da7 CPC \u0db6\u0dbd\u0dcf\u0db4\u0ddc\u0dbb\u0ddc\u0dad\u0dca\u0dad\u0dd4 \u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca\u0dba.",
        "\u0db8\u0dd9\u0db8 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0daf\u0dd9\u0d9a\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4\u0dc0 \u0daf\u0dd2\u0db1 40\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0db4\u0dd6\u0dbb\u0dca\u0dab \u0db0\u0dcf\u0dbb\u0dd2\u0dad\u0dcf\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0daf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "CPC \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4\u0dc0 \u0d85\u0daf \u0dc3\u0dd2\u0da7 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5\u0dcf. \u0db6\u0ddc\u0dbb \u0dad\u0dd9\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 100,000 \u0d9a\u0dca \u0db8\u0dd4\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d85\u0dad\u0dbb \u0dbd\u0db6\u0db1 \u0dc3\u0dad\u0dd2\u0dba\u0dda 2 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0ddc\u0dbb\u0dad\u0dd9\u0dbd\u0dca \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 120,000 \u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db6\u0dbd\u0dcf\u0db4\u0ddc\u0dbb\u0ddc\u0dad\u0dca\u0dad\u0dd4 \u0dc0\u0dda. 2 Cargos \u0dc3\u0db8\u0d9f \u0db4\u0dd2\u0dbb\u0dd2\u0db4\u0dc4\u0daf\u0dd4\u0dc0 \u0daf\u0dd2\u0db1 40\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab \u0db0\u0dcf\u0dbb\u0dd2\u0dad\u0dcf\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. \u0da2\u0dd9\u0da7\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0daf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0db6\u0dcf\u0db1\u0dc0\u0dcf.\u2014 Kanchana Wijesekera (@kanchana_wij) 2022 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 20"
      ],
