          },
          {
            "text": "\u0dc3\u0dd2\u0da9\u0dca\u0db1\u0dd2",
            "label": "GPE"
          },
          {
            "text": "\u0db4\u0dd0\u0dbb\u0dd2\u0dc3\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0dc4\u0dad\u0dbb\u0dc0\u0db1",
