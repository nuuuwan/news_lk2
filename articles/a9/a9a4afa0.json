    "si": {
      "title": "\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0dad\u0dd0\u0db4\u0dd0\u0dbd\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0db8\u0dd4\u0dbd\u0dd2\u0db1\u0dca\u0db8 \u0d85\u0daf \u0db4\u0dd2\u0dc5\u0dd2\u0d9c\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
