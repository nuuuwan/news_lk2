    "si": {
      "title": "\u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc0\u0dc0\u0dd4\u0db1\u0dd2\u0dba\u0dcf\u0dc0, \u0dc3\u0dd9\u0d9a\u0dca\u0d9a\u0da7\u0dd2\u0db4\u0dd4\u0dbd\u0dc0\u0dd4 \u0db4\u0dcf\u0dc3\u0dbd\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0db6\u0db1 \u0dbb\u0dcf\u0dc3\u0dda\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db1\u0dca \u0d9a\u0dd8\u0db4\u0dcf\u0db1\u0dca (\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 15) \u0db1\u0db8\u0dd0\u0dad\u0dd2 \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 16 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0db4\u0dd6\u0dc0\u0dbb\u0dc3\u0d82\u0d9c\u0dd4\u0dbd\u0db8\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd3 \u0d87\u0dad.",
        "\u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca \u0dc0\u0dd6 \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf\u0d9c\u0dda \u0dc3\u0ddc\u0dc4\u0ddc\u0dba\u0dd4\u0dbb\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db4\u0dd9\u0dbb\u0dda\u0daf\u0dcf (16\u0daf\u0dcf) \u0d85\u0dbd\u0dd4\u0dba\u0db8 1\u0da7 \u0d91\u0db8 \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0db1\u0dd2\u0db1\u0dca\u0daf\u0dd9\u0db1\u0dca \u0db1\u0dd0\u0d9c\u0dd2\u0da7 \u0da2\u0dbd\u0dba \u0db4\u0dcf\u0db1\u0dba \u0d9a\u0dbb \u0d91\u0dad\u0dd9\u0d9a\u0dca \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0dc3\u0dd2\u0da7\u0dd2 \u0db6\u0dc0 \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0d9a\u0dc5 \u0db6\u0dc0\u0dad\u0dca 16 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0db4\u0dcf\u0db1\u0dca\u0daf\u0dbb 4 \u0da7 \u0d85\u0dc0\u0daf\u0dd2 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db6\u0dc0\u0dad\u0dca\u0dba. \u0dad\u0db8 \u0db4\u0dd4\u0dad\u0dcf \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0db8\u0dc0 \u0db4\u0dd6\u0dc0\u0dbb\u0d82\u0d9c\u0dd4\u0dbd\u0db8\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0d9a\u0dc5\u0dcf.",
        "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba 15 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dba\u0da7 \u0db1\u0ddc\u0dba\u0dd1\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf\u0da7 \u0dad\u0dbb\u0dc0\u0da7\u0dd4 \u0d9a\u0dbb \u0d87\u0dad. \u0d92 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d91\u0db8 \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca \u0dc0\u0db1\u0dca\u0db1\u0da7 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc3\u0dd0\u0d9a \u0d9a\u0dd9\u0dbb\u0dda. \u0d9a\u0dd9\u0dc3\u0dda\u0dc0\u0dd9\u0dad\u0dad\u0dca",
        "\u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf\u0d9c\u0dda \u0dc3\u0ddc\u0dc4\u0ddc\u0dba\u0dd4\u0dbb\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d9a\u0dc0\u0dd4\u0dbb\u0dd4\u0db1\u0dca \u0dc4\u0ddd \u0d94\u0dc4\u0dd4 \u0dc4\u0db3\u0dd4\u0db1\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dda \u0db1\u0db8\u0dca 0766922218, 0779987491 \u0dba\u0db1 \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0d85\u0d82\u0d9a\u0dc0\u0dbd\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd9\u0db1 \u0dbd\u0dd9\u0dc3\u0dba\u0dd2."
      ],
      "title_ents": [],
