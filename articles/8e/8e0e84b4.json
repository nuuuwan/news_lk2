    "si": {
      "title": "\u0dc3\u0dda\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db6\u0ddc\u0dad\u0dcf\u0dbd\u0dca \u0dc3\u0db8\u0d9c \u0da1\u0db1\u0dca\u0daf\u0dba \u0daf\u0dd4\u0db1\u0dca \u0db4\u0dcf.\u0db8",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dd9\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda \u0daf\u0dd3 \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0dc3\u0db8\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba \u0dc4\u0dda\u0dbb\u0dad\u0dca \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0dda\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db6\u0ddd\u0dad\u0dbd\u0dca \u0dc3\u0db8\u0d9f \u0dc3\u0db7\u0dcf\u0dc0 \u0dad\u0dd4\u0dc5\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dda\u0dba.",
        "\u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db1\u0db8 \u0dc0\u0d9c\u0dd4\u0dc0\u0dda \u0d85\u0d82\u0d9a 223 \u0dc0\u0dda. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0dc4\u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db7\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0db8\u0dc3\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0d85\u0dad\u0dd4\u0dbb\u0dd4 \u0dc3\u0db8\u0dca\u0db8\u0dad \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0da7 \u0da1\u0db1\u0dca\u0daf\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf \u0dad\u0dd2\u0db6\u0dda\u0daf \u0dba\u0db1\u0dca\u0db1\u0dba\u0dd2.",
        "\u0dc3\u0dda\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db6\u0ddd\u0dad\u0dbd\u0dba, \u0dc3\u0dc4\u0dcf\u0dba\u0d9a\u0dba\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dad\u0db6\u0dcf \u0d9c\u0dad \u0dba\u0dd4\u0dad\u0dd4\u0dba. \u0da1\u0db1\u0dca\u0daf\u0dd9 \u0daf\u0dd3\u0dbd\u0dcf \u0d9c\u0dd9\u0daf\u0dbb\u0dd2\u0db1\u0dca \u0d9c\u0dd2\u0dba\u0dcf."
      ],
