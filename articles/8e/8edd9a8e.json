  "text_idx": {
    "en": {
      "title": "Railways hikes regular fares",
      "author": "unknown",
      "body_lines": [
        "According to sources, the railway department has issued a gazette notice to raise the normal fares of the railways from midnight on the 23rd.",
        "Accordingly, it has been further learned that the normal railway fare has been increased by half of the bus fare."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
