    "si": {
      "title": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba 66.7% \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0db8\u0dd2\u0dbd \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba\u0dda (NCPI) \u0dc0\u0dc3\u0dbb\u0dd2\u0db1\u0dca \u0dc0\u0dc3\u0dbb (YoY) \u0dc0\u0dd9\u0db1\u0dc3 \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db8\u0db1\u0dd2\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba, 2022 \u0da2\u0dd6\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dc3\u0dd2\u0dba\u0dba\u0da7 58.9 \u0dc3\u0dd2\u0da7 2022 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 66.7 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd9\u0db8 YYY \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba\u0dda \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dc4 \u0d86\u0dc4\u0dcf\u0dbb \u0db1\u0ddc\u0dc0\u0db1 \u0d9a\u0dcf\u0dab\u0dca\u0da9 \u0daf\u0dd9\u0d9a\u0dd9\u0dc4\u0dd2\u0db8 \u0db8\u0dcf\u0dc3\u0dd2\u0d9a \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0dca \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dc0\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0dba.",
        "\u0d86\u0dc4\u0dcf\u0dbb \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 75.8 \u0dc3\u0dd2\u0da7 2022 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 82.5 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0dd2\u0dba \u0d85\u0dad\u0dbb \u0d86\u0dc4\u0dcf\u0dbb \u0db1\u0ddc\u0dc0\u0db1 \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba 2022 \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 43.6 \u0dc3\u0dd2\u0da7 \u0dc3\u0dd2\u0dba\u0dba\u0da7 52.4 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "NCPI \u0dc4\u0dd2 \u0db8\u0dcf\u0dc3\u0dd2\u0d9a \u0dc0\u0dd9\u0db1\u0dc3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 5.57 \u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0d85\u0dad\u0dbb, \u0d86\u0dc4\u0dcf\u0dbb \u0dc3\u0dc4 \u0d86\u0dc4\u0dcf\u0dbb \u0db1\u0ddc\u0dc0\u0db1 \u0d9a\u0dcf\u0dab\u0dca\u0da9 \u0daf\u0dd9\u0d9a\u0dd9\u0dc4\u0dd2\u0db8 \u0d85\u0dba\u0dd2\u0dad\u0db8\u0dc0\u0dbd \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc0\u0dd6 \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 2.42 \u0dc3\u0dc4 \u0dc3\u0dd2\u0dba\u0dba\u0da7 3.15 \u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0d86\u0dc4\u0dcf\u0dbb \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba \u0dad\u0dd4\u0dc5 \u0d9a\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7\u0dd2, \u0dc3\u0dc4\u0dbd\u0dca, \u0db1\u0dd0\u0dc0\u0dd4\u0db8\u0dca \u0db8\u0dcf\u0dc5\u0dd4, \u0db6\u0dd2\u0dc3\u0dca\u0d9a\u0da7\u0dca \u0dc3\u0dc4 \u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca \u0db8\u0dc3\u0dca \u0db8\u0dd2\u0dbd\u0dd9\u0dc4\u0dd2 \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8 \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc0\u0dd2\u0dba. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0db8\u0dcf\u0dc3\u0dba \u0dad\u0dd4\u0dc5 \u0d91\u0dc5\u0dc0\u0dc5\u0dd4, \u0db4\u0ddc\u0dbd\u0dca\u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0dc4 \u0db4\u0ddc\u0dbd\u0dca \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba.",
        "\u0d86\u0dc4\u0dcf\u0dbb \u0db1\u0ddc\u0dc0\u0db1 \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba \u0dad\u0dd4\u0dc5, \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 (\u0db6\u0dc3\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4, \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dc3\u0dc4 \u0da9\u0dd3\u0dc3\u0dbd\u0dca), \u0d9c\u0dd8\u0dc4 \u0db7\u0dcf\u0dab\u0dca\u0da9, \u0d9c\u0dd8\u0dc4 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0dc3\u0dc4 \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0d9c\u0dd8\u0dc4 \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 (\u0dc3\u0ddd\u0daf\u0db1 \u0dc3\u0db6\u0db1\u0dca) \u0dc3\u0dc4 \u0db1\u0dd2\u0dc0\u0dcf\u0dc3, \u0da2\u0dbd\u0dba, \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba, \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dc4 \u0d85\u0db1\u0dd9\u0d9a\u0dd4\u0dad\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1\u0dc0\u0dbd \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8 \u0db1\u0dd2\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc0\u0dd2\u0dba. \u0db1\u0da9\u0dad\u0dca\u0dad\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dca\u0dbb\u0dc0\u0dca\u0dba) \u0db8\u0dcf\u0dc3\u0dba \u0dad\u0dd4\u0dc5 \u0d8b\u0db4 \u0d9a\u0dcf\u0dab\u0dca\u0da9.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb, \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba 2022 \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 20.8 \u0dc3\u0dd2\u0da7 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 25.9 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a\u0dba\u0dda \u0dba\u0da7\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0dd2\u0db9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba 2022 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 49.3 \u0dc3\u0dd2\u0da7 \u0dc3\u0dd2\u0dba\u0dba\u0da7 57.3 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba 2022 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 16.8 \u0dc3\u0dd2\u0da7 \u0dc3\u0dd2\u0dba\u0dba\u0da7 21.3 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd2\u0dba."
      ],
