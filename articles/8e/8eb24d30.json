    "si": {
      "title": "\u0db4\u0dca\u200d\u0dbb\u0db7\u0dd6\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db1\u0dd0\u0dc0\u0dca \u0daf\u0dd9\u0d9a\u0d9a\u0da7 \u0db1\u0d9f\u0dd2\u0dad\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0da7 \u0d85\u0dba\u0dad\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dbb\u0dc5 \u0dc3\u0dc4 \u0d9c\u0da2\u0db6\u0dcf \u0db1\u0dde\u0d9a\u0dcf \u0daf\u0dd9\u0d9a\u0dd9\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db7\u0dd6 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0 \u0dba\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0dc3\u0db8\u0dcf\u0da2\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dc0\u0dbd \u0dc0\u0dd3\u0da9\u0dd2\u0dba\u0ddd\u0dc0\u0d9a\u0dca \u0dc3\u0d82\u0dc3\u0dbb\u0dab\u0dba \u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0db4\u0dca\u200d\u0dbb\u0db7\u0dd6\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0d9a\u0dc0\u0dd4\u0daf \u0dba\u0db1\u0dca\u0db1 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d89\u0dad\u0dcf \u0dc4\u0daf\u0dd2\u0dc3\u0dca\u0dc3\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0db6\u0da9\u0dd4 \u0db6\u0dcf\u0dc4\u0dd2\u0dbb\u0dcf\u0daf\u0dd2\u0dba \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0da7 \u0db1\u0d9c\u0dd2\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf \u0d91\u0dc4\u0dd2\u00a0 \u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0dc0\u0dda.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0dbb\u0dae \u0db4\u0dd9\u0dc5\u0d9a\u0dca \u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a \u0d9a\u0ddc\u0dc5\u0db9 \u0d85\u0db0\u0dd2\u0dc0\u0dda\u0d9c\u0dd3 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0daf \u0d9c\u0db8\u0db1\u0dca \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf \u0dc3\u0db8\u0dcf\u0da2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dc0\u0dbd \u0dc3\u0dd0\u0dbb\u0dd2 \u0dc3\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0dba\u0dd2."
      ],
