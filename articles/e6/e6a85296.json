    "si": {
      "title": "\u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0db1 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 600\u0d9a\u0dca - WHO",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda (WHO) \u0db1\u0dc0\u0dad\u0db8 \u0daf\u0dad\u0dca\u0dad\u0dc0\u0dbd\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca-19 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 600\u0d9a\u0dca \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dcf \u0d87\u0dad.",
        "\u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dc0\u0db1 \u0dc0\u0dd2\u0da7, \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda, \u0db8\u0dbb\u0dab 6,472,914 \u0d87\u0dad\u0dd4\u0dc5\u0dd4\u0dc0 \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca-19 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 600,555,262 \u0d9a\u0dca \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd6 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0dc4 \u0db8\u0dbb\u0dab \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 93.21\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc3\u0dc4 \u0db8\u0dbb\u0dab \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.03\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0d87\u0dad. \u0db8\u0dd9\u0dba \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0dc3\u0db8\u0dc3\u0dca\u0dad\u0dba\u0dd9\u0db1\u0dca 15%\u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dd2.",
        "\u0db8\u0dd3\u0dc5\u0d9f \u0d89\u0dc4\u0dc5\u0db8 \u0d91\u0d9a\u0dad\u0dd4\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0dc3\u0dc4 \u0db6\u0dca\u200d\u0dbb\u0dc3\u0dd3\u0dbd\u0dba\u0dda \u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 44 \u0dc3\u0dc4 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 34 \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0db8\u0dbb\u0dab 527,911 \u0dc3\u0dc4 683,851\u0d9a\u0dca\u0daf \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0d9a\u0dbd\u0dcf\u0db4\u0dd3\u0dba \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d9c\u0dad\u0dca \u0d9a\u0dbd, \u0dba\u0dd4\u0dbb\u0ddd\u0db4\u0dba \u0dc3\u0dc4 \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0 \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd6 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 248 \u0dc3\u0dc4 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 175\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dbb\u0dab 2,077,355 \u0dc3\u0dc4 2,817,530 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda. \u0db8\u0dd9\u0db8 \u0d9a\u0dbd\u0dcf\u0db4 \u0daf\u0dd9\u0d9a \u0d92\u0d9a\u0dcf\u0db6\u0daf\u0dca\u0db0\u0dc0 \u0dbd\u0ddc\u0dc0 \u0db8\u0dd4\u0dc5\u0dd4 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd6 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca 70%\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0dc3\u0dc4 \u0db8\u0dbb\u0dab\u0dc0\u0dbd\u0dd2\u0db1\u0dca 75%\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0dc0\u0dda.",
        "\u0dc3\u0dad\u0dd2\u0db4\u0dad\u0dcf \u0db1\u0dc0 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca-19 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0dc4 \u0db8\u0dbb\u0dab \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0d85\u0da9\u0dd4\u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dad\u0dd4\u0db1\u0daf, \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda \u0dbd\u0ddd\u0d9a\u0dba \"\u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda \u0db8\u0dda \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0db8\u0dbb\u0dab \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1\u0dba\u0d9a \u0d9b\u0dda\u0daf\u0db1\u0dd3\u0dba \u0dc3\u0db1\u0dca\u0db0\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0db4\u0dc3\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0db8\u0dd9\u0db8 \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad \u0d85\u0d9c\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0db8\u0dbb\u0dab \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0db8\u0dd3\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0db6\u0dc0 \u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0daf\u0dad\u0dca\u0dad \u0dc0\u0dd2\u0dc1\u0dca\u0dbd\u0dda\u0dc2\u0dab\u0dba \u0d9a\u0dbb\u0db1 \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0d86\u0dba\u0dad\u0db1 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dc0\u0dc3\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2."
      ],
