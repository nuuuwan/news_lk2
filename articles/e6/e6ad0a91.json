  "original_title": "\u0da1\u0db1\u0dca\u0daf\u0dd9\u0da7 \u0daf\u0dd9\u0db1\u0dca\u0db1\u0dd9\u0d9a\u0dca \u0db1\u0dd1",
  "text_idx": {
    "en": {
      "title": "There are no two people to vote",
      "author": "unknown",
      "body_lines": [
        "The General Secretary of the Parliament announced that two MPs did not vote for the election of the President.",
        "Mr. Selvarasa Kajendran and Mr. GG Ponnambalam representing the Tamil National People's Alliance did not vote for the presidential election."
      ],
      "title_ents": [
        {
          "text": "two",
          "label": "CARDINAL"
        }
      ],
      "body_line_ents_list": [
        [
          {
