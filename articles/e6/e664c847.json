    "si": {
      "title": "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0dad\u0dd0\u0dad\u0dd2 \u0d85\u0dba\u0da7 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0db8\u0dcf\u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dad\u0db8\u0dcf \u0dc3\u0db1\u0dca\u0dad\u0d9a\u0dba\u0dda \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dad\u0db6\u0dcf \u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc4\u0ddd \u0db1\u0dda\u0dc0\u0dcf\u0dc3\u0dd2\u0d9a \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0dc4\u0da7 \u0d91\u0db8 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba \u0dad\u0dd4\u0dc5\u0da7 \u0d86\u0d9a\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0db8\u0dcf \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0db8\u0dcf \u0d9a\u0dcf\u0dbd\u0dba 2022.08.15 \u0daf\u0dd2\u0db1 \u0dc3\u0dd2\u0da7 \u0db8\u0dc3\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a\u0dba. \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0daf\u0dcf\u0dc5 \u0db8\u0dd4\u0daf\u0dbd\u0dca,",
        "i. \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0d9a\u0da7 \u0dc4\u0ddd \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0d9a\u0da7 \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0ddd",
        "ii. \u0db6\u0dbd\u0dba\u0dbd\u0dad\u0dca \u0dc0\u0dd9\u0dc5\u0dd9\u0db1\u0dca\u0daf\u0dd9\u0d9a\u0dd4\u0da7 (\u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dbd\u0dcf\u0db7\u0dd3 \u0dc0\u0dcf\u0dab\u0dd2\u0da2 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0d9a\u0da7 \u0dc4\u0ddd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0da7) \u0dc0\u0dd2\u0d9a\u0dd2\u0dab\u0dd3\u0db8\u0da7"
      ],
      "title_ents": [],
