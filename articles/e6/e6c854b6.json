        [
          {
            "text": "\u0d9a\u0dcf\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0da7\u0dcf\u0dbb\u0dca \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2",
