            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0dde\u0daf\u0dca\u0db0\u0dcf\u0dbd\u0ddd\u0d9a \u0db8\u0dcf\u0dc0\u0dad",
            "label": "FAC"
          },
          {
