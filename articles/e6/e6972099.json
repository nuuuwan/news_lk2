    "si": {
      "title": "\u0db1\u0dc0 \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0db0\u0dbb\u0dca\u0db8\u0dcf\u0dba\u0dad\u0db1\u0dba\u0da7 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db1\u0dc0 \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 7, \u0db6\u0dde\u0daf\u0dca\u0db0\u0dcf\u0dbd\u0ddd\u0d9a \u0db8\u0dcf\u0dc0\u0dad\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db0\u0dbb\u0dca\u0db8\u0dcf\u0dba\u0dad\u0db1\u0dba\u0da7 \u0d85\u0daf (22) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d9c\u0ddc\u0dc3\u0dca \u0d86\u0d9c\u0db8\u0dd2\u0d9a \u0dc0\u0dad\u0dcf\u0dc0\u0dad\u0dca\u0dc0\u0dbd \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd2\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0db0\u0dbb\u0dca\u0db8\u0dcf\u0dba\u0dad\u0db1\u0dba",
