      "body_line_ents_list": [
        [
          {
            "text": "\u0bb5\u0b9a\u0ba8\u0bcd\u0ba4 \u0bae\u0bc1\u0ba4\u0bb2\u0bbf\u0b95\u0bc7",
            "label": "PERSON"
          },
          {
            "text": "\u0bb9\u0b9a\u0ba8\u0bcd\u0ba4 \u0b95\u0bc1\u0ba3\u0ba4\u0bbf\u0bb2\u0b95\u0bcd\u0b95",
            "label": "PERSON"
          },
          {
            "text": "\u0bb5\u0bc6\u0ba3\u0bcd \u0b95\u0bb2\u0bcd\u0bb5\u0bc7\u0bb5\u0bbe",
            "label": "PERSON"
          },
          {
            "text": "\u0b9a\u0bbf\u0bb1\u0bbf\u0ba4\u0bae\u0bcd\u0bae \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "90 \u0ba8\u0bbe\u0b9f\u0bcd\u0b95\u0bb3\u0bcd",
