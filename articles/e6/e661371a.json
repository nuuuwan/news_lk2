            "text": "\u0dad\u0dca\u200d\u0dbb\u0dc3\u0dca\u0dad \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0d85\u0d82\u0dc1\u0dba",
            "label": "ORG"
