  "original_title": "\u0b85\u0bb5\u0b9a\u0bb0\u0bae\u0bbe\u0b95 \u0bb5\u0bc6\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0bb2\u0bcd\u0bb5\u0bcb\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0bae\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0baa\u0bcd\u0baa\u0bc1",
  "text_idx": {
    "en": {
      "title": "Important notice for those traveling abroad urgently",
      "author": "unknown",
      "body_lines": [
        "The Department has announced that the time and date allocations for obtaining passports at the Immigration and Emigration Department Head Office have been completed for the next 60 days.",
        "WhatsApp number has been provided by the department to those who are going abroad for urgent business."
      ],
      "title_ents": [],
