          }
        ],
        [
          {
            "text": "92,000 \u0d9a\u0dca \u0db4\u0db8\u0dab \u0dc0\u0dda",
            "label": "CARDINAL"
          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 21\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc3\u0dad\u0dd2\u0dba",
            "label": "DATE"
