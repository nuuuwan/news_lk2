      "body_line_ents_list": [
        [
          {
            "text": "\u0dc5\u0db8\u0dcf \u0dbb\u0ddd\u0d9c \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0d87\u0d9a\u0da9\u0db8\u0dd2\u0dba (AAP",
            "label": "ORG"
          },
          {
            "text": "\u0dc5\u0db8\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 14 \u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0dba",
