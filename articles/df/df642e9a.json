    "si": {
      "title": "\u0da0\u0dd3\u0db1\u0dba\u0dda \u0d85\u0d9f\u0dc4\u0dbb\u0dd4 \u0d9c\u0dc0\u0dda\u0dc2\u0dab \u0dba\u0dcf\u0db1\u0dba \u0db1\u0dc0 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4 \u0d91\u0dc0\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0da0\u0dd3\u0db1\u0dba\u0dda \u0d85\u0d9f\u0dc4\u0dbb\u0dd4 \u0d9c\u0dc0\u0dda\u0dc2\u0dab \u0dba\u0dcf\u0db1\u0dba\u0dda \u0da7\u0dd2\u0dba\u0dcf\u0db1\u0dca\u0dc0\u0dd9\u0db1\u0dca-1 \u0d9a\u0d9a\u0dca\u0dc2\u0dd3\u0dba \u0dba\u0dcf\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8 \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dbb \u0dc0\u0dc3\u0dbb \u0daf\u0dd9\u0d9a\u0d9a \u0dc3\u0d82\u0dc0\u0dad\u0dca\u0dc3\u0dbb\u0dba \u0dc3\u0db1\u0dd2\u0da7\u0dd4\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dbb\u0dad\u0dd4 \u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dbd\u0ddd\u0d9a\u0dba\u0dda \u0dc6\u0ddd\u0db6\u0ddd\u0dc3\u0dca \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dba\u0dcf\u0d9c\u0dda \u0d85\u0db0\u0dd2-\u0dc0\u0dd2\u0db7\u0dda\u0daf\u0db1 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4 \u0d91\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0da0\u0dd3\u0db1\u0dba 2020 \u0da2\u0dd6\u0dbd\u0dd2 23 \u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dd2\u0db1 \u0da7\u0dd2\u0dba\u0dcf\u0db1\u0dca\u0dc0\u0dd9\u0db1\u0dca-1 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8 \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dc5 \u0d85\u0dad\u0dbb, \u0dbb\u0dad\u0dd4 \u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dbd\u0ddd\u0d9a\u0dba\u0dda \u0d9a\u0d9a\u0dca\u0dc2\u0dd3\u0dba \u0dba\u0dcf\u0db1\u0dba, \u0dbd\u0dd1\u0db1\u0dca\u0da9\u0dbb\u0dca \u0dba\u0dcf\u0db1\u0dba \u0dc3\u0dc4 \u0dbb\u0ddd\u0dc0\u0dbb\u0dba \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dba\u0dc0\u0db1 \u0dbd\u0daf\u0dd3. \u0d9a\u0d9a\u0dca\u0dc2\u0dd3\u0dba \u0dba\u0dcf\u0db1\u0dba 2021 \u0db4\u0dd9\u0db6\u0dbb\u0dc0\u0dcf\u0dbb\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0d9f\u0dc4\u0dbb\u0dd4 \u0d9a\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0dbd\u0dd1\u0db1\u0dca\u0da9\u0dbb\u0dba \u0dc3\u0dc4 \u0dbb\u0ddd\u0dc0\u0dbb\u0dba \u0d85\u0d9f\u0dc4\u0dbb\u0dd4 \u0db8\u0dad \u0dc3\u0dca\u0db4\u0dbb\u0dca\u0dc1 \u0d9a\u0dbb 2021 \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d85\u0d9f\u0dc4\u0dbb\u0dd4 \u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dba\u0dcf \u0dc3\u0dad\u0dd4\u0dc0 \u0d9a\u0dd4\u0da9\u0dcf \u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0d9a \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dba\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0dc6\u0ddd\u0db6\u0ddd\u0dc3\u0dca \u0dc3\u0dc4 \u0da9\u0dba\u0dd2\u0db8\u0ddd\u0dc3\u0dca \u0dbd\u0dd9\u0dc3 \u0d92\u0dc0\u0dcf \u0dc3\u0dd0\u0dbd\u0d9a\u0dd9\u0dba\u0dd2. \u0dc6\u0ddd\u0db6\u0ddd\u0dc3\u0dca \u0dba\u0db1\u0dd4 \u0d92 \u0daf\u0dd9\u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dba\u0dcf\u0dba.",
        "\u0d91\u0dba \u0d85\u0d9f\u0dc4\u0dbb\u0dd4 \u0db8\u0dad\u0dd4\u0db4\u0dd2\u0da7 \u0dc3\u0dd2\u0da7 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb\u0dca 6,000\u0d9a\u0dca \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0d9a\u0dc0\u0dcf\u0d9a\u0dcf\u0dbb \u0db4\u0dae\u0dba\u0d9a \u0db4\u0dbb\u0dd2\u0db7\u0dca\u200d\u0dbb\u0db8\u0dab\u0dba \u0dc0\u0db1 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb 11\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba \u0d85\u0dbb\u0dba\u0d9a\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0d85\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc0\u0dad\u0dca \u0dc4\u0dd0\u0da9\u0dd0\u0dad\u0dd2 \u0d9a\u0dd4\u0da9\u0dcf \u0dc0\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0d9a\u0dd2. \u0d91\u0dba \u0db4\u0dd0\u0dba 7\u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 39\u0d9a\u0dd2\u0db1\u0dca \u0d9a\u0d9a\u0dca\u0dc2\u0dba\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab \u0d9a\u0dbb\u0dba\u0dd2."
      ],
