    "ta": {
      "title": "\u0baa\u0bc1\u0ba4\u0bcd\u0ba4\u0bb0\u0bbf\u0ba9\u0bcd \u0b86\u0b9a\u0bbf\u0b95\u0bb3\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0ba8\u0bbe\u0b9f\u0bb3\u0bbe\u0bb5\u0bbf\u0baf \u0bb0\u0bc0\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0bcc\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bbe\u0bb2\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbe\u0b9f\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0b9a\u0bb2 \u0baa\u0bcc\u0bb0\u0bcd\u0ba3\u0bae\u0bbf \u0ba4\u0bbf\u0ba9\u0bae\u0bbe\u0ba9 \u0b87\u0ba9\u0bcd\u0bb1\u0bc1. \u0baa\u0bc1\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd \u0ba4\u0ba9\u0ba4\u0bc1 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0ba4\u0bae\u0bcd\u0bae \u0baa\u0bbf\u0bb0\u0b9a\u0b99\u0bcd\u0b95\u0bae\u0bbe\u0ba9 '\u0ba4\u0bae\u0bcd\u0bae \u0b9a\u0b95\u0bcd\u0b95 \u0baa\u0bb5\u0b9f\u0bcd\u0b9f\u0bbe\u0ba9 \u0b9a\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe'\u0bb5\u0bc8 \u0baa\u0bbf\u0bb0\u0b9a\u0b99\u0bcd\u0b95\u0bbf\u0ba4\u0bcd\u0ba4 \u0ba8\u0bbe\u0bb3\u0bbe\u0ba9 \u0b8e\u0b9a\u0bb2 \u0baa\u0bcb\u0baf\u0bbe \u0baa\u0bcc\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0bcd \u0bb5\u0bbe\u0baf\u0bcd\u0ba8\u0bcd\u0ba4\u0ba4\u0bc1. \u0b95\u0b99\u0bcd\u0b95\u0bbe\u0bb0\u0bbe\u0bae \u0b95\u0bcb\u0bb5\u0bbf\u0bb2\u0bbf\u0bb2\u0bcd \u0baa\u0b95\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0bae\u0baf \u0bb5\u0bb4\u0bbf\u0baa\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bc1\u0bb5\u0ba4\u0bc8 \u0baa\u0b9f\u0bae\u0bcd \u0b95\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1. \u0baa\u0bbf\u0b95\u0bcd\u0bb8\u0bcd - \u0b95\u0bbf\u0ba4\u0bcd\u0b9a\u0bbf\u0bb1\u0bbf \u0b9f\u0bbf \u0bae\u0bc6\u0bb2\u0bcd"
      ],
