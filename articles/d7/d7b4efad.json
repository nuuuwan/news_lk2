    "si": {
      "title": "\u0db6\u0dd4\u0daf\u0dd4 \u0dc3\u0dbb\u0dab\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0daf\u0dd3\u0db4\u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dca\u0dad \u0db6\u0dde\u0daf\u0dca\u0db0 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0dbb\u0db1 \u0d87\u0dc3\u0dc5 \u0db4\u0dd4\u0dbb \u0db4\u0dc3\u0dc5\u0ddc\u0dc3\u0dca\u0dc0\u0d9a \u0db4\u0ddc\u0dc4\u0ddc\u0dba \u0daf\u0dd2\u0db1\u0dba \u0d85\u0daf\u0dba\u0dd2. \u0db6\u0dd4\u0daf\u0dca\u0db0 \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0db0\u0dbb\u0dca\u0db8 \u0daf\u0dda\u0dc1\u0db1\u0dcf\u0dc0 \u0dc0\u0db1 \u2018\u0db0\u0db8\u0dca\u0db8 \u0da0\u0d9a\u0dca\u0d9a \u0db4\u0dc0\u0dad\u0dca\u0dad\u0db1 \u0dc3\u0dd6\u0dad\u0dca\u200d\u0dbb\u0dba\u2019 \u0daf\u0dda\u0dc1\u0db1\u0dcf \u0d9a\u0dc5 \u0daf\u0dd2\u0db1\u0dba \u0dbd\u0dd9\u0dc3 \u0d87\u0dc3\u0dc5 \u0db4\u0ddc\u0dc4\u0ddc\u0dba \u0db6\u0dde\u0daf\u0dca\u0db0\u0dba\u0db1\u0dca\u0da7 \u0dc0\u0dd0\u0daf\u0d9c\u0dad\u0dca \u0dc0\u0dda. \u0d9c\u0d82\u0d9c\u0dcf\u0dbb\u0dcf\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca \u0d86\u0d9c\u0db8\u0dd2\u0d9a \u0dc0\u0dad\u0dcf\u0dc0\u0dad\u0dca\u0dc0\u0dbd \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0da1\u0dcf\u0dba\u0dcf\u0dbb\u0dd6\u0db4\u0dba\u0dda \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dda. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dd2\u0dad\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0daf \u0db8\u0dd9\u0dbd\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dd2"
      ],
