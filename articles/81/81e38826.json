    "si": {
      "title": "\u0db8\u0dba\u0dd4\u0dbb\u0db4\u0dad\u0dd2 \u0d9a\u0ddd\u0dc0\u0dd2\u0dbd\u0dda \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db1\u0db8\u0dc3\u0dca\u0d9a\u0dcf\u0dbb\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf (01) \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dc0\u0dad \u0db8\u0dba\u0dd4\u0dbb\u0db4\u0dad\u0dd2 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db4\u0dd4\u0da2\u0dcf \u0dc3\u0dad\u0dca\u0d9a\u0dcf\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0db1 \u0db8\u0db1\u0ddd \u0d9c\u0db1\u0dda\u0dc2\u0db1\u0dca, \u0db4\u0dcf\u0da8\u0dbd\u0dd3 \u0dc3\u0db8\u0dca\u0db6\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dca \u0dc0\u0dd9\u0dbd\u0dca\u0d9a\u0db8 \u0d91\u0d9a\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dcf."
      ],
