        ],
        [
          {
            "text": "\u0d9a\u0dd4\u0da9\u0dcf\u0dc0\u0dd0\u0dbd\u0dca\u0dbd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc3\u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb \u0d9c\u0dbd\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dd3\u0d9a\u0dbb\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd9\u0dbb\u0dc5\u0dcf\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0db6\u0dbd\u0d9a\u0dcf\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dda\u0d9c \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0d9a \u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0",
            "label": "ORG"
