          {
            "text": "\u0da2\u0dd9\u0dba\u0dbb\u0dcf\u0da2\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4\u0db4\u0dd4\u0dbd\u0dca\u0dbd\u0dda",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0da2\u0dd9\u0dba\u0dbb\u0dcf\u0da2\u0dca \u0d9d\u0dcf\u0dad\u0db1 \u0db1\u0da9\u0dd4\u0dc0",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0dc3\u0dca\u0db4\u0dd3 \u0dc3\u0dc4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca.\u0da7\u0dd3.\u0da7\u0dd3.\u0d8a",
            "label": "ORG"
