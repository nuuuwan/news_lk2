          },
          {
            "text": "\u0dc3\u0dc4\u0db1\u0dca \u0db8\u0dcf\u0db4\u0dcf \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0dca\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf",
