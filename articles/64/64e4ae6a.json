          },
          {
            "text": "\u0d85\u0dbd\u0dd4\u0dad\u0dca \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dca\u0daf\u0d9a\u0dca",
            "label": "DATE"
          },
          {
            "text": "\u0dc0\u0dd0\u0dbd\u0dd2\u0dc0\u0dda\u0dbb\u0dd2\u0dba",
