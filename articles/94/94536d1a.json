          }
        ],
        [
          {
            "text": "43 \u0dc0\u0db1 \u0dc3\u0dda\u0db1\u0dcf\u0d82\u0d9a\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db4\u0dcf\u0da8\u0dbd\u0dd3 \u0da0\u0db8\u0dca\u0db4\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a",
