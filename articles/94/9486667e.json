  "original_title": "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5\u0da7",
  "text_idx": {
    "en": {
      "title": "Rail fares up",
      "author": "unknown",
      "body_lines": [
        "It is reported that it has been decided to increase the train fares from next Monday (11th).",
        "Accordingly, it is also reported that the minimum fare will be increased to 20 rupees and other fares will be increased by half of the bus fare."
      ],
      "title_ents": [],
