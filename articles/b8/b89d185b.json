          }
        ],
        [],
        [
          {
            "text": "\u0dc3\u0dd4\u0dbb\u0d82\u0d9c \u0dc4\u0dda\u0dc0\u0dcf\u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dd4\u0db1\u0dbb\u0dd4\u0dad\u0dca\u0dae\u0dcf\u0db4\u0db1 \u0dbb\u0ddd\u0dc4\u0dbd",
