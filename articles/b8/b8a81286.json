    "si": {
      "title": "\u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d89\u0d9a\u0ddc\u0db1\u0dca. \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0db4\u0dcf\u0dc5\u0dd4\u0dc0\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0d85\u0daf \u0db4\u0dcf\u0dc5\u0dd4\u0dc0\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0dd9\u0db1\u0dda. \u0d9c\u0db1\u0dd4\u0daf\u0dd9\u0db1\u0dd4\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dc4 \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0dc0\u0dd9\u0dc5\u0dd9\u0db1\u0dca\u0daf\u0db1\u0dca\u0da7 \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0d85\u0db4\u0dc4\u0dc3\u0dd4 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca, \u0daf\u0dd4\u0dbb\u0dca\u0dc0\u0dbd \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb \u0db4\u0dd2\u0dbb\u0dd2\u0dc0\u0dd0\u0da7\u0dd4\u0db8 \u0d9c\u0dd0\u0db1 \u0dc0\u0dd9\u0dc5\u0dd9\u0db1\u0dca\u0daf\u0ddd \u0dc0\u0dd2\u0dbd\u0dcf\u0db4 \u0daf\u0dd9\u0dad\u0dd2. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db4\u0dca\u200d\u0dbb\u0daf\u0dd3\u0db4\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dab"
      ],
