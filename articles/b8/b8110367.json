    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0db8\u0db0\u0dca\u200d\u0dba \u0daf\u0dd2\u0db1 \u0dc0\u0dd9\u0dc5\u0db3\u0dcf\u0db8\u0dda \u0daf\u0dd3 \u0dc3\u0dd2\u0dba\u0dba\u0da7 2\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dda",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT - \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0dc0\u0db1 LOLC, Hayleys \u0dc3\u0dc4 Expolanka \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dbd\u0dcf\u0db7 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0db8\u0dad \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0daf\u0dd9\u0dc0\u0db1 \u0dc3\u0dd0\u0dc3\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db6\u0daf\u0dcf\u0daf\u0dcf (17) \u0dc3\u0dd2\u0dba\u0dba\u0da7 2 \u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd4\u0dab\u0dd2.",
        "\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba \u0d92\u0d9a\u0d9a 203.45 \u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0ddd \u0dc3\u0dd2\u0dba\u0dba\u0da7 2.24 \u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0db4\u0dd0\u0dba 1145 \u0daf\u0dd3 \u0d92\u0d9a\u0d9a 8,882.79 \u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0dc0\u0da9\u0dcf\u0dad\u0dca\u0db8 \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dc1\u0dd3\u0dbd \u0daf\u0dbb\u0dca\u0dc1\u0d9a\u0dba \u0dc3\u0dd2\u0dba\u0dba\u0da7 3.26 \u0d9a\u0dd2\u0db1\u0dca \u0dc4\u0ddd \u0d92\u0d9a\u0d9a 99.15 \u0d9a\u0dd2\u0db1\u0dca 2,938.44 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad."
      ],
