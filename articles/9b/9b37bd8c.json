    "si": {
      "title": "\u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dba\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0daf\u0dc0\u0dc3\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0db0\u0dca\u200d\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dcf\u0db1\u0dca\u0dad\u0dba \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dca\u0dc0\u0dbd \u0db6\u0dbb \u0d85\u0dc0\u0db8 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dad\u0dd2\u0dba\u0d9a\u0da7 \u0d91\u0d9a\u0dca \u0daf\u0dd2\u0db1\u0d9a\u0dca \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dca \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0daf\u0dd2\u0db1\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda. \u0db8\u0dda \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0ddd\u0db4\u0daf\u0dda\u0dc1 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dbb\u0da2\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0db8\u0db0\u0dca\u200d\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dca \u0dbb\u0da2\u0dba \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db4\u0dad\u0dca\u0dad\u0dd2\u0dba \u0db8\u0dad \u0db4\u0daf\u0db1\u0db8\u0dca\u0dc0 \u0db8\u0dd9\u0db8 \u0dba\u0ddd\u0da2\u0db1\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0d85\u0db1\u0dd4\u0d9c\u0db8\u0db1\u0dba \u0d9a\u0dbb \u0d87\u0dad. \u0db8\u0dd9\u0dba \u0db4\u0dca\u200d\u0dbb\u0dcf\u0db1\u0dca\u0dad\u0dba\u0dda \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dc4 \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0daf\u0dcf\u0dc5 \u0dc0\u0db1 \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dc3\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 1 \u0dc3\u0dc4 2 \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dba \u0db6\u0dbb\u0dd2\u0db1\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 1.6\u0dad\u0dca 2.2\u0dad\u0dca \u0d85\u0dad\u0dbb \u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4\u0dba. 3 \u0dc3\u0dd2\u0da7 5 \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dba\u0d9a \u0dc3\u0dca\u0d9a\u0db1\u0dca\u0db0\u0dba 1.7 \u0dc3\u0dd2\u0da7 2.5 kg \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. 6 \u0dc3\u0dc4 7 \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dc0\u0dbd \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dba\u0d9a\u0dca \u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u0dbb\u0dd1\u0db8\u0dca 2 \u0dc3\u0dd2\u0da7 3 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db6\u0dbb \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a. \u0d85\u0da7\u0dc0\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba\u0dda \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dba\u0d9a\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 2.5 \u0dad\u0dca 4.5 \u0dad\u0dca \u0d85\u0dad\u0dbb \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. 9 \u0dc0\u0db1 \u0dc3\u0dc4 10 \u0dc0\u0db1 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db6\u0dd1\u0d9c\u0dba 2.5 kg \u0dc3\u0dd2\u0da7 4.5 kg \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a.",
        "\u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dda 11 \u0dc3\u0dc4 12 \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dc0\u0dbd \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db4\u0ddc\u0dad\u0dca \u0db6\u0dd1\u0d9c\u0dba\u0dda \u0db6\u0dbb \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dad\u0ddd\u0dbb\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dc0\u0dd2\u0dc2\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0daf\u0dcf\u0dc5 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb\u0dd3\u0dad\u0dca\u0dc0\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dda.",
        "\u0db8\u0dd3\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0, 8 \u0dc0\u0db1 \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0db4\u0db1\u0dca\u0dad\u0dd2 \u0d9a\u0dcf\u0db8\u0dbb\u0dba\u0dda \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db4\u0ddc\u0dad\u0dca \u0dc3\u0dc4 \u0d85\u0dad\u0dca \u0d85\u0d9a\u0dd4\u0dbb\u0dd4 \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db4\u0ddc\u0dad\u0dca \u0dad\u0db6\u0dcf \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. 8 \u0dc0\u0dd0\u0db1\u0dd2 \u0db4\u0db1\u0dca\u0dad\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0db4\u0dbb\u0dd2\u0d9c\u0dab\u0d9a \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dc0, \u0dc3\u0daf\u0dcf\u0da0\u0dcf\u0dbb\u0dba, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dc0, \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba, \u0dc1\u0dcf\u0dbb\u0dd3\u0dbb\u0dd2\u0d9a \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1\u0dba, \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dc3\u0dc4 \u0d9a\u0dbd\u0dcf \u0dc0\u0dd2\u0dc2\u0dba\u0dba\u0db1\u0dca\u0dc0\u0dbd\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0db4\u0dd9\u0dc5\u0db4\u0ddc\u0dad\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd9\u0dad \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d92\u0db8 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0daf \u0d91\u0db8 \u0da0\u0d9a\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9b\u0dba\u0dda \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0dda."
      ],
