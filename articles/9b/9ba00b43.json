          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 4",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db8\u0db0\u0dca\u200d\u0dba \u0db7\u0dcf\u0dbb\u0dad\u0dd3\u0dba \u0da2\u0db1\u0dad\u0dcf \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0dd3.\u0da2\u0dda.\u0db4\u0dd3",
