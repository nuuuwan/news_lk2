          }
        ],
        [
          {
            "text": "\u0db8\u0daf\u0dd4\u0dbb\u0dcf\u0dc3\u0dd2 \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba",
