          {
            "text": "\u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db1\u0dcf\u0da9\u0dd4\u0dc0",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0db8\u0dcf\u0dbb\u0dca\u0dad\u0dd4 \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0dc3\u0dad\u0dd2\u0dba\u0dda",
            "label": "DATE"
          },
          {
            "text": "\u0db8\u0dd4\u0db1\u0dd2\u0dc2\u0dca\u0dc0\u0dbb\u0dca\u0db1\u0dcf\u0dad\u0dca \u0db7\u0dab\u0dca\u0da9\u0dcf\u0dbb\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db7\u0dcf\u0dbb\u0dad \u0da0\u0d9a\u0dca\u200d\u0dbb\u0db6\u0ddd\u0dbb\u0dca\u0dad\u0dd2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dad\u0db8\u0dd2\u0dbd\u0dca\u0db1\u0dcf\u0da9\u0dd4\u0dc0",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
