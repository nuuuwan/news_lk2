    "si": {
      "title": "\u0d85\u0dbb\u0dca\u0da2\u0dd4\u0db1 \u0d87\u0dbd\u0ddd\u0dc3\u0dd2\u0dba\u0dc3\u0dca\u0da7 \u0dc3\u0dd2\u0dad\u0dcf\u0dc3\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca. \u0d91\u0db8\u0dca. \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca \u0dc3\u0dc4 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0d9a\u0ddd\u0da7\u0dd2 167 \u0d9a \u0db6\u0daf\u0dd4 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d85\u0daf (02) \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0dda \u0db4\u0dd9\u0db1\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dbd\u0dd9\u0dc3\u0da7 \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d9a\u0ddc\u0dc5\u0db9 \u0d85\u0dad\u0dd2\u0dbb\u0dda\u0d9a \u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0da7\u0dd3. \u0d91\u0db1\u0dca. \u0d91\u0dbd\u0dca. \u0d89\u0dbd\u0d82\u0d9c\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf\u00a0 \u0d85\u0dbb\u0dca\u0da2\u0dd4\u0db1 \u0d87\u0dbd\u0ddd\u0dc3\u0dd2\u0dba\u0dc3\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0dc3\u0dd2\u0dad\u0dcf\u0dc3\u0dd2 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0dc3\u0dd2\u0dad\u0dcf\u0dc3\u0dd2 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db4\u0dca\u200d\u0dbb\u0dd2\u0db1\u0dca\u0dc3\u0dca \u0da7\u0dc0\u0dbb\u0dca, \u0d87\u0dbd\u0dca\u0dc6\u0da9\u0dca \u0dc4\u0dc0\u0dd4\u0dc3\u0dca, \u0d9a\u0ddc\u0dc5\u0db9 03 \u0dbd\u0dd2\u0db4\u0dd2\u0db1\u0dd0\u0dad\u0dd2 \u0d92. \u0da2\u0dda. \u0d87\u0dbd\u0ddd\u0dc3\u0dd2\u0dba\u0dc3\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0da7\u0dba.",
        "\u0db1\u0ddc.309/5, \u0db8\u0dd3\u0d9c\u0db8\u0dd4 \u0db4\u0dcf\u0dbb, \u0dc0\u0dd0\u0dbd\u0dd2\u0dc3\u0dbb \u0dbd\u0dd2\u0db4\u0dd2\u0db1\u0dd0\u0dad\u0dd2 \u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca. \u0d91\u0db8\u0dca. \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca \u0dc3\u0dc4 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1,678,795,049/= \u0d9a \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0db6\u0daf\u0dd4 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dcf \u0db4\u0dd0\u0dc4\u0dd0\u0dbb \u0dc4\u0dd0\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0db1\u0da9\u0dd4\u0dc0 \u0d9c\u0ddc\u0db1\u0dd4\u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6 \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dda \u0d89\u0d9a\u0dd4\u0dad\u0dca 2021 \u0dc0\u0dc3\u0dbb\u0dda\u0daf\u0dd3\u0dba."
      ],
      "title_ents": [],
