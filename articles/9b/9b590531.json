            "label": "CARDINAL"
          },
          {
            "text": "\u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba",
            "label": "GPE"
          },
          {
