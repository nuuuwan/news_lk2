          {
            "text": "30 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0dad\u0db1\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0db8\u0dd4\u0da7\u0dd2\u0dba\u0db1\u0dca\u0dc3\u0dcf\u0dbd\u0dcf\u0dc0\u0dda",
