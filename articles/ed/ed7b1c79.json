      "body_line_ents_list": [
        [
          {
            "text": "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0ba8\u0bbe\u0bb3\u0bc8",
            "label": "DATE"
          },
          {
            "text": "\u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0bae\u0bbe\u0bb5\u0b9f\u0bcd\u0b9f \u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0bb0\u0ba3\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb0\u0bae\u0b9a\u0bbf\u0b99\u0bcd\u0b95",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0baa\u0ba4\u0bc1\u0bb3\u0bc8 \u0bae\u0bbe\u0bb5\u0b9f\u0bcd\u0b9f\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0b85\u0bb0\u0bb5\u0bbf\u0ba8\u0bcd\u0ba4\u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bbf\u0ba9\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0bb0\u0ba3\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0bb0\u0bae\u0b9a\u0bbf\u0b99\u0bcd\u0b95",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b85\u0bb0\u0bb5\u0bbf\u0ba8\u0bcd\u0ba4\u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bcd \u0b8e\u0bae\u0bcd.\u0baa\u0bbf",
