    "si": {
      "title": "\u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dad\u0dc0 \u0d85\u0da9\u0dd4 \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0dbd\u0db6\u0db1 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dbd\u0dcf\u0dc6\u0dca\u0dc3\u0dca \u0dc3\u0db8\u0dd6\u0dc4 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca .\u0d9a\u0dda \u0d91\u0da0\u0dca \u0dc0\u0dd1\u0d9c\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1050 \u0d9a\u0dd2\u0db1\u0dca \u0d85\u0da9\u0dd4 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb ,\u0d8a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dd2\u0db1\u0dca \u0dbd\u0db6\u0db1 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0daf \u0d85\u0da9\u0dd4 \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d94\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba .",
        "\u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 12.5 \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0daf\u0dd0\u0db1\u0da7 \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 5,800\u0d9a\u0dca \u0dc0\u0db1 \u0d85\u0dad\u0dbb ,\u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 5 \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 2,320 \u0d9a\u0dca \u0dc0\u0dda.\u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 2.5 \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 928 \u0d9a\u0dd2."
      ],
