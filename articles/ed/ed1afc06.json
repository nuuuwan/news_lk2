            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0db1\u0dcf\u0dc3\u0dd2\u0dad\u0db8\u0dca\u0db6\u0dd2 \u0db1\u0dcf\u0d9c\u0dda\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0db8\u0dca",
