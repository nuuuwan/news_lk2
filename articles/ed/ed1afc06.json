          {
            "text": "\u0d9a\u0db1\u0dca\u0daf\u0dc3\u0dcf\u0db8\u0dd2 \u0db6\u0dcf\u0dbd\u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dc2\u0dca\u0dab\u0db1\u0dca",
