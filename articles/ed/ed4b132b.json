      "body_line_ents_list": [
        [
          {
            "text": "\u0b86\u0baf\u0bbf\u0bb0\u0b95\u0bcd\u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd",
            "label": "CARDINAL"
