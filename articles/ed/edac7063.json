    "si": {
      "title": "\u0d85\u0dbd\u0dd2 \u0dc3\u0db6\u0dca\u200d\u0dbb\u0dd2 \u0dc0\u0dd0\u0da9 \u0d85\u0dbb\u0db9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d85\u0dbd\u0dd2 \u0dc3\u0db6\u0dca\u200d\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0dc3\u0dd2\u0dba \u0db0\u0dd4\u0dbb\u0dba\u0dda \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd3 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d85\u0daf (25\u0daf\u0dcf) \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd2\u0dba. \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba\u0dda\u0daf\u0dd2 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0da2\u0dd3.\u0d92\u0dbd\u0dca. \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0d91\u0db8 \u0db0\u0dd4\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0d85\u0dbd\u0dd2 \u0dc3\u0db6\u0dca\u0dbb\u0dd2",
