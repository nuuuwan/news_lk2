          },
          {
            "text": "\u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dda.\u0d86\u0dbb\u0dca.",
            "label": "PERSON"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
