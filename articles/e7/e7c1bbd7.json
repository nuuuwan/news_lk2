    "si": {
      "title": "\u0dba\u0dcf\u0db4\u0db1\u0dba. \u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0da7 \u0d92\u0db8\u0db1\u0d9a \u0dbb\u0db9\u0dd4\u0da7\u0db1\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0db1\u0dca\u0d9c\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0dbb\u0dda \u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0db1\u0dca\u0d9a\u0dbd\u0da7\u0dca\u0da7\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0db0\u0dbb\u0dca\u0db8\u0dbb\u0dcf\u0dc3\u0dcf \u0daf\u0dbb\u0dca\u0dc1\u0dd2\u0d9a\u0db1\u0dca \u0db1\u0db8\u0dd0\u0dad\u0dd2 10 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0dc5\u0db8\u0dba\u0dd9\u0d9a\u0dd4 \u0dbb\u0db9\u0dd4\u0da7\u0db1\u0dca \u0d87\u0da7\u0dba\u0d9a\u0dca \u0d9c\u0dd2\u0dbd\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d9b\u0dda\u0daf\u0da2\u0db1\u0d9a \u0dbd\u0dd9\u0dc3 \u0db8\u0dd2\u0dba \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0dbb\u0db9\u0dd4\u0da7\u0db1\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba \u0d9c\u0dd2\u0dbd \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0dc4\u0dd4\u0dc3\u0dca\u0db8 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d85\u0db4\u0dc4\u0dc3\u0dd4\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0dc5\u0db8\u0dba\u0dcf \u0dad\u0dd9\u0dbd\u0dca\u0dbd\u0dd2\u0db4\u0db4\u0dca\u0db4\u0dcf \u0d86\u0daf\u0dcf\u0dbb\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad."
      ],
      "title_ents": [
        {
          "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba",
          "label": "PERSON"
        },
        {
          "text": "\u0d91\u0db8\u0db1\u0d9a \u0dbb\u0db9\u0dd4\u0da7\u0db1\u0dca",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "10 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0db0\u0dbb\u0dca\u0db8\u0dbb\u0dcf\u0dc3\u0dcf \u0daf\u0dbb\u0dca\u0dc1\u0dd2\u0d9a\u0db1\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0db1\u0dca\u0d9a\u0dbd\u0da7\u0dca\u0da7\u0dd2",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0db1\u0dca\u0d9c\u0dc3\u0db1\u0dca\u0dad\u0dd4\u0dbb\u0dda",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0dad\u0dd9\u0dbd\u0dca\u0dbd\u0dd2\u0db4\u0db4\u0dca\u0db4\u0dcf \u0d86\u0daf\u0dcf\u0dbb\u0dca \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "WORK_OF_ART"
