    "ta": {
      "title": "\u0baf\u0bbe\u0bb4\u0bcd. \u0b9a\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0bae\u0ba9\u0bbe\u0b95\u0bbf\u0baf \u0bb0\u0bae\u0bcd\u0baa\u0bc1\u0b9f\u0bcd\u0b9f\u0bbe\u0ba9\u0bcd",
      "author": "unknown",
      "body_lines": [
        "\u0b95\u0bbe\u0b99\u0bcd\u0b95\u0bc7\u0b9a\u0ba9\u0bcd\u0ba4\u0bc1\u0bb1\u0bc8 - \u0b95\u0bca\u0bb2\u0bcd\u0bb2\u0ba9\u0bcd\u0b95\u0bb2\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bb0\u0bae\u0bcd\u0baa\u0bc1\u0b9f\u0bcd\u0b9f\u0bbe\u0ba9\u0bcd \u0bb5\u0bbf\u0ba4\u0bc8\u0baf\u0bc8 \u0bb5\u0bbf\u0bb4\u0bc1\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba4\u0bb0\u0bcd\u0bae\u0bb0\u0bbe\u0b9a\u0bbe \u0ba4\u0bb0\u0bcd\u0b9a\u0bbf\u0b95\u0ba9\u0bcd (10 \u0bb5\u0baf\u0ba4\u0bc1) \u0b9a\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bcd \u0baa\u0bb0\u0bbf\u0ba4\u0bbe\u0baa\u0bae\u0bbe\u0b95 \u0b89\u0baf\u0bbf\u0bb0\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd .",
        "\u0b95\u0bc1\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4 \u0b9a\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bcd \u0bb0\u0bae\u0bcd\u0baa\u0bc1\u0b9f\u0bcd\u0b9f\u0bbe\u0ba9\u0bcd \u0baa\u0bb4\u0ba4\u0bcd\u0ba4\u0bc8 \u0bb5\u0bbf\u0bb4\u0bc1\u0b99\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd, \u0bae\u0bc2\u0b9a\u0bcd\u0b9a\u0bc1 \u0b8e\u0b9f\u0bc1\u0b95\u0bcd\u0b95 \u0b85\u0bb5\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0baa\u0bcb\u0ba4\u0bc1 , \u0ba4\u0bc6\u0bb2\u0bcd\u0bb2\u0bbf\u0baa\u0bcd\u0baa\u0bb4\u0bc8 \u0b86\u0ba4\u0bbe\u0bb0 \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0ba9\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bb4\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1\u0b9a\u0bcd \u0b9a\u0bc6\u0bb2\u0bcd\u0bb2\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd ."
      ],
      "title_ents": [
        {
          "text": "\u0baf\u0bbe\u0bb4\u0bcd",
          "label": "PERSON"
        },
        {
          "text": "\u0b8e\u0bae\u0ba9\u0b95\u0bcd\u0b95 \u0bb0\u0bae\u0bcd\u0baa\u0bc1\u0b9f\u0bcd\u0b9f\u0bbe\u0ba9\u0bcd",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "10 \u0bb5\u0baf\u0ba4\u0bc1",
            "label": "DATE"
          },
          {
            "text": "\u0ba4\u0bb0\u0bcd\u0bae\u0bb0\u0bbe\u0b9a\u0bbe \u0ba4\u0bb0\u0bcd\u0bb7\u0bbf\u0b95\u0ba9\u0bcd",
            "label": "GPE"
          },
          {
            "text": "\u0b95\u0bca\u0bb2\u0bcd\u0bb2\u0b99\u0bcd\u0b95\u0bb2\u0b9f\u0bcd\u0b9f\u0bbf",
            "label": "GPE"
          },
          {
            "text": "\u0b95\u0bbe\u0b99\u0bcd\u0b95\u0bc7\u0b9a\u0ba9\u0bcd\u0ba4\u0bc1\u0bb1\u0bc8",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0ba4\u0bc6\u0bb2\u0bcd\u0bb2\u0bbf\u0baa\u0bcd\u0baa\u0baa\u0bcd\u0baa\u0bbe \u0b86\u0ba4\u0bbe\u0bb0\u0bcd \u0bae\u0bb0\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bae\u0ba9\u0bc8",
            "label": "WORK_OF_ART"
          }
        ]
      ]
    }
  }
