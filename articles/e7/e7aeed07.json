          }
        ],
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dca\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0ddc\u0dc5",
            "label": "FAC"
          },
          {
            "text": "\u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0db1\u0dd4",
