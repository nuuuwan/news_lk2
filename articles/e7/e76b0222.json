          {
            "text": "\u0d86\u0d9c\u0db8\u0db1 \u0dc4\u0dcf \u0dc0\u0dd2\u0d9c\u0db8\u0db1 \u0db4\u0dcf\u0dbd\u0d9a \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca",
