          },
          {
            "text": "\u0b9c\u0bbf \u0b8e\u0bb2\u0bcd \u0baa\u0bc0\u0bb0\u0bbf\u0bb8\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bbe\u0ba4\u0bcd\u0ba4\u0bb1\u0bc8",
