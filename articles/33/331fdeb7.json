    "si": {
      "title": "\u0daf\u0dd0\u0dbb\u0dd2\u0dba\u0d9a\u0dca \u0d85\u0db4\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dc5\u0dcf\u0da7 \u0dc0\u0dc3\u0dbb 36\u0d9a \u0dc3\u0dd2\u0dbb\u0d9c\u0dd9\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dc3\u0dbb 12\u0d9a\u0da7 \u0db4\u0dd9\u0dbb \u0d85\u0d9c\u0dd4\u0dab\u0dd4\u0d9a\u0ddc\u0dc5\u0db4\u0dd0\u0dbd\u0dd0\u0dc3\u0dca\u0dc3\u0dda\u0daf\u0dd3 12 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0daf\u0dd0\u0dbb\u0dd2\u0dba\u0d9a \u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0d85\u0db4\u0dba\u0ddd\u0da2\u0db1\u0dba\u0da7 \u0dbd\u0d9a\u0dca \u0d9a\u0dc5 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0d9a\u0dd4\u0da7 \u0dc0\u0dc3\u0dbb 36\u0d9a \u0db6\u0dbb\u0db4\u0dad\u0dc5 \u0dc0\u0dd0\u0da9 \u0dc3\u0dc4\u0dd2\u0dad \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca\u00a0\u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0dad \u0dbd\u0dd2\u0dba\u0db1\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5\u0dd9\u0dca\u0dba.",
        "\u0dc3\u0dd2\u0dbb \u0daf\u0dac\u0dd4\u0dc0\u0db8\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 30,000\u0d9a \u0daf\u0da9 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0dc4\u0dcf \u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dd2\u0dad \u0daf\u0dd0\u0dbb\u0dd2\u0dba\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 03\u0d9a \u0dc0\u0db1\u0dca\u0daf\u0dd2 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0d9c\u0dd9\u0dc0\u0db1 \u0dbd\u0dd9\u0dc3 \u0daf\u00a0 \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0dc0\u0dbb\u0dba\u0dcf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5\u0dda\u0dba.",
        "12 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0daf\u0dd0\u0dbb\u0dd2\u0dba\u0d9a \u0dbb\u0dc0\u0da7\u0dcf \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0daf\u0dd2\u0db8 \u0d85\u0db4\u0dba\u0ddd\u0da2\u0db1\u0dba\u0da7 \u0dbd\u0d9a\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0 \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0dda\u0daf\u0dd2 \u0d9a\u0dd2\u0dba\u0dd0\u0dc0\u0dd2\u0db1\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0daf\u0dd3\u0dbb\u0dca\u0d9d \u0db1\u0da9\u0dd4 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dda\u0daf\u0dd2 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dbd \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0da0\u0dd4\u0daf\u0dd2\u0dad\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0db1\u0d9c\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0da0\u0ddd\u0daf\u0db1\u0dcf 04\u0db8 \u0dc3\u0dcf\u0db0\u0dcf\u0dbb\u0dab \u0dc3\u0dd0\u0d9a\u0dba\u0dd9\u0db1\u0dca \u0d94\u0db6\u0dca\u0db6\u0da7 \u0d94\u0db4\u0dca\u0db4\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd2\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0dad \u0dbd\u0dd2\u0dba\u0db1\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0da0\u0dd4\u0daf\u0dd2\u0dad\u0da7 \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd2 \u0db1\u0dd3\u0dad\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0dda \u0db4\u0dd9\u0db1\u0dd2 \u0dc3\u0dd2\u0da7\u0dd2 \u0dbb\u0da2\u0dba\u0dda \u0db1\u0dd2\u0db8\u0db1\u0dca\u0dad \u0da2\u0dba\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0daf\u0d9a\u0dca\u0dc0\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd2\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d85\u0d9c\u0dad\u0dd2\u0dba\u0da7\u0db4\u0dad\u0dca \u0daf\u0dd0\u0dbb\u0dd2\u0dba \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 12\u0d9a \u0d85\u0dba\u0d9a\u0dd4 \u0db6\u0dc0\u0dad\u0dca, \u0da0\u0dd4\u0daf\u0dd2\u0dad 29 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd2\u0dba\u0dda \u0db4\u0dc3\u0dd4 \u0dc0\u0dd4 \u0d85\u0dba\u0d9a\u0dd4 \u0db6\u0dc0\u0dad\u0dca\u0dba.\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc0\u0dd0\u0dbb\u0daf\u0dd2\u0dc0\u0dbd\u0daf\u0dd3 \u0da0\u0dd4\u0daf\u0dd2\u0dad\u0dba\u0d9a\u0dd4\u0da7 \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0daf\u0da9\u0dd4\u0dc0\u0db8 \u0daf\u0dd9\u0dc3 \u0dc3\u0db8\u0dcf\u0da2\u0dba\u0dcf\u0daf \u0db6\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca,\u0d91\u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0da2\u0dba\u0dda \u0d85\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca\u0da7\u0daf \u0d86\u0daf\u0dbb\u0dca\u0dc1\u0dba\u0d9a\u0dca \u0dc3\u0dd0\u0db4\u0dba\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0d86\u0d9a\u0dcf\u0dbb\u0dba\u0dda \u0daf\u0dd0\u0da9\u0dd2 \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0dbd\u0dd9\u0dc3 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0dc0\u0dd4 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0dc3\u0dc5\u0d9a\u0dcf \u0db6\u0dd0\u0dbd\u0dd6 \u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab \u0dc0\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0dbb\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0dad \u0dbd\u0dd2\u0dba\u0db1\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0da0\u0dd4\u0daf\u0dd2\u0dad\u0da7 1 \u0dc4\u0dcf 3 \u0da0\u0ddd\u0daf\u0db1\u0dcf\u0dc0\u0db1\u0dca \u0dc3\u0daf\u0dc4\u0dcf \u0dc0\u0dc3\u0dbb 04 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dc0\u0dc3\u0dbb 08\u0d9a \u0db6\u0dbb\u0db4\u0dad\u0dc5 \u0dc0\u0dd0\u0da9 \u0dc3\u0dc4\u0dd2\u0dad \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d85\u0daf\u0dcf\u0dbd \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0daf\u0dd9\u0d9a \u0dc3\u0daf\u0dc4\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 5000 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,000\u0d9a \u0daf\u0da9\u0dba\u0d9a\u0dca\u0daf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd2.",
        "\u0daf\u0da9 \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dba\u0dd2 \u0db1\u0db8\u0dca \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0db8\u0dcf\u0dc3 06\u0d9a \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca\u0daf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd2. \u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 02 \u0dc4\u0dcf 04 \u0da0\u0ddd\u0daf\u0db1\u0dcf\u0dc0\u0db1\u0dca \u0dc3\u0daf\u0dc4\u0dcf \u0dc0\u0dc3\u0dbb 14 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dc0\u0dc3\u0dbb 28\u0d9a \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0daf\u0dd9\u0d9a \u0dc3\u0daf\u0dc4\u0dcf\u0daf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,000 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 20,000\u0d9a \u0daf\u0da9\u0dba\u0d9a\u0dca\u0daf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd2. \u0daf\u0da9 \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dba\u0dd2 \u0db1\u0db8\u0dca \u0dc0\u0dc3\u0dbb 01 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dc0\u0dc3\u0dbb \u0daf\u0dd9\u0d9a\u0d9a \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca\u0daf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd2. \u0db8\u0dd3\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0d85\u0d9c\u0dad\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0daf\u0dd0\u0dbb\u0dd2\u0dba \u0dc3\u0daf\u0dc4\u0dcf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 03\u0d9a \u0dc0\u0db1\u0dca\u0daf\u0dd2 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0d9c\u0dd9\u0dc0\u0db1 \u0dbd\u0dd9\u0dc3\u0da7\u0daf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbd \u0d85\u0dad\u0dbb \u0da0\u0dd4\u0daf\u0dd2\u0dad \u0d91\u0db8 \u0dc0\u0db1\u0dca\u0daf\u0dd2 \u0db8\u0dd4\u0daf\u0dbd \u0db1\u0ddc\u0d9c\u0dd9\u0dc0\u0dba\u0dd2 \u0db1\u0db8\u0dca \u0dad\u0dc0\u0dad\u0dca \u0dc0\u0dc3\u0dbb 02\u0d9a \u0db6\u0dbb\u0db4\u0dad\u0dc5 \u0dc0\u0dd0\u0da9 \u0dc3\u0dc4\u0dd2\u0dad \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd2."
      ],
