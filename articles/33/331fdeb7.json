          {
            "text": "\u0baa\u0bbf\u0bb0\u0bbf\u0baf\u0ba8\u0bcd\u0ba4\u0bbe",
            "label": "PERSON"
          },
          {
            "text": "12 \u0bb5\u0baf\u0ba4\u0bc1",
            "label": "DATE"
          },
          {
            "text": "\u0b85\u0b95\u0bc1\u0ba9\u0bc1\u0b95\u0bcb\u0bb2\u0baa\u0bb2\u0bb8\u0bcd\u0bb8",
            "label": "PERSON"
