    "si": {
      "title": "\u0d9c\u0dd1\u0dc3\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dba\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0dc4\u0dd2\u0dc3\u0da7 \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba\u0d9a\u0dca \u0dc0\u0dd0\u0da7\u0dd3 \u0dbb\u0ddd\u0dc4\u0dbd\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0d9c\u0dd1\u0dc3\u0dca\u00a0 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dba\u0d9a\u0dd4\u0d9c\u0dda \u0dc4\u0dd2\u0dc3\u0da7 \u0d85\u0daf (21\u0daf\u0dcf)\u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba\u0d9a\u0dca \u0dc0\u0dd0\u0da7\u0dd2 \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d9c\u0dad \u0d9a\u0dbd \u0db6\u0dc0 \u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2 .",
        "\u0db8\u0dd9\u0dc3\u0dda \u0dbb\u0ddd\u0dc4\u0dbd\u0dca\u0d9c\u0dad \u0d9a\u0ddc\u0da7 \u0d87\u0dad\u0dca\u0dad\u0dda \u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dbd \u0d89\u0daf\u0dd2\u0db4\u0dbd\u0d9c\u0ddc\u0da9 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0db8 \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dad\u0dd2\u0daf\u0dbb\u0dd4 \u0db4\u0dd2\u0dba\u0dd9\u0d9a\u0dca \u0db6\u0dc0\u0daf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0daf\u0dd0\u0db1\u0da7 \u0daf\u0dd2\u0db1 \u0db4\u0dc4\u0d9a\u0dca \u0dad\u0dd2\u0dc3\u0dca\u0dc3\u0dda \u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dbd \u0d89\u0daf\u0dd2\u0db4\u0dbd\u0dda\u0d9c\u0ddc\u0da9 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0d9c\u0dd1\u0dc3\u0dca \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dba\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0dc4\u0dd2\u0dc3\u0da7 \u0db8\u0dda \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba \u0dc0\u0dd0\u0da7\u0dd2 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc4\u0dd2\u0dc3\u0da7 \u0db4\u0ddc\u0dbd\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba \u0dc0\u0dd0\u0da7\u0dd4\u0dab\u0dd4 \u0dad\u0dd0\u0db1\u0dd0\u0dad\u0dca\u0dad\u0dcf\u0d9c\u0dda \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0db6\u0dc0 \u0d87\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d86\u0dbb\u0d82\u0da0\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0d9a\u0dd2\u0dba\u0dba\u0dd2 . \u0db4\u0dd2\u0da7\u0dd2\u0d9c\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8\u0dda \u0db4\u0dd2\u0dbd\u0dd2\u0db6\u0daf\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dba\u0dd2 ."
      ],
