    "si": {
      "title": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0da7\u0dd2\u0db1\u0dca \u0db8\u0dcf\u0dc5\u0dd4 \u0d9c\u0dda\u0db1\u0dca\u0db1 \u0dc0\u0dd0\u0da9\u0dd2 \u0dbd\u0db1\u0dca\u0dc3\u0dd4\u0dc0\u0da7 \u0daf\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0d86\u0dba\u0dad\u0db1\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0db8\u0dd2\u0dbd\u0da7 \u0db8\u0dcf\u0dc5\u0dd4 \u0da7\u0dd2\u0db1\u0dca 75000\u0d9a\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0da7\u0dd9\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a\u0da7 \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba \u0dbd\u0db6\u0dcf \u0daf\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0ddd \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0d9a\u0dbb\u0dad\u0dd2.",
        "\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 425 \u0db6\u0dbb \u0db8\u0dcf\u0dc5\u0dd4\u0da7\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 620\u0d9a \u0db8\u0dd2\u0dbd\u0d9a\u0da7 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0d86\u0dba\u0dad\u0db1\u0dba\u0da7 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0da7\u0dd2\u0db1\u0dca\u0db8\u0dcf\u0dc5\u0dd4 \u0db1\u0dd2\u0db4\u0daf\u0dc0\u0db1\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba \u0d91\u0d9a\u0d9f\u0dad\u0dcf\u0dc0\u0dba \u0db4\u0dc5\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd2\u0dba\u0daf\u0dd3 \u0d91\u0db8 \u0d86\u0dba\u0dad\u0db1\u0dba \u0d91\u0dba \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4 \u0d9a\u0dbb \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0db8\u0dcf\u0dc5\u0dd4\u0da7\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 700\u0d9a \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0da7 \u0db8\u0dd2\u0dbd\u0daf\u0dd2 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0da7\u0dd9\u0db1\u0dca\u0da9\u0dbb\u0dba\u0d9a\u0da7 \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba \u0dbd\u0db6\u0dcf \u0daf\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0d91\u0db8 \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0ddd \u0d9a\u0dd2\u0dba\u0dad\u0dd2.",
        "\u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0da7\u0dd2\u0db1\u0dca 7500\u0d9a\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0db8\u0dd2\u0dbd\u0d9a\u0da7 \u0dbd\u0db6\u0dd0\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0d86\u0dba\u0dad\u0db1\u0dba\u0da7 \u0d85\u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0db1 \u0db8\u0dd4\u0daf\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 60\u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0dc0\u0db1 \u0db6\u0dc0 \u0daf \u0d94\u0dc0\u0dd4\u0dc4\u0dd4 \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dad\u0dd2."
      ],
