            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dbd\u0dbd \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf",
