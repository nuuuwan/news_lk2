    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dc0\u0dc3\u0dbb\u0db4\u0dad\u0da7 \u0dc4\u0dd2\u0db8\u0dd2 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc1\u0dda\u0dc2\u0dba \u0daf\u0dd0\u0db1\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dc0\u0dc3\u0dbb\u0db4\u0dad \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dba\u0da7 \u0dc4\u0dd2\u0db8\u0dd2 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d9a\u0ddd\u0da7\u0dcf \u0dc1\u0dda\u0dc2\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0dc0\u0dad\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc0\u0dda\u0daf\u0dba\u0d9a\u0dca \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd3 \u0d87\u0dad.",
        "\u0d91\u0dc4\u0dd2\u0daf\u0dd3 FUEL BAL \u0d94\u0db6\u0dda \u0dbb\u0dae\u0dba\u0dda \u0d85\u0d82\u0d9a\u0dba (\u0d8b\u0daf\u0dcf ABC 1234) \u0dbd\u0dd9\u0dc3 \u0da7\u0dba\u0dd2\u0db4\u0dca \u0d9a\u0dbb 0766 220 000 \u0dba\u0db1 \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1 \u0d85\u0d82\u0d9a\u0dba \u0dc0\u0dd9\u0dad SMS \u0db4\u0dab\u0dd2\u0dc0\u0dd4\u0da9\u0dba\u0d9a\u0dca \u0dba\u0ddc\u0db8\u0dd4\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d91\u0db8 \u0dc1\u0dda\u0dc2\u0dba \u0daf\u0dd0\u0db1\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dc0\u0dc3\u0dbb\u0db4\u0dad \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf www.fuelpass.gov.lk \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba\u0da7 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3 \u0d85\u0daf\u0dcf\u0dc5 \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0dc4\u0dd0\u0d9a."
      ],
