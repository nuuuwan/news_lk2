        [
          {
            "text": "\u0b9c\u0bc6\u0ba9\u0bcd\u0b9a\u0bbf\u0b95\u0bbe \u0b9a\u0bbf\u0bb5\u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bcd",
