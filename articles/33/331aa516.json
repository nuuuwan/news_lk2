        [
          {
            "text": "\u0bb0\u0bbe\u0b9c\u0b9a\u0bc7\u0b95\u0bb0\u0bcd \u0bb5\u0bbf\u0ba4\u0bc2\u0b9a\u0ba9\u0bcd",
