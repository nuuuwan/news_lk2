          {
            "text": "\u0d9a\u0da9\u0dd4\u0dc0\u0dd9\u0dbd \u0dbb\u0db1\u0dca\u0d9a\u0dcf\u0da9\u0dd4 \u0db4\u0dad\u0dca\u0dad\u0dd2\u0db1\u0dd2 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0d9a\u0da9\u0dd4\u0dc0\u0dd9\u0dbd",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db8\u0dd3\u0da7\u0dbb\u0dca 800 \u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "QUANTITY"
          },
          {
            "text": "\u0dad\u0dd4\u0db1\u0dca",
