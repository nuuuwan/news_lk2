    "si": {
      "title": "\u0dbb\u0dd2\u0daf\u0dd3\u0d9c\u0db8\u0daf\u0dd3 \u0db1\u0dc0 \u0dba\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0dc0\u0dd2\u0dba\u0dda \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dd9\u0d9a\u0dca \u0daf\u0dd2\u0dba\u0dda \u0d9c\u0dd2\u0dbd\u0dd3 \u0db8\u0dbb\u0dd4\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dbb\u0dd2\u0daf\u0dd3\u0d9c\u0db8, \u0d95\u0d9c\u0ddc\u0da9\u0db4\u0ddc\u0dbd \u0db8\u0dc4\u0dba\u0dcf\u0dba \u0d87\u0dc5\u0dda \u0d9c\u0dd2\u0dbd\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dd9\u0d9a\u0dd4 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc5\u0db8\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0daf\u0dd2\u0dba\u0db1\u0dd1\u0db8\u0da7 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf \u0db8\u0dd9\u0db8 \u0d9b\u0dda\u0daf\u0dc0\u0dcf\u0da0\u0d9a\u0dba\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda.",
        "\u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca\u0dad\u0dda \u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 16 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dad\u0dbb\u0dd4\u0dab\u0dba\u0dd9\u0d9a\u0dd2.",
        "\u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d9c\u0ddc\u0d9a\u0dbb\u0dd0\u0dbd\u0dca\u0dbd \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0d9a\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d86\u0db4\u0dc3\u0dd4 \u0d91\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0daf\u0dd2\u0dba \u0db1\u0dd1\u0db8\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dc5\u0dda \u0d9c\u0dd2\u0dbd\u0dd3 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dad\u0dd8\u0db4\u0dca\u0dad\u0dd2\u0db8\u0dad\u0dca \u0dc0\u0db1 \u0dad\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0dc3\u0dc4\u0dba \u0daf\u0dd9\u0db1\u0dc0\u0dcf: \u0dc3\u0dd3.\u0dc0\u0dd3. \u0dc0\u0dd2\u0d9c\u0dca\u0db1\u0dda\u0dc2\u0dca\u0dc0\u0dbb\u0db1\u0dca"
      ],
