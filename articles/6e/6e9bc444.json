    "si": {
      "title": "\u0dad\u0dd9\u0dbd\u0dca\u0dbd\u0dd2\u0db4\u0dbd\u0dba \u0d86\u0daf\u0dcf\u0dbb\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 \u0db4\u0dc4\u0d9a \u0d96\u0dc2\u0db0 \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dca\u0db1",
      "author": "T. Saranya",
      "body_lines": [
        "\u0dad\u0dd9\u0dbd\u0dca\u0dbd\u0dd2\u0db4\u0dbd\u0dba \u0d86\u0daf\u0dcf\u0dbb\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 \u0db4\u0dc4\u0d9a\u0dca \u0dc0\u0da7\u0dd2\u0db1\u0dcf \u0d96\u0dc2\u0db0 \u0d8a\u0dba\u0dda \u0db4\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dba\u0dcf\u0d9c \u0d9a\u0dc5\u0dcf.",
        "\u0dbd\u0ddd\u0d9a \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc3\u0dca\u0d9a\u0dd8\u0dad\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dad\u0dd8 \u0dc3\u0ddd\u0db8\u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb\u0db8\u0dca \u0dad\u0d82\u0d9c\u0dbb\u0dcf\u0dc3\u0dcf \u0db8\u0dbd\u0dca\u0dbd\u0dd2\u0d9a\u0dcf\u0d9c\u0dda \u0db4\u0dc0\u0dd4\u0dbd\u0dda \u0d85\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0daf\u0dd2\u0dba\u0dab\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0dc4\u0dd2\u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0d96\u0dc2\u0db0 \u0db4\u0dbb\u0dd2\u0dad\u0dca\u200d\u0dba\u0dcf\u0d9c \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba\u0d9a\u0daf\u0dd3 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dd2\u0da9 \u0da2\u0db1\u0dbb\u0da2 \u0db4\u0d9a\u0dca\u200d\u0dc2\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db8\u0dcf\u0dc0\u0dd9\u0dba\u0dd2 \u0dc3\u0dda\u0db1\u0dcf\u0db0\u0dd2\u0dbb\u0dcf\u0da2\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d96\u0dc2\u0db0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd9\u0dad \u0db7\u0dcf\u0dbb \u0daf\u0dd9\u0db1 \u0dbd\u0daf\u0dd3."
      ],
