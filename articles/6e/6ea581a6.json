    "si": {
      "title": "\u0db6\u0db9\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dba\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda \u0d9c\u0dd0\u0db6\u0dd2\u0db1\u0dd2 \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dc0\u0dca \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf (23) \u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d8a\u0da7 \u0d9c\u0dd0\u0db6\u0dd2\u0dab\u0dd2 \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca\u0daf \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dca\u0db1\u0dda.",
        "\u0db6\u0d9c\u0dc0\u0db1\u0dca\u0dad\u0dbd\u0dcf - \u0db6\u0dca\u200d\u0dbb\u0dd2\u0da9\u0dca\u0dc0\u0dd9\u0dbd\u0dca \u0dc0\u0dad\u0dca\u0dad\u0dda \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0db1\u0dca 4 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db6\u0db9\u0dbb \u0daf\u0dc2\u0dca\u0da7 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca\u0dc0\u0dbd\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb \u0d9c\u0dd0\u0db6\u0dd2\u0dab\u0dd2 \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0da7 \u0db6\u0db9\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0daf\u0dc2\u0dca\u0da7 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d87\u0dba\u0dc0 \u0db4\u0ddc\u0d9a\u0dc0\u0db1\u0dca\u0dad\u0dbd\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0dd9\u0db1\u0dca \u0da7\u0dd2\u0d9a\u0ddd\u0dba \u0d9a\u0dca\u0dbd\u0dd0\u0d82\u0d9c\u0db1\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0db8\u0dcf\u0dbb\u0dd4\u0d9a\u0dbb \u0dba\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbb\u0ddd\u0dc4\u0dbd\u0dca \u0d86\u0dbb\u0d82\u0da0\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
