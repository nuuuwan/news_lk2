    "si": {
      "title": "\u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dba\u0dcf\u0db4\u0dcf \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (13) \u0dc3\u0dc0\u0dc3 5.00 \u0da7 \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dba\u0dcf\u0db4\u0dcf \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
