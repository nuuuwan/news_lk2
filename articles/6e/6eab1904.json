          },
          {
            "text": "\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db6\u0dd4\u0daf\u0dca\u0db0\u0dd2 \u0db8\u0dcf\u0dbb\u0db9\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dbb\u0dca\u0dc2\u0dd2 \u0daf\u0db1\u0dca\u0daf\u0dd9\u0dab\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0db8\u0db1\u0dca \u0db0\u0dbb\u0dca\u0db8\u0d9a\u0dd3\u0dbb\u0dca\u0dad\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d8b\u0db4\u0dd4\u0dbd\u0dca \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba, \u0dbb\u0ddd\u0dc4\u0dab \u0db4\u0dd4\u0dc2\u0dca\u0db4\u0d9a\u0dd4\u0db8\u0dcf\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0da2\u0db1\u0dca\u0dad\u0dcf \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d87\u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0db8\u0dcf\u0dbb\u0dc0\u0dd3\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0db1\u0dba \u0d9a\u0dbb\u0db1\u0dca\u0db1",
            "label": "PERSON"
          }
        ]
