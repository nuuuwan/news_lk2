    "si": {
      "title": "\u0d9a\u0ddc\u0dab\u0dca\u0da9\u0dcf \u0d9a\u0dd0\u0db4\u0dd3\u0db8 \u0dc4\u0dcf \u0dc3\u0dd0\u0d9a\u0dc3\u0dd3\u0db8\u0da7 \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc0\u0dda\u0daf\u0dba",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a\u0dad\u0dca\u0dc0 \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba (NAITA) \u0dc3\u0db8\u0d9c \u0d91\u0d9a\u0dca\u0dc0, \u0da9\u0dca\u200d\u0dbb\u0dd3\u0db8\u0dca\u0dbb\u0ddc\u0db1\u0dca \u0db4\u0dcf\u0dc3\u0dbd \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc0\u0dda\u0daf\u0dba (National Trade Test/NTT ) \u0dad\u0dd4\u0dc5\u0dd2\u0db1\u0dca \u0daf\u0dd0\u0db1\u0da7 \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2\u0dba\u0dd9\u0dc4\u0dd2 \u0db1\u0dd2\u0dba\u0dd4\u0dad\u0dd4 \u0dc1\u0dd2\u0dbd\u0dca\u0db4\u0dd3\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf 'Hair Cutting Gents - Fashionable\u00a0 Hairdresser' \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dda \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0dc4\u0dad\u0dd2\u0d9a\u0dba\u0d9a\u0dca \u0dc0\u0db1 \u0db8\u0dd9\u0dba \u0dad\u0dbb\u0dd4\u0dab\u00a0\u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dc3\u0dc4 \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf \u0dc0\u0dd9\u0dc5\u0dd9\u0db3\u0db4\u0ddc\u0dc5 \u0da2\u0dba \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dbb\u0dd4\u0d9a\u0dd4\u0dbd\u0d9a\u0dca \u0db6\u0dc0 \u0d9a\u0dd2\u0dba\u0dba\u0dd2. \u0db8\u0dd9\u0db8 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc0\u0dda\u0daf\u0dba \u0dad\u0dd4\u0dc5 (NTT) \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba \u0dbd\u0dd9\u0dc3 \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0db1\u0dca\u0db1\u0dda, \u0daf\u0dd0\u0db1\u0dd4\u0db8 \u0dc3\u0dc4\u00a0 \u0d9a\u0dd4\u0dc3\u0dbd\u0dad\u0dcf\u0dc0 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db8\u0dd9\u0db1\u0dca\u0db8, \u0d9a\u0dca\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb\u0dba \u0dad\u0dd4\u0dc5 \u0d9a\u0dd9\u0da7\u0dd2 \u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0d85\u0dad\u0dca\u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0dca \u0d87\u0dad\u0dd2 \u0dc1\u0dd2\u0dbd\u0dca\u0db4\u0dd3\u0db1\u0dca\u0da7 \u0db4\u0dc0\u0dcf \u0d85\u0dc0\u0dc3\u0dcf\u0db1 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dba\u0ddc\u0db8\u0dd4\u0dc0\u0dd3\u0db8\u0da7 \u0d87\u0dad\u0dd2 \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0\u0dba\u0dd2. \u0dad\u0dbb\u0dd4\u0dab \u0dc3\u0dc4 \u0dc0\u0dd0\u0da9\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dba\u0dc3\u0dca \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0dad\u0ddc\u0dbb\u0dc0\u0daf \u0db8\u0dd9\u0db8 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0 \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd6 \u0d85\u0dc0\u0db6\u0ddd\u0db0\u0dad\u0dcf \u0d9c\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0dca \u0d85\u0dad\u0dca\u0dc3\u0db1\u0dca \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a\u0dad\u0dca\u0dc0 \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dad\u0dbb\u0d82\u0d9c \u0db1\u0dbd\u0dd3\u0db1\u0dca \u0d9c\u0db8\u0dca\u0dbd\u0dad\u0dca, \u0d8b\u0db4 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dbb\u0dd6\u0db4\u0dc3\u0dd2\u0d82\u0dc4, \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0da9\u0db6\u0dca.\u0d91\u0db8\u0dca.\u0d91\u0dc3\u0dca. \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4, \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 (\u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0) \u0da0\u0db1\u0dca\u0db1 \u0dc3\u0dd4\u0db6\u0dc3\u0dd2\u0d82\u0dc4 \u0dc3\u0dc4 \u0dc3\u0dc4\u0d9a\u0dcf\u0dbb \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 (\u0d87\u0d9c\u0dba\u0dd3\u0db8\u0dca- NVQ) \u0dc3\u0dd4\u0da2\u0dd3\u0dc0 \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0da9\u0dca\u200d\u0dbb\u0dd2\u0db8\u0dca\u0dbb\u0ddc\u0db1\u0dca \u0d86\u0dba\u0dad\u0db1\u0dba \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0d9a\u0dd2\u0dc2\u0dd6 \u0d9c\u0ddd\u0db8\u0dc3\u0dca, \u0dc3\u0db8\u0dd6\u0dc4 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dcf \u0db1\u0dd3\u0dc1\u0dcf \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf, \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dd2\u0d9a\u0dcf \u0dc3\u0da0\u0dd2\u0dad\u0dca\u200d\u0dbb\u0dcf \u0d9a\u0dc5\u0dd4\u0db6\u0ddd\u0dc0\u0dd2\u0dbd, \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0dc0\u0dd9\u0dc5\u0dd9\u0db3 (EVON) \u0db1\u0daf\u0dd3\u0dbb \u0d89\u0db1\u0dca\u0daf\u0dd2\u0d9a \u0db4\u0dad\u0dd2\u0dbb\u0dab, \u0da2\u0dca\u200d\u0dba\u0dd9\u0dc2\u0dca\u0da8 \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0d86\u0dbb\u0dd2\u0dba \u0db8\u0daf\u0dd4\u0dbb\u0dc3\u0dd2\u0d82\u0dc4 \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dcf \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd3\u0db1\u0dca \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0dd6\u0dc4."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a\u0dad\u0dca\u0dc0 \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dba\u0dd2\u0da7\u0dcf",
            "label": "ORG"
          },
          {
            "text": "Dreamron \u0db4\u0dcf\u0dc3\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd9\u0dc5\u0db3 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dba/NTT",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db8\u0dd9\u0db8 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "NTT",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d86\u0db0\u0dd4\u0db1\u0dd2\u0d9a\u0dad\u0dca\u0dc0 \u0dc3\u0dc4 \u0d9a\u0dcf\u0dbb\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0dbb\u0d82\u0d9c \u0db1\u0dbd\u0dd2\u0db1\u0dca \u0d9c\u0db8\u0dca\u0dbd\u0dad\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dbb\u0dd6\u0db4\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca.\u0d91\u0db8\u0dca.\u0d91\u0dc3\u0dca.",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd4\u0da2\u0dd3\u0dc0 \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "Kishu Gomes",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dca\u0dbb\u0dd2\u0db8\u0dca\u0dbb\u0ddc\u0db1\u0dca",
            "label": "ORG"
