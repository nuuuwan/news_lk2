          {
            "text": "\u0ba4\u0bae\u0bcd\u0bae\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe",
            "label": "PERSON"
          },
          {
            "text": "\u0baf\u0bc1\u0ba9\u0bbf\u0bb2\u0bc0\u0bb5\u0bb0\u0bcd",
