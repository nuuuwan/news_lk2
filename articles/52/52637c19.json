          },
          {
            "text": "\u0bb9\u0b9c\u0bb0\u0bcd \u0b85\u0bb2\u0bbe\u0b83\u0baa\u0bbf \u0bb2\u0bbe\u0b9f\u0bc6\u0bb2\u0bcd",
