            "label": "PERSON"
          },
          {
            "text": "\u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0b90\u0b93\u0b9a\u0bbf \u0baa\u0bbf\u0b8e\u0bb2\u0bcd\u0b9a\u0bbf",
            "label": "ORG"
          },
