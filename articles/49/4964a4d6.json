          },
          {
            "text": "\u0db8\u0dd2\u0dad\u0dca\u200d\u0dbb\u0db4\u0dcf\u0dbd \u0dbd\u0d82\u0d9a\u0dda\u0dc1\u0dca\u0dc0\u0dbb",
