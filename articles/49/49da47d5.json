          }
        ],
        [
          {
            "text": "\u0b95\u0bb5\u0bbf\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb0\u0bb7\u0bcd\u0bae\u0bbf\u0ba4\u0bcd \u0b9c\u0bc6\u0baf\u0b9a\u0bc2\u0bb0\u0bbf\u0baf",
            "label": "FAC"
          },
          {
            "text": "11 \u0b86\u0bae\u0bcd \u0b86\u0ba3\u0bcd\u0b9f\u0bc1",
            "label": "DATE"
          },
          {
            "text": "\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1",
            "label": "CARDINAL"
          },
          {
            "text": "\u0b95\u0bca\u0b95\u0bb0\u0bc6\u0bb2\u0bcd\u0bb2 \u0baa\u0bca\u0bb2\u0bcd\u0b95\u0bca\u0bb2\u0bcd\u0bb2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b95\u0bcb\u0b95\u0bb0\u0bc6\u0bb2\u0bcd\u0bb2\u0bbe",
            "label": "PERSON"
          },
          {
            "text": "\u0b87\u0baa\u0bcd\u0baa\u0bbe\u0b95\u0bae\u0bc1\u0bb5 \u0b95\u0bb2\u0bcd\u0bb5\u0bbf \u0bb5\u0bb2\u0baf\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b85\u0ba4\u0bc7 \u0ba8\u0bbe\u0bb3\u0bcd",
            "label": "DATE"
          }
        ],
        [],
        [
