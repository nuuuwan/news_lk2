            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9c\u0ddc\u0d9a\u0dbb\u0dd0\u0dbd\u0dca\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0d89\u0db6\u0dca\u0db6\u0dcf\u0d9c\u0db8\u0dd4\u0dc0 \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d9a\u0dbd\u0dcf\u0db4\u0dba",
