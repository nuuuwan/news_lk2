    "si": {
      "title": "\u2018\u2018\u0d87\u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0da7\u0dad\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0db1\u0dca\u0da7\u0dad\u0dca \u0daf\u0dd0\u0d9a\u0dca\u0db8\u0d9a\u0dca \u0db1\u0dd1\u2018\u2018",
      "author": "unknown",
      "body_lines": [
        "\u0d87\u0db8\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0da7 \u0db1\u0dd2\u0dc3\u0dd2 \u0daf\u0dd0\u0d9a\u0dca\u0db8\u0d9a\u0dca \u0db1\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0daf\u0dd0\u0d9a\u0dca\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0d85\u0dba\u0d9c\u0dd9\u0db1\u0dca \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0db1\u0ddc\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0\u0dad \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0dcf\u0db8\u0da4\u0dca\u0da4 \u0db8\u0dc4\u0dcf \u0db1\u0dd2\u0d9a\u0dcf\u0dba\u0dda \u0d85\u0db1\u0dd4 \u0db1\u0dcf\u0dba\u0d9a \u0d9c\u0dd0\u0da7\u0db9\u0dda \u0dbb\u0dcf\u0da2\u0ddd\u0db4\u0dc0\u0db1\u0dcf\u0dbb\u0dcf\u0db8\u0dcf\u0db0\u0db4\u0dad\u0dd2\u00a0 \u0d9a\u0dd0\u0db4\u0dca\u0db4\u0dd9\u0da7\u0dd2\u0dba\u0dcf\u0d9c\u0ddc\u0da9 \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dd2\u0db8\u0dbd \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd4\u0dc4.",
        "\u0d9a\u0dbb\u0db1\u0dc0\u0dd0\u0da9\u0dc0\u0dbd \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0d9a\u0dca \u0db1\u0dd1. \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dc0\u0dd0\u0da9 \u0d85\u0dc0\u0dd4\u0dbd\u0dca \u0d9a\u0dbb\u0d9c\u0dd9\u0db1. \u0db8\u0dda \u0d9c\u0dd0\u0db1 \u0daf\u0dd0\u0db1\u0dd3\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db8\u0dda \u0d9c\u0dd0\u0db1 \u0dc4\u0dd0\u0d9c\u0dd3\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0daf\u0dc0 \u0d95\u0db1\u0d9a\u0db8\u0dca\u0d9a \u0d87\u0dad\u0dd2 \u0d85\u0dba\u0d9c\u0dd9\u0db1\u0dca \u0d8b\u0db4\u0daf\u0dd9\u0dc3\u0dca \u0d9c\u0dd0\u0db1\u0dd2\u0db8\u0d9a\u0dca \u0db1\u0ddc\u0d9a\u0dbb\u0db1 \u0db1\u0dd2\u0dc3\u0dcf \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d9a\u0dda\u0dc2\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd9\u0dba\u0dca \u0d9c\u0dd0\u0da7\u0dbd\u0dd4 \u0db4\u0dd0\u0db1 \u0db1\u0dd0\u0d9c\u0dd2 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0d85\u0db1\u0dd4\u0db1\u0dcf\u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd6\u0dc4",
        "\u0dc0\u0dad\u0dca\u0db8\u0db1\u0dca \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d9a\u0dca\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb\u0dba\u0dda \u0d8b\u0daf\u0dca\u0d9c\u0dad\u0dc0\u0dd2 \u0d87\u0dad\u0dd2 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4 \u0db1\u0dd2\u0dc3\u0dcf \u0dba\u0dc5 \u0db8\u0dc4 \u0d9a\u0db1\u0dca\u0db1 3 \u0d9a\u0dca \u0dc0\u0dd2\u0db1\u0dcf\u0dc1 \u0dc0\u0dd2\u0db8 \u0dc4\u0dcf \u0db4\u0dbd\u0dd2\u0db6\u0ddc\u0db0 \u0db1\u0dcf\u0dc1\u0d9a \u0dc4\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db1\u0dd2\u0dc3\u0dd2\u0dba\u0dcf\u0d9a\u0dcf\u0dbb\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd2\u0db8 \u0d87\u0dad\u0dd4\u0dbd\u0dd4 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0daf\u0dc0 \u0dc3\u0db8\u0dc3\u0dca\u0dae \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0db1\u0dca\u00a0 \u00a0\u0d85\u0db1\u0dd4 \u0db1\u0dcf\u0dba\u0d9a\u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca \u0db6\u0dd0\u0dc4\u0dd0\u0daf\u0dd0\u0d9a\u0dd2 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd2 \u0db8\u0dda \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dc3\u0dd2\u0dba."
      ],
      "title_ents": [],
