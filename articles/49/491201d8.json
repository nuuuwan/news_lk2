    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0dd3\u0da7\u0dbb\u0dca 33,000\u0d9a\u0dca \u0db4\u0dcf\u0dbb\u0dda \u0d85\u0db4\u0dad\u0dda \u0d9c\u0dd2\u0dba\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba IOC \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d9c\u0db6\u0da9\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0dc4\u0db4\u0dd4\u0dad\u0dbd \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d9c\u0db6\u0da9\u0dcf\u0dc0 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0d9a\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
        "\u0d85\u0daf \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0dd3\u0da7\u0dbb\u0dca 33000\u0d9a\u0dca \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0dc4\u0db4\u0dd4\u0dad\u0dbd\u0dda - \u0db4\u0db1\u0dca\u0d9a\u0dd0\u0da7\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
        "\u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0dba\u0dcf\u0db8\u0dd9\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0dd9\u0d9a\u0dd4\u0da7\u0dad\u0dca \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dca\u0db1\u0dda."
      ],
