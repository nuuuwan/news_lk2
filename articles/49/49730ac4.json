            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 90 \u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "PERCENT"
          },
          {
            "text": "\u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0dc3\u0dd2\u0dba\u0dba\u0da7 10",
