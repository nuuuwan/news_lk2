          {
            "text": "\u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc0\u0dd9\u0dbd\u0dca\u0d9a\u0db8",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dc0 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
          }
        ],
        [
