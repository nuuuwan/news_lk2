    "si": {
      "title": "\u0d89\u0d9a\u0dca\u0db8\u0db1\u0dd2\u0db1\u0dca \u0db6\u0dd6\u0dc3\u0dca\u0da7\u0dbb \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0db1\u0dca\u0db1; \u0d94\u0d9a\u0dca\u200c\u0dad\u0ddd\u0db6\u0dbb\u0dca 31 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0da7 \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca \u0d9a\u0dbd\u0dca \u0d89\u0d9a\u0dd4\u0dad\u0dca \u0dc0\u0dda: \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d9c\u0dd2\u0db1\u0dd2\u0d9c\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0daf\u0dd0\u0db1\u0da7 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca \u0dad\u0ddc\u0d9c \u0d94\u0d9a\u0dca\u0dad\u0ddd\u0db6\u0dbb\u0dca 31 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dba\u0dd2\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0dad\u0ddc\u0dbb\u0dc0 COVID-19 \u0d91\u0db1\u0dca\u0db1\u0dad \u0db6\u0dd6\u0dc3\u0dca\u0da7\u0dbb \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dbd\u0dd9\u0dc3 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dba\u0ddd \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2.",
        "\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dc3\u0d82\u0d9c\u0dad \u0dbb\u0ddd\u0d9c \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0da5 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0db8\u0dd2\u0dad \u0d9c\u0dd2\u0db1\u0dd2\u0d9c\u0dda \u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0d9a\u0daf\u0dd3 \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc0\u0dc3\u0dbb 20 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 14.4 \u0d9a \u0da2\u0db1\u0d9c\u0dc4\u0db1\u0dba\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 20 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 \u0d85\u0da7\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db6\u0dd6\u0dc3\u0dca\u0da7\u0dbb \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0dc0\u0dc3\u0dbb 20 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db6\u0dd6\u0dc3\u0dca\u0da7\u0dbb \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0\u0dda \u0dc3\u0db8\u0dca\u0db4\u0dd6\u0dbb\u0dca\u0dab \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dad\u0dcf\u0dc0\u0dba \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0d95\u0db1\u0dd1 \u0dad\u0dbb\u0db8\u0dca \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca \u0dad\u0ddc\u0d9c \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\"\u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 20 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 \u0dc4\u0dba\u0d9a\u0dca \u0db4\u0db8\u0dab \u0dad\u0dc0\u0db8\u0dad\u0dca \u0db6\u0dd6\u0dc3\u0dca\u0da7\u0dbb \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d87\u0dad. \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0dad\u0dca \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0daf\u0dd9\u0db1\u0dcf \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dae\u0db8\u0dd2\u0d9a \u0d91\u0db1\u0dca\u0db1\u0dad \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0dc0\u0dbb\u0dca\u0dad\u0db8\u0dcf\u0db1\u0dba\u0dda \u0db1\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba \u0db4\u0dd0\u0dad\u0dd2\u0dbb\u0dd3\u0db8 \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db6\u0dd6\u0dc3\u0dca\u0da7\u0dbb \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc0\u0dda.\" \u0d94\u0dc4\u0dd4 \u0d9a\u0dd2\u0dc0\u0dca\u0dc0\u0dcf.",
        "60 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d85\u0dba\u0da7 \u0dc3\u0dc4 \u0db1\u0dd2\u0daf\u0db1\u0dca\u0d9c\u0dad \u0dbb\u0ddd\u0d9c \u0d87\u0dad\u0dd2 \u0d85\u0dba\u0da7 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc3\u0dd2\u0dc0\u0dca\u0dc0\u0db1 \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0\u0d9a\u0dca \u0db1\u0dd2\u0dbb\u0dca\u0daf\u0dda\u0dc1 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca, \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 20 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d95\u0db1\u0dd1\u0db8 \u0d9a\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d9a\u0dd0\u0db8\u0dad\u0dd2 \u0db1\u0db8\u0dca \u0dc3\u0dd2\u0dc0\u0dca\u0dc0\u0db1 \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 60 \u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d85\u0dba \u0dc3\u0dc4 \u0db1\u0dd2\u0daf\u0db1\u0dca\u0d9c\u0dad \u0dbb\u0ddd\u0d9c \u0d87\u0dad\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0d82\u0d9a\u0dd6\u0dbd\u0dad\u0dcf \u0dc4\u0dcf \u0db8\u0dbb\u0dab\u0dba\u0da7 \u0db4\u0dc0\u0dcf \u0d9c\u0ddc\u0daf\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd3\u0db8\u0dda \u0dc0\u0dd0\u0da9\u0dd2 \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dc0\u0dca\u0dc0\u0db1 \u0db8\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc0\u0dd0\u0daf\u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d9c\u0dd2\u0db1\u0dd2\u0d9c\u0dda \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba. (\u0d85\u0da2\u0dd2\u0dad\u0dca \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1)"
      ],
