            "label": "DATE"
          }
        ],
        [],
        [
          {
            "text": "\"\u0dc1\u0dcf\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dba \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dca \u0dc3\u0db8\u0dd4\u0dc5\u0dd4\u0dc0 - 2022",
            "label": "EVENT"
          },
          {
