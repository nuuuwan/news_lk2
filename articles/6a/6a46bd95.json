      "body_line_ents_list": [
        [
          {
            "text": "\u0dc4\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
