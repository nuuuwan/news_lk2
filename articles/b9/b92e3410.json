          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d85\u0daf\u0dcf\u0dc5 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
