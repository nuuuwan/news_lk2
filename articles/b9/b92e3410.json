  "original_title": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0baa\u0bbf\u0bb0\u0b9c\u0bc8\u0b95\u0bb3\u0bcd \u0bae\u0bc0\u0ba4\u0bc1 \u0baa\u0bbe\u0bb0\u0bbf\u0baf \u0b95\u0b9f\u0ba9\u0bcd",
  "text_idx": {
    "en": {
      "title": "A huge debt on the citizens of Sri Lanka",
      "author": "unknown",
      "body_lines": [
        "Professor Vasantha Athukorala of the Department of Economics and Statistics of the University of Perada said that due to inflation in the country, every family in the country has become a debtor of Rs 58 lakh by May this year.",
        "He pointed out that the matter was discovered in a special study carried out by the concerned department of the university.",
        "He also mentioned that every citizen in the country is seen as a debtor of 15 lakh 56 thousand rupees."
      ],
      "title_ents": [
        {
          "text": "Sri Lanka",
          "label": "GPE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "Vasantha Athukorala",
            "label": "PERSON"
          },
          {
            "text": "the Department of Economics and Statistics of the University of Perada",
            "label": "ORG"
          },
          {
            "text": "May this year",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "the concerned department of the university",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "15",
            "label": "CARDINAL"
          },
          {
            "text": "56 thousand",
            "label": "CARDINAL"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dd4\u0dbb\u0dc0\u0dd0\u0dc3\u0dd2\u0dba\u0db1\u0dca \u0db8\u0dad \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0dab\u0dba\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dcf \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc4\u0dcf \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dda\u0d9b\u0db1 \u0d85\u0d82\u0dc1\u0dba\u0dda \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dc0\u0dc3\u0db1\u0dca\u0dad \u0d85\u0dad\u0dd4\u0d9a\u0ddd\u0dbb\u0dbd \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dbb\u0da7\u0dda \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dbb\u0da7\u0dda \u0dc3\u0dd1\u0db8 \u0db4\u0dc0\u0dd4\u0dbd\u0d9a\u0dca\u0db8 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 58\u0d9a \u0dab\u0dba\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d85\u0d82\u0dc1\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1\u0dba\u0d9a\u0daf\u0dd3 \u0db8\u0dda \u0db6\u0dc0 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd6 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba.",
        "\u0dbb\u0da7\u0dda \u0dc3\u0dd1\u0db8 \u0db4\u0dd4\u0dbb\u0dc0\u0dd0\u0dc3\u0dd2\u0dba\u0dd9\u0d9a\u0dd4\u0db8 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 15 \u0dbd\u0d9a\u0dca\u0dc2 56,000\u0d9a \u0dab\u0dba\u0d9a\u0dcf\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0dc3\u0dbd\u0d9a\u0db1 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dcf."
      ],
      "title_ents": [
        {
