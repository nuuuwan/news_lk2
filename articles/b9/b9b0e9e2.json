    "si": {
      "title": "\u0dba\u0dcf\u0dbd\u0dd2 \u0dc0\u0dbd \u0d86\u0dc1\u0dca\u0da0\u0dbb\u0dca\u0dba\u0db8\u0dad\u0dca \u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca \u0db8\u0dc3\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0da0\u0dd4\u0dc0\u0dda\u0dbd\u0dd2 - \u0d9a\u0dbd\u0dab\u0dd9\u0dba\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0d9a \u0d9a\u0d9a\u0dd4\u0dbd\u0dca \u0dc4\u0dad\u0dbb\u0d9a\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0d9a\u0dd4\u0d9a\u0dd4\u0dc5\u0dd9\u0d9a\u0dd4 \u0db6\u0dd2\u0dc4\u0dd2\u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db4\u0dc0\u0dd4\u0dbd\u0dda \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0dc0\u0db1 \u0db8\u0dc4\u0dcf\u0dbb\u0dcf\u0da2\u0dcf \u0d9c\u0dde\u0dbb\u0dd2 \u0d9a\u0dd4\u0d9a\u0dd4\u0dc5\u0dd4 \u0d9c\u0ddc\u0dc0\u0dd2\u0dad\u0dd0\u0db1\u0dd9\u0dc4\u0dd2 \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dda. \u0d94\u0dc4\u0dd4 \u0da2\u0dd3\u0dc0\u0db1 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d9c\u0dd9\u0db1 \u0d91\u0db1\u0dca\u0db1\u0dda \u0d9a\u0dd4\u0d9a\u0dd4\u0dc5\u0dd4 \u0d9c\u0ddc\u0dc0\u0dd2\u0dad\u0dd0\u0db1\u0dba\u0dd2.",
        "\u0d94\u0dc4\u0dd4\u0d9c\u0dda \u0db1\u0dd2\u0dc0\u0dc3\u0dda \u0db4\u0dd0\u0da7\u0dc0\u0dd4\u0db1\u0dca \u0dc4\u0dba \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db6\u0dd2\u0dc4\u0dd2 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0d89\u0db1\u0dca \u0d91\u0d9a\u0dca \u0d85\u0dba\u0dd9\u0d9a\u0dd4 \u0d9a\u0d9a\u0dd4\u0dbd\u0dca \u0dc4\u0dad\u0dbb\u0d9a\u0dca \u0dc3\u0dc4\u0dd2\u0dad\u0dc0 \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dbd\u0daf\u0dd3."
      ],
