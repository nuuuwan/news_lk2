          },
          {
            "text": "\u0b95\u0bb0\u0bcd\u0ba8\u0bbe\u0b9f\u0b95 \u0bae\u0bbe\u0ba8\u0bbf\u0bb2 \u0b9a\u0b9f\u0bcd\u0b9f \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bb3\u0bcd \u0b86\u0ba3\u0bc8\u0baf\u0bae\u0bcd",
