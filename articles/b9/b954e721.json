        [
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d92\u0da2\u0db1\u0dca\u0dc3\u0dd2\u0dba",
            "label": "ORG"
