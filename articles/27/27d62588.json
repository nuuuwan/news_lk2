  "text_idx": {
    "en": {
      "title": "171,497 university admissions",
      "author": "unknown",
      "body_lines": [
        "According to the Department of Examinations, 171,497 students have qualified for university admission on the basis of their results in the General Standard Higher Examination for the year 2021.",
        "The department announced that 62.9 percent of the total number of students who applied for the higher level examination qualified for university admission.",
        "The department also informed that the results of 49 examinees, including 37 school examinees, have been withheld."
      ],
