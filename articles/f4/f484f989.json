            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dbb\u0dca\u0dc0\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
