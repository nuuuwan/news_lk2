    "si": {
      "title": "\u0dad\u0db8\u0dcf\u0dbb\u0dba\u0dd2 \u0d9c\u0ddd\u0db4\u0dd4\u0dbb\u0db8\u0dca 15 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dc4\u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0db8\u0dbb\u0dd2\u0d9a\u0ddd\u0db4\u0dd4\u0dbb\u0db8\u0dca \u0dc0\u0dd9\u0dad \u0dba\u0dcf \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. \u0d87\u0dad\u0dd4\u0dbd\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 500 \u0dc3\u0dd2\u0da7 2000 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dbb\u0dcf\u0dc3\u0dba\u0d9a \u0db4\u0dc0\u0dad\u0dd3. 20 USD \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0d9a\u0dba\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0d85\u0dba \u0d9a\u0dd9\u0dbb\u0dda."
      ],
      "title_ents": [
        {
          "text": "\u0dad\u0db8\u0dbb\u0dba\u0dd2 \u0d9c\u0ddd\u0db4\u0dd4\u0dbb\u0db8\u0dca",
          "label": "PERSON"
        },
        {
          "text": "15 \u0dc0\u0dd0\u0db1\u0dd2",
