    "si": {
      "title": "\u0d86\u0dba\u0dd4\u0dbb\u0dca\u0dc0\u0dda\u0daf TUs \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca\u0da7 \u0db1\u0dd2\u0dbb\u0dca\u0daf\u0dda\u0dc1\u0dd2\u0dad \u0d86\u0dc4\u0dcf\u0dbb \u0dc0\u0dda\u0dbd \u0dbd\u0db6\u0dcf \u0db1\u0ddc\u0daf\u0dd3\u0db8, \u0d96\u0dc2\u0db0 \u0dc4\u0dcf \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0dc4\u0dd2\u0d9f\u0dba \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0db8\u0dd4\u0dbd\u0dca \u0d9a\u0dbb \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0d86\u0dba\u0dd4\u0dbb\u0dca\u0dc0\u0dda\u0daf \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2 \u0d91\u0d9a\u0db8\u0dd4\u0dad\u0dd4\u0dc0 \u0d85\u0daf \u0db6\u0ddc\u0dbb\u0dd0\u0dbd\u0dca\u0dbd \u0d86\u0dba\u0dd4\u0dbb\u0dca\u0dc0\u0dda\u0daf \u0dc1\u0dd2\u0d9a\u0dca\u0dc2\u0dab \u0dbb\u0ddd\u0dc4\u0dbd \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd2\u0dba. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db1\u0dd2\u0db8\u0dca\u0dc3\u0dbd\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0d91\u0daf\u0dd2\u0dbb\u0dd2\u0dc3\u0dd2\u0d82\u0dc4"
      ],
