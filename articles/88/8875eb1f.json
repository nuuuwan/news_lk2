    "si": {
      "title": "\u0db4\u0dc5\u0db8\u0dd4 \u0db8\u0dcf\u0dc3 \u200b\u200b\u0db4\u0dc4 \u0dad\u0dd4\u0dc5 \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0db6\u0daf\u0dd4\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 93 \u0d9a \u0d86\u0daf\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0d8b\u0db4\u0dba\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda \u0db8\u0dd4\u0dbd\u0dca \u0db8\u0dcf\u0dc3 \u0db4\u0dc4 \u0dad\u0dd4\u0dc5 \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0dc0\u0dd0\u0dbb\u0daf\u0dd2 \u0dc3\u0dc4 \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0d86\u0da5\u0dcf\u0db4\u0db1\u0dad \u0d8b\u0dbd\u0dca\u0dbd\u0d82\u0d9d\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0db1\u0dc0\u0db1 \u0dbd\u0daf \u0daf\u0da9 \u0db8\u0dd4\u0daf\u0dbd\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dbb\u0da2\u0dba\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 93 \u0d9a \u0daf\u0dd0\u0dc0\u0dd0\u0db1\u0dca\u0dad \u0d86\u0daf\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0d8b\u0db4\u0dba\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd3 \u0d87\u0dad.",
        "2022 \u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd2 01 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0db8\u0dd0\u0dba\u0dd2 31 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0da7\u0db4\u0dd4\u0dbb\u0dcf \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dca 13,405\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0db1\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0daf\u0da9 \u0db8\u0dd4\u0daf\u0dbd\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db8\u0dd9\u0db8 \u0d86\u0daf\u0dcf\u0dba\u0db8 \u0d8b\u0db4\u0dba\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0db4\u0dd2\u0dbd \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dda\u0d9b\u0db1\u0dc0\u0dbd\u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0d86\u0da5\u0dcf\u0db4\u0db1\u0dad, \u0daf\u0dd4\u0db8\u0dca\u0d9a\u0ddc\u0dc5 \u0dc3\u0dc4 \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dcf\u0dbb \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0db1\u0dad (NATA) \u0dc3\u0dc4 \u0dc0\u0dd2\u0dc2, \u0d85\u0db6\u0dd2\u0d82 \u0dc3\u0dc4 \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dcf\u0dba\u0d9a\u0dbb \u0d96\u0dc2\u0db0 \u0d86\u0da5\u0dcf\u0db4\u0db1\u0dad \u0dba\u0da7\u0dad\u0dda \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dca 12,313 \u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0daf\u0da9 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 52, 990, 370 \u0d9a \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d91\u0dc3\u0dda\u0db8, \u0dbb\u0da7\u0db4\u0dd4\u0dbb\u0dcf \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dbd\u0dcf\u0db7\u0dd3 \u0db4\u0dbb\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dc0\u0dbd\u0dd2\u0db1\u0dca TCR (\u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0) 1, 092 \u0d9a\u0dca \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0daf\u0da9 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 41, 572, 480 \u0d9a \u0d86\u0daf\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0d8b\u0db4\u0dba\u0dcf \u0d87\u0dad.",
        "\u0db1\u0dd3\u0dad\u0dd2\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0db8\u0dad\u0dca\u0db4\u0dd0\u0db1\u0dca \u0dc3\u0dc4 \u0dc3\u0dca\u0db4\u0dca\u200d\u0dbb\u0dd3\u0dad\u0dd4 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dba, \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1\u0dba \u0dc3\u0dc4 \u0dc0\u0dd2\u0d9a\u0dd2\u0dab\u0dd3\u0db8, \u0dc4\u0dd9\u0dbb\u0ddc\u0dba\u0dd2\u0db1\u0dca, \u0d9a\u0ddc\u0d9a\u0dda\u0db1\u0dca, \u0d9c\u0d82\u0da2\u0dcf, \u0db1\u0dd3\u0dad\u0dd2 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0daf\u0dd4\u0db8\u0dca\u0dc0\u0dd0\u0da7\u0dd2 \u0dc3\u0dc4 \u0d85\u0db6\u0dd2\u0d82 \u0dc5\u0d9f \u0dad\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc0\u0dd2\u0d9a\u0dd2\u0dab\u0dd3\u0db8 \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc0\u0dd0\u0dbb\u0daf\u0dd2 \u0d85\u0dad\u0dbb \u0dc0\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca 10,432 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb 1,881\u0d9a\u0dca \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0db1\u0dca \u0dc0\u0dda.",
        "\u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1 57\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dc3\u0dc4 \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db1\u0dcf\u0dc1\u0d9a \u0d85\u0d82\u0dc1\u0dba \u0dc3\u0db8\u0d9f \u0dc3\u0dd4\u0dbb\u0dcf\u0db6\u0daf\u0dd4 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca 900\u0d9a\u0dca \u0db4\u0db8\u0dab \u0db8\u0dd9\u0db8 \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0dd6\u0dc4. (\u0d9a\u0dd4\u0dbb\u0dd4\u0dc5\u0dd4 \u0d9a\u0dd6\u0da2\u0db1 \u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0d9a\u0dbb\u0dc0\u0db1)"
      ],
