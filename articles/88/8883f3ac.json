          },
          {
            "text": "30",
            "label": "CARDINAL"
          },
          {
            "text": "1.00 \u0db4.\u0dc0",
            "label": "TIME"
          },
          {
            "text": "\u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0dba\u0dcf\u0db4\u0dcf \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "1.00 \u0db4.\u0dc0",
            "label": "TIME"
          }
        ],
        [
          {
            "text": "\u0d85\u0dba\u0dc0\u0dd0\u0dba \u0dc0\u0dd2\u0dc3\u0dbb\u0dca\u0da2\u0db1 \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1 \u0db4\u0db1\u0dad\u0dca \u0d9a\u0dd9\u0da7\u0dd4\u0db8\u0dca\u0db4\u0dad",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
