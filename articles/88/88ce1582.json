    "si": {
      "title": "\u0d85\u0db8\u0dca\u0db8\u0dcf \u0dc5\u0db8\u0dba\u0dd2 \u0daf\u0dd9\u0db1\u0dca\u0db1\u0dad\u0dca \u0d91\u0d9a\u0dca\u0d9a \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf \u0dc0\u0dd0\u0dc0\u0da7 \u0db4\u0db1\u0dd2\u0dba\u0dd2; \u0daf\u0dd2\u0dba\u0dab\u0dd2\u0dba \u0db8\u0dd2\u0dba \u0dba\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d87\u0db9\u0dd2\u0dbd\u0dd2\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf \u0dc0\u0dd0\u0dc0\u0da7 \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 32 \u0d9a \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0dc3\u0dd2\u0dba \u0daf\u0dbb\u0dd4 \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0daf \u0dc3\u0db8\u0d9f\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0db1\u0dd3\u0db8\u0dd0\u0dbb\u0dd4\u0db8\u0d9a\u0dca\u200c \u0d9a\u0dbb \u0dc3\u0dd2\u0dba\u0daf\u0dd2\u0dc0\u0dd2 \u0db1\u0dc3\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1 \u0d85\u0db1\u0dca\u0daf\u0db8\u0da7 \u0db8\u0dc0 \u0dc3\u0dc4 \u0d87\u0d9c\u0dda 11 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db4\u0dd4\u0dad\u0dca\u200d\u0dbb\u0dba\u0dcf \u0db6\u0dda\u0dbb\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb 05 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0daf\u0dd2\u0dba\u0dab\u0dd2\u0dba \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d85\u0dc3\u0dcf\u0db0\u0dca\u200d\u0dba \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0dda \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0db8\u0dc0 \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0d87\u0db9\u0dd2\u0dbd\u0dd2\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0daf\u0dd0\u0da9\u0dd2 \u0dc3\u0dad\u0dca\u0d9a\u0dcf\u0dbb \u0d92\u0d9a\u0d9a\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dcf\u0dbb \u0dbd\u0db6\u0db1\u0dc0\u0dcf."
      ],
