          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb\u0dcf\u0db0\u0db4\u0dd4\u0dbb \u0dad\u0dd2\u0dc4\u0dd2\u0dba\u0dcf\u0d9c\u0db8 \u0dc4\u0db1\u0dca\u0daf\u0dd2\u0dba \u0d86\u0dc4\u0dcf\u0dbb \u0db4\u0ddc\u0dc5",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dd3 \u0d8b\u0db4\u0dcf\u0dbd\u0dd2 \u0db4\u0dd2\u0dba\u0dbb\u0dad\u0dca\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0db4\u0dd4\u0dc0\u0dad\u0dca\u0dad \u0dbb\u0dc3\u0dd2\u0daf\u0dd4 \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0dba\u0d9a\u0dbd\u0dca\u0dbd \u0db8\u0dd9\u0d9c\u0ddc\u0da9\u0dc0\u0dd0\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0daf\u0dcf\u0dc3\u0dca \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0dc3\u0dd2\u0dbb\u0dcf\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dc4\u0dbd\u0dca \u0db8\u0ddd\u0dbd\u0dca",
