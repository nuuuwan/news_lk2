          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb\u0dcf\u0db0\u0db4\u0dd4\u0dbb \u0da9\u0dd3\u0da2\u0dd3 \u0dc0\u0dd2\u0da2\u0dd2\u0dad",
