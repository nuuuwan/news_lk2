          },
          {
            "text": "\u0db4\u0dbb\u0dc3\u0db1\u0dca\u0d9c\u0dc3\u0dca\u0dc0\u0dd0\u0dc0 \u0dbb\u0dad\u0dca\u0db8\u0dbd\u0dda \u0dc4\u0db1\u0dca\u0daf\u0dd2\u0dba \u0dbb\u0da2 \u0d9c\u0db6\u0da9\u0dcf",
