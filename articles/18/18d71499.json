    "si": {
      "title": "\u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0ddd \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd9\u0dad\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dc0\u0dbd \u0dbb\u0db3\u0dc0\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0db1\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 G. C. E. \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0dc3\u0dd1\u0db8 \u0dc0\u0dc3\u0dbb\u0d9a\u0db8 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0db8\u0d9f \u0d91\u0d9a\u0dca\u0dc0 \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0dad\u0dca \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0db1\u0dca \u0d8b\u0dc3\u0dc3\u0dca \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dba\u0ddc\u0db8\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0, \u0d9a\u0ddc\u0dc5\u0db9 \u0db8\u0dd0\u0d9c\u0dc3\u0dd2\u0db1\u0dca \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0dbb\u0db3\u0dc0\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7 2021 \u0dc0\u0dc3\u0dbb \u0dc3\u0db3\u0dc4\u0dcf \u00a0G. C. E. \u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0da7 \u0db4\u0dd9\u0db1\u0dd3 \u0dc3\u0dd2\u0da7\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dbb \u0dbd\u0dd0\u0db6\u0dd2\u0dab\u0dd2.",
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 38 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0db7\u0dd6 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0dc3\u0dc4 \u0dc4\u0dd2\u0db1\u0dca\u0daf\u0dd4 \u0d8b\u0dbb\u0dd4\u0db8\u0dba \u0dc3\u0db3\u0dc4\u0dcf C \u0dc3\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0dae\u0dba\u0d9a\u0dca \u0dc3\u0dc4 \u0daf\u0dd9\u0db8\u0dc5 \u0db7\u0dcf\u0dc2\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf S \u0dc3\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0dae\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0da9 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0dbb\u0db3\u0dc0\u0dcf \u0dc3\u0dd2\u0da7\u0dd2 46 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0dd9\u0d9a\u0dca \u0daf \u0daf\u0dda\u0dc1\u0db4\u0dcf\u0dbd\u0db1 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dc0, \u0db6\u0dde\u0daf\u0dca\u0db0 \u0d8b\u0dbb\u0dd4\u0db8\u0dba \u0dc3\u0dc4 \u0dc3\u0dd2\u0d82\u0dc4\u0dbd \u0dc0\u0dd2\u0dc2\u0dba\u0dba\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d91\u0dc3\u0dca \u0dc3\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0dae \u0dc3\u0dc4\u0dd2\u0dad\u0dc0 \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba \u0dc3\u0db8\u0dad\u0dca\u0dc0 \u0d87\u0dad.",
        "\u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0da9 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0da7\u0dd2 \u0dad\u0dc0\u0dad\u0dca \u0dc3\u0dd2\u0dbb\u0d9a\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dd4 \u0daf \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba \u0dc3\u0db8\u0dad\u0dca\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2 \u0db6\u0dc0 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb \u0d9a\u0ddc\u0db8\u0dd2\u0dc3\u0db8 \u0da0\u0db1\u0dca\u0daf\u0db1 \u0d92\u0d9a\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc0\u0dd3\u0dbb\u0dc0\u0d82\u0dc1 \u0dc3\u0dc4 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc3\u0dd0\u0db4\u0dca\u0dad\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca 4 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0db1\u0dc0 \u2018\u0d93\u0dad\u0dd2\u0dc4\u0dcf\u0dc3\u0dd2\u0d9a \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba\u0d9a\u0dca\u2019 \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0da7"
      ],
