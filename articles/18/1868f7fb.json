    "si": {
      "title": "\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8 \u0db4\u0dd6\u0db1\u0d9c\u0dca\u200d\u0dbb\u0dd2 \u0dc4\u0dd2 \u0dc3\u0dd4\u0dc5\u0d82 \u0d9c\u0ddc\u0dc0\u0dd2\u0db4\u0dc5: Adani Group \u0d85\u0db1\u0dd4\u0db8\u0dad \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8\u0dda \u0db8\u0dd9\u0d9c\u0dcf\u0dc0\u0ddc\u0da7\u0dca 286\u0d9a \u0dc3\u0dc4 \u0db4\u0dd6\u0db1\u0d9c\u0dca\u200d\u0dbb\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db8\u0dd9\u0d9c\u0dcf\u0dc0\u0ddc\u0da7\u0dca 234\u0d9a \u0db0\u0dcf\u0dbb\u0dd2\u0dad\u0dcf\u0dc0\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 500\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0da7\u0dd2\u0db1\u0dcf\u0d9a\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0dc3\u0dd4\u0dc5\u0d82 \u0db6\u0dbd\u0dcf\u0d9c\u0dcf\u0dbb \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dd8\u0dad\u0dd2 \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf Adani Green Energy \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0da7 \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba \u0dbd\u0dd0\u0db6\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0dcf\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0db4\u0dd6\u0db1\u0d9c\u0dca\u200d\u0dbb\u0dd2, \u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8: Adani Group",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0dcf\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "Adani Green Energy",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 500 \u0d9a\u0da7 \u0dc0\u0da9\u0dcf",
            "label": "MONEY"
          },
          {
            "text": "\u0db8\u0dd9\u0d9c\u0dcf\u0dc0\u0ddc\u0da7\u0dca 286 \u0d9a\u0dd2",
            "label": "QUANTITY"
          },
          {
            "text": "\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dd9\u0d9c\u0dcf\u0dc0\u0ddc\u0da7\u0dca 234 \u0d9a\u0dd2",
            "label": "QUANTITY"
          },
          {
            "text": "\u0db4\u0dd6\u0db1\u0d9c\u0dca\u0dbb\u0dd2",
            "label": "GPE"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0bae\u0ba9\u0bcd\u0ba9\u0bbe\u0bb0\u0bcd, \u0baa\u0bc2\u0ba8\u0b95\u0bb0\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b95\u0bbe\u0bb1\u0bcd\u0bb1\u0bbe\u0bb2\u0bc8: \u0b85\u0ba4\u0bbe\u0ba9\u0bbf \u0b95\u0bc1\u0bb4\u0bc1\u0bae\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf",
      "author": "unknown",
      "body_lines": [
        "\u0bae\u0ba9\u0bcd\u0ba9\u0bbe\u0bb0\u0bbf\u0bb2\u0bcd 286 \u0bae\u0bc6\u0b95\u0bbe \u0bb5\u0bcb\u0bb1\u0bcd \u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0bb3\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3, \u0baa\u0bc2\u0ba8\u0b95\u0bb0\u0bbf\u0baf\u0bbf\u0bb2\u0bcd 234 \u0bae\u0bc6\u0b95\u0bbe \u0bb5\u0bcb\u0bb1\u0bcd \u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0bb3\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3 500 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0ba9\u0bcd \u0b90\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0b9f\u0bca\u0bb2\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0b95\u0bbe\u0bb1\u0bcd\u0bb1\u0bbe\u0bb2\u0bc8\u0ba4\u0bcd \u0ba4\u0bbf\u0b9f\u0bcd\u0b9f \u0bae\u0bc1\u0ba4\u0bb2\u0bc0\u0b9f\u0bcd\u0b9f\u0bca\u0ba9\u0bcd\u0bb1\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba4\u0bbe\u0ba9\u0bbf \u0b95\u0bbf\u0bb1\u0bc0\u0ba9\u0bcd \u0b8e\u0ba9\u0bb0\u0bcd\u0b9c\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba9\u0bc1\u0bae\u0ba4\u0bbf \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0b95 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bb0\u0bcd \u0b95\u0bbe\u0b9e\u0bcd\u0b9a\u0ba9\u0bbe \u0bb5\u0bbf\u0b9c\u0bc7\u0b9a\u0bc7\u0b95\u0bb0 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd."
      ],
      "title_ents": [
        {
          "text": "\u0baa\u0bc2\u0ba8\u0b95\u0bb0\u0bbf, \u0bae\u0ba9\u0bcd\u0ba9\u0bbe\u0bb0\u0bcd: \u0b85\u0ba4\u0bbe\u0ba9\u0bbf \u0b95\u0bc1\u0bb4\u0bc1\u0bae\u0bae\u0bcd",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b95\u0bbe\u0b9e\u0bcd\u0b9a\u0ba9\u0bbe \u0bb5\u0bbf\u0b9c\u0bc7\u0b9a\u0bc7\u0b95\u0bb0",
            "label": "PERSON"
          },
          {
            "text": "\u0b85\u0ba4\u0bbe\u0ba9\u0bbf \u0baa\u0b9a\u0bc1\u0bae\u0bc8 \u0b86\u0bb1\u0bcd\u0bb1\u0bb2\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1",
            "label": "CARDINAL"
          },
          {
            "text": "500 \u0bae\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0ba9\u0bcd \u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0b9f\u0bbe\u0bb2\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bae\u0bc7\u0bb2\u0bcd",
            "label": "MONEY"
          },
          {
            "text": "286 \u0bae\u0bc6\u0b95\u0bbe\u0bb5\u0bbe\u0b9f\u0bcd",
            "label": "QUANTITY"
          },
          {
            "text": "\u0bae\u0ba9\u0bcd\u0ba9\u0bbe\u0bb0\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "234 \u0bae\u0bc6\u0b95\u0bbe\u0bb5\u0bbe\u0b9f\u0bcd",
            "label": "QUANTITY"
          },
          {
            "text": "\u0baa\u0bc2\u0ba8\u0b95\u0bb0\u0bbf",
            "label": "GPE"
          }
        ]
      ]
    }
  }
