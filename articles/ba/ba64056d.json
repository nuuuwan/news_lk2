            "label": "PERSON"
          },
          {
            "text": "\u0b9f\u0bb2\u0bcd\u0bb2\u0bbe\u0bb8\u0bcd",
            "label": "GPE"
          },
          {
            "text": "\u0b85\u0ba9\u0bc1\u0bb0\u0b95\u0bc1\u0bae\u0bbe\u0bb0 \u0ba4\u0bbf\u0bb8\u0bbe\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95",
            "label": "PERSON"
          },
          {
            "text": "\u0bb5\u0bbf\u0b9c\u0bbf\u0ba4 \u0bb9\u0bc7\u0bb0\u0ba4\u0bcd",
