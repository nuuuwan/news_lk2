            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dc0\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3\u0dad\u0dca\u0dc0 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
