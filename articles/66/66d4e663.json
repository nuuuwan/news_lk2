    "si": {
      "title": "\u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0db1\u0dd2\u0dba\u0db8\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0db1\u0dd2\u0db1\u0dca\u0daf \u0d9c\u0dd2\u0dc4\u0dd2\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dad\u0dba \u0db8\u0d9f \u0dc4\u0dd0\u0dbb\u0dd2\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0dad\u0dd2\u0dba\u0ddd\u0db4\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0db8\u0d9c\u0dd3 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba\u0d9a\u0dca \u0db4\u0dd2\u0dba\u0dcf\u0dc3\u0dbb \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0db1\u0dd2\u0dba\u0db8\u0dd4\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0d9a\u0dd4\u0da7 \u0db1\u0dd2\u0db1\u0dca\u0daf \u0d9c\u0ddc\u0dc3\u0dca, \u0d9c\u0dd4\u0dc0\u0db1\u0dca\u0dad\u0ddc\u0da7\u0dd4\u0db4\u0ddc\u0dc5 \u0db8\u0d9f \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda \u0db4\u0dd4\u0dc0\u0dad\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u2018\u0db6\u0ddd\u0dba\u0dd2\u0d82 737\u2019 \u0dc0\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0db8\u0dd9\u0db8 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba, \u0dc3\u0dd4\u0da9\u0dcf\u0db1\u0dba\u0dda \u0d9a\u0dbb\u0dca\u0da7\u0ddd\u0db8\u0dca \u0db1\u0dd4\u0dc0\u0dbb \u0dc3\u0dd2\u0da7 \u0d89\u0dad\u0dd2\u0dba\u0ddd\u0db4\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0d85\u0da9\u0dd2\u0dc3\u0dca \u0d85\u0db6\u0dcf\u0db6\u0dcf \u0db1\u0dd4\u0dc0\u0dbb \u0db6\u0dbd\u0dcf \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dad\u0dd2\u0db6\u0dda. \u0dba\u0dcf\u0db1\u0dba \u0dc3\u0dca\u0dc0\u0d9a\u0dca\u200d\u0dbb\u0dd3\u0dba \u0db1\u0dd2\u0dba\u0db8\u0dd4 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dba\u0dcf\u0dc3\u0dbb \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db1\u0dd2\u0dba\u0db8\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dd2\u0dba\u0dc3\u0dd0\u0dbb \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dca\u0dc0\u0d82\u0d9a\u0dca\u200d\u0dbb\u0dd3\u0dba \u0db1\u0dd2\u0dba\u0db8\u0dd4 \u0db4\u0daf\u0dca\u0db0\u0dad\u0dd2\u0dba\u0da7 \u0db6\u0dcf\u0dbb \u0daf\u0dd3 \u0db1\u0dd2\u0daf\u0dcf\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d9c\u0dd4\u0dc0\u0db1\u0dca\u0dad\u0ddc\u0da7\u0dd4\u0db4\u0ddc\u0dc5 \u0dc3\u0dc4 \u0d9c\u0dd4\u0dc0\u0db1\u0dca\u0db4\u0dae\u0dba \u0db8\u0d9f \u0dc4\u0dd0\u0dbb\u0dd3, \u0db1\u0dd2\u0dba\u0db8\u0dd4\u0dc0\u0db1\u0dca \u0d85\u0dc0\u0daf\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dcf\u0dbd\u0db1 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0daf\u0dd2\u0d9c\u0dd2\u0db1\u0dca \u0daf\u0dd2\u0d9c\u0da7\u0db8 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d87\u0db8\u0dd0\u0dad\u0dd6 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dd2."
      ],
