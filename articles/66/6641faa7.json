          "label": "CARDINAL"
        },
        {
          "text": "\u0b89\u0b9a\u0bcd\u0b9a \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd",
          "label": "ORG"
        },
        {
          "text": "\u0b87\u0b9f\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0bb2 \u0ba8\u0bbf\u0bb5\u0bbe\u0bb0\u0ba3\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0bb5\u0bbf\u0bb0\u0bc8\u0bb5\u0bbe\u0b95",
          "label": "WORK_OF_ART"
        },
        {
          "text": "\u0b9c\u0bc2\u0bb2\u0bc8 4",
          "label": "DATE"
        }
      ],
      "body_line_ents_list": [
        [
