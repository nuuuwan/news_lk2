    "si": {
      "title": "NIMH \u0dc4\u0dd2 \u0db8\u0dcf\u0db1\u0dc3\u0dd2\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0dda\u0dc0\u0dcf\u0dc0 WhatsApp \u0dc4\u0dbb\u0dc4\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d91\u0dba\u0dcf\u0dbb\u0dca\u0da7\u0dd9\u0dbd\u0dca \u0dbd\u0d82\u0d9a\u0dcf, \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0dcf\u0db1\u0dc3\u0dd2\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1\u0dba (NIMH) \u0dc3\u0db8\u0d9f \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dba\u0dd9\u0db1\u0dca, WhatsApp \u0dc3\u0dda\u0dc0\u0dcf\u0dc0 \u0dc4\u0dbb\u0dc4\u0dcf 1926 \u0db8\u0dcf\u0db1\u0dc3\u0dd2\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0dda \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dca\u0dad\u0dd2\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dc5\u0dda\u0dba. \u0db8\u0dcf\u0db1\u0dc3\u0dd2\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dc4\u0dba \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d95\u0db1\u0dd1\u0db8 \u0d85\u0dba\u0dd9\u0d9a\u0dd4\u0da7 NIMH \u0dc4\u0dd2 \u0db8\u0dcf\u0db1\u0dc3\u0dd2\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dcf\u0dbb\u0d9a \u0d85\u0d82\u0d9a\u0dba\u0da7 WhatsApp \u0dc4\u0dbb\u0dc4\u0dcf 075 555 1926 \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a. Pix by Pradeep Dilrukshana"
      ],
