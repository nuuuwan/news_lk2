          {
            "text": "4",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dad\u0dcf\u0dbb\u0d9a \u0db6\u0dcf\u0dbd\u0dc3\u0dd6\u0dbb\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dd3\u0dad\u0dcf \u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0dc0\u0dbd\u0db8",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd1\u0d9c\u0dbd\u0dca\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0d9a\u0dd1\u0d9c\u0dbd\u0dca\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dad\u0dcf\u0dbb\u0d9a \u0db6\u0dcf\u0dbd\u0dc3\u0dd6\u0dbb\u0dd2\u0dba",
