    "si": {
      "title": "\u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca,\u0dbd\u0ddc\u0d9a\u0dd4\u0dbd\u0dd6\u0dab \u0dc3\u0dc4 \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0db8\u0dd2\u0dbd \u0dba\u0dc5\u0dd2 \u0db4\u0dc4\u0dad\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca, \u0dbd\u0ddc\u0d9a\u0dd4 \u0dbd\u0dd6\u0dab\u0dd4, \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0d87\u0dad\u0dd4\u0dbd\u0dd6 \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d9a\u0dd3\u0db4\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0d9c\u0dab\u0db1\u0dca\u00a0 \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0ddc\u0dc5 \u0d86\u0dbb\u0d82\u0da0\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0db4\u0dd2\u0da7\u0d9a\u0ddc\u0da7\u0dd4\u0dc0\u0dda \u0daf\u0dda\u0dc1\u0dd2\u0dba \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a \u0dc3\u0dd2\u0dbd\u0dca\u0dbd\u0dbb \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 180 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0daf, \u0dbd\u0ddc\u0d9a\u0dd4 \u0dbd\u0dd6\u0dab\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 150 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0daf \u0db4\u0dc4\u0dc5 \u0db6\u0dd0\u0dc3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0daf\u0dd0\u0d9a\u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba.",
        "\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca \u0db8\u0dd2\u0dbd\u0daf \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 380 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dc4\u0dad \u0db6\u0dd0\u0dc3 \u0d87\u0dad. \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda\u0daf \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a \u0db8\u0dd2\u0dbd \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 220 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d85\u0da9\u0dd4\u0dc0\u0dd2 \u0d87\u0dad. \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca \u0db8\u0dd2\u0dbd \u0db8\u0dd3\u0da7 \u0dc3\u0dad\u0dd2 \u0daf\u0dd9\u0d9a\u0d9a\u0da7 \u0db4\u0db8\u0dab \u0db4\u0dd9\u0dbb \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dba\u0dda \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 230- 240 \u0d85\u0dad\u0dbb \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0dda\u0dba.",
        "\u0dbd\u0ddc\u0d9a\u0dd4 \u0dbd\u0dd6\u0dab\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddc\u0dca\u0dc0\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 150 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd2 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0d91\u0dba \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 170\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dab.",
        "\u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca\u0dc0\u0dbd\u0daf \u0dbd\u0dd6\u0dab\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 165\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dbd\u0dd9\u0dc3 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0dc0\u0db1\u0dd4 \u0daf\u0dd0\u0d9a\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba. \u0dbd\u0ddc\u0d9a\u0dd4 \u0dbd\u0dd6\u0dab\u0dd4 \u0db8\u0dd2\u0dbd \u0db8\u0dd2\u0da7 \u0db4\u0dd9\u0dbb \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dba\u0dda \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 220- 240\u0dad\u0dca \u0d85\u0dad\u0dbb\u0dba. \u0db6\u0ddc\u0dc4\u0ddc\u0db8\u0dba\u0d9a\u0dca \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca\u0dc0\u0dbd \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0d85\u0dbd \u0daf\u0dd0\u0d9a\u0dd2\u0dba \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0d85\u0dad\u0dbb \u0d92\u0dc0\u0dcf\u0dba\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dca\u0db1\u0dda \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca \u0db4\u0db8\u0dab. \u0d91\u0dc4\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 560\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u200d\u0dca\u200d\u0dbb\u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd2\u0dab.",
        "\u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0db8\u0dd2\u0dbd \u0d9c\u0dab\u0db1\u0dca\u0daf \u0dc3\u0dd0\u0dc5\u0d9a\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db8\u0da7\u0dca\u0da7\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dad \u0dc0\u0dd0\u0da7\u0dd2 \u0d87\u0dad. \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 460\u0dad\u0dca 480\u0dad\u0dca \u0d85\u0dad\u0dbb \u0db4\u0dc0\u0dad\u0dd3. \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3\u0dda \u0d91\u0dba \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 485\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0daf\u0dd0\u0d9a\u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba.",
        "\u0dc0\u0dd2\u0dba\u0dc5\u0dd2 \u0db8\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1600\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dd2\u0da7\u0d9a\u0ddc\u0da7\u0dd4\u0dc0\u0dda \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd4 \u0d85\u0dad\u0dbb \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0d91\u0dba \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1640\u0d9a\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db4\u0dd2\u0da7\u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0dc4\u0dcf \u0db1\u0dcf\u0dbb\u0dcf\u0dc4\u0dda\u0db1\u0dca\u0db4\u0dd2\u0da7 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0dc3\u0dd4\u0daf\u0dd4 \u0dc3\u0dd3\u0db1\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddc\u0db8\u0dca\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 300\u0dad\u0dca 305\u0dad\u0dca \u0d85\u0dad\u0dbb \u0db4\u0dd0\u0dc0\u0dad\u0dd2\u0dab. \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3\u0dda \u0dc3\u0dd4\u0daf\u0dd4 \u0dc3\u0dd3\u0db1\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 298\u0d9a\u0da7 \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2\u0dba. \u0d91\u0dc4\u0dd9\u0dad\u0dca \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca\u0dc0\u0dbd \u0dad\u0dc0\u0db8\u0dad\u0dca \u0dc3\u0dd3\u0db1\u0dd2 \u0db8\u0dd2\u0dbd \u0d9c\u0dab\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dca\u0db1\u0dda \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 356\u0dad\u0dca 359\u0dad\u0dca \u0d85\u0dad\u0dbb\u0dba."
      ],
