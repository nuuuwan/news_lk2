    "si": {
      "title": "\u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0db4\u0dd0\u0dba 5\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0db4\u0dd0\u0dba \u0db4\u0dc4\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0db7\u0dca\u200d\u0dbb\u0db8\u0dab \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4\u0da2\u0db1 \u0d8b\u0db4\u0dba\u0ddd\u0d9c\u0dd2\u0dad\u0dcf \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0 (PUCSL) \u0d85\u0db1\u0dd4\u0db8\u0dd0\u0dad\u0dd2\u0dba \u0dbd\u0db6\u0dcf \u0daf\u0dd3 \u0d87\u0dad.",
        "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0db1\u0dd2\u0db4\u0daf\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0d9a\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d85\u0dc0\u0dc3\u0dbb\u0dba \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0d87\u0dad.",
        "\u0dc3\u0db3\u0dd4\u0daf\u0dcf A,B, C \u0dc3\u0dc4 \u0db4\u0dd0\u0dba 5 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dba \u0dc4\u0dad\u0dbb\u0dba\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 40\u0d9a (\u0db4\u0dd9.\u0dc0. 8.30 \u0dc3\u0dd2\u0da7 \u0db4.\u0dc0. 4.30 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dba 2\u0dba\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 40\u0d9a\u0dca \u0dc3\u0dc4 \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 4.30 \u0dc3\u0dd2\u0da7 10.30 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dba 2\u0d9a\u0dca) \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 PUCSL \u0d85\u0dc0\u0dc3\u0dbb \u0dbd\u0db6\u0dcf \u0daf\u0dd3 \u0d87\u0dad. \u0dc3\u0dc4 P,Q,R,S,T,U,V,W.(DSB) \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 15 (\u0db4\u0dd9.\u0dc0. 8.30 \u0dc3\u0dd2\u0da7\u00a0 \u0dc3\u0dc0\u0dc3 4.45 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dba 2 \u0dba\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 45 \u0dba\u0dd2 \u0dc3\u0dc4 \u0dc3\u0dc0\u0dc3 4.45 \u0dc3\u0dd2\u0da7 9.45 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dba 2 \u0dba\u0dd2)"
      ],
