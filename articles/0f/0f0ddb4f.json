        },
        {
          "text": "\u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
