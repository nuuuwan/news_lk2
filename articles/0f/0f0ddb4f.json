    "si": {
      "title": "\u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0db0\u0dd4\u0dbb\u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dd2\u0d9a \u0da2\u0dd9\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u00a0 \u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3,\u00a0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf\u00a0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dba\u0dc5\u0dd2 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6 \u0d87\u0dad .",
        "\u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d91\u0db8 \u0dad\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0db8\u0dd4\u0dbd\u0dd2\u0db1\u0dca\u0db8 \u0db4\u0dad\u0dca\u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dda\u00a0 2019 \u0dc0\u0dbb\u0dca\u0dc2\u0dba\u0dda \u0db1\u0ddc\u0dc0\u0dd0\u0db8\u0dca\u0db6\u0dbb\u0dca \u0dc0\u0dd2\u0dc3\u0dd2 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1",
          "label": "PERSON"
        },
        {
          "text": "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1",
