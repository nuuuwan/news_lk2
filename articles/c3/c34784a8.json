    "si": {
      "title": "\u0dc0\u0dcf\u0dc4\u0db1 \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0db8\u0d9c\u0dd2\u0db1\u0dca QR \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba\u0da7 \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0dda \u0da0\u0dd0\u0dc3\u0dd2 \u0d85\u0d82\u0d9a\u0dba \u0d85\u0db1\u0dd4\u0dc0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd6 \u0d85\u0dba \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dcf\u0dc4\u0db1 \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dba\u0ddc\u0daf\u0dcf\u0d9c\u0dd9\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba\u0da7 \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2\u0dc0\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dbd\u0dd0\u0db6\u0dd3 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d91\u0dc3\u0dda\u0db8 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dc0\u0dcf\u0dc4\u0db1 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 4.7\u0d9a\u0dca \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0db4\u0dc0\u0dc3\u0dba\u0dd2. \u0d8a\u0dba\u0dda \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 8.30\u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db8\u0dd9\u0db8 \u0dc0\u0dcf\u0dc4\u0db1 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd4\u0dab\u0dd2.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1\u0dc4\u0dbd\u0dca 1060\u0d9a\u0dca \u0db8\u0dd9\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0d85\u0dad\u0dca\u0dc4\u0daf\u0dcf \u0db6\u0dbd\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d8a\u0dba\u0dda \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb\u0dba \u0dc4\u0dbb\u0dc4\u0dcf \u0d89\u0db1\u0dca\u0db0\u0db1\u0dc4\u0dbd\u0dca 746\u0d9a\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba. \u0db8\u0dda \u0dc4\u0dbb\u0dc4\u0dcf \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0d9c\u0db1\u0dd4\u0daf\u0dd9\u0db1\u0dd4 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.1\u0d9a\u0dca \u0db6\u0dc0\u0daf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc3\u0dd2\u0dba \u0da7\u0dca\u0dc0\u0dd2\u0da7\u0dbb\u0dca \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2.\u0dad"
      ],
      "title_ents": [],
