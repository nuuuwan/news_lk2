    "en": {
      "title": "The power cut will be less than 2 hours",
      "author": "unknown",
      "body_lines": [
        "Janaka Rathnayake, chairman of the Public Utilities Commission, said today (29) afternoon that the 3-hour power cut has been reduced to 2 hours and 20 minutes from tomorrow (30) and the power cut will continue until September 2.",
        "Accordingly, Mr. Janaka Ratnayake further mentioned that electricity will be cut for 20 zones from 'A' to 'W' for one hour during the day and for one hour and 20 minutes during the night."
      ],
      "title_ents": [
        {
          "text": "less than 2 hours",
          "label": "TIME"
        }
      ],
