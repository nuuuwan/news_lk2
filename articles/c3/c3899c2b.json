          }
        ],
        [
          {
            "text": "\u0da2\u0dda.\u0d86\u0dbb\u0dca. \u0dc3\u0dda\u0db1\u0dcf\u0db0\u0dd3\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0d8b\u0dad\u0dd4\u0dbb",
            "label": "LOC"
          },
          {
            "text": "\u0dc0\u0dbb\u0dd4\u0dab \u0da2\u0dba\u0dc3\u0dd4\u0db1\u0dca\u0daf\u0dbb",
            "label": "PERSON"
          },
          {
