    "si": {
      "title": "\u0db8\u0da9\u0d9a\u0dbd\u0db4\u0dd4\u0dc0 \u0d9c\u0d9f\u0da7 \u0d9c\u0dbd\u0dcf \u0d9c\u0dd2\u0dba \u0dbd\u0ddc\u0dbb\u0dd2\u0dba\u0d9a\u0dca",
      "author": "\u0da7\u0dd3 \u0dba\u0dd4\u0dc0\u0dbb\u0dcf\u0da2\u0dca",
      "body_lines": [
        "\u0db8\u0da9\u0d9a\u0dbd\u0db4\u0dd4\u0dc0 \u0dc0\u0dc0\u0dca\u0db1\u0dad\u0dd2\u0dc0\u0dca \u0dc0\u0dbd\u0dba\u0dd2\u0dbb\u0dc0\u0dd4 \u0db4\u0dcf\u0dbd\u0db8 \u0d85\u0dc3\u0dbd\u0daf\u0dd3 \u0db6\u0dbb \u0dbd\u0ddc\u0dbb\u0dd2 \u0dbb\u0dae\u0dba\u0d9a\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0da7 \u0db4\u0dd0\u0db1 \u0dc0\u0dbd\u0dba\u0dd2\u0dbb\u0dcf\u0dc0\u0dd4 \u0d9c\u0d9f\u0da7 \u0dc0\u0dd0\u0da7\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd2\u0dba.",
        "\u0dbd\u0ddc\u0dbb\u0dd2 \u0dbb\u0dae \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0d91\u0d9a\u0dc0\u0dbb \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0d9c\u0db8\u0db1\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dad\u0dca \u0d91\u0d9a\u0dca \u0dbd\u0ddc\u0dbb\u0dd2 \u0dbb\u0dae\u0dba\u0d9a\u0dca \u0d85\u0db1\u0dd9\u0d9a\u0dca \u0dbd\u0ddc\u0dbb\u0dd2 \u0dbb\u0dae\u0dba \u0db4\u0dc3\u0dd4\u0d9a\u0dbb \u0dba\u0dcf\u0db8\u0da7 \u0d8b\u0dad\u0dca\u0dc3\u0dc4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd3\u0dad\u0dca \u0db8\u0dd9\u0db8 \u0d85\u0db1\u0dad\u0dd4\u0dbb \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0da7 \u0db4\u0dd0\u0db1 \u0d9c\u0d9f\u0da7 \u0db4\u0dd9\u0dbb\u0dc5\u0dd4\u0dab\u0dd4 \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0da7 \u0d85\u0dbd\u0dcf\u0db7 \u0dc4\u0dcf\u0db1\u0dd2 \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd9\u0daf\u0dca\u0daf\u0dd3 \u0dc0\u0dcf\u0dc4\u0db1\u0dba\u0dda \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0dc3\u0dc4 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0d9a\u0dbb\u0dd4 \u0dc4\u0dcf\u0dc3\u0dca\u0d9a\u0db8\u0d9a\u0dd2\u0db1\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dba\u0dd9\u0db1\u0dca \u0db6\u0dda\u0dbb\u0dd3 \u0d87\u0dad."
      ],
