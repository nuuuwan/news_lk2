    "ta": {
      "title": "\u0b92\u0ba9\u0bcd\u0bb1\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0bcb\u0ba9\u0bbe\u0bb2\u0bc1\u0bae\u0bcd 2\u0b95\u0bcd\u0b95\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0ba9\u0bbe\u0bb2\u0bc1\u0bae\u0bcd 40 \u0bb0\u0bc2\u0baa\u0bbe\u0baf\u0bcd",
