          {
            "text": "\u0db8\u0dc4\u0dbb\u0d9c\u0db8 \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dc5\u0dd4\u0db6\u0ddd\u0dc0\u0dd2\u0dbd \u0dc1\u0dd2\u0d9a\u0dca\u0dc2\u0dab \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dcf\u0dc3 \u0dc4\u0dad\u0dbb\u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0db4\u0db8\u0dab\u0d9a\u0dca",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d85\u0db9",
            "label": "LOC"
          }
        ],
        [],
        [
          {
            "text": "\u0dc3\u0dde\u0d9b\u0dca\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          }
