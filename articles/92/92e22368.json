          {
            "text": "\u0bb9\u0bbf\u0b95\u0bcd\u0b95\u0b9f\u0bc1\u0bb5 \u0baa\u0ba9\u0b99\u0bcd\u0b95\u0bca\u0b9f \u0b95\u0b9f\u0bb2\u0bcd",
            "label": "LOC"
          },
