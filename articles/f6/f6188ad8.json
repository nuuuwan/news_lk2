  "original_title": "\u0da2\u0db1\u0db4\u0dad\u0dd2 \u0da2\u0dd6\u0dbd\u0dd2 13 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0d85\u0dc3\u0dca \u0dc0\u0dda",
  "text_idx": {
    "en": {
      "title": "The President will resign on July 13",
      "author": "unknown",
      "body_lines": [
        "President Gotabhaya Rajapakse has informed the Speaker in a letter that he will resign on the 13th.",
        "In the party leaders' meeting held this evening, the party leaders were of the opinion that the President and the Prime Minister should resign.",
        "Speaker's office sources say that the Speaker has informed the President and in response to the letter, the President has informed the Speaker of his resignation."
      ],
      "title_ents": [
        {
          "text": "July 13",
          "label": "DATE"
        }
      ],
