  "original_title": "\u0da9\u0ddc\u0dbd\u0dbb\u0dca\u0dc0\u0dbd\u0da7 \u0dad\u0dc0\u0dad\u0dca \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0d9a\u0dca",
  "text_idx": {
    "en": {
      "title": "Another limit for dollars",
      "author": "unknown",
      "body_lines": [
        "The Central Bank of Sri Lanka has decided to reduce the amount of foreign currency that can be held or held by a resident of Sri Lanka from US $ 15,000 to US $ 10,000."
      ],
      "title_ents": [],
