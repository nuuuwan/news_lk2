        [
          {
            "text": "\u0da7\u0dca\u200d\u0dbb\u0dd2\u0dc0\u0dd2\u0da9 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0",
            "label": "ORG"
