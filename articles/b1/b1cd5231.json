          },
          {
            "text": "\u0db4\u0dca\u0dbb\u0dad\u0dd2\u0dc1\u0d9a\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0dc3\u0dcf\u0dad\u0dca\u0db8\u0dd2\u0d9a\u0dad\u0dcf",
            "label": "GPE"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0db4\u0dd4\u0dbb \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8 \u0da2\u0dd3\u0dc0\u0db1\u0dca\u0dad\u0dbb",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d85\u0db4\u0dca\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4",
