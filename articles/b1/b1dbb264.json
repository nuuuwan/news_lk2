    "si": {
      "title": "\u0dc0\u0dcf\u0db1\u0dd2\u0da2 \u0d85\u0d82\u0dc1\u0dba\u0dda \u0d9a\u0db4\u0dca \u0d91\u0d9a \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0da7",
      "author": "unknown",
      "body_lines": [
        "2021\u00a0 \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0db4\u0ddc\u0daf\u0dd4 \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0db4\u0dad\u0dca\u200d\u0dbb (\u0d8b\u0dc3\u0dc3\u0dca \u0db4\u0dd9\u0dc5) \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dcf\u0db1\u0dd2\u0da2 \u0d85\u0d82\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dd9\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7\u00a0 \u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dc0\u0dbd\u0dd3 \u0db6\u0dcf\u0dbd\u0dd2\u0d9a\u0dcf \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d89\u0dc2\u0dd2\u0db1\u0dd2 \u0db1\u0dda\u0dc4\u0dcf \u0d85\u0db8\u0dbb\u0dbb\u0dad\u0dca\u0db1 \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dd2\u0dba \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd6\u0dc0\u0dcf\u0dba.",
        "\u0d89\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dd3\u0dc3\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0db7\u0dcf\u0d9c\u0dba\u0da7 \u0db4\u0dd9\u0db1\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0d87\u0dba \u0dc0\u0dcf\u0db1\u0dd2\u0da2 \u0d85\u0d82\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dbd\u0db6\u0dcf \u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0d8a\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0 \u0da2\u0dd3\u0dc0 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dd9\u0db1\u0dca\u0db8 \u0daf\u0dd9\u0dc0\u0db1 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0daf \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dc0\u0dbd\u0dd2 \u0db6\u0dcf\u0dbd\u0dd2\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dd2\u0dba\u0d9a \u0dc3\u0db8\u0dad\u0dca\u0dc0 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dd3 \u0dc4\u0dda\u0db8\u0dcf \u0da2\u0dba\u0dc0\u0dbb\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd4\u0dc0\u0dcf\u0dba."
      ],
