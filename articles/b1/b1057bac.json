          }
        ],
        [
          {
            "text": "\u0b8e\u0b95\u0bcd\u0bb8\u0bcd\u0baa\u0bbf\u0bb0\u0bb8\u0bcd \u0baa\u0bc7\u0bb0\u0bcd\u0bb2\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0b9a\u0bbf\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0bc2\u0bb0\u0bcd",
            "label": "GPE"
          },
          {
            "text": "9 \u0b95\u0b9f\u0bb2\u0bcd \u0bae\u0bc8\u0bb2\u0bcd\u0b95\u0bb3\u0bcd",
            "label": "QUANTITY"
          },
          {
            "text": "\u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1",
            "label": "GPE"
