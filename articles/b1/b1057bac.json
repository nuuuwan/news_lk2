            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0bb2\u0bb9\u0ba8\u0bcd\u0ba4\u0baa\u0bc1\u0bb0",
            "label": "PERSON"
          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0ba9\u0bc1\u0bae\u0bcd \u0baa\u0bb2 \u0b86\u0ba3\u0bcd\u0b9f\u0bc1\u0b95\u0bb3\u0bcd",
