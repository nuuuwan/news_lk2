        [
          {
            "text": "\u0db4\u0dd0\u0dad\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dc1\u0dca\u0dc1\u0d82\u0d9a \u0d95\u0dc2\u0daf \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4Sri LankaSri Lanka",
