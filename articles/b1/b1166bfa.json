    "si": {
      "title": "\u201c\u0da2\u0dba\u0dc3\u0dcf\u0d9c\u0dbb\u201d \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dd9\u0dbb\u0dc5 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a\u00a0 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd4 \u201c\u0da2\u0dba\u0dc3\u0dcf\u0d9c\u0dbb\u201d \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u00a0 \u0dc0\u0dd9\u0dbb\u0dc5 \u0d86\u0dbb\u0d9a\u0dc2\u0dcf\u00a0 \u0db1\u0dde\u0d9a\u0dcf \u201c\u0da2\u0dba\u0dc3\u0dcf\u0d9c\u0dbb\u201d\u00a0 \u0db1\u0db8\u0dd2\u0db1\u0dca\u00a0 \u00a0 \u00a0\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf\u00a0 \u00a0 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0dc0\u0dd9\u0dbb\u0dc5 \u0d86\u0dbb\u0d9a\u0dca\u0dc2 \u0db1\u0dde\u0d9a\u0dcf \u0dc3\u0db8\u0dd4\u0dc4\u0dba \u0dc0\u0dd9\u0dad\u00a0 \u0d91\u0d9a\u0dca \u0dc0\u0dd4 \u0db6\u0dc0 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0da2\u0dd9\u0db1\u0dbb\u0dcf\u0dbd\u0dca (\u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dd2\u0d9a ) \u0d9a\u0db8\u0dbd\u0dca \u0d9c\u0dd4\u0dab\u0dbb\u0dad\u0dca\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0dad\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd\u0dba \u0db1\u0dcf\u0dc0\u0dd2\u0d9a\u00a0 \u0dad\u0da8\u0dcf\u0d9a\u0dcf\u0d82\u0d9c\u0db1 \u0db4\u0dbb\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dba\u0dda \u0daf\u0dd3\u00a0 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd2\u0dab\u0dd2.",
        "\u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db1\u0dde\u0d9a\u0dcf \u0dc3\u0db8\u0dd4\u0dc4\u0dba\u0dda \u0dad\u0dd2\u0db6\u0dd4 \u0dc3\u0dd3 \u0da2\u0dd3 61 \u0db1\u0db8\u0dca \u0dc0\u0dd4\u00a0 \u00a0\u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0dca\u0db1\u0dca \u0d89\u0d9a\u0dd4\u0dad\u0dca \u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd2 \u0db8\u0dc3\u00a0 \u0dc0\u0dd9\u0dbb\u0dc5 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad\u00a0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dcf\u0db1\u0dba \u0d9a\u0dc5 \u0db6\u0dc0 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0d91\u0db8\u00a0 \u0dc3\u0dd3 \u0da2\u0dd3\u00a0 61 \u0db1\u0db8\u0dca \u0d91\u0db8\u00a0 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0daf\u0dc1\u0d9a\u00a0 4 \u0d9a \u0db4\u0dd4\u0dbb\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0dc3\u0dd4\u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dd2 \u0db8\u0dd9\u0dc4\u0dd9\u0dc0\u0dbb\u0d9a\u0dca\u00a0 \u0d89\u0da7\u0dd4\u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db4\u0dc3\u0dd4\u0dc0 \u0dc0\u0dd9\u0dbb\u0dc5 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0dc0\u0dd9\u0dad \u0db6\u0dcf\u0dbb \u0daf\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u00a0 \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0da2\u0dba\u0dc3\u0dcf\u0d9c\u0dbb\u00a0 \u0db1\u0db8\u0dd2\u0db1\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd4 \u0db6\u0dc0 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0da2\u0dba\u0dc3\u0dcf\u0d9c\u0dbb \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u00a0 \u00a0\u0daf\u0dd2\u0d9c\u0dd2\u0db1\u0dca \u0db8\u0dd3\u0da7\u0dbb\u0dca 39.8 \u0daf, \u0db4\u0dc5\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd3\u0da7\u0dbb\u0dca 7\u00a0 \u00a0 \u0daf\u0dd2\u0d9c\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0d9a\u0dca\u0dad \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2 \u0da7\u0ddc\u0db1\u0dca 313 \u0d9a \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca\u0dad \u0dc0\u0dda.",
        "\u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca 10 \u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0dc4\u0dcf\u00a0 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a\u0dba\u0db1\u0dca 68\u00a0 \u0daf\u0dd9\u0db1\u0d9a\u0dd4\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0d9a\u0dcf\u0dbb\u0dca\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0dc0\u0dd9\u0dad\u0dd2."
      ],
