    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba\u0da7 \u0dad\u0dd3\u0d9a\u0dca\u0dc2\u0dab, \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dcf\u0dbd\u0d9c\u0dda \u0dc3\u0dc4 \u0db8\u0db1\u0dc3\u0dd2\u0d82\u0dc4 \u0d91\u0d9a\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0d9c\u0dcf\u0dbd\u0dca\u0dbd\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0da7 \u0db4\u0dd9\u0dbb \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0daf\u0d9f \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8\u0dda \u0dc0\u0dd2\u0d9a\u0dbd\u0dca\u0db4\u0dba \u0dc1\u0d9a\u0dca\u0dad\u0dd2\u0db8\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db8\u0dc4\u0dda\u0dc2\u0dca \u0dad\u0dd3\u0d9a\u0dca\u0dc2\u0dab, \u0daf\u0dd4\u0db1\u0dd2\u0dad\u0dca \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dcf\u0dbd\u0d9c\u0dda \u0dc3\u0dc4 \u0dbd\u0d9a\u0dca\u0dc2\u0dd2\u0dad \u0db8\u0dcf\u0db1\u0dc3\u0dd2\u0d82\u0dc4 \u0dba\u0db1 \u0daf\u0d9f \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dc0\u0db1\u0dca\u0db1\u0db1\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0d87\u0dad."
      ],
