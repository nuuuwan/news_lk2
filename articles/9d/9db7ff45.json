            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dbd\u0db6\u0db1 \u0db8\u0dcf\u0dc3\u0dda 1 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0dc3\u0dd1\u0db8 \u0db8\u0dc3\u0d9a\u0db8 1 \u0dc0\u0db1 \u0dc3\u0dc4 15 \u0dc0\u0db1 \u0daf\u0dd2\u0db1",
            "label": "DATE"
          }
