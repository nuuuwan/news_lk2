            "text": "\u0d9c\u0dbd\u0dca\u0dc0\u0dd0\u0dc0 \u0dc3\u0dd2\u0dbb\u0dd2\u0db0\u0db8\u0dca\u0db8 \u0dc4\u0dd2\u0db8\u0dd2",
