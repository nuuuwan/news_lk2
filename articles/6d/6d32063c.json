    "si": {
      "title": "\u0db4\u0dd2\u0dbd\u0dd2\u0db4\u0dd3\u0db1\u0dba \u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0dbd\u0dd0\u0db9\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db4\u0dbb\u0dd2\u0db8\u0dcf\u0dab\u0dba\u0dda \u0d92\u0d9a\u0d9a 7.1 \u0d9a \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0dc3\u0da7\u0dc4\u0db1\u0dca \u0d9a\u0dc5 \u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0daf\u0dd2\u0d9c \u0db4\u0dd2\u0dbd\u0dd2\u0db4\u0dd3\u0db1\u0dba\u0dda \u0dbd\u0dd4\u0dc3\u0ddc\u0db1\u0dca \u0daf\u0dd6\u0db4\u0dad \u0d9a\u0dd0\u0dbd\u0dd0\u0db9\u0dd2\u0dab\u0dd2.",
        "\u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0dc0\u0dd4 \u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0db6\u0dc0\u0dad\u0dca 60 \u0d9a\u0da7 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd4\u0dab\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0db4\u0dd2\u0dbd\u0dd2\u0db4\u0dd3\u0db1 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba. \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc3\u0dc4 \u0d9c\u0ddc\u0da9\u0db1\u0dd0\u0d9c\u0dd2\u0dbd\u0dd2 \u0dbb\u0dd0\u0dc3\u0d9a\u0dca \u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0db1\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dc4\u0da7\u0d9c\u0dad\u0dca\u0dad\u0dda \u0da9\u0ddc\u0dbd\u0ddd\u0dbb\u0dda\u0dc3\u0dca \u0db1\u0d9c\u0dbb\u0dba\u0da7 \u0d94\u0db6\u0dca\u0db6\u0dd9\u0db1\u0dca \u0d9a\u0dd2\u0dbd\u0ddd \u0db8\u0dd2\u0da7\u0dbb\u0dca 11 \u0d9a\u0dca \u0daf\u0dd4\u0dbb\u0dd2\u0db1\u0dca \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0db4\u0dad\u0dd4\u0dc5\u0dda\u0dba.",
        "\u0db7\u0dd6\u0db8\u0dd2 \u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0dcf\u0db1\u0dd2 \u0dc0\u0dd4\u0dab\u0dd4 \u0d9c\u0ddc\u0da9\u0db1\u0dd0\u0d9c\u0dd2\u0dbd\u0dd2 \u0d9c\u0dab\u0db1 108 \u0d9a\u0dd2. \u0db1\u0dcf\u0dba\u0dba\u0dd1\u0db8\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0db1\u0dcf\u0dc1 \u0dc0\u0dd4\u0dab\u0dd4 \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0d9c\u0dab\u0db1 58 \u0d9a\u0dd2."
      ],
