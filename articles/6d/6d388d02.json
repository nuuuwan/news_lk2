    "si": {
      "title": "\u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0dad\u0dad\u0dca\u0db4\u0dbb 10 \u0da7 \u0d85\u0da9\u0dd4 \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dc5 \u0db4\u0dc5\u0db8\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a\u0dba\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d94\u0dbd\u0dd2\u0db8\u0dca\u0db4\u0dd2\u0d9a\u0dca \u0d9a\u0dd9\u0da7\u0dd2 \u0daf\u0dd4\u0dbb \u0db0\u0dcf\u0dc0\u0db1 \u0dc1\u0dd6\u0dbb \u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0d85\u0db6\u0dda\u0d9a\u0ddd\u0db1\u0dca \u0dc3\u0dca\u0dc0\u0dd2\u0da7\u0dca\u0dc3\u0dbb\u0dca\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dbb\u0dd9\u0dc3\u0dd2\u0dc3\u0dca\u0db4\u0dca\u200d\u0dbb\u0dd2\u0db1\u0dca\u0da7\u0dca \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dad\u0dbb\u0d9c\u0dba\u0dda\u0daf\u0dd3 \u0dad\u0dad\u0dca\u0db4\u0dbb 9.96 \u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0d89\u0dc3\u0dc0\u0dca\u0dc0\u0dda \u0db1\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db8\u0dd2\u0db1\u0dca \u0d91\u0db8 \u0d89\u0dc3\u0dc0\u0dca\u0dc0\u0dda \u0dad\u0dad\u0dca\u0db4\u0dbb 10 \u0d9a \u0db6\u0dcf\u0db0\u0d9a\u0dba \u0db6\u0dd2\u0db3 \u0daf\u0dd0\u0db8\u0dd6 \u0db4\u0dc5\u0db8\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a\u0dba\u0dcf \u0dc0\u0dd2\u0dba.",
        "\u0d85\u0db6\u0dda\u0d9a\u0ddd\u0db1\u0dca \u0d89\u0dc3\u0dc0\u0dca\u0dc0 \u0da2\u0dba\u0d9c\u0dad\u0dca \u0d85\u0dad\u0dbb \u0d9a\u0dd2\u0dba\u0dd4\u0db6\u0dcf\u0db1\u0dd4 \u0d9a\u0dd9\u0da7\u0dd2 \u0daf\u0dd4\u0dbb \u0db0\u0dcf\u0dc0\u0db1 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0dbb\u0dd9\u0dba\u0dd2\u0db1\u0dd2\u0dba\u0dbb\u0dca \u0db8\u0dd9\u0db1\u0dcf \u0dad\u0dad\u0dca\u0db4\u0dbb 9.99\u0d9a\u0dd2\u0db1\u0dca \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0db8\u0dba\u0dd2\u0d9a\u0dbd\u0dca \u0dc3\u0dd3\u0dc3\u0dca \u0db8\u0dd9\u0db6\u0dcf \u0dad\u0dad\u0dca\u0db4\u0dbb 10.00\u0d9a\u0dd2\u0db1\u0dca \u0dad\u0dbb\u0d9c\u0dba \u0db1\u0dd2\u0db8\u0d9a\u0dbb \u0dad\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd2\u0dba.",
        "\u0d85\u0db6\u0dda\u0d9a\u0ddd\u0db1\u0dca \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0da7 \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf \u0db4\u0dc5\u0db8\u0dd4 \u0dad\u0dbb\u0d9c\u0dba\u0dda\u0daf\u0dd3 \u0dad\u0dad\u0dca\u0dad\u0dca\u0db4\u0dbb 10.11\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd2\u0dba."
