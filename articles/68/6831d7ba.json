    "si": {
      "title": "\u0db1\u0dd9\u0dc3\u0dca\u0da7\u0ddd\u0db8\u0ddd\u0dbd\u0dca\u0da7\u0dca \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba \u0d9a\u0ddc\u0dc5\u0db9\u0daf\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dad\u0dbb\u0dd4\u0dab \u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0db8\u0d9f\u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dd3\u0db8 \u0dba\u0da7\u0dad\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd9\u0dc3\u0dca\u0dbd\u0dda \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0d9f \u0d91\u0d9a\u0dca\u0dc0 \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0daf\u0dd9\u0dc0\u0db1 \u0dc0\u0dbb\u0da7\u0dad\u0dca \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db1\u0dd9\u0dc3\u0dca\u0da7\u0ddd\u0db8\u0ddd\u0dbd\u0dca\u0da7\u0dca \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba 2022, 500\u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d85\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dcf\u0dab\u0dca\u0da9 \u0dc4\u0dad\u0d9a\u0dca \u0dba\u0da7\u0dad\u0dda \u0d89\u0dbb\u0dd2\u0daf\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2. \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dd2\u0dad\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0daf \u0db8\u0dd9\u0dbd\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dd2"
      ],
