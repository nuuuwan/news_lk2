    "si": {
      "title": "\u0db4\u0dd2\u0da7\u0dd4\u0dc0\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0db6\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u200d\u0dba instagrammer \u0d9c\u0dda \u0dbb\u0dd2\u0da7\u0dca \u0db4\u0dd9\u0dad\u0dca\u0dc3\u0db8 CA \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dad\u0db8\u0db1\u0dca\u0dc0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dd4\u0dc0\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d9c\u0dad\u0dca \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0da7 \u0dbd\u0d9a\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db6\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u200d\u0dba \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf \u0d89\u0db1\u0dca\u0dc3\u0dca\u0da7\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca \u0d9c\u0dcf\u0dba\u0dd2\u0d9a\u0dcf \u0d9a\u0dda\u0dbd\u0dd3 \u0dc6\u0dca\u200d\u0dbb\u0dda\u0dc3\u0dbb\u0dca \u0d9c\u0ddc\u0db1\u0dd4 \u0d9a\u0dc5 \u0dbb\u0dd2\u0da7\u0dca \u0db4\u0dd9\u0dad\u0dca\u0dc3\u0db8\u0d9a\u0dca \u0d85\u0db7\u0dd2\u0dba\u0dcf\u0da0\u0db1\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0daf \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dca\u200d\u0dbb\u0db7 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf \u0dc3\u0db8\u0dcf\u0da2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0dbd\u0dda\u0d9b\u0db1\u0d9c\u0dad \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0d9a\u0dda\u0dbd\u0dd3 \u0dc6\u0dca\u200d\u0dbb\u0dda\u0dc3\u0dbb\u0dca \u0db8\u0dd9\u0db8 \u0db4\u0dd9\u0dad\u0dca\u0dc3\u0db8 \u0d9c\u0ddc\u0db1\u0dd4 \u0d9a\u0dc5\u0dda \u0dad\u0db8\u0db1\u0dca \u0d85\u0dad\u0dca\u0dad\u0db1\u0ddd\u0db8\u0dad\u0dd2\u0d9a \u0dbd\u0dd9\u0dc3 \u0db4\u0dd2\u0da7\u0dd4\u0dc0\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d86\u0d9c\u0db8\u0db1 \u0dc4\u0dcf \u0dc0\u0dd2\u0d9c\u0db8\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d9c\u0dad\u0dca \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d85\u0dc0\u0dbd\u0d82\u0d9c\u0dd4 \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3\u0da7 \u0db1\u0dd2\u0dba\u0ddd\u0d9c\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3\u0dba\u0dd2. (\u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca \u0dc3\u0dd6\u0dbb\u0dd2\u0dba\u0d9c\u0ddc\u0da9)"
