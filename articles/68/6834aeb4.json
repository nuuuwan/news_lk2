    "si": {
      "title": "\u0dc3\u0dcf\u0db1\u0dca\u0dad \u0da2\u0ddd\u0dc3\u0db4\u0dca \u0db4\u0dd2\u0dbd\u0da7 \u0dc0\u0dd2\u0dc1\u0dd2\u0dc2\u0dca\u0da7 \u0da2\u0dba\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0dd2\u0dba",
