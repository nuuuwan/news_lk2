    "ta": {
      "title": "\u0b9a\u0bc6\u0baf\u0bbf\u0ba9\u0bcd\u0b9f\u0bcd \u0b9c\u0bcb\u0b9a\u0baa\u0bcd \u0b85\u0ba3\u0bbf \u0b85\u0baa\u0bbe\u0bb0 \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf \u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1",
