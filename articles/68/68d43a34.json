            "label": "PERSON"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dc4\u0dcf\u0dbd\u0dd2 \u0d91\u0dbd\u0dca-\u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0d85\u0dad\u0dbb \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db4\u0dca\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0dcf\u0dbd\u0dd2 \u0d91\u0dbd\u0dca \u0dc3\u0dd2\u0da7 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0\u0da7 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db4\u0dd0\u0da7\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0d9a\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4\u0dc0 \u0d87\u0dad. \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0d86\u0dba\u0ddd\u0da2\u0d9a\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dba \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dba\u0dd2"
      ],
      "title_ents": [
        {
          "text": "\u0dc4\u0dcf\u0dbd\u0dd2 \u0d91\u0dbd\u0dca-\u0d9a\u0ddc\u0da7\u0dd4\u0dc0",
          "label": "PERSON"
        }
      ],
