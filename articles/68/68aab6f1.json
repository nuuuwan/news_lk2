    "si": {
      "title": "\u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d85\u0db7\u0dd2\u0db6\u0dc0\u0dcf \u0dba\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0d9a\u0dc5\u0dda\u0dba - 2022 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba\u0dda \u0d86\u0dbb\u0db8\u0dca\u0db7\u0d9a \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2 \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0dab\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0da9\u0dd4\u0dbd\u0dd4 8 \u0d9a \u0da2\u0dba\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db8\u0ddc\u0dc4\u0ddc\u0db8\u0da9\u0dca \u0db1\u0db6\u0dd3\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba \u0dad\u0dbb\u0d9c\u0dba\u0dda \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dad\u0dd4\u0db1\u0dd9\u0db1\u0dca\u0db8 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d85\u0db7\u0dd2\u0db6\u0dc0\u0dcf \u0d9c\u0dd2\u0dba\u0dda\u0dba.",
        "\u0dc4\u0dc3\u0dca\u0dbb\u0dad\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dc3\u0dcf\u0dba\u0dd2 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 37*\u0d9a\u0dca \u0db6\u0dd2\u0db3 \u0daf\u0dd0\u0db8\u0dd6 \u0d85\u0dad\u0dbb \u0dbb\u0dc4\u0dca\u0db8\u0dcf\u0db1\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0d9c\u0dd4\u0dbb\u0dca\u0db6\u0dcf\u0dc3\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 40\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0dc3\u0dca\u0dbb\u0dad\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dc3\u0dcf\u0dba\u0dd2 \u0d91\u0d9a\u0dca \u0d9a\u0da9\u0dd4\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0daf\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba. \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 106\u0d9a\u0dca \u0dc4\u0db9\u0dcf\u0d9c\u0dd2\u0dba \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba \u0d86\u0dbb\u0db8\u0dca\u0db7\u0d9a \u0db4\u0dd2\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc0\u0db1 \u0dc4\u0dc3\u0dca\u0dbb\u0dad\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dc3\u0dcf\u0dba\u0dd2 \u0dc3\u0dc4 \u0dbb\u0dc4\u0dca\u0db8\u0dcf\u0db1\u0dd4\u0dbd\u0dca\u0dbd\u0dcf \u0d9c\u0dd4\u0dbb\u0dca\u0db6\u0dcf\u0dc3\u0dca \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0d9a\u0dd4 \u0db1\u0ddc\u0daf\u0dd0\u0dc0\u0dd3 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 83\u0d9a\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0d9a\u0dbb\u0daf\u0dca\u0daf\u0dd3 \u0dc3\u0dcf\u0dbb\u0dca\u0dae\u0d9a \u0d86\u0dbb\u0db8\u0dca\u0db7\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba."
      ],
