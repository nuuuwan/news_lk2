    "si": {
      "title": "\u0dc4\u0dbb\u0d9a\u0dca \u0db6\u0dbd\u0db1\u0dca\u0db1 \u0d9c\u0dd2\u0dba \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0dc0\u0dbd\u0dca \u0d85\u0dbd\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dbb\u0dd4\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d9c\u0dc0\u0dba\u0dd2\u0db1\u0dca \u0db6\u0dd0\u0dbd\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9c\u0dd2\u0dba \u0daf\u0dd2\u0db9\u0dd4\u0dbd\u0dcf\u0d9c\u0dbd \u0dc3\u0dc4 \u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0db1\u0dca\u0daf, \u0daf\u0dd2\u0db9\u0dd4\u0dbd\u0dcf\u0d9c\u0dbd \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dc0\u0dbd \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0d9a\u0dd4 21 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0d91\u0dbd\u0dca\u0dbd \u0d9a\u0dc5 \u0dc0\u0db1 \u0d85\u0dbd\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0db1\u0dca\u0daf \u0dc3\u0dc4 \u0d85\u0dbb\u0dbd\u0d9c\u0d82\u0dc0\u0dd2\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d85\u0dbb\u0dbd\u0d9c\u0d82\u0dc0\u0dd2\u0dbd \u0d9a\u0db1\u0dca\u0daf\u0dda\u0d9c\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dca\u0dba\u0dda \u0daf\u0dd3 \u0dc0\u0dbd\u0dca \u0d85\u0dbd\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca\u0dad\u0dda\u00a0 \u0dc3\u0dbb\u0dad\u0dca \u0db4\u0dcf\u0dbd\u0dd2\u0dad,\u00a0 \u0d85\u0dc0\u0dd2\u0dc0\u0dcf\u0dc4\u0d9a \u0d85\u0dba\u0d9a\u0dd4 \u0dc3\u0dc4\u00a0\u00a0\u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0db1\u0dca\u0daf \u0daf\u0dd2\u0db9\u0dd4\u0dbd\u0dcf\u0db1\u0dda \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dd4\u0daf\u0dd2\u0dba\u0db1\u0dca\u0dc3\u0dda\u0dbd\u0dcf\u0d9c\u0dda \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dba\u0db1 \u0dad\u0dd2\u0dc3\u0dca \u0dc4\u0dad\u0dca \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0d85\u0dba\u0d9a\u0dd4 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2."
      ],
