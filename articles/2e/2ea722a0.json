            "label": "CARDINAL"
          },
          {
            "text": "\u0d87\u0db1\u0dca\u0da7\u0db1\u0dd2 \u0dc0\u0dda\u0dbb\u0d82\u0d9c \u0db4\u0dd4\u0dc2\u0dca\u0db4\u0dd2\u0d9a\u0dcf",
