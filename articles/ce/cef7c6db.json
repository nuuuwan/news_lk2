          }
        ],
        [
          {
            "text": "\u0ba8\u0bbf\u0bb2\u0bcd\u0bb5\u0bb2\u0bbe \u0b8e\u0bb2\u0bc6\u0b95\u0bcd\u0b9f\u0bcd\u0bb0\u0bbf\u0b9a\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf \u0baa\u0bbf\u0bb0\u0bc8\u0bb5\u0bc7\u0b9f\u0bcd. \u0bb2\u0bbf\u0bae\u0bbf\u0b9f\u0bc6\u0b9f\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0bb5\u0bbf\u0b9f\u0bc1\u0b9a\u0bb5\u0bbf\u0baf \u0b95\u0bae\u0ba4 \u0b92\u0bb2\u0bbf\u0b95\u0bcd",
            "label": "WORK_OF_ART"
          }
        ],
        [
