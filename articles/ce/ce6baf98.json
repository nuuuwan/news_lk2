          {
            "text": "\u0dbd\u0ddd\u0d9a \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dd2\u0da9 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dd3\u0d9a\u0dbb\u0dab \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dd2\u0da9 \u0d8a\u0dc5\u0dcf\u0db8\u0dca \u0db8\u0dc4\u0da2\u0db1 \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba",
            "label": "ORG"
          },
          {
