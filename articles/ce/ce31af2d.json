    "si": {
      "title": "\u0d9a\u0ddd\u0da0\u0dca\u0da0\u0dd2 \u0db4\u0dcf\u0dbb \u0d85\u0dba\u0dd2\u0db1\u0dd9\u0db1\u0dca \u0db8\u0dc5\u0dc3\u0dd2\u0dbb\u0dd4\u0dbb\u0dd4 \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0dc4\u0db8\u0dd4 \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0db9\u0dda\u0db4\u0dd4\u0dc3\u0dca\u0dc3 \u0dc4\u0dcf \u0db6\u0ddd\u0dad\u0dbd\u0dda \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0daf\u0dd9\u0d9a \u0d85\u0dad\u0dbb \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db4\u0da7\u0dd4 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0d85\u0dba\u0dd2\u0db1\u0dda \u0dc0\u0dd0\u0da7\u0dd3 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd2\u0da7\u0dd2 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0d9a\u0dd4\u0d9c\u0dda \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb\u0dd4 \u0dc4\u0db8\u0dd4 \u0dc0\u0dd6 \u0db6\u0dc0 \u0db8\u0dd3\u0dbb\u0dd2\u0d9c\u0db8 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0dc3\u0dbb\u0db8\u0dca \u0dc4\u0dcf \u0d9a\u0db8\u0dd2\u0dc3\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd0\u0dbb\u0dc3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0db8\u0dd9\u0db8 \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dad\u0dbb\u0db8\u0d9a\u0dca \u0dc0\u0dba\u0dc3\u0dca\u0d9c\u0dad\u0dc0\u0dd6\u0dc0\u0db1\u0dca \u0db6\u0dc0 \u0db4\u0dd9\u0db1\u0dd2\u0dba\u0db1 \u0db6\u0dc0\u0daf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0db8\u0dda \u0daf\u0dd9\u0db1\u0dca\u0db1\u0dcf \u0db4\u0da7\u0dd4 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0d85\u0dba\u0dd2\u0db1\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba\u0dda \u0d9c\u0dd0\u0da7\u0dd4\u0db1\u0dcf\u0daf \u0db1\u0dd0\u0dad\u0dc4\u0ddc\u0dad\u0dca \u0d9a\u0dd2\u0dc3\u0dd2\u0dba\u0db8\u0dca \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dd4\u0db1\u0dcf \u0daf\u0dd0\u0dba\u0dd2 \u0dc4\u0dd9\u0dbd\u0dd2 \u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2."
      ],
