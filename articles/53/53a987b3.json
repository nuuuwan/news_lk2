        [
          {
            "text": "\u0b9a\u0bbf\u0bb1\u0bbf\u0b95\u0bca\u0ba4\u0bcd\u0ba4",
            "label": "PERSON"
          },
          {
            "text": "\u0b90.\u0ba4\u0bc7.\u0b95",
            "label": "ORG"
