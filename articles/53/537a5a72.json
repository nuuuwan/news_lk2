          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0da8\u0dbd\u0dd3 \u0dc3\u0db8\u0dca\u0db6\u0dd2\u0d9a \u0dbb\u0dab\u0dc0\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "43 \u0dc0\u0dd0\u0db1\u0dd2 \u0db6\u0dbd\u0dc3\u0dda\u0db1\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0da2\u0db1 \u0dc0\u0dd2\u0db8\u0dd4\u0d9a\u0dca\u0dad\u0dd2 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0da2\u0db1\u0dad\u0dcf \u0dc0\u0dd2\u0db8\u0dd4\u0d9a\u0dca\u0dad\u0dd2 \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd4\u0db1\u0dd2\u0dbd\u0dca \u0d85\u0dad\u0dd4\u0db1\u0dd9\u0dad\u0dd2",
            "label": "PERSON"
          },
          {
