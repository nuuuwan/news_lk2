          },
          {
            "text": "Australia",
            "label": "GPE"
          },
          {
            "text": "Waruna Wanniarachchi",
            "label": "PERSON"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0d9a\u0dc4 \u0db4\u0dcf\u0da7\u0dd2\u0db1\u0dca \u0dbb\u0dc3\u0dd2\u0d9a\u0dba\u0ddd...",
      "body_lines": [
        "\u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba\u0d9a\u0dca \u0db8\u0db0\u0dca\u200d\u0dba\u0dba\u0dda \u0db8\u0dd9\u0db8 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba \u0daf\u0dd2\u0d9c\u0da7\u0db8 \u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dba\u0dcf\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0dc3\u0dca\u0dad\u0dd4\u0dad\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dbd\u0ddd\u0dbd\u0dd3\u0db1\u0dca \u0d9a\u0dc4 \u0d87\u0db3\u0dd4\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd0\u0dbb\u0dc3\u0dd3 \u0d86\u0dbb\u0dca. \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0dab\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0dc0\u0dbb\u0dd4\u0dab \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2"
      ],
      "title_ents": [],
