    "si": {
      "title": "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0\u0dda \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0d9a \u0db6\u0ddd\u0db8\u0dca\u0db6 \u0db6\u0dd2\u0dba\u0d9a\u0dca - \u0db8\u0dbb\u0dab 2\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0\u0dda \u0db6\u0dca\u200d\u0dbb\u0dd2\u0da7\u0dd2\u0dc2\u0dca \u0d9a\u0ddc\u0dbd\u0ddc\u0db8\u0dca\u0db6\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0d9a \u0db6\u0ddd\u0db8\u0dca\u0db6 \u0db6\u0dd2\u0dba\u0d9a\u0dca \u0dc3\u0db8\u0d9c \u0dc3\u0db1\u0dca\u0db1\u0daf\u0dca\u0db0 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0d9a\u0dca\u0dc2\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0d9c\u0dd0\u0da7\u0dd4\u0db8 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc4\u0dba \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7 \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0db6\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db6\u0ddd\u0db8\u0dca\u0db6 \u0db6\u0dd2\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0dc3\u0dbd \u0d87\u0dad\u0dd2 \u0db1\u0dd2\u0dc0\u0dcf\u0dc3\u0dc0\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0d89\u0dc0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7\u0daf \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db8\u0dda \u0dc3\u0db8\u0d9c \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0dad\u0dbb\u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb,\u00a0\u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db6\u0dc0 \u0d9a\u0dd0\u0db1\u0da9\u0dcf \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
