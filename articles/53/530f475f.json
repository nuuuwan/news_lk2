    "si": {
      "title": "\u0db8\u0db1\u0dca\u0d9a\u0dd2\u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 50,000 \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dba\u0dd2 - WHO",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba \u0dad\u0dd4\u0dc5 \u0db8\u0db1\u0dca\u0d9a\u0dd2\u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 50,000\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0\u0d9a\u0dca \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0da7 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dda\u0d9b\u0db1 \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dba\u0dd2.",
        "\u0da2\u0dd4\u0dbd\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba \u0db4\u0dd0\u0dad\u0dd2\u0dbb\u0dba\u0dcf\u0db8 \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0db8\u0dc4\u0da2\u0db1 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0da7 \u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d92\u0da2\u0db1\u0dca\u0dc3\u0dd2\u0dba \u0dc4\u0dd9\u0dc0\u0dad\u0dca \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba\u00a0\u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0daf\u0dad\u0dca\u0dad \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda \u0db8\u0dda \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 50,496\u0d9a\u0dca \u0dc3\u0dc4 \u0db8\u0dbb\u0dab 16\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3\u00a0\u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2."
      ],
