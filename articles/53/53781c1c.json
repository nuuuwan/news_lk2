    "ta": {
      "title": "\u0b9a\u0bbe\u0bae\u0bb0\u0bbf \u0b85\u0ba4\u0baa\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bbf\u0ba9\u0bcd \u0b86\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0bb4\u0b95\u0bcd\u0b95\u0bbe\u0bae\u0bb2\u0bcd, \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0baa\u0bcd \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bbe\u0b95 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bc8 \u0b8e\u0bb3\u0bbf\u0ba4\u0bbe\u0b95 \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf \u0baa\u0bc6\u0bb1 \u0bb5\u0bb4\u0bbf\u0bb5\u0b95\u0bc1\u0ba4\u0bcd\u0ba4\u0ba4\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "COLOMBO (News 1st); \u0ba4\u0bbf\u0b99\u0bcd\u0b95\u0b9f\u0bcd\u0b95\u0bbf\u0bb4\u0bae\u0bc8 (27) \u0ba4\u0bbf\u0bae\u0baa\u0bc1\u0bb2\u0bcd\u0bb2\u0bbe\u0bb5\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf \u0bae\u0b95\u0bb3\u0bbf\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0bae\u0bc2\u0ba9\u0bcd\u0bb1\u0bbe\u0bb5\u0ba4\u0bc1 \u0b9f\u0bbf20 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0baa\u0bb5\u0bb0\u0bcd-\u0bb9\u0bbf\u0b9f\u0bcd\u0b9f\u0bb0\u0bcd \u0b9a\u0bbe\u0bae\u0bb0\u0bbf \u0b85\u0ba4\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 \u0b86\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0bb4\u0b95\u0bcd\u0b95\u0bbe\u0bae\u0bb2\u0bcd 80 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0bb5\u0bbf\u0bb3\u0bbe\u0b9a\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd.",
        "\u0bae\u0bc1\u0ba4\u0bb2\u0bbf\u0bb2\u0bcd \u0baa\u0bc7\u0b9f\u0bcd\u0b9f\u0bbf\u0b99\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0ba4 \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0bcd 20 \u0b93\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd 138/5 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd, \u0b9c\u0bc6\u0bae\u0bbf\u0bae\u0bbe \u0bb0\u0bcb\u0b9f\u0bcd\u0bb0\u0bbf\u0b95\u0bcd\u0bb8\u0bcd 33 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bcd \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd, \u0bb8\u0bcd\u0bae\u0bbf\u0bb0\u0bc1\u0ba4\u0bbf \u0bae\u0ba8\u0bcd\u0ba4\u0ba9\u0bbe \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bc7\u0ba9\u0bbf \u0bae\u0bc7\u0b95\u0ba9\u0bbe \u0ba4\u0bb2\u0bbe 22 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bcd \u0b8e\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bae\u0b95\u0bb3\u0bbf\u0bb0\u0bcd \u0b85\u0ba3\u0bbf \u0b9a\u0bbe\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0b9a\u0bc1\u0b95\u0ba8\u0bcd\u0ba4\u0bbf\u0b95\u0bbe \u0b95\u0bc1\u0bae\u0bbe\u0bb0\u0bbf, \u0b85\u0bae\u0bbe \u0b95\u0bbe\u0b9e\u0bcd\u0b9a\u0ba9\u0bbe, \u0b92\u0bb7\u0bbe\u0ba4\u0bbf \u0bb0\u0ba3\u0b9a\u0bbf\u0b99\u0bcd\u0b95, \u0b87\u0ba9\u0bcb\u0b95\u0bbe \u0bb0\u0ba3\u0bb5\u0bc0\u0bb0 \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0ba4\u0bb2\u0bbe \u0b92\u0bb0\u0bc1 \u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd\u0b9f\u0bc8 \u0b95\u0bc8\u0baa\u0bcd\u0baa\u0bb1\u0bcd\u0bb1\u0bbf\u0ba9\u0bb0\u0bcd.",
        "139 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0ba4\u0bc1\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0baf \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bae\u0b95\u0bb3\u0bbf\u0bb0\u0bcd \u0b85\u0ba3\u0bbf, \u0bb5\u0bbf\u0bb7\u0bcd\u0bae\u0bbf \u0b95\u0bc1\u0ba3\u0bb0\u0ba4\u0bcd\u0ba9\u0bc7\u0bb5\u0bc8 5 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0b87\u0bb4\u0ba8\u0bcd\u0ba4\u0bc1 \u0bae\u0bc6\u0ba4\u0bc1\u0bb5\u0bbe\u0b95\u0ba4\u0bcd \u0ba4\u0bca\u0b9f\u0b99\u0bcd\u0b95\u0bbf\u0baf\u0ba4\u0bc1.",
        "\u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bc1\u0bae\u0bcd, \u0b95\u0bc7\u0baa\u0bcd\u0b9f\u0ba9\u0bcd \u0b9a\u0bbe\u0bae\u0bb0\u0bbf \u0b85\u0ba4\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb2\u0b95\u0bcd\u0bb7\u0bbf \u0b9f\u0bbf \u0b9a\u0bbf\u0bb2\u0bcd\u0bb5\u0bbe \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b85\u0ba3\u0bbf\u0baf\u0bc8 100 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0b95\u0b9f\u0ba8\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd, \u0baa\u0bbf\u0ba8\u0bcd\u0ba4\u0bc8\u0baf\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd 30 \u0bb0\u0ba9\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bc0\u0bb4\u0bcd\u0b9a\u0bcd\u0b9a\u0bbf\u0baf\u0b9f\u0bc8\u0ba8\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd.",
        "\u0b95\u0bc7\u0baa\u0bcd\u0b9f\u0ba9\u0bcd \u0b9a\u0bbe\u0bae\u0bb0\u0bbf \u0b85\u0ba4\u0baa\u0ba4\u0bcd\u0ba4\u0bc1 17\u0bb5\u0ba4\u0bc1 \u0b93\u0bb5\u0bb0\u0bbf\u0bb2\u0bcd \u0bb2\u0bc6\u0b95\u0bcd \u0b9a\u0bc8\u0b9f\u0bbf\u0bb2\u0bcd \u0bb0\u0bbe\u0ba4\u0bbe \u0baf\u0bbe\u0ba4\u0bb5\u0bcd \u0baa\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb5\u0bc0\u0b9a\u0bcd\u0b9a\u0bbf\u0bb2\u0bcd 4 \u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bb3\u0bc8 \u0bb5\u0bc0\u0bb4\u0bcd\u0ba4\u0bcd\u0ba4\u0bbf \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf\u0baf\u0bc8 \u0b89\u0bb1\u0bc1\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bae\u0b95\u0bb3\u0bbf\u0bb0\u0bcd \u0b9f\u0bbf20 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb5\u0bc8 \u0b9a\u0bca\u0ba8\u0bcd\u0ba4 \u0bae\u0ba3\u0bcd\u0ba3\u0bbf\u0bb2\u0bcd \u0bb5\u0bc0\u0bb4\u0bcd\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bc1 \u0b87\u0ba4\u0bc1\u0bb5\u0bc7 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0bae\u0bc1\u0bb1\u0bc8.",
        "\u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bbf\u0bb2\u0bc1\u0bae\u0bcd \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf \u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf \u0bae\u0b95\u0bb3\u0bbf\u0bb0\u0bcd \u0b85\u0ba3\u0bbf 2-1 \u0b8e\u0ba9\u0bcd\u0bb1 \u0b95\u0ba3\u0b95\u0bcd\u0b95\u0bbf\u0bb2\u0bcd \u0ba4\u0bca\u0b9f\u0bb0\u0bc8 \u0b95\u0bc8\u0baa\u0bcd\u0baa\u0bb1\u0bcd\u0bb1\u0bbf\u0baf\u0ba4\u0bc1.",
        "\u0b9a\u0bbe\u0bae\u0bb0\u0bbf \u0b85\u0ba4\u0bcd\u0ba4\u0baa\u0ba4\u0bcd\u0ba4\u0bc1, \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b85\u0ba3\u0bbf\u0ba4\u0bcd\u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b86\u0b9f\u0bcd\u0b9f \u0ba8\u0bbe\u0baf\u0b95\u0ba9\u0bcd.",
        "\u0b9a\u0bbe\u0bae\u0bb0\u0bbf \u0b85\u0ba4\u0baa\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bbf\u0ba9\u0bcd \u0b86\u0b9f\u0bcd\u0b9f\u0bae\u0bbf\u0bb4\u0b95\u0bcd\u0b95\u0bbe\u0bae\u0bb2\u0bcd, \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0baa\u0bcd \u0baa\u0bc6\u0ba3\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b8e\u0ba4\u0bbf\u0bb0\u0bbe\u0b95 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bc8 \u0b8e\u0bb3\u0bbf\u0ba4\u0bbe\u0b95 \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf \u0baa\u0bc6\u0bb1 \u0bb5\u0bb4\u0bbf\u0bb5\u0b95\u0bc1\u0ba4\u0bcd\u0ba4\u0ba4\u0bc1",
        "\u0ba8\u0bbf\u0ba4\u0bbf \u0ba8\u0bbf\u0bb0\u0bcd\u0bb5\u0bbe\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bc1\u0b9f\u0bcd\u0baa \u0b89\u0ba4\u0bb5\u0bbf\u0baf\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95 \u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bbe; \u0b89\u0baf\u0bb0\u0bcd\u0bae\u0b9f\u0bcd\u0b9f \u0baa\u0bbf\u0bb0\u0ba4\u0bbf\u0ba8\u0bbf\u0ba4\u0bbf\u0b95\u0bb3\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bae\u0bb0\u0bc8 \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd"
