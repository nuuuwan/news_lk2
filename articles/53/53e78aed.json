        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8 \u0da2\u0dd3\u0dc0\u0db1\u0dca\u0daf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0da2\u0dba\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0db4\u0dd4\u0dbb \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc1\u0d9a\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dab \u0dc4\u0dcf \u0d85\u0dab\u0dd4\u0d9a \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddd\u0dc0\u0dd2\u0da7\u0dca",
