    "si": {
      "title": "\u0daf\u0dda\u0dc0 \u0db8\u0dcf\u0dad\u0dcf\u0dc0\u0da7 \u0db4\u0dc5\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0dbb\u0db1\u0dca \u0d86\u0db7\u0dbb\u0dab \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc0\u0da9\u0db8\u0dcf\u0dbb\u0da0\u0dca\u0da0\u0dd2 \u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb \u0d9a\u0da7\u0dca\u0da7\u0dd9\u0dba\u0dd2\u0d9a\u0dcf\u0da9\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0d9a\u0dad\u0ddc\u0dbd\u0dd2\u0d9a \u0daf\u0dda\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0d9a \u0daf\u0dda\u0dc0 \u0db8\u0dcf\u0dad\u0dcf\u0dc0\u0da7 \u0db4\u0dc5\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6\u0dbb\u0db1\u0dca \u0d86\u0db7\u0dbb\u0dab \u0d8a\u0dba\u0dda (17\u0daf\u0dcf)\u00a0 \u0d9a\u0dd2\u0dc3\u0dd2\u0dba\u0db8\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0ddc\u0da7 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db8\u0dbb\u0db3\u0db1\u0dca\u0d9a\u0dda\u0db1\u0dd2 \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0daf\u0dda\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0daf\u0dda\u0dc0 \u0db8\u0dd9\u0dc4\u0dd9\u0dba \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba 14 \u0dc3\u0dc4 15 \u0dba\u0db1 \u0daf\u0dd2\u0db1\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0db4\u0dd0\u0dc0\u0dad\u0dca\u0dc0\u0dd4\u0db1\u0dd4 \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0daf\u0dd2\u0db1\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0daf\u0dda\u0dc0 \u0db8\u0dd9\u0dc4\u0dd9\u0dba \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd6 \u0db6\u0dc0\u0da7\u0dad\u0dca \u0d91\u0dba\u0da7 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd6 \u0dba\u0db8\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d85\u0daf\u0dcf\u0dbd \u0dbb\u0db1\u0dca\u0d86\u0db7\u0dbb\u0db1 \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0da7 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0dc3\u0dd0\u0d9a \u0db4\u0dbd \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0daf\u0dda\u0dc0 \u0db8\u0dcf\u0dad\u0dcf\u0dc0\u0da7 \u0db4\u0dc5\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0dbb\u0db1\u0dca \u0d86\u0db6\u0dbb\u0dab \u0dc3\u0ddc\u0dbb\u0d9c\u0dad\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0dca \u0d9a\u0dc0\u0dca\u0dbb\u0dd4\u0db1\u0dca\u0daf\u0dd0\u0dba\u0dd2 \u0dba\u0db1\u0dca\u0db1 \u0db8\u0dd9\u0dad\u0dd9\u0d9a\u0dca \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0db1\u0dba \u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0daf\u0dda\u0dc0\u0db8\u0dcf\u0dad\u0dcf\u0dc0\u0da7 \u0dc4\u0dcf\u0db1\u0dd2\u0dba\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0\u0da7\u0dad\u0dca \u0dbb\u0dab\u0dca \u0d86\u0db6\u0dbb\u0dab \u0db4\u0db8\u0dab\u0d9a\u0dca \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0dc4\u0db1\u0dca \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0daf\u0dda\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dd6\u0da2\u0d9a\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dc5\u0dd2 \u0d9a\u0ddc\u0da7 \u0d87\u0dad.",
        "\u0dc3\u0ddc\u0dbb\u0dcf\u0d9c\u0dad\u0dca \u0dbb\u0dab\u0dca\u0d86\u0db6\u0dbb\u0dab \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 30 \u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0dc0\u0db1 \u0db6\u0dc0\u0da7\u0dad\u0dca \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0ddc\u0dba\u0dcf \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dd4\u0dbd\u0dd4\u0dbd\u0dca \u0db4\u0dbb\u0dd2\u0d9a\u0dca\u0dc2\u0dab\u0dba\u0d9a\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0ddc\u0da7 \u0d87\u0dad\u0dd0\u0dba\u0dd2\u0daf \u0db8\u0dbb\u0db3\u0db1\u0dca\u0d9a\u0dda\u0db1\u0dd2 \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
