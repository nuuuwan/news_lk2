            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0b95\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd \u0b86\u0bb1\u0bcd\u0bb1\u0bb2\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b95\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd \u0bae\u0bc7\u0bae\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0ba8\u0bbf\u0ba4\u0bbf",
