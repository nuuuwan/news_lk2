          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0daf\u0d9a\u0dca\u0dc2\u0dd2\u0dab \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
