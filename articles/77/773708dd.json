          {
            "text": "\u0dc0\u0dd9\u0dbb\u0dc5\u0db6\u0da9 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db8\u0d9c\u0dd3 \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
