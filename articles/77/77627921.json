            "text": "\u0d94\u0dbb\u0dd2\u0dba\u0db1\u0dca\u0da7\u0dca \u0dc6\u0dd2\u0db1\u0dd1\u0db1\u0dca\u0dc3\u0dca \u0db4\u0dd3\u0d91\u0dbd\u0dca\u0dc3\u0dd3",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dd9\u0dbd\u0dd2\u0db1\u0dca\u0d9a\u0ddd \u0dbd\u0dba\u0dd2\u0dc6\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
