    "ta": {
      "title": "\u0ba4\u0bc1\u0baa\u0bcd\u0baa\u0bbe\u0b95\u0bcd\u0b95\u0bbf\u0b9a\u0bcd \u0b9a\u0bc2\u0b9f\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd 02 \u0baa\u0bc7\u0bb0\u0bcd \u0baa\u0bb2\u0bbf",
