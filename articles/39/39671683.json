          },
          {
            "text": "\u0da2\u0dba\u0db1\u0dca\u0dad \u0da2\u0dba\u0dc3\u0dd6\u0dbb\u0dd2\u0dba",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dd4\u0dbb\u0dda\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
