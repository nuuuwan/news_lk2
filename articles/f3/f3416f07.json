    "si": {
      "title": "\u0db6\u0dd9\u0daf\u0dd4\u0db8\u0dca\u0dc0\u0dcf\u0daf\u0dd3 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab \u0db4\u0dbb\u0daf\u0dc0\u0db8\u0dd4...",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db6\u0dd9\u0daf\u0dd4\u0db8\u0dca\u0dc0\u0dcf\u0daf\u0dd3 \u0d9a\u0dd4\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0db4\u0dbb\u0dcf\u0da2\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0db8\u0dd4\u0dbd\u0dca \u0d9a\u0dbb\u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0db6\u0ddc\u0daf\u0dd4 \u0d8b\u0dbb\u0dd4\u0db8\u0dba \u0dc3\u0dd4\u0dbb\u0dd0\u0d9a\u0dd3\u0db8\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0d85\u0daf \u0d9c\u0dcf\u0dbd\u0dd4\u0db8\u0dd4\u0dc0\u0daf\u0ddc\u0dbb '\u0d8b\u0daf\u0dca\u0d9d\u0ddd\u0dc2\u0dab \u0d85\u0da9\u0dc0\u0dd2\u0dba' \u0d85\u0dc3\u0dbd\u0daf\u0dd3 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd4\u0dab\u0dcf. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0dc0\u0dbb\u0dd4\u0dab \u0dc0\u0db1\u0dca\u0db1\u0dd2\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db6\u0ddc\u0daf\u0dd4 \u0d8b\u0dbb\u0dd4\u0db8\u0dba \u0dc3\u0dd4\u0dbb\u0dd0\u0d9a\u0dd3\u0db8\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "\u0d8b\u0daf\u0dca\u0d9d\u0ddd\u0dc2\u0dab \u0d85\u0da9\u0dc0\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dd4 \u0db8\u0dd4\u0dc0\u0daf\u0ddc\u0dbb \u0db4\u0dd2\u0da7\u0dd2\u0dba",
            "label": "FAC"
          },
          {
            "text": "Waruna Wanniarachchi",
            "label": "PERSON"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0baa\u0bbf\u0bb0\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb3\u0bc1\u0bae\u0bcd \u0b9a\u0ba4\u0bbf\u0baf\u0bc8 \u0bae\u0bc1\u0bb1\u0bbf\u0baf\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0bcb\u0bae\u0bcd...",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0bbf\u0bb0\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb3\u0bc1\u0bae\u0bcd \u0b9a\u0ba4\u0bbf\u0baf\u0bc8 \u0bae\u0bc1\u0bb1\u0bbf\u0baf\u0b9f\u0bbf\u0b95\u0bcd\u0b95 \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0ba9\u0bcd\u0baa\u0ba9 \u0b89\u0bb3\u0bcd\u0bb3\u0bbf\u0b9f\u0bcd\u0b9f \u0baa\u0bb2\u0bcd\u0bb5\u0bc7\u0bb1\u0bc1 \u0b95\u0bcb\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0b95\u0bb3\u0bc8 \u0bae\u0bc1\u0ba9\u0bcd\u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0bca\u0ba4\u0bc1 \u0bae\u0bb0\u0baa\u0bc1\u0b95\u0bb3\u0bc8 \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0baa\u0bbf\u0bb0\u0b9a\u0bbe\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bbe\u0bb2\u0bbf \u0bae\u0bc1\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0b9f\u0bb2\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 '\u0baa\u0bcb\u0bb0\u0bbe\u0b9f\u0bcd\u0b9f \u0ba4\u0bb3\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd' \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f\u0ba9\u0bb0\u0bcd. \u0bb5\u0bb0\u0bc1\u0ba3 \u0bb5\u0ba9\u0bcd\u0ba9\u0bbf\u0baf\u0bbe\u0bb0\u0bbe\u0b9a\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0baa\u0b9f\u0b99\u0bcd\u0b95\u0bb3\u0bcd"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0baa\u0bca\u0ba4\u0bc1 \u0baa\u0bbe\u0bb0\u0bae\u0bcd\u0baa\u0bb0\u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bc8 \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0baa\u0bbf\u0bb0\u0b9a\u0bcd\u0b9a\u0bbe\u0bb0\u0bae\u0bcd",
