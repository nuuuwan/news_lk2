    "si": {
      "title": "\u0da2\u0dba\u0dbb\u0dcf\u0da2\u0dca \u0d9d\u0dcf\u0dad\u0db1\u0dba: \u0d9a\u0ddc\u0da7\u0dd2 \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dcf \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0da2\u0dba\u0dbb\u0dcf\u0da2\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4\u0db4\u0dd4\u0dbd\u0dca\u0dbd\u0dda \u0d9d\u0dcf\u0dad\u0db1\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0da7\u0dd2 \u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0dc3\u0dc4\u0d9a\u0dcf\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0dbd\u0d9a\u0dca\u0dc2\u0dca\u0db8\u0db1\u0dca \u0d9a\u0dd4\u0dbb\u0dda \u0dc3\u0dc4 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0d91\u0dbd\u0dca.\u0da7\u0dd3.\u0da7\u0dd3.\u0d8a \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a \u0dc3\u0dd9\u0dbd\u0dca\u0dc0\u0dbb\u0dcf\u0da2\u0dcf \u0d9a\u0dd8\u0db4\u0dcf\u0d9a\u0dbb\u0db1\u0dca \u0db1\u0dd2\u0daf\u0ddc\u0dc3\u0dca \u0d9a\u0ddc\u0da7 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0db8\u0dc4\u0dcf\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba\u0daf\u0dcf \u0db1\u0dd2\u0dba\u0ddd\u0d9c \u0d9a\u0dc5\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0da2\u0dba\u0dbb\u0dcf\u0da2\u0dca \u0d9d\u0dcf\u0dad\u0db1\u0dba",
