          {
            "text": "\u0dc3\u0dd9\u0dbd\u0dca\u0dc0\u0dbb\u0dcf\u0da2\u0dcf \u0d9a\u0dd8\u0db4\u0dcf\u0d9a\u0dbb\u0db1\u0dca",
