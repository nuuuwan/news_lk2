      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9c\u0db8\u0dca\u0db4\u0dc4 \u0dc3\u0dc4\u0d9a\u0dcf\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0dbd\u0d9a\u0dca\u0dc2\u0dca\u0db8\u0db1\u0dca \u0d9a\u0dd4\u0dbb\u0dda",
