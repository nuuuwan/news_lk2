    "si": {
      "title": "\u0d96\u0dc2\u0db0 120 \u0d9a \u0dc4\u0dd2\u0d9f\u0dba\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d96\u0dc2\u0db0 14\u0d9a \u0dc4\u0dd2\u0d9f\u0dba\u0da7 \u0dc0\u0dd2\u0dc3\u0db3\u0dd4\u0db8\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab \u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d85\u0db1\u0dca\u0dc0\u0dbb\u0dca \u0dc4\u0db8\u0dca\u0daf\u0dcf\u0db1\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dda \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0d85\u0d9a\u0dca\u0dc2\u0dd2 \u0d9a\u0dcf\u0da0, \u0dc1\u0dca\u200d\u0dbb\u0dc0\u0dab\u0dcf\u0db0\u0dcf\u0dbb, \u0dc1\u0dbd\u0dca\u200d\u0dba \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0dc0\u0dd0\u0db1\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0dc4\u0dd2\u0d9f\u0dba \u0db8\u0d9f\u0dc4\u0dbb\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda\u0dba. (\u0d86)"
      ],
