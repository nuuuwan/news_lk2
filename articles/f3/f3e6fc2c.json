    "si": {
      "title": "\u0db6\u0dad\u0dca\u0dad\u0dd4\u0dbd\u0dd4 \u0d94\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0dc0\u0dc3\u0dcf \u0daf\u0db8\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0db1\u0dda\u0dc0\u0dcf\u0dc3\u0dd2\u0d9a\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0d9a\u0dda\u0dbb\u0dc5 \u0d9c\u0d82\u0da2\u0dcf \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8",
      "author": "\u0da7\u0dd3 \u0dba\u0dd4\u0dc0\u0dbb\u0dcf\u0da2\u0dca",
      "body_lines": [
        "\u0db4\u0dd4\u0dad\u0dca\u0dad\u0dbd\u0db8 - \u0db6\u0dad\u0dca\u0dad\u0dd4\u0dbd\u0dd4\u0d94\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0dc3\u0d82\u0dc0\u0dd8\u0dad \u0db1\u0dda\u0dc0\u0dcf\u0dc3\u0dd2\u0d9a\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0d9a \u0dc3\u0d9f\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0d9a\u0dda\u0dbb\u0dc5 \u0d9c\u0d82\u0da2\u0dcf \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db8\u0dd4\u0db1\u0dca\u0daf\u0dbd\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8\u0dda \u0db6\u0dad\u0dca\u0dad\u0dd4\u0dbd\u0dd4\u0d94\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0dc0\u0dc3\u0dcf \u0daf\u0db8\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0dc4\u0ddd\u0da7\u0dbd\u0dba\u0d9a \u0dc3\u0d9f\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd6 \u0d9a\u0dda\u0dbb\u0dc5 \u0d9c\u0d82\u0da2\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 9 \u0d9a \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca \u0d85\u0daf (21) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0d9c\u0d82\u0da2\u0dcf \u0d87\u0dc3\u0dd4\u0dbb\u0dd4\u0db8\u0dca \u0dc4\u0ddd\u0da7\u0dbd\u0dba\u0d9a \u0dc3\u0d9f\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0d85\u0d82\u0dc1\u0dba\u0da7 \u0dbd\u0daf \u0dbb\u0dc4\u0dc3\u0dd2\u0d9c\u0dad \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0db8\u0dad \u0d91\u0db8 \u0dc4\u0ddd\u0da7\u0dbd\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dc5 \u0dc3\u0ddd\u0daf\u0dd2\u0dc3\u0dd2 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0d9a\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0d9c\u0d82\u0da2\u0dcf \u0d85\u0dc3\u0dd4\u0dbb\u0db1 \u0dbd\u0daf \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dd4\u0db1\u0dca\u0dad\u0dbd\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dc3\u0dd0\u0d9a\u0db4\u0dd2\u0da7 \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0d9a\u0dd4 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc0\u0dd2\u0db8\u0dbb\u0dca\u0dc1\u0db1 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dba\u0dd2."
      ],
