    "si": {
      "title": "\u0dad\u0dd4\u0dc0\u0dcf\u0dbd\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db6\u0dbd\u0db1\u0dca\u0db1 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0db4\u0dad\u0dd2 \u0dc0\u0dd2\u0d9a\u0dd4\u0db8\u0dca \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd\u00a0 \u00a0\u0db4\u0ddc\u0dbd\u0dca\u0daf\u0dd6\u0dc0 \u0dc0\u0da7\u0dbb\u0dc0\u0dd4\u0db8\u0dda\u0daf\u0dd3\u00a0 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0daf\u0dcf \u0d87\u0dad\u0dd2 \u0dc0\u0dd6\u00a0 \u0db1\u0ddc\u0dc3\u0db1\u0dca\u0dc3\u0dd4\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0dba \u0d85\u0dad\u0dbb\u0dad\u0dd4\u0dbb \u0db4\u0dc4\u0dbb \u0d9a\u0dd1\u0db8\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0dd0\u0db6\u0dd6\u00a0 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0db1\u0dca \u0d9c\u0dda \u0dc3\u0dd4\u0dc0 \u0daf\u0dd4\u0d9a\u0dca \u0db6\u0dd0\u0dbd\u0dd3\u0db8\u0da7 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0db4\u0dad\u0dd2 \u0dbd\u0dd4\u0dad\u0dd2\u0db1\u0db1\u0dca \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u00a0 \u0dc0\u0dd2\u0d9a\u0dd4\u0db8\u0dca\u00a0 \u00a0\u0dbd\u0dd2\u0dba\u0db1\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0d8a\u0dba\u0dda \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2\u0dba\u0dda\u0dba .",
        "\u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0dd0\u0db6\u0dd6 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0db1\u0dca \u0d85\u0dc3\u0dbd\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0d94\u0dc0\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dd4\u0dc0\u0daf\u0dd4\u0d9a\u0dca \u0dc0\u0dd2\u0db8\u0dc3\u0dd3\u0db8 \u0dba ."
      ],
