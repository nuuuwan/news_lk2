    "si": {
      "title": "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dba\u0dc5\u0dd2 \u0dc4\u0dd2\u0dc3 \u0d94\u0dc3\u0dc0\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca 62 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc3\u0dc4 \u0d86\u0dc3\u200d\u0dcf\u0daf\u0dd2\u0dad \u0db8\u0dbb\u0dab \u0dad\u0dd4\u0db1\u0d9a\u0dca \u0d8a\u0dba\u0dda (19) \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0dba\u0dcf\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6\u0dba\u0dda \u0db8\u0dcf\u0dc3 \u0daf\u0dd9\u0d9a \u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0da7 \u0db4\u0db8\u0dab \u0db4\u0dc3\u0dd4\u0dc0 \u0db6\u0dc0 \u0dc3\u0dd9\u0ddf\u0d9b\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0dba\u0dc5\u0dd2 \u0d89\u0dc4\u0dc5\u0dba\u0dcf\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0db8\u0dad\u0dd4\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0 \u0dc0\u0dc3\u0d82\u0d9c\u0dad \u0dbb\u0ddd\u0d9c \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0d85\u0d82\u0dc1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd3 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0db8\u0dd2\u0dad \u0d9c\u0dd2\u0db1\u0dd2\u0d9c\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba"
      ],
