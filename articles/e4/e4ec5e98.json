  "text_idx": {
    "en": {
      "title": "There is no momentum for unity at the party leaders' meeting",
      "author": "unknown",
      "body_lines": [
        "Opposition leader Sajith Premadasa said in a statement that Samagi Jana Balawegaya will not participate in the party leaders' meeting called by Prime Minister Ranil Wickremesinghe.",
        "A special party leader meeting is scheduled to be held today at 4 pm at the Parliament complex under the chairmanship of Prime Minister Ranil Wickramasinghe.",
        "A group of parliament workers have been called to the parliament complex to prepare the proceedings of this meeting.",
        "Mr. Sajith Premadasa is currently in a private hospital in Colombo due to a sudden illness."
      ],
