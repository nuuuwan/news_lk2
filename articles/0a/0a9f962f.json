            "label": "DATE"
          },
          {
            "text": "28",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddd\u0da7\u0dca\u0da7\u0db4\u0dcf\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db8\u0dcf\u0dc3 \u0d91\u0d9a\u0dc4\u0db8\u0dcf\u0dbb\u0d9a\u0dca",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          }
        ],
        [],
        [
          {
            "text": "\u0dbd\u0db6\u0db1 \u0db8\u0dcf\u0dc3\u0dda \u0d9a\u0dc5\u0dd4 \u0da2\u0dd6\u0dbd\u0dd2\u0dba",
            "label": "EVENT"
          }
        ],
        [
          {
            "text": "\u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2\u0dbd\u0dcf",
            "label": "GPE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
