    "en": {
      "title": "R.M.V. Introduces e-cards",
      "author": "unknown",
      "body_lines": [
        "Road Transport Commissioner (Development) Mrs. Trofi de Silva said that the ability to pay by e-card for services obtained from the Department of Motor Transport (RMV) started today (5).",
        "She said that the people will be able to use e-cards in all the services provided by the Motor Commissioner's Department and that the Motor Transport Department has also worked to fulfill that requirement as there are card payment facilities in many transactions."
      ],
      "title_ents": [
        {
          "text": "R.M.V. Introduces",
          "label": "ORG"
        }
      ],
