          },
          {
            "text": "RMV",
            "label": "ORG"
          },
          {
            "text": "today",
            "label": "DATE"
          },
          {
            "text": "5",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "the Motor Commissioner's Department",
            "label": "ORG"
          },
          {
