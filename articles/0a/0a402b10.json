    },
    "si": {
      "title": "\u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4\u0db6\u0da9 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7 \u0db6\u0dcf\u0db0\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dd3\u0dbd\u0dd2 \u0db4\u0dd0\u0db1\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4\u0db6\u0da9 \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7 \u0db6\u0dcf\u0db0\u0dcf \u0d91\u0dbd\u0dca\u0dbd \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d85\u0daf \u0daf\u0dd9\u0dbb\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0d9a\u0dbb\u0dd4 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc0\u0dc0\u0dd4\u0db1\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0dc3\u0dd2\u0da7 \u0db6\u0dd9\u0dbd\u0dd2\u0d85\u0dad\u0dca\u0dad \u0db6\u0dbd\u0dcf \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u2018\u0dbb\u0da2\u0dbb\u0da7 \u0dbb\u0dd0\u0da2\u0dd2\u0db1\u2019 \u0db8\u0d9c\u0dd3 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d85\u0daf \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d85\u0db8\u0dca\u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0d86\u0dc3\u0db1\u0dca\u0db1\u0dba\u0dda \u0db1\u0dad\u0dbb \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda."
      ],
