    "si": {
      "title": "\u0dc1\u0dcf\u0db1\u0dca\u0dad \u0d85\u0db1\u0dca\u0dad\u0ddd\u0db1\u0dd2 \u0db4\u0dd2\u0dba\u0dad\u0dd4\u0db8\u0dcf \u0dbb\u0db3\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d91\u0dc3\u0dca. \u0dad\u0ddd\u0db8\u0dc3\u0dca \u0dc3\u0da7\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2. \u0d87\u0db1\u0dca\u0da2\u0dbd\u0ddd \u0dbb\u0ddc\u0dc3\u0dcf\u0da7\u0dd2 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc4\u0dd0\u0dc0\u0dca\u0dbd\u0ddc\u0d9a\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d8a\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dd2 \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0d85\u0db1\u0dca\u0dad\u0ddd\u0db1\u0dd2 \u0db4\u0dd2\u0dbd\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 32\u0da7 25\u0d9a \u0db4\u0dc4\u0dc3\u0dd4 \u0da2\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0daf\u0dd0\u0db1\u0da7 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0da9\u0dba\u0dbd\u0ddc\u0d9c\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0d9c\u0dca\u0db6\u0dd2 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0da2\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d9c\u0dbd\u0dca\u0d9a\u0dd2\u0dc3\u0dca\u0dc3 \u0d91\u0dc3\u0dca.\u0dad\u0ddd\u0db8\u0dc3\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd2\u0dba. \u0db8\u0dd9\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d91\u0dc3\u0dca. \u0dad\u0ddd\u0db8\u0dc3\u0dca \u0db4\u0dd2\u0dba\u0dad\u0dd4\u0db8\u0dcf \u0dbb\u0db3\u0dc0\u0dcf \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba. \u0d87\u0db1\u0dca\u0da2\u0dbd\u0ddd \u0dbb\u0ddc\u0dc3\u0dcf\u0da7\u0dd2 \u0d9a\u0dd4\u0dc3\u0dbd\u0dcf\u0db1\u0dba."
      ],
