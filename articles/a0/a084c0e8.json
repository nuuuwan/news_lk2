    "si": {
      "title": "\u0db4\u0dcf\u0dc3\u0dca\u0db4\u0ddd\u0da7\u0dca \u0d9a\u0db1\u0dca\u0dad\u0ddd\u0dbb\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0daf\u0dbb\u0dd4 \u0d8b\u0db4\u0dad\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0dad\u0dca\u0dad\u0dbb\u0db8\u0dd4\u0dbd\u0dca\u0dbd\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0d86\u0d9c\u0db8\u0db1 \u0dc0\u0dd2\u0d9c\u0db8\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0db8\u0db1\u0dca \u0db6\u0dbd\u0db4\u0dad\u0dca\u200d\u0dbb \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dbb\u0dd0\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2 \u0d9c\u0dd0\u0db6\u0dd2\u0db1\u0dd2 \u0db8\u0dc0\u0d9a\u0dca \u0d85\u0daf (7) \u0d85\u0dc5\u0dd4\u0dba\u0db8 \u0daf\u0dbb\u0dd4\u0dc0\u0dd9\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc3\u0dd6\u0dad \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dc4\u0dd0\u0da7\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 26 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0db8\u0dc0 \u0dc3\u0dc4 \u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db6\u0ddc\u0dbb\u0dd0\u0dbd\u0dca\u0dbd \u0d9a\u0dcf\u0dc3\u0dbd\u0dca \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0d89\u0dad\u0dcf\u0db8 \u0dc4\u0ddc\u0db3 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dad\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0db6\u0dc0\u0dad\u0dca \u0d87\u0dba \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dda \u0dbb\u0dd0\u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0db4\u0dca\u200d\u0dbb\u0dc3\u0dd6\u0dad \u0dc0\u0dda\u0daf\u0db1\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca\u0dc0 \u0dbb\u0ddd\u0dc4\u0dbd\u0dca\u0d9c\u0dad \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d86\u0d9c\u0db8\u0db1 \u0dc0\u0dd2\u0d9c\u0db8\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dd9\u0d9a\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
