          {
            "text": "\u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0dc3\u0db1\u0dca\u0daf\u0db1\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0daf \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda",
            "label": "TIME"
          },
          {
            "text": "\u0db8\u0dcf\u0d9a\u0dca\u0dc3\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 \u0db8\u0dcf\u0dc0\u0dad",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0db8\u0daf\u0dca\u0daf\u0dd4\u0db8 \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
