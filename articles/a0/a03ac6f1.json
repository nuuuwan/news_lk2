          {
            "text": "\u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dc0\u0dab\u0dcf\u0d9c\u0dcf\u0dbb\u0dba",
