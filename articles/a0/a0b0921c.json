    "si": {
      "title": "\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0d9a\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0db1\u0dd2\u0dba\u0db1\u0dca \u0db4\u0dd9\u0daf\u0dd9\u0dc3 \u0dc3\u0dc4 \u0db1\u0d9c\u0dbb \u0dc1\u0dcf\u0dbd\u0dcf\u0dc0 \u0d85\u0dad\u0dbb \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba \u0d85\u0dc0\u0dc4\u0dd2\u0dbb \u0dc0\u0dd3 \u0d87\u0dad",
