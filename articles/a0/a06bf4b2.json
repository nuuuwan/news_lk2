    "si": {
      "title": "\u0dc0\u0dd9\u0dc5\u0db3 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba\u0d9a",
      "author": "unknown",
      "body_lines": [
        "2022 \u0dc0\u0dc3\u0dbb\u0dda \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc0\u0dd9\u0dc5\u0db3 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.2\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dda. \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0d87\u0d9f\u0dc5\u0dd4\u0db8\u0dca \u0dc4\u0dcf \u0dbb\u0dd9\u0daf\u0dd2 \u0db4\u0dd2\u0dc5\u0dd2, \u0dbb\u0db6\u0dbb\u0dca \u0dc4\u0dcf \u0db4\u0ddc\u0dbd\u0dca \u0d86\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1\u0dc0\u0dbd \u0dc0\u0dbb\u0dca\u0daf\u0db0\u0db1\u0dba \u0d9a\u0dd0\u0db4\u0dd3 \u0db4\u0dd9\u0db1\u0dd9\u0db1 \u0dbd\u0dd9\u0dc3 \u0db4\u0dd9\u0db1\u0dd9\u0db1\u0dca\u0da7 \u0dad\u0dd2\u0db6\u0dda.",
        "2021 \u0dc0\u0dc3\u0dbb\u0dda \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d91\u0db8 \u0d85\u0d9c\u0dba \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1\u0dba\u0d9a\u0dca \u0dc0\u0dd2\u0dba. \u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dbd\u0d9a\u0dcf \u0db6\u0dd0\u0dbd\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc3\u0dd2\u0dba\u0dba\u0da7 20\u0d9a\u0dca \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d91\u0dc3\u0dda\u0db8 2020, 2021 \u0dc4\u0dcf 2022 \u0db8\u0dd4\u0dbd\u0dca \u0db8\u0dcf\u0dc3 \u0dc4\u0dba \u0dc3\u0dbd\u0d9a\u0dcf \u0db6\u0dd0\u0dbd\u0dd3\u0db8\u0dda\u0daf\u0dd2 \u0dc0\u0dd9\u0dc5\u0db3\u00a0 \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dc5\u0dd2\u0db1\u0dca \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 4.4, 5.7 \u0d9a\u0dca \u0dc4\u0dcf 6.4\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0dad\u0dda \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0db4\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda. \u0daf\u0dd2\u0dba\u0db8\u0db1\u0dca\u0dad\u0dd2 \u0dc4\u0dcf \u0db8\u0dd0\u0dab\u0dd2\u0d9a\u0dca \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 20.33 \u0dc3\u0dd2\u0da7 \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 40.72\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc3\u0dd2\u0dba\u0dba\u0da7 100\u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d91\u0dc3\u0dda\u0db8 \u0dc3\u0dd0\u0d9a\u0dc3\u0dd6 \u0d86\u0dc4\u0dcf\u0dbb \u0db4\u0dcf\u0db1 \u0dc0\u0dbb\u0dca\u0d9c \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 26.70 \u0dc3\u0dd2\u0da7 45.52\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0daf \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dd4 \u0d86\u0dc4\u0dcf\u0dbb \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 15.77 \u0dc3\u0dd2\u0da7 36.39\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda."
      ],
