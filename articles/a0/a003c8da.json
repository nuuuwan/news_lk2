    "si": {
      "title": "\u0d9a\u0ddc\u0dad\u0dca\u0dad\u0dd4-\u0db6\u0dad\u0dca-\u0dbb\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0dc3\u0dd2\u0dba\u0dba\u0da7 10 \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0ddc\u0dad\u0dca\u0dad\u0dd4, \u0db6\u0dad\u0dca \u0db4\u0dd0\u0d9a\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0d9a\u0dca \u0dc3\u0dc4 \u0dbb\u0dba\u0dd2\u0dc3\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d86\u0dc4\u0dcf\u0dbb\u0dc0\u0dbd \u0db8\u0dd2\u0dbd \u0dc3\u0dd2\u0dba\u0dba\u0da7 10 \u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0d86\u0db4\u0db1\u0dc1\u0dcf\u0dbd\u0dcf \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d85\u0dc3\u0dda\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0dc3\u0dda \u0d86\u0db4\u0db1\u0dc1\u0dcf\u0dbd\u0dcf \u0d86\u0dc4\u0dcf\u0dbb \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 10 \u0d9a\u0dd2",
          "label": "PERCENT"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d85\u0dc3\u0dda\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca",
