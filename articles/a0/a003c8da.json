  "original_title": "\u0d9a\u0ddc\u0dad\u0dca\u0dad\u0dd4-\u0db6\u0dad\u0dca-\u0dbb\u0dba\u0dd2\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0dc3\u0dd2\u0dba\u0dba\u0da7 10 \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
  "text_idx": {
    "en": {
      "title": "Kottu-rice-rice prices up by 10 percent",
      "author": "unknown",
      "body_lines": [
        "Asela Sampath, president of the All Ceylon Restaurant Owners' Association, said prices of all foods, including kottu, a packet of rice and rice, would be increased by about 10 percent.",
        "Mr. Sampath added that due to the increase in fuel prices, restaurants have to increase food prices."
      ],
      "title_ents": [
        {
          "text": "10 percent",
          "label": "PERCENT"
        }
      ],
