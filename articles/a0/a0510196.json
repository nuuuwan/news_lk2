    "si": {
      "title": "\u0db1\u0dc0 Covid Omicron \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0db8\u0dd4 \u0dc0\u0dd2\u0dba: WHO",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COVID-19 \u0dc4\u0dd2 Omicron \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0dda \u0db1\u0dc0 \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0d9a\u0dca BA.2.75 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0dc0\u0dd2\u0dc0\u0dd2\u0db0 \u0dbb\u0da7\u0dc0\u0dbd \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca Tedros Adhanom Ghebreyesus \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "Ghebreyesus \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dbd\u0ddd\u0d9a \u0d86\u0dba\u0dad\u0db1\u0dba \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0d85\u0db1\u0dd4\u0d9c\u0db8\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dba\u0dd2. \u201cCOVID-19 \u0db8\u0dad, \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2 \u0daf\u0dd9\u0d9a \u0dad\u0dd4\u0dc5 \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 30 \u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda. \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0d8b\u0db4 \u0d9a\u0dbd\u0dcf\u0db4 \u0dc4\u0dba\u0dd9\u0db1\u0dca \u0dc4\u0dad\u0dbb\u0d9a\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0d9a\u0daf\u0dd3 \u0d9c\u0dd9\u0db6\u0dca\u200d\u0dbb\u0dd9\u0dba\u0dd2\u0dc3\u0dc3\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u201c\u0dba\u0dd4\u0dbb\u0ddd\u0db4\u0dba\u0dda \u0dc3\u0dc4 \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0\u0dda, BA.4 \u0dc3\u0dc4 BA.5 \u0db0\u0dcf\u0dc0\u0db1 \u0dad\u0dbb\u0d82\u0d9c \u0dc0\u0dda. \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0dc0\u0dd0\u0db1\u0dd2 \u0dbb\u0da7\u0dc0\u0dbd BA.2.75 \u0dc4\u0dd2 \u0db1\u0dc0 \u0d8b\u0db4 \u0db4\u0dd9\u0dc5\u0db4\u0dad\u0d9a\u0dca \u0daf \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0d85\u0db4\u0dd2 \u0d85\u0db1\u0dd4\u0d9c\u0db8\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db8\u0dd4, \u201dWHO \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc4\u0dcf \u0db4\u0dc0\u0dd4\u0dbd\u0dca \u0dc3\u0dd4\u0db6\u0dc3\u0dcf\u0db0\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0db6\u0daf\u0dcf\u0daf\u0dcf, \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db4\u0dd0\u0dba 24 \u0dad\u0dd4\u0dc5 \u0db1\u0dc0 COVID \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 16,159 \u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0, \u0d91\u0db8 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 15,394 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dbb\u0ddd\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0db6\u0dcf \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba \u0d86\u0dbb\u0db8\u0dca\u0db7\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0dc3\u0dd4\u0dc0\u0dba \u0dbd\u0dd0\u0db6\u0dd6 \u0db8\u0dd4\u0dc5\u0dd4 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 4,29,07,327 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda. \u0daf\u0dd0\u0db1\u0da7 \u0dba\u0dae\u0dcf \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0d85\u0db1\u0dd4\u0db4\u0dcf\u0dad\u0dba \u0dc3\u0dd2\u0dba\u0dba\u0da7 98.53 \u0d9a\u0dd2.",
        "\u0d8a\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0da5 \u0dc3\u0dde\u0db8\u0dca\u200d\u0dba \u0dc3\u0dca\u0dc0\u0dcf\u0db8\u0dd2\u0db1\u0dcf\u0daf\u0db1\u0dca \u0d9a\u0dd2\u0dba\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dda BA.2.75 \u0dbd\u0dd9\u0dc3 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0db1 \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0d9a\u0dca \u0db8\u0dad\u0dd4\u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\"\u0db8\u0dd4\u0dbd\u0dd2\u0db1\u0dca\u0db8 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0db4\u0dc3\u0dd4\u0dc0 \u0dad\u0dc0\u0dad\u0dca \u0dbb\u0da7\u0dc0\u0dbd\u0dca 10 \u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd2\u0dba,\" \u0d87\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dcf\u0dba.",
        "\u201c\u0dc0\u0dd2\u0dc1\u0dca\u0dbd\u0dda\u0dc2\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0dda \u0dc3\u0dd3\u0db8\u0dd2\u0dad \u0d85\u0db1\u0dd4\u0db4\u0dd2\u0dc5\u0dd2\u0dc0\u0dd9\u0dbd\u0dc0\u0dbd\u0dca \u0dad\u0dc0\u0db8\u0dad\u0dca \u0db4\u0dc0\u0dad\u0dd3, \u0db1\u0db8\u0dd4\u0dad\u0dca \u0db8\u0dd9\u0db8 \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0da7 \u0dc3\u0dca\u0db4\u0dba\u0dd2\u0d9a\u0dca \u0db4\u0dca\u200d\u0dbb\u0ddd\u0da7\u0dd3\u0db1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0dc4\u0d9a-\u0db6\u0db1\u0dca\u0db0\u0db1 \u0dc0\u0dc3\u0db8 \u0db8\u0dad \u0dc0\u0dd2\u0d9a\u0dd8\u0dad\u0dd2 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0dd9\u0db1\u0dda. \u0d91\u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db4\u0dd0\u0dc4\u0dd0\u0daf\u0dd2\u0dbd\u0dd2\u0dc0\u0db8, \u0d91\u0dba \u0db8\u0dcf\u0db1\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0dc4\u0d9a\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dc0\u0db1 \u0dc0\u0ddb\u0dbb\u0dc3\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d9a\u0ddc\u0da7\u0dc3\u0d9a\u0dd2. \u0d92 \u0db1\u0dd2\u0dc3\u0dcf \u0d85\u0db4\u0dd2\u0da7 \u0d92\u0d9a \u0db6\u0dbd\u0dcf\u0d9c\u0db1\u0dca\u0db1 \u0dc0\u0dd9\u0db1\u0dc0\u0dcf. \u0db8\u0dd9\u0db8 \u0d8b\u0db4 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba\u0da7 \u0d85\u0dad\u0dd2\u0dbb\u0dda\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc1\u0d9a\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dab \u0db8\u0d9c \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda \u0d9c\u0dd4\u0dab \u0dad\u0dd2\u0db6\u0dda\u0daf \u0db1\u0dd0\u0dad\u0dc4\u0ddc\u0dad\u0dca \u0d87\u0dad\u0dca\u0dad \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca\u0db8 \u0dc0\u0da9\u0dcf \u0dc3\u0dcf\u0dba\u0db1\u0dd2\u0d9a\u0dc0 \u0db6\u0dbb\u0db4\u0dad\u0dbd \u0dc0\u0dd3\u0db8\u0dda \u0d9c\u0dd4\u0dab \u0dad\u0dd2\u0db6\u0dda\u0daf\u0dd0\u0dba\u0dd2 \u0daf\u0dd0\u0db1 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dad\u0dc0\u0db8\u0dad\u0dca \u0d9a\u0dbd\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0dba. \u0d85\u0db4\u0dd2 \u0d92\u0d9a \u0daf\u0db1\u0dca\u0db1\u0dda \u0db1\u0dd0\u0dc4\u0dd0, \u201d\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0da5\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u201c\u0d91\u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d85\u0db4\u0da7 \u0db6\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1\u0dd4 \u0d87\u0dad,\u201d \u0d87\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1\u0dba \u0d91\u0dba \u0dbd\u0dd4\u0dc4\u0dd4\u0db6\u0db3\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca SARS-CoV-2 \u0dc0\u0ddb\u0dbb\u0dc3\u0dca \u0db4\u0dbb\u0dd2\u0dab\u0dcf\u0db8\u0dba (TAG-VE) \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d91\u0dc4\u0dd2 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0db1\u0dd2\u0dbb\u0db1\u0dca\u0dad\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0ddc\u0dc0 \u0db4\u0dd4\u0dbb\u0dcf \u0daf\u0dad\u0dca\u0dad \u0daf\u0dd9\u0dc3 \u0db6\u0dbd\u0db1 \u0db6\u0dc0\u0dad\u0dca\u0dba. .",
        "\u0dbd\u0ddd\u0d9a \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dca \u0d9a\u0dc5\u0db8\u0dab\u0dcf\u0d9a\u0dbb\u0dd4 COVID-19 \u0d85\u0db6\u0dca\u0da9\u0dd2 \u0db8\u0dc4\u0db8\u0dd4\u0daf\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0daf\u0dd0\u0db1\u0dca \u0d9a\u0dcf\u0dbd\u0dba \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u201c\u0d85\u0db4\u0dd2 \u0dad\u0dc0\u0db8\u0dad\u0dca \u0dc0\u0dc3\u0d82\u0d9c\u0dad\u0dba \u0db8\u0db0\u0dca\u200d\u0dba\u0dba\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0dad\u0dbb \u0dc0\u0ddb\u0dbb\u0dc3\u0dba\u0da7 \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db6\u0dbd\u0dba\u0d9a\u0dca \u0d89\u0dad\u0dd2\u0dbb\u0dd2\u0dc0 \u0d87\u0dad. \u0d91\u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d91\u0dba BA.4 \u0dc4\u0ddd BA.5 \u0dc4\u0ddd BA.2.75 \u0dc4\u0ddd \u0dc0\u0dda\u0dc0\u0dcf, \u0dc0\u0ddb\u0dbb\u0dc3\u0dba \u0daf\u0dd2\u0d9c\u0da7\u0db8 \u0db4\u0dc0\u0dad\u0dd2\u0db1\u0dd4 \u0d87\u0dad. \u0d91\u0dba \u0dba\u0dc4\u0db4\u0dad \u0d9a\u0dbb\u0db1 \u0daf\u0dda \u0d9a\u0dbb\u0dba\u0dd2, \u201d\u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dd2\u0db1\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dc0\u0db1\u0dca \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0dc0\u0dd9\u0dc3\u0dca\u0db8\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db4\u0dd0\u0dc5\u0db3\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca, \u0dc3\u0dd9\u0db1\u0d9f \u0d9c\u0dd0\u0dc0\u0dc3\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0dc5\u0d9a\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca, \u0dc0\u0da9\u0dcf\u0dad\u0dca \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0da7 \u0dbd\u0d9a\u0dca\u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc3\u0dc4 \u0d89\u0dc4\u0dc5 \u0d85\u0dc0\u0daf\u0dcf\u0db1\u0db8\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0da2\u0db1\u0d9c\u0dc4\u0db1\u0dba \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba. (ANI)"
      ],
