    "si": {
      "title": "\u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dcf \u0da9\u0dd0\u0dc4\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba \u0daf\u0dbb\u0dd4\u0dc0\u0dcf\u0d9c\u0dda \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb \u0dc4\u0db8\u0dd4\u0dc0\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d9a\u0db1\u0dca\u0da9\u0dbd\u0db8 \u0daf\u0dd4\u0db1\u0dca\u0db1 \u0db6\u0dd2\u0db3\u0dd4\u0dab\u0dd4\u0dc0\u0dd0\u0dc0\u0dda\u00a0 \u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca\u0da9\u0dd0 \u0dc4\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba \u0dc4\u0dad\u0dca \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0d9a\u0dd4\u0da9\u0dcf \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dcf\u0d9c\u0dda \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb \u0d85\u0da9\u0dd2\u00a0 \u0dc0\u0dd2\u0dc3\u0dca\u0dc3\u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a\u00a0 \u0d9c\u0dd0\u0db9\u0dd4\u0dbb\u0dd4 \u0dc0\u0dbd\u0d9a \u0dad\u0dd2\u0db6\u0dd3 16 \u0daf\u0dd2\u0db1 \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 \u0daf\u0dc4\u0dba\u0dba\u0dd2\u00a0 10.45 \u0da7 \u0db4\u0db8\u0dab \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dda \u0d9a\u0dd2\u0db8\u0dd2\u0daf\u0dd4\u0db8\u0dca \u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0ddc\u0dba\u0dcf\u0d9c \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "15\u00a0 \u00a0\u0daf\u0dd2\u0db1 \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db8\u0dc0 \u0db4\u0dd2\u0dba\u0dcf \u0dc3\u0dc4 \u0dc3\u0dc4\u0ddd\u0daf\u0dbb\u0dd2\u0dba \u0dc3\u0db8\u0d9c \u0daf\u0dd2\u0dba \u0db1\u0dd1\u0db8\u0da7 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0db8\u0dd9\u0db8\u00a0 \u00a0\u0daf\u0dbb\u0dd4\u0dc0\u0dcf\u00a0 \u0db4\u0dd2\u0dba\u0dcf\u0d9c\u0dda \u0d85\u0dad\u0dd2\u0db1\u0dca \u0d91\u0dbd\u0dca\u0dbd\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0da9\u0dd0\u0dc4\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dd2\u0dab\u0dd2.",
        "\u0daf\u0dbb\u0dd4\u0dc0\u0dcf \u0dc3\u0dd9\u0dc0\u0dd3\u0db8\u0dda \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0d91\u0db8 \u0db8\u0ddc\u0dc4\u0ddc\u0dad\u0dda \u0dc3\u0dd2\u0da7\u00a0 \u0db8\u0dda \u0dc0\u0db1 \u0dad\u0dd9\u0d9a\u0dca \u0d9a\u0dca\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0dd2\u0dba, \u0db4\u0dc3\u0dd4\u0dc0 \u0dc3\u0dd3\u0d9c\u0dd2\u0dbb\u0dd2\u0dba \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dda\u00a0 \u0d9a\u0dd2\u0db8\u0dd2\u0daf\u0dd4\u0db8\u0dca\u00a0 \u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0d9c\u0dd9\u0db1\u0dd0\u0dc0\u0dd2\u0dad\u0dca \u0dc0\u0dd0\u0dc0\u0dda \u0dc3\u0ddd\u0daf\u0dd2\u0dc3\u0dd2 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0dc0\u0dd0\u0dc0 \u0db8\u0dd0\u0daf\u0da7 \u0dc0\u0db1\u0dca\u0db1\u0da7 \u0db4\u0dca\u0dbb\u0daf\u0dda\u0dc1\u0dca\u0dba\u0dda \u0d85\u0da9\u0dd2 \u0dc0\u0dd2\u0dc3\u0dd2 25\u0d9a \u0db4\u0db8\u0dab \u0d9c\u0dd0\u0db9\u0dd4\u0dbb\u0dd4 \u0dc0\u0dbd\u0dca\u0d9a \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0daf\u0dbb\u0dd4\u0dc0\u0dcf\u0d9c\u0dda \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb \u0dc3\u0ddc\u0dba\u0dcf\u00a0 \u0d9c\u0dd9\u0db1 \u0d87\u0dad\u00a0 \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb\u0dda \u0dad\u0dd0\u0db1 \u0dad\u0dd0\u0db1 \u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0db4\u0dcf \u0d9a\u0dd1 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd\u00a0 \u0daf\u0dd0\u0d9a \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd3\u0db8 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2."
      ],
