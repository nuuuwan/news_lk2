    "si": {
      "title": "\u0dba\u0dd6\u0dbb\u0dd2\u0dba\u0dcf \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0db1\u0dd0\u0dc0\u0dad\u0dca \u0db8\u0dd9\u0dd2 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d91\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0dab\u0dba \u0dba\u0ddd\u0da2\u0db1\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0db8\u0dba \u0dba\u0da7\u0dad\u0dda \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0dba\u0dd4\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 21,000\u0d9a\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0daf\u0dd9\u0dc0\u0db1 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0db8\u0dd9\u0db8 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0da7 \u0dbd\u0d9f\u0dcf\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0 \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d91\u0dbd\u0dd9\u0dc3 \u0dbd\u0dd0\u0db6\u0dd9\u0db1 \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dad\u0ddc\u0d9c\u0dba \u0dc4\u0dcf \u0daf\u0dd0\u0db1\u0da7 \u0dba\u0dbd \u0d9a\u0db1\u0dca\u0db1\u0dba \u0dc3\u0daf\u0dc4\u0dcf \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb \u0d89\u0dad\u0dd2\u0dbb\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0dba\u0dd4\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dad\u0ddc\u0d9c \u0dc0\u0dd3, \u0db6\u0da9\u0d89\u0dbb\u0dd2\u0d9f\u0dd4, \u0dad\u0dda \u0dc4\u0dcf \u0d85\u0dbd \u0dc0\u0d9c\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0daf \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0d85\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0dbb\u0da2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0dbd\u0daf \u0dba\u0dd4\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 65,000\u0db1\u0dca \u0db4\u0dc5\u0db8\u0dd4 \u0dad\u0ddc\u0d9c\u0dba \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0dd0\u0db6\u0dd4\u0db1\u0dd4 \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 44,000\u0d9a\u0dca \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0dbd\u0dd0\u0db6\u0dd2\u0dab\u0dd2."
      ],
