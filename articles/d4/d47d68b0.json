    "ta": {
      "title": "\u0bb5\u0ba3\u0bcd\u0ba3\u0bae\u0baf\u0bae\u0bbe\u0ba9 \u0b95\u0bbe\u0ba4\u0bcd\u0ba4\u0bbe\u0b9f\u0bbf\u0b95\u0bb3\u0bcd...",
