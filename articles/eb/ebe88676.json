    "si": {
      "title": "\u2019\u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db0\u0dd4\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u2019 \u0dba\u0db1 \u0dbd\u0dd2\u0db4\u0dd2\u0dba \u0dc0\u0dca\u200d\u0dba\u0dcf\u0da2\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d9c\u0ddd\u0da8\u0dcf\u0db7\u0dba \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2 \u0db8\u0dc4\u0dad\u0dcf \u0da2\u0db1\u0db4\u0dad\u0dd2\u0db0\u0dd4\u0dbb\u0dba\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca\u0dc0\u0dd2\u0db8\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0dbd\u0dd2\u0db4\u0dd2\u0dba \u0db6\u0dc0 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0da2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0da2\u0dcf\u0dbd\u0dcf \u0dad\u0dd4\u0dc5 \u0dc4\u0dd4\u0dc0\u0db8\u0dcf\u0dbb\u0dd4\u0dc0\u0db1 \u0dbd\u0dd2\u0db4\u0dd2\u0dba \u0dc0\u0dca\u200d\u0dba\u0dcf\u0da2\u00a0 \u0dbd\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0db6\u0dc0 \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
