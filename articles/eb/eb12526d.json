          },
          {
            "text": "\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dd2\u0da9 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba",
