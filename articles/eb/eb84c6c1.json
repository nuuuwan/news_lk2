    "si": {
      "title": "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd4\u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0d9a\u0dd0\u0dc3\u0dca\u0db8, \u0db1\u0dd0\u0dc0\u0dad \u0dc3\u0dca\u0dae\u0dcf\u0db4\u0dd2\u0dad \u0d9a\u0dbb \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd6 \u0dc3\u0dd4\u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd0\u0d9a\u0dd0\u0dc3\u0dca\u0db8 \u0dc4\u0dd9\u0da7 (15) \u0dc3\u0dd2\u0da7 \u0dba\u0dc5\u0dd2 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0dba\u0da7\u0dad\u0dca\u0dc0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0daf\u0dd9\u0db1 \u0dbd\u0dd9\u0dc3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca 109\u0d9a\u0da7 \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0ddd\u0da7\u0dbb\u0dca \u0dbb\u0dae \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0dd3\u0da7\u0dbb\u0dca 20 \u0d9a\u0dca \u0daf \u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0dd3\u0da7\u0dbb\u0dca 8 \u0d9a\u0dca \u0daf \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2 \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0dd3\u0da7\u0dbb\u0dca 6 \u0d9a\u0dca \u0daf \u0d85\u0dc0\u0dc3\u0dbb \u0dbd\u0dd0\u0db6\u0dda.",
        "\u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0db6\u0dc0 \u0d85\u0dc0\u0db0\u0dcf\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0dc3\u0dd4\u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dd3 \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db1 \u0dbd\u0daf\u0dd3.",
        "\u0dc4\u0dd9\u0da7 (15) \u0dc0\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0dbb\u0da7 \u0db1\u0ddc\u0dba\u0db1 \u0db6\u0dc0\u0da7 \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf, \u0db6\u0dd0\u0dc3\u0dd2\u0dbd\u0dca \u0dc3\u0dc4 \u0d86\u0da7\u0dd2\u0d9c\u0dbd \u0db4\u0ddc\u0dbb\u0ddc\u0db1\u0dca\u0daf\u0dd4 \u0dc0\u0dd9\u0dba\u0dd2"
      ],
