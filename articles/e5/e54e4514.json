            "label": "ORG"
          },
          {
            "text": "\u0b85\u0bb2\u0bb0\u0bbf\u0bae\u0bbe\u0bb3\u0bbf\u0b95\u0bc8",
            "label": "LOC"
          }
        ],
        [
