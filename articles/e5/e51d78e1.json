          },
          {
            "text": "\u0daf\u0dd9\u0d9a",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "the Talatuoya Police",
            "label": "ORG"
          },
          {
            "text": "\u0dba\u0dcf\u0db4\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d92\u0d9a\u0d9a\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dc5\u0daf\u0dcf \u0db8\u0dcf\u0dbd\u0dd2\u0d9c\u0dcf\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "1721 \u0da2\u0dba\u0db1\u0dca\u0dad\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0d82\u0d9c\u0dbd, \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc3\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca \u0dc4\u0dad\u0dcf\u0dba\u0dd2",
            "label": "GPE"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0dbd\u0dcf\u0dbd\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd4\u0dc0\u0dd9\u0da0\u0dca\u0da0 \u0da2\u0dd3\u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0d9a\u0dca\u0dc2\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d82\u0dc3\u0dca\u0db1\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4",
            "label": "TIME"
          },
          {
            "text": "45-\u0db4\u0dd0\u0dba",
            "label": "TIME"
          }
        ],
        [
          {
