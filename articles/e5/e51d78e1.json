            "label": "ORG"
          },
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd \u0da2\u0dbd\u0dcf\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0daf\u0dd2\u0db1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dca\u0d9c\u0ddc\u0dbd\u0dca\u0dbd",
            "label": "ORG"
          },
          {
            "text": "03.00 \u0db4\u0db8\u0dab",
