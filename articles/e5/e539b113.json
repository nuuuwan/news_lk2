    "si": {
      "title": "\u0db6\u0dbd\u0dba \u0d9c\u0db1\u0dca\u0db1 \u0d8b\u0d9c\u0db1\u0dca\u0dc0\u0db1\u0dca\u0db1 \u0d91\u0db1\u0dca\u0db1 - \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc3\u0da2\u0dd2\u0dad\u0dca\u0da7 \u0d9a\u0dd2\u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0dbd\u0dba \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dda \u0d9a\u0dd9\u0dc3\u0dda\u0daf \u0dba\u0db1\u0dca\u0db1 \u0d89\u0d9c\u0dd0\u0db1\u0dca\u0dc0\u0dd2\u0db8\u0da7 \u0dad\u0db8\u0db1\u0dca \u0dc3\u0dd6\u0daf\u0dcf\u0db1\u0db8\u0dca \u0db6\u0dc0\u0dad\u0dca \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0dad\u0db8\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0dc0\u0db1 \u0dbd\u0dd9\u0dc3\u0dad\u0dca \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd9\u0dad \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba.",
        "\u0db6\u0dbd\u0dba \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0dc4\u0dd0\u0da7\u0dd2 \u0dad\u0db8\u0db1\u0dca \u0d8b\u0d9c\u0db1\u0dca\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0dad\u0db8\u0db1\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0d9a\u0dca \u0dad\u0dd4\u0db1\u0dca\u0db4\u0dcf\u0dbb\u0d9a\u0dca \u0db6\u0dbd\u0dba \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ],
