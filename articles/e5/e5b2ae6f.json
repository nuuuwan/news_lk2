            "text": "2 \u0d9a\u0dd2.\u0db8\u0dd3",
            "label": "QUANTITY"
          }
        ],
        [
          {
            "text": "\u0db1\u0dc0\u0daf\u0ddc\u0db9\u0d9a\u0dbb",
            "label": "GPE"
          },
          {
            "text": "\u0dc4\u0db8\u0dca\u0db6\u0db1\u0dca\u0dad\u0ddc\u0da7 \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dc0\u0dbb\u0dcf\u0dba \u0dc3\u0db8\u0dd6\u0dc4\u0dba",
            "label": "FAC"
          },
          {
            "text": "HIPG",
            "label": "ORG"
          },
          {
            "text": "2018",
            "label": "DATE"
          },
          {
            "text": "\u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "HIPG",
            "label": "ORG"
