        ],
        [
          {
            "text": "\u0db8\u0dd2\u0dbb\u0dd2\u0da2\u0dca\u0da2\u0dc0\u0dd2\u0dbd \u0d86\u0dba\u0ddd\u0da2\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "FAC"
          },
