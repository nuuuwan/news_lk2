    "si": {
      "title": "\u0d9a\u0db1\u0dca\u0daf\u0d9a\u0dcf\u0da9\u0dd4 \u0db4\u0dd4\u0db1\u0dd4\u0dbb\u0dd4\u0dad\u0dca\u0dae\u0dcf\u0db4\u0db1 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca- \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0db1\u0dca 250\u0d9a\u0dca \u0db4\u0dd0\u0db1 \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0db1\u0dca\u0daf \u0d9a\u0db1\u0dca\u0daf\u0d9a\u0dcf\u0da9\u0dd4\u00a0 \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db4\u0dd4\u0db1\u0dd4\u0dbb\u0dd4\u0dad\u0dca\u0dae\u0dcf\u0db4\u0db1 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb\u0dda \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0dd9\u0d9a\u0dd4 \u0d85\u0daf (29\u0daf\u0dcf) \u0d8b\u0daf\u0dd1\u0dc3\u0db1\u00a0 \u0d85\u0db7\u0dd2\u0dbb\u0dc4\u0dc3\u0dca \u0dbd\u0dd9\u0dc3 \u0db8\u0dbb\u0dab\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9c\u00a0\u00a0 \u0d91\u0db8 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dbb\u0dd0\u0db3\u0dd2\u0dc0\u0dd2\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0d85\u0dad\u0dbb\u00a0 \u0d85\u0dad\u0dbb \u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda .",
        "\u0d8b\u0dab\u0dd4\u0dc3\u0dd4\u0db8\u0dca\u0d9a\u0dcf\u0dbb\u0dd3 \u0dad\u0dad\u0dca\u0dc0\u0dba \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dba\u0dd4\u0daf \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0dc3\u0dc4 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dd0\u0dbd\u0dd2\u0d9a\u0db1\u0dca\u0daf \u0db4\u0ddc\u0dbd\u0dd3\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc3\u0dd0\u0d9a\u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0dcf\u0d9c\u0dda \u0db8\u0dc5 \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0dc4\u0ddd \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0da7\u00a0\u00a0 \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2\u0dc0 \u0d91\u0db8 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda\u0db8 \u0dad\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0da7\u0dd3\u0db8\u0da7 \u0dbb\u0dd0\u0db3\u0dc0\u0dd2\u0dba\u0db1\u0dca \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb \u0d87\u0dad."
      ],
