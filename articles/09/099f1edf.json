          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a ICT \u0dc0\u0dd2\u0dc3\u0db3\u0dd4\u0db8\u0dca \u0dc3\u0db4\u0dba\u0db1\u0dca\u0db1\u0dcf",
            "label": "ORG"
          },
