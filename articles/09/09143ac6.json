    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf\u0d9c\u0dda \u0da1\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db4\u0dd4\u0dbb\u0db4\u0dca\u0db4\u0dcf\u0da9\u0dd4 \u0dc0\u0dd6 \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0d85\u0dc3\u0dd4\u0db1 \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd4\u0dbb\u0dc0\u0dba\u0dd2",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT -\u00a0 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db1\u0dc0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0d91\u0da2\u0dcf\u0db4 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db4\u0dd4\u0dbb\u0db4\u0dca\u0db4\u0dcf\u0da9\u0dd4 \u0dc0\u0dd6 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d85\u0dc3\u0dd4\u0db1 \u0dc3\u0db3\u0dc4\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db8\u0db0\u0dca\u200d\u0dba-\u0daf\u0d9a\u0dca\u0dc2\u0dd2\u0dab\u0dcf\u0d82\u0dc1\u0dd2\u0d9a \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda (\u0d91\u0da2\u0dcf\u0db4) \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0dc0\u0da2\u0dd2\u0dbb \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbd\u0dd0\u0dba\u0dd2\u0dc3\u0dca\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db0\u0dd4\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0d9a\u0dca\u0dc2\u0dba\u0dda \u0d91\u0d9a\u0db8 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd2\u0dba\u0dda\u0dba. \u0d94\u0dc4\u0dd4 \u0db8\u0dd0\u0dba\u0dd2 12 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0dbd\u0dd9\u0dc3 \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0d85\u0dad\u0dbb \u0db8\u0dda \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d94\u0dc4\u0dd4 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0da1\u0db1\u0dca\u0daf\u0dba\u0dd9\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db1\u0dc0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0d85\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db4\u0dd4\u0dbb\u0db4\u0dca\u0db4\u0dcf\u0da9\u0dd4 \u0dc0\u0db1 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db0\u0dd6\u0dbb\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0da2\u0dd2\u0dbb \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dbb\u0dab \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0da2\u0dd6\u0dbd\u0dd2 22 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd2\u0dab\u0dd2.",
        "\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0db0\u0dd4\u0dbb\u0dba \u0daf\u0dd0\u0dbb\u0dd6 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0dbb\u0da2\u0dba \u0dc3\u0db8\u0dba\u0dda \u0d85\u0db7\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0dc4\u0dcf \u0dc3\u0dca\u0dc0\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dc4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf \u0dc3\u0dc4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0db4\u0dcf\u0dbd\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd6\u0dba\u0dda \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba.",
        "\u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb 2001 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0d9a\u0dca\u0dc2 \u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0\u0dda \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0dbd\u0db1, \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc3\u0d82\u0dc3\u0dca\u0d9a\u0dbb\u0dab \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0daf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5\u0dda\u0dba. \u0d94\u0dc4\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d9c\u0dcf\u0dbd\u0dca\u0dbd \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca\u0d9a\u0dba\u0da7 \u0dad\u0dbb\u0d9f \u0d9a\u0dbb 2020 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dbb\u0dab\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dbb\u0dcf\u0da2\u0dba\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0d94\u0dc4\u0dd4 1989 - 1994 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0db8\u0ddc\u0dbb\u0da7\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0dc3\u0db8\u0dcf\u0da2\u0dc0\u0dcf\u0daf\u0dd3 \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0dc3\u0dc4 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0dad\u0dd9\u0dc0\u0dbb\u0d9a\u0dca \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0d94\u0dc4\u0dd4 1982-1994 UNP \u0dad\u0dbb\u0dd4\u0dab \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0d9a\u0dd8\u0dad\u0dca\u200d\u0dba\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0db8\u0dab\u0dca\u0da9\u0dbd \u0dc3\u0db7\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0daf 1994 \u0daf\u0dd3 UNP \u0dc3\u0dc4\u0d9a\u0dcf\u0dbb \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0daf \u0dc0\u0dd2\u0dba. (\u0d9a\u0ddc\u0dc5\u0db9/ \u0da2\u0dd6\u0dbd\u0dd2 23/2022)"
      ],
      "title_ents": [
        {
          "text": "\u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dba",
          "label": "GPE"
        },
        {
          "text": "\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7 \u0db4\u0dc3\u0dca\u0dc3\u0dda \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
          "label": "WORK_OF_ART"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda",
            "label": "GPE"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0da2\u0dcf\u0db4",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0da2\u0dd2\u0dbb \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0da2\u0dcf\u0db4",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db8\u0dd0\u0dba\u0dd2 12",
            "label": "DATE"
          },
          {
            "text": "\u0db8\u0dd9\u0db8 \u0dc3\u0dad\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 22",
            "label": "DATE"
          },
          {
            "text": "\u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dbb\u0dab \u0d9a\u0ddc\u0db8\u0dd2\u0dc3\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0da2\u0dd2\u0dbb \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf \u0dc3\u0dc4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0db4\u0dcf\u0dbd\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0dbd\u0db1 \u0d87\u0db8\u0dd0\u0dad\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba \u0dc3\u0dc4 \u0db4\u0dca\u0dbb\u0dad\u0dd2\u0dc3\u0d82\u0dc3\u0dca\u0d9a\u0dbb\u0dab",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0da2\u0dcf\u0db4",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "2001",
            "label": "DATE"
          },
          {
            "text": "2020 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4",
            "label": "DATE"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda",
            "label": "GPE"
          },
          {
            "text": "\u0d9c\u0dcf\u0dbd\u0dca\u0dbd",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dd4\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0ddc\u0dbb\u0da7\u0dd4\u0dc0 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "1989 - 1994",
            "label": "DATE"
          },
          {
            "text": "\u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d91\u0da2\u0dcf\u0db4 \u0dad\u0dbb\u0dd4\u0dab",
            "label": "ORG"
          },
          {
            "text": "1982-1994",
            "label": "DATE"
