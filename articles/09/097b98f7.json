    "si": {
      "title": "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d91\u0db1\u0dad\u0dd9\u0d9a\u0dca \u0db6\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd3\u0db8...",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc0\u0dda\u0daf\u0dd2\u0d9a\u0dcf \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1\u0dd4 \u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0da7 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0dbb\u0dd0\u0db3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1\u0dd4 \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dda. \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dad\u0dcf\u0dc0\u0d9a\u0dcf\u0dbd\u0dd2\u0d9a\u0dc0 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0daf\u0dd0\u0da9\u0dd2 \u0d9a\u0dbd\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0d9a\u0dca \u0db4\u0dc5 \u0d9a\u0dc5\u0dcf. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dd2\u0dad\u0dca\u0dc3\u0dd2\u0dbb\u0dd2 \u0daf \u0db8\u0dd9\u0dbd\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dd2"
