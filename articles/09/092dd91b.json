            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0bbf\u0bb5\u0bbf\u0ba4\u0bc1\u0bb0\u0bc1 \u0bb9\u0bc6\u0bb2 \u0b89\u0bb1\u0bc1\u0bae\u0baf",
            "label": "PERSON"
          },
          {
            "text": "\u0b9c\u0ba9\u0ba8\u0bbe\u0baf\u0b95\u0bae\u0bcd",
            "label": "NORP"
          },
          {
            "text": "\u0b87\u0b9f\u0ba4\u0bc1 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf",
            "label": "PERSON"
          },
          {
