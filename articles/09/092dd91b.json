    "si": {
      "title": "\u0dc0\u0dd2\u0db8\u0dbd\u0dca\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d85\u0dbd\u0dd4\u0dad\u0dca \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba\u0d9a\u0dca \u0db6\u0dd2\u0dc4\u0dd2\u0dc0\u0dd9\u0db1\u0dc0\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d86\u0dab\u0dca\u0da9\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d89\u0dc0\u0dad\u0dca \u0dc0\u0dd6 \u0dc4\u0dc0\u0dd4\u0dbd\u0dca\u0d9a\u0dcf\u0dbb \u0db4\u0d9a\u0dca\u0dc2 \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0d9c\u0dad\u0dca \u0d89\u0dc4\u0dc5 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba\u0dda \u0dc3\u0db8\u0dcf\u0dbb\u0db8\u0dca\u0db7\u0d9a \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0d85\u0daf (04) \u0db8\u0dc4\u0dbb\u0d9c\u0db8\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc3\u0dc4 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab\u0dda \u0db1\u0dcf\u0dba\u0d9a \u0dc0\u0dd2\u0db8\u0dbd\u0dca \u0dc0\u0dd3\u0dbb\u0dc0\u0d82\u0dc1\u0d9c\u0dda \u0db1\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0db8\u0dd9\u0db8 \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba\u0da7 \u0db6\u0dd2\u0dc0\u0dd2\u0daf\u0dd4\u0dbb\u0dd4 \u0dc4\u0dd9\u0dc5 \u0d8b\u0dbb\u0dd4\u0db8\u0dba, \u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dad\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0daf\u0dd3 \u0dc0\u0dcf\u0db8\u0dcf\u0d82\u0dc1\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab \u0dc3\u0dc4 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dc3\u0db8\u0dcf\u0da2 \u0db4\u0d9a\u0dca\u0dc2\u0dba \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0dc0\u0dda."
      ],
      "title_ents": [
        {
          "text": "\u0dc0\u0dd2\u0db8\u0dbd\u0dca",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d89\u0dc4\u0dc5 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba",
            "label": "FAC"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "04",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db8\u0dc4\u0dbb\u0d9c\u0db8",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dd2\u0db8\u0dbd\u0dca \u0dc0\u0dd3\u0dbb\u0dc0\u0d82\u0dc1",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0dd2\u0dc0\u0dd2\u0daf\u0dd4\u0dbb\u0dd4 \u0dc4\u0dd9\u0dc5 \u0d8b\u0dbb\u0dd4\u0db8\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0da2\u0dcf\u0dad\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0daf\u0dd3",
            "label": "NORP"
          },
          {
            "text": "\u0dc0\u0db8\u0dca \u0db4\u0dd9\u0dbb\u0db8\u0dd4\u0dab",
            "label": "PERSON"
          },
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0db8\u0dc3\u0db8\u0dcf\u0da2 \u0db4\u0d9a\u0dca\u0dc2\u0dba",
            "label": "ORG"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0bb5\u0bbf\u0bae\u0bb2\u0bcd \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0bc1\u0ba4\u0bbf\u0baf \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0ba3\u0bbf \u0b89\u0ba4\u0baf\u0bae\u0bcd",
      "author": "unknown",
      "body_lines": [
        "\u0b85\u0bb0\u0b9a\u0bbe\u0b99\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0bb2\u0b95\u0bbf\u0baf \u0baa\u0b99\u0bcd\u0b95\u0bbe\u0bb3\u0bbf\u0b95\u0bcd \u0b95\u0b9f\u0bcd\u0b9a\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bbe\u0bb2\u0bcd \u0b89\u0bb0\u0bc1\u0bb5\u0bbe\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3 \u0bae\u0bc7\u0bb2\u0bb5\u0bc8 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0ba3\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b85\u0b99\u0bcd\u0b95\u0bc1\u0bb0\u0bbe\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0ba3 \u0ba8\u0bbf\u0b95\u0bb4\u0bcd\u0bb5\u0bc1, \u0bae\u0bb9\u0bb0\u0b95\u0bae\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (04) \u0b87\u0b9f\u0bae\u0bcd\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1.",
        "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1 \u0b89\u0bb1\u0bc1\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bb0\u0bc1\u0bae\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b9a\u0bc1\u0ba4\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bc1\u0bae\u0bbe\u0ba9 \u0bb5\u0bbf\u0bae\u0bb2\u0bcd \u0bb5\u0bc0\u0bb0\u0bb5\u0ba9\u0bcd\u0b9a \u0ba4\u0bb2\u0bc8\u0bae\u0bc8\u0baf\u0bbf\u0bb2\u0bbe\u0ba9 \u0b87\u0ba8\u0bcd\u0ba4 \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0ba3\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0bbf\u0bb5\u0bbf\u0ba4\u0bc1\u0bb0\u0bc1 \u0bb9\u0bc6\u0bb2 \u0b89\u0bb1\u0bc1\u0bae\u0baf, \u0b9c\u0ba9\u0ba8\u0bbe\u0baf\u0b95 \u0b87\u0b9f\u0ba4\u0bc1\u0b9a\u0bbe\u0bb0\u0bbf \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf, \u0bb2\u0b99\u0bcd\u0b95\u0bbe \u0b9a\u0bae\u0b9a\u0bae\u0bbe\u0b9c \u0b95\u0b9f\u0bcd\u0b9a\u0bbf \u0b89\u0bb3\u0bcd\u0bb3\u0bbf\u0b9f\u0bcd\u0b9f\u0bb5\u0bc8 \u0b85\u0b99\u0bcd\u0b95\u0bae\u0bcd \u0bb5\u0b95\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9."
      ],
      "title_ents": [
        {
          "text": "\u0bb5\u0bbf\u0bae\u0bb2\u0bcd",
