  "original_title": "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dba\u0dc5\u0dd2 \u0da7\u0dd2\u0d9a \u0da7\u0dd2\u0d9a  \u0db0\u0dcf\u0dc0\u0db1\u0dba\u0da7",
  "text_idx": {
    "en": {
      "title": "The train is slowly running again",
      "author": "unknown",
      "body_lines": [
        "General Manager of the Railways Dhammika Jayasundara said that the train service which had been suspended for nearly two hours due to the departure of the train controllers was resumed.",
        "Mr. Jayasundera said that this situation had arisen due to the sudden resignation of the train controllers and that two delayed trains had already left the Colombo Fort Railway Station for Polgahawela and Kankesanthurai."
      ],
      "title_ents": [],
      "body_line_ents_list": [
