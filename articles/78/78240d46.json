            "label": "CARDINAL"
          },
          {
            "text": "\u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1",
            "label": "EVENT"
          }
        ],
        [
          {
            "text": "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0db8\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca\u0d9c\u0dda \u0dbd\u0dd0\u0dba\u0dd2\u0dc3\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0dcf\u0dad\u0dd3\u0db1\u0dca\u0d9c\u0dda \u0dbb\u0dd9\u0d9c\u0dd4\u0dbd\u0dcf\u0dc3\u0dd2 \u0d85\u0d82\u0d9a",
            "label": "ORG"
          },
          {
            "text": "1",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc3\u0daf\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0dca\u200d\u0dbb\u0dd2\u0dad\u0dcf\u0db1\u0dca\u200d\u0dba \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc3\u0daf\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0dd3\u0da7\u0dd3\u0d91\u0dc6\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd0\u0db1\u0dda\u0da9\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0daf\u0dd9\u0db8\u0dc5 \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba",
            "label": "ORG"
          },
          {
            "text": "CTC",
            "label": "ORG"
          },
          {
            "text": "\u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0daf\u0dd9\u0db8\u0dc5 \u0d9a\u0ddc\u0d82\u0d9c\u0dca\u200d\u0dbb\u0dc3\u0dba",
            "label": "ORG"
          },
          {
            "text": "ATC",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0d8a\u0dc5\u0dcf\u0db8\u0dca \u0da2\u0db1\u0dad\u0dcf \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0dad\u0dbb\u0dd4\u0dab \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dd3\u0d9a\u0dbb\u0dab \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
