      "title": "Management Officers to Passport Office",
      "author": "unknown",
      "body_lines": [
        "The Ministry of Public Administration has informed all heads of institutions to assign Management Service Officers to the Immigration Department for a period of three months.",
        "This decision has been taken as per the request of the Comptroller General of Immigration, paying attention to the current congestion in the Battaramulla head office of the Immigration Department, and accordingly, management service officers residing within 10 km of the Immigration Department office are to be assigned to that office."
      ],
      "title_ents": [
        {
          "text": "Management Officers to",
          "label": "ORG"
        },
        {
          "text": "Passport Office",
          "label": "FAC"
        }
      ],
