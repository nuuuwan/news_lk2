  "original_title": "\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0da7 \u0db4\u0dc4\u0dbb\u0daf\u0dd3 \u0db6\u0dda\u0dbb\u0dda \u0dc0\u0dd0\u0dc0\u0da7  \u0dad\u0dbd\u0dca\u0dbd\u0dd4\u0d9a\u0dc5 \u0dad\u0dbb\u0dd4\u0dab\u0dd2\u0dba \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7",
