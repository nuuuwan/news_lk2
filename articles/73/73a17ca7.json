    "si": {
      "title": "\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0da7 \u0db4\u0dc4\u0dbb\u0daf\u0dd3 \u0db6\u0dda\u0dbb\u0dda \u0dc0\u0dd0\u0dc0\u0da7  \u0dad\u0dbd\u0dca\u0dbd\u0dd4\u0d9a\u0dc5 \u0dad\u0dbb\u0dd4\u0dab\u0dd2\u0dba \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dca\u200d\u0dbb\u0dcf \u0daf\u0dda\u0dc1\u0dd3\u0dd2\u0dba \u0dc3\u0db7\u0dcf\u00a0 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4\u0da7 \u0db4\u0dc4\u0dbb\u0daf\u0dd3\u00a0 \u00a0\u0d94\u0dc4\u0dd4\u0dc0 \u0db6\u0dda\u0dbb\u0dda \u0dc0\u0dd0\u0dc0\u0da7\u00a0 \u0dad\u0dbd\u0dca\u0dbd\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca\u00a0 \u0d85\u0dc0\u0dd4\u0dd4\u0dbb\u0dd4\u0daf\u0dd4\u00a0 26 \u0d9a \u0dad\u0dbb\u0dd4\u0dab\u0dd2\u0dba\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dd2\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dd0\u0dba\u0dd2 9\u00a0 \u0daf\u0dcf\u00a0 \u0db8\u0dd9\u0db8\u00a0 \u0dc3\u0dd2\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0dd2\u0db8 \u0dc3\u0dd2\u0dd2\u0daf\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dda.\u00a0 \u0dad\u0db8\u0db1\u0dca\u0da7\u00a0 \u0db4\u0dc4\u0dbb\u0daf\u0dd3\u0dd2 \u0db8\u0dd4\u0daf\u0dbd\u0dca\u00a0 \u0db4\u0dc3\u0dd4\u0dd4\u0db8\u0dca\u0db6\u0dd2\u0dd2\u0dba \u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0d9a\u0dcf\u00a0 \u0db6\u0dda\u0dbb\u0dda \u0dc0\u0dd0\u0dc0\u0da7 \u0dad\u0dbd\u0dca\u0dbd\u0dd4 \u0d9a\u0dc5\u00a0 \u0db6\u0dc0\u0da7 \u0d9a\u0ddc\u0dc5\u0db9 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba \u0dc0\u0dd9\u0dad \u0d94\u0dc4\u0dd4\u0dd4 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0db4\u0dd0\u0db8\u0dd2\u0dd2\u0dab\u0dd2\u0dbd\u0dca\u0dca\u0dbd\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0dd9\u0dba\u0dd2.",
        "\u0dad\u0dbb\u0dd4\u0dab\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0d9a\u0ddc\u0da7\u0dca\u0da8\u0dcf\u0dc3\u0dba \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0dd2\u0db8\u0dd9\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0\u00a0 \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7\u00a0 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda."
      ],
