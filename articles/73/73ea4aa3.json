    "si": {
      "title": "\u0dc1\u0dd3\u0dbb\u0dca\u0dc2 \u0db4\u0dcf\u0da8\u0dba \u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0dc0\u0dd2\u0dba: \u0da2\u0dd6\u0dbd\u0dd2 10 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dc4\u0da2\u0dca \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0dc3\u0dd0\u0db8\u0dbb\u0dd3\u0db8\u0dda \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0",
      "author": "\u0da7\u0dd3 \u0dba\u0dd4\u0dc0\u0dbb\u0dcf\u0da2\u0dca",
      "body_lines": [
        "\u0dad\u0dd4\u0dbd\u0dca \u0dc4\u0da2\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0dc1\u0dd3\u0dbb\u0dca\u0dc2 \u0db4\u0dcf\u0da8\u0dba \u0d85\u0daf \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dda \u0d87\u0dad\u0dd0\u0db8\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0db4\u0dc5\u0dc0\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d91\u0dc5\u0dd0\u0db9\u0dd9\u0db1 \u0d8a\u0daf\u0dd4\u0dbd\u0dca \u0d85\u0dc2\u0dcf \u0dc4\u0da2\u0dca \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0dbd\u0db6\u0db1 10 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd0\u0db8\u0dbb\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dad\u0dd4\u0dbd\u0dca \u0dc4\u0da2\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0dad\u0dda\u0db8\u0dcf\u0dc0 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc3\u0db8\u0dca\u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba \u0d85\u0daf \u0d9a\u0ddc\u0dc5\u0db9 \u0db8\u0dc4 \u0db4\u0dbd\u0dca\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0db8\u0dc4\u0dbb\u0dd2\u0dc6\u0dca \u0dba\u0dcf\u0da5\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb, \u0d9a\u0ddc\u0dc5\u0db9 \u0db8\u0dc4 \u0db4\u0dbd\u0dca\u0dbd\u0dd2\u0dba \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dc5\u0dda, \u0dbb\u0da7\u0dda \u0dc3\u0db8\u0dc4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dbb\u0dc3\u0dca\u0dad\u0dbd \u0d85\u0dbd\u0dca\u0dbd\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dc3\u0dcf\u0d9a\u0dca\u0dc2\u0dd2 \u0dc3\u0ddc\u0dba\u0dcf\u0d9c\u0dad\u0dca \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d91\u0dc5\u0db9\u0dd9\u0db1 Eid-ul-Azha Hajj \u0d8b\u0dad\u0dca\u0dc3\u0dc0\u0dba \u0dbd\u0db6\u0db1 10 \u0dc0\u0dd0\u0db1\u0dd2 \u0d89\u0dbb\u0dd2\u0daf\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0dc3\u0dd0\u0db8\u0dbb\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad."
      ],
