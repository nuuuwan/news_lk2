            "label": "ORG"
          }
        ],
        [
          {
            "text": "\"\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0dc3\u0d82\u0dc3\u0dca\u0d9a\u0dbb\u0dab \u0dc3\u0dc4 \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0d9c\u0db8\u0db1",
            "label": "ORG"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          },
          {
            "text": "04",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3\u0db4\u0dcf\u0dbd \u0dc3\u0dd2\u0dbb\u0dd2\u0dc3\u0dda\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf \u0dc1\u0d9a\u0dca\u0dad\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0db8\u0dad\u0dd4\u0db8 \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0dcf\u0da2\u0dd2\u0dad \u0dc3\u0dda\u0db1\u0dcf\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "Mano Ganesan",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0dc0\u0dd4\u0db6\u0dca \u0dc4\u0d9a\u0dd3\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd3 \u0dc0\u0dd2\u0d9c\u0dca\u0db1\u0dda\u0dc2\u0dca\u0dc0\u0dbb\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dd3.\u0daf\u0dd2\u0d9c\u0db8\u0dca\u0db6\u0dbb\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0d85\u0dba\u0dd2\u0dc0\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0db1\u0dbb\u0d82\u0da2\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dcf\u0db8\u0dd2\u0dab\u0dd3 \u0dc0\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0ddc\u0da9",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0ddc\u0dc4\u0dcf\u0db1\u0dca \u0dc3\u0db8\u0dbb\u0da2\u0dd3\u0dc0",
            "label": "ORG"
          }
        ]
