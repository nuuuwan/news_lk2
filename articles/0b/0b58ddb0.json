        {
          "text": "\u0b9c\u0bbe\u0b95\u0bcd\u0b9a\u0ba9\u0bcd \u0b86\u0ba3\u0bcd\u0b9f\u0ba9\u0bbf",
          "label": "PERSON"
        },
        {
