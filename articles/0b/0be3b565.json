    "si": {
      "title": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d86\u0dbb\u0d9a\u0dca\u200d\u0dc2\u0d9a \u0db4\u0dd2\u0dba\u0dc0\u0dbb\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0d85\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0daf\u0dd2\u0db1 \u0daf\u0dd9\u0d9a \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd2\u0dba \u0dc3\u0dda\u0dc0\u0dcf\u0dc0\u0db1\u0dca \u0d85\u0dc0\u0dbd\u0d82\u0d9c\u0dd4 \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2."
      ],
      "title_ents": [
        {
          "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba",
