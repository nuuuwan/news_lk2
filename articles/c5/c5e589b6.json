    "si": {
      "title": "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dc5\u0d9f\u0daf\u0dd3\u0db8 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dbb\u0db1\u0dc0\u0dcf - \u0d87\u0db8\u0dd0\u0dad\u0dd2 \u0dc4\u0dbb\u0dd3\u0db1\u0dca",
      "author": "T. Saranya",
      "body_lines": [
        "\u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0d9c\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0dc5\u0d9f\u0daf\u0dd3\u0db8 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d8a\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dbd\u0dd2\u0dba\u0d9a\u0dd2\u0dba\u0dc0\u0dd2\u0dbd\u0dd2 \u0dc3\u0d9a\u0dc3\u0dca \u0d9a\u0dbb \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc4\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dbd\u0dd2\u0db4\u0dd2 \u0dbd\u0dda\u0d9b\u0db1 \u0d91\u0d9a\u0dad\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db1\u0dd3\u0dad\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf\u0d9c\u0dda \u0dad\u0dc0\u0dad\u0dca \u0db1\u0dd2\u0dbb\u0dca\u0daf\u0dda\u0dc1\u0dba\u0d9a\u0dca \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dba\u0dd2. \u0d91\u0db8 \u0db1\u0dd2\u0dbb\u0dca\u0daf\u0dda\u0dc1\u0dba \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0db4\u0dc3\u0dd4 \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dbd\u0dd2\u0db4\u0dd2\u0dba\u0da7 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0dad\u0dca\u0dc3\u0db1\u0dca \u0dad\u0db6\u0db1 \u0db6\u0dc0 \u0daf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc4\u0dbb\u0dd3\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
