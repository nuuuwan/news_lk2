      "body_line_ents_list": [
        [
          {
            "text": "\u0dad\u0dd2\u0db8\u0ddd\u0dad\u0dd2 \u0dc3\u0dca\u0db4\u0dd9\u0dbd\u0dca\u0da9\u0dd9\u0dc0\u0dd2\u0db1\u0dca\u0da9\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dca\u0dc0\u0dcf\u0db0\u0dd3\u0db1 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0ddc\u0dc0\u0db1",
            "label": "ORG"
          },
          {
            "text": "The Board of The Kingsbury PLC",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dbb\u0dbd\u0dad\u0dca \u0d9c\u0dab\u0d9a\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0d86\u0dba\u0dad\u0db1\u0dba",
