    "si": {
      "title": "\u0d9a\u0dd2\u0d82\u0d9c\u0dca\u0dc3\u0dca\u0db6\u0dbb\u0dd2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0da7 \u0dad\u0dd2\u0db8\u0ddd\u0dad\u0dd2 \u0dc3\u0dca\u0db4\u0dd9\u0dbd\u0dca\u0da9\u0dd9\u0dc0\u0dd2\u0db1\u0dca\u0da9\u0dca \u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0daf\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "Timothy Speldewinde The Kingsbury PLC \u0dc4\u0dd2 \u0dc3\u0dca\u0dc0\u0dcf\u0db0\u0dd3\u0db1 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0ddc\u0dc0\u0db1 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad.",
        "Speldewinde \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dc0\u0dbb\u0dbd\u0dad\u0dca \u0d9c\u0dab\u0d9a\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0d86\u0dba\u0dad\u0db1\u0dba\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0dbb\u0dcf\u0da2\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dda \u0dc0\u0dbb\u0dbd\u0dad\u0dca \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0d9c\u0dab\u0d9a\u0dcf\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd3 \u0d86\u0dba\u0dad\u0db1\u0dba\u0dda \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd2.",
        "\u0d94\u0dc4\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc3\u0dc4 \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dc3\u0dc4\u0dd2\u0dad \u0dc4\u0ddc\u0d82\u0d9a\u0ddc\u0d82 \u0dc4\u0dd2 \u0db8\u0dd6\u0dbd\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0dc0\u0db1 Stretchline Holdings \u0dc4\u0dd2 \u0dc4\u0dd2\u0da7\u0db4\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dcf \u0dc0\u0dd2\u0dba. \u0d94\u0dc4\u0dd4 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0db4\u0dd4\u0dc5\u0dd4\u0dbd\u0dca \u0db4\u0dc5\u0db4\u0dd4\u0dbb\u0dd4\u0daf\u0dca\u0daf\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0dc0\u0dc3\u0dbb 26 \u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca MAS \u0dc3\u0db8\u0dd6\u0dc4\u0dba\u0dda \u0db4\u0dd6\u0dbb\u0dca\u0dab \u0dc3\u0dcf\u0db8\u0dcf\u0da2\u0dd2\u0d9a\u0dba\u0dd9\u0d9a\u0dd2. Speldewinde \u0daf\u0dd0\u0db1\u0da7 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0ddc\u0dc0\u0db1 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dbd\u0dd9\u0dc3 MAS Holdings Ltd \u0dc4\u0dd2 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dda \u0dc3\u0dda\u0dc0\u0dba \u0d9a\u0dbb\u0dba\u0dd2, \u0dc3\u0dd3\u0db8\u0dcf\u0dc3\u0dc4\u0dd2\u0dad \u0dc0\u0dd9\u0dbd\u0dca\u0dad\u0dca \u0da7\u0dca\u200d\u0dbb\u0dc3\u0dca\u0da7\u0dca \u0dc3\u0dd2\u0d9a\u0dd2\u0dba\u0dd4\u0dbb\u0dd2\u0da7\u0dd3\u0dc3\u0dca \u0dc4\u0dd2 \u0dc0\u0dd2\u0d9c\u0dab\u0db1 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0dc3\u0dc4 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0dc4 Contemporary Ceylon Ltd \u0dc4\u0dd2 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd2.",
        "\u0db1\u0dc0\u0dad\u0db8 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dad\u0dca \u0dc3\u0db8\u0d9f The Kingsbury \u0dc4\u0dd2 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db8\u0ddc\u0dc4\u0dcf\u0db1\u0dca \u0db4\u0dab\u0dca\u0da9\u0dd2\u0dad\u0d9c\u0dda, \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 Rohan Karr, N.J. De S. Deva Aditya, S.C.Ganegoda, S.J. \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dd2\u0d82\u0dc4, \u0d86\u0dbb\u0dca.\u0d91\u0db1\u0dca. \u0db4\u0ddc\u0db1\u0dca\u0db1\u0db8\u0dca\u0db6\u0dbd\u0db8\u0dca, \u0da2\u0dda.\u0db4\u0dd3.\u0dc0\u0dd3. Twest, I. Jamaldeen \u0dc3\u0dc4 T.A.B. Spledewinde."
      ],
      "title_ents": [
        {
          "text": "\u0dad\u0dd2\u0db8\u0ddd\u0dad\u0dd2 \u0dc3\u0dca\u0db4\u0dd9\u0dbd\u0dca\u0da9\u0dd9\u0dc0\u0dd2\u0db1\u0dca\u0da9\u0dca",
          "label": "PERSON"
