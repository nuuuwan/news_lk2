          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf \u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb\u0db1\u0dcf\u0dba\u0d9a",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dad\u0dd4\u0d82\u0d9c \u0dba",
            "label": "PERSON"
          },
          {
            "text": "1997 \u0da2\u0db1\u0dc0\u0dcf\u0dbb\u0dd2 31 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dd3.\u0d92. \u0da2\u0dba\u0d9a\u0dcf\u0db1\u0dca\u0dad",
            "label": "PERSON"
