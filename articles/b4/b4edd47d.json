          {
            "text": "\u0b9c\u0bbe\u0b95\u0bcd\u0b95\u0bc1\u0bb2\u0bbf\u0ba9\u0bcd \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bb8\u0bcd",
            "label": "PERSON"
          },
          {
