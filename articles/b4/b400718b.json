    "si": {
      "title": "\u0dad\u0dd9\u0dbd\u0dd2\u0db4\u0dca\u0db4\u0dbd\u0dd9\u0dba\u0dd2 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dc6\u0dcf\u0db8\u0dc3\u0dd2\u0dba\u0d9a \u0d9c\u0dd2\u0db1\u0dca\u0db1\u0d9a\u0dca \u0dc4\u0da7\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda",
