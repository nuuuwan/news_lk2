            "text": "\u0db8\u0dd4\u0dbb\u0dd4\u0d82\u0d9c\u0db1\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba, \u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0db0\u0db1\u0dd4\u0dc2\u0dca\u0d9a\u0ddc\u0da9\u0dd2",
