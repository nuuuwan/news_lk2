          },
          {
            "text": "\u0bae\u0bc1\u0bb0\u0bc1\u0b99\u0bcd\u0b95\u0ba9\u0bcd\u0baa\u0bbf\u0b9f\u0bcd\u0b9f\u0bbf\u0baf, \u0bae\u0ba9\u0bcd\u0ba9\u0bbe\u0bb0\u0bcd",
