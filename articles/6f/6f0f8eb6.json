  "original_title": "\u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0db1\u0dd2\u0dc0\u0dc3\u0da7 \u0d9c\u0dd2\u0db1\u0dd2\u0dad\u0db6\u0daf\u0dca\u0daf\u0dd3 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0daf\u0dd2\u0dc0\u0dd3\u0db8 \u0d9c\u0dd0\u0db1 \u0db4\u0dbb\u0dd2\u0d9a\u0dca\u0dc2\u0dab",
