            "text": "\u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0baa\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1\u0ba4\u0bcd \u0ba4\u0bc1\u0bb1\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (20\u0bae\u0bcd \u0ba4\u0bc7\u0ba4\u0bbf",
            "label": "DATE"
          },
          {
            "text": "\u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1",
            "label": "CARDINAL"
