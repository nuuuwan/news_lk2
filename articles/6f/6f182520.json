          },
          {
            "text": "\u0d9a\u0dd6\u0da9 \u0dc3\u0dc4 \u0db4\u0dd0\u0dbd\u0da7\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc6\u0dd3\u0db1\u0dd2\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dd6\u0da9",
            "label": "FAC"
          }
        ],
        [
          {
            "text": "2022",
            "label": "DATE"
          },
          {
