    "si": {
      "title": "\u0dc3\u0dd2\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0d89\u0dbd\u0d9a\u0dca\u0d9a \u0dc0\u0dd9\u0dad \u0d8a\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0dba\u0dbd\u0dca \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb",
      "author": "unknown",
      "body_lines": [
        "\u0d8a\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0dba\u0dbd\u0dba \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dbb\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0d89\u0dbd\u0d9a\u0dca\u0d9a \u0dc0\u0dd9\u0dad \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb \u0d91\u0dbd\u0dca\u0dbd \u0d9a\u0dc5 \u0d85\u0dad\u0dbb, \u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0d87\u0dbd\u0dd9\u0db4\u0dca\u0db4\u0ddd \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5\u0da7 \u0dc3\u0dc4 \u0da9\u0dd0\u0db8\u0dc3\u0dca\u0d9a\u0dc3\u0dca \u0d85\u0d9c\u0db1\u0dd4\u0dc0\u0dbb \u0d86\u0dc3\u0db1\u0dca\u0db1\u0dba\u0dda \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd\u0da7 \u0db8\u0dd9\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc4\u0dcf\u0db1\u0dd2 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd6\u00a0\u0db6\u0dc0 \u0dc3\u0dd2\u0dbb\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2.",
        "\u0d87\u0dbd\u0dd9\u0db4\u0dca\u0db4\u0ddd \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5\u0da7 \u0db4\u0dc4\u0dbb \u0daf\u0dd4\u0db1\u0dca \u0d8a\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0dba\u0dbd \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0db8\u0db0\u0dca\u200d\u0dba\u0db0\u0dbb\u0dab\u0dd3 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0da7 \u0d89\u0dc4\u0dc5\u0dd2\u0db1\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0dcf\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0db4\u0dd4\u0dc0\u0dad\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db4\u0dd0\u0dba\u0d9a\u0da7 \u0db4\u0db8\u0dab \u0db4\u0dc3\u0dd4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0da9\u0dd0\u0db8\u0dc3\u0dca\u0d9a\u0dc3\u0dca \u0d86\u0dc3\u0db1\u0dca\u0db1\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd\u0da7 \u0db4\u0dc4\u0dbb \u0daf\u0dd4\u0db1\u0dca \u0db8\u0dd2\u0dc3\u0dba\u0dd2\u0dbd \u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0d8a\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0dba\u0dbd\u0dba\u0dda \u0d9c\u0dbd\u0dd3\u0dbd\u0dd3 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0da7 \u0d89\u0dc4\u0dc5\u0dd2\u0db1\u0dca \u0d91\u0dbd\u0dca\u0dbd \u0dc0\u0dd6 \u0db6\u0dc0\u0dba\u0dd2."
      ],
