  "original_title": "\u0ba4\u0bc7\u0baf\u0bbf\u0bb2\u0bc8 \u0b9a\u0bc6\u0baf\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b89\u0bb0\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95 \u0ba4\u0bc0\u0bb0\u0bcd\u0bae\u0bbe\u0ba9\u0bae\u0bcd",
  "text_idx": {
    "en": {
      "title": "Decision to provide fertilizer for tea cultivation",
      "author": "unknown",
      "body_lines": [
        "Agriculture Minister Mahinda Amaraweera says that it has been decided to supply 15 thousand metric tons of urea fertilizer required for tea cultivation.",
        "This decision was taken in a meeting held at the Ministry of Agriculture yesterday (23).",
        "The heads of two state-owned fertilizer companies said that 60 percent of the 44 thousand metric tons of fertilizer available to the country has been distributed. (a)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "Mahinda Amaraweera",
            "label": "PERSON"
          },
          {
            "text": "15 thousand metric tons",
            "label": "QUANTITY"
          }
        ],
        [
          {
            "text": "the Ministry of Agriculture",
            "label": "ORG"
          },
          {
            "text": "yesterday",
            "label": "DATE"
          },
          {
            "text": "23",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "two",
            "label": "CARDINAL"
          },
          {
            "text": "60 percent",
            "label": "PERCENT"
          },
          {
            "text": "44 thousand metric tons",
            "label": "QUANTITY"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dad\u0dda \u0dc0\u0d9c\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dad\u0dda \u0dc0\u0d9c\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dba\u0dd6\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 15,000\u0d9a\u0dca \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0dc4\u0dd2\u0db1\u0dca\u0daf \u0d85\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d8a\u0dba\u0dda (23) \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf\u0dc0\u0d9a\u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0dbb\u0da2\u0dba\u0da7 \u0d85\u0dba\u0dad\u0dca \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dca \u0daf\u0dd9\u0d9a\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd3\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dbb\u0da7\u0da7 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 44,000\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 60\u0d9a\u0dca \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2. (\u0d92)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
