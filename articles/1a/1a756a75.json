      "title": "Resolution to reduce power outage time",
      "author": "unknown",
      "body_lines": [
        "Sri Lanka Public Utilities Commission informs that today (28) it has decided to reduce the power outage time to one hour.",
        "It has been decided to reduce the usual power outage time from 3 hours and 40 minutes to one hour. (R)"
      ],
      "title_ents": [],
      "body_line_ents_list": [
