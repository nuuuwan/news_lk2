            "label": "ORG"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b95\u0b9f\u0bb1\u0bcd\u0baa\u0b9f\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bbf\u0baf\u0bb5\u0ba9\u0bcd\u0ba9\u0bbe\u0bb5 \u0baa\u0bbe\u0bb2\u0bae\u0bcd",
