    "si": {
      "title": "T-56 Rabil \u0d9c\u0dbd\u0dc0\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dd4\u0dbd\u0dd2 13 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0db4\u0ddc\u0dbd\u0dca\u0dad\u0dd4\u0dc0\u0dcf \u0dc4\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0dda \u0daf\u0dd3 \u0dc3\u0ddc\u0dbd\u0dca\u0daf\u0dcf\u0daf\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dad\u0dd4\u0dc0 \u0dad\u0dd2\u0db6\u0dd3 \u0dbb\u0dcf\u0da2\u0dc3\u0db1\u0dca\u0dad\u0d9a \u0d9a\u0dbb\u0db1 \u0dbd\u0daf T-56 Rabil \u0dc3\u0dc4 \u0dc4\u0dd2\u0dc3\u0dca \u0db8\u0dd0\u0d9c\u0dc3\u0dd2\u0db1\u0dba\u0d9a\u0dca \u0dad\u0dd2\u0dc0\u0db1\u0dca\u0db1\u0dcf\u0dc0 \u0db4\u0dcf\u0dbd\u0db8 \u0dba\u0da7 \u0dad\u0dd2\u0db6\u0dd3 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dda \u0dc4\u0dd9\u0dbd\u0dd2\u0d9a\u0ddc\u0db4\u0dca\u0da7\u0dbb\u0dca \u0dba\u0dcf\u0db1\u0dcf \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc3\u0ddc\u0dba\u0dcf \u0d9c\u0dd9\u0db1 \u0d87\u0dad."
      ],
      "title_ents": [
        {
          "text": "\u0da7\u0dd3-56 \u0dbb\u0db6\u0dd2\u0dbd\u0dca",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "T-56 Rabil",
            "label": "PRODUCT"
          },
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 13",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0ddc\u0dbd\u0dca\u0dad\u0dd4\u0dc0\u0dcf \u0dc4\u0db1\u0dca\u0daf\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dad\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1\u0dcf\u0dc0 \u0db4\u0dcf\u0dbd\u0db8",
            "label": "FAC"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b9f\u0bbf-56 \u0bb0\u200b\u0baa\u0bbf\u0bb2\u0bcd \u0bae\u0bc0\u0b9f\u0bcd\u0baa\u0bc1",
      "author": "unknown",
      "body_lines": [
        "\u0baa\u0bca\u0bb2\u0bcd\u0ba4\u0bc1\u0bb5 \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd, \u0b9c\u0bc2\u0bb2\u0bc8 13 \u0b86\u0bae\u0bcd \u0ba4\u0bbf\u0b95\u0ba4\u0bbf\u0baf\u0ba9\u0bcd\u0bb1\u0bc1 \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0baa\u0bcb\u0bb0\u0bbe\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0baa\u0bcb\u0ba4\u0bc1, \u0baa\u0b9f\u0bc8\u0baf\u0bbf\u0ba9\u0bb0\u0bbf\u0b9f\u0bae\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 \u0b85\u0baa\u0b95\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b9f\u0bbf-56 \u0bb0\u0baa\u0bbf\u0bb2\u0bcd, \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bc1 \u0bae\u0bc6\u0b95\u0bb7\u0bbf\u0ba9\u0bcd \u0b86\u0b95\u0bbf\u0baf\u0ba9, \u0ba4\u0bbf\u0baf\u0bb5\u0ba9\u0bcd\u0ba9\u0bbe\u0bb5 \u0baa\u0bbe\u0bb2\u0ba4\u0bcd\u0ba4\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b95\u0bc0\u0bb4\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1, \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b95\u0b9f\u0bb1\u0bcd\u0baa\u0b9f\u0bc8 \u0b9a\u0bc1\u0bb4\u0bbf\u0baf\u0bcb\u0b9f\u0bbf\u0b95\u0bb3\u0bbe\u0bb2\u0bcd \u0bae\u0bc0\u0b9f\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9."
      ],
      "title_ents": [
        {
