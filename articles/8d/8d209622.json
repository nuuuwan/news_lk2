    "si": {
      "title": "\u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0dba \u0dc3\u0ddc\u0dbb\u0dcf\u0d9c\u0dd9\u0db1 \u0daf\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1\u0dcf\u0dc0\u0da7 \u0db4\u0dd0\u0db1\u0dbd\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0dca \u0dc3\u0ddc\u0dbb\u0d9a\u0db8\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dcf\u0dc0\u0dbd \u0dc4\u0d82\u0daf\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0daf\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1\u0dcf \u0d94\u0dba\u0da7 \u0db4\u0db1\u0dd2\u0db1 \u0dbd\u0daf \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd9\u0d9a\u0dca \u0dad\u0dbd\u0d82\u0d9c\u0db8 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0daf \u0d8b\u0daf\u0dda \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0dba.",
        "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0db1\u0dca \u0dbd\u0dd4\u0dc4\u0dd4\u0db6\u0dd0\u0db3 \u0d91\u0db1\u0dd4 \u0daf\u0dd4\u0da7\u0dd4 \u0dc3\u0dd0\u0d9a\u0d9a\u0dbb\u0dd4 \u0daf\u0dd2\u0dba\u0dc0\u0db1\u0dca\u0db1\u0dcf \u0d94\u0dba\u0da7 \u0db8\u0dd9\u0dc3\u0dda \u0db4\u0dd0\u0db1 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
      "title_ents": [],
