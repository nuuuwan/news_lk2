    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0db1\u0dc0 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca -19 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 119 \u0d9a\u0dca \u0dc3\u0dc4 \u0dad\u0dc0\u0dad\u0dca \u0db8\u0dbb\u0dab \u0db4\u0dc4\u0d9a\u0dca \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d8a\u0dba\u0dda (\u0da2\u0dd6\u0dbd\u0dd2 25) \u0daf\u0dd2\u0db1\u0dba\u0dda\u0daf\u0dd3 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 Covid-19 \u0db8\u0dbb\u0dab 5 \u0d9a\u0dca \u0dc3\u0dc4 \u0d86\u0dc3\u0dcf\u0daf\u0db1 119 \u0d9a\u0dca \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db1\u0dc0 \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba\u0dad\u0dca \u0dc3\u0db8\u0d9f \u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 Covid-19 \u0d86\u0dc1\u0dca\u200d\u0dbb\u0dd2\u0dad \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 665,094 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc3\u0dc4 \u0db8\u0dbb\u0dab \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 16,544 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9c\u0dd9\u0db1 \u0d91\u0dba\u0dd2.",
        "\u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0d85\u0dad\u0dbb \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 60\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0dcf\u0db1\u0dca\u0dad\u0dcf\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dca \u0daf \u0dc0\u0dd9\u0dad\u0dd2."
      ],
