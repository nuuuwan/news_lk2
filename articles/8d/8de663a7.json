    "si": {
      "title": "\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd1\u0db1\u0dca \u0dc3\u0dc4 \u0db6\u0dc3\u0dca \u0dbb\u0dae\u0dc0\u0dbd\u0da7 \u0db6\u0dcf\u0db0\u0dcf",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc5\u0db8\u0dd4\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dbb\u0dae \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0dba\u0da7 75 \u0d9a\u0dca \u0db4\u0db8\u0dab \u0d85\u0daf (25) \u0daf\u0dd2\u0db1\u0dba\u0dda \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dd6 \u0db6\u0dc0 \u0dc3\u0db8\u0dc3\u0dca\u0dad \u0dbd\u0d82\u0d9a\u0dcf \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc5\u0db8\u0dd4\u0db1\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0dbd\u0dbd\u0dd2\u0dad\u0dca \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc3\u0dd2\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d9c\u0dd0\u0da7\u0dbd\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d87\u0dad\u0dd0\u0db8\u0dca\u00a0 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd1\u0db1\u0dca \u0dbb\u0dae \u0dc3\u0dc4 \u0db6\u0dc3\u0dca \u0dbb\u0dae \u0dc0\u0dbd\u0da7 \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd1\u0db1\u0dca \u0dbb\u0dae \u0dc3\u0dc4 \u0db6\u0dc3\u0dca \u0dbb\u0dae 48000 \u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0dcf \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0dc0\u0dda.",
        "\u0db8\u0dd9\u0db8 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd1\u0db1\u0dca \u0dbb\u0dae \u0dc3\u0dc4 \u0db6\u0dc3\u0dca \u0dbb\u0dae \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0d82\u0d9c\u0db8 \u0da9\u0dd2\u0db4\u0ddd \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0dad\u0dca\u0dad\u0dad\u0dca \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0d9c\u0dd0\u0da7\u0dc5\u0dd4 \u0db8\u0dad\u0dd4\u0dc0\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc3\u0dd2\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dd3\u0dc0\u0dda\u0dba.",
        "\u0da9\u0dd2\u0db4\u0ddd \u0dc0\u0dbd\u0da7 \u0d87\u0dad\u0dd2 \u0daf\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8, \u0da9\u0dd2\u0db4\u0ddd \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd3\u0db8\u0dcf\u0dc3\u0dc4\u0dd2\u0dad \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d9c\u0dd0\u0da7\u0dc5\u0dd4 \u0db8\u0dad\u0dd4\u0dc0\u0dd6 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db4\u0dc5 \u0dc0\u0db1 \u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0dc3\u0dd2\u0dba\u0dbd\u0dd6\u0db8 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc0\u0dd1\u0db1\u0dca \u0dbb\u0dae \u0dc3\u0dc4 \u0db6\u0dc3\u0dca \u0dbb\u0dae \u0db0\u0dcf\u0dc0\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db4\u0dd2\u0dba\u0dc0\u0dbb \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dc0\u0dda\u0dba."
      ],
      "title_ents": [],
