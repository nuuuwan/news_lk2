    "si": {
      "title": "SriLankan Catering & Ground Handling \u0dc3\u0db3\u0dc4\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 EOI \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0dd2\u0dba \u0dbb\u0ddd\u0d9c\u0dd3 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba \u0dc0\u0db1 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba \u0dba\u0dc5\u0dd2 \u0db4\u0dab \u0d9c\u0dd0\u0db1\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d8b\u0db1\u0db1\u0dca\u0daf\u0dd4\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0d9a\u0dd0\u0db3\u0dc0\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d9a\u0dda\u0da7\u0dbb\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda 49%\u0d9a \u0d9a\u0ddc\u0da7\u0dc3\u0dca \u0d86\u0dba\u0ddd\u0da2\u0db1 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0d85\u0d82\u0dc1\u0dba\u0da7 \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0db6\u0dc0 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db1\u0dd2\u0db8\u0dbd\u0dca \u0dc3\u0dd2\u0dbb\u0dd2\u0db4\u0dcf\u0dbd \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db8\u0dd3\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0, \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d91\u0dba\u0dcf\u0dbb\u0dca\u0dbd\u0dba\u0dd2\u0db1\u0dca\u0dc3\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dc0\u0dd4\u0db1\u0dca\u0da9\u0dca \u0dc4\u0dd0\u0db1\u0dca\u0da9\u0dca\u0dbd\u0dd2\u0db1\u0dca \u0dc0\u0dbd\u0dd2\u0db1\u0dca 49%\u0d9a\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0db1\u0db8\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0d85\u0dad\u0dbb 51%\u0d9a\u0dca \u0dbb\u0da2\u0dba \u0dc3\u0db8\u0d9f \u0dbb\u0db3\u0dc0\u0dcf \u0dad\u0db6\u0dcf \u0d9c\u0db1\u0dd3.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 50% \u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0db8\u0dd4\u0daf\u0dbd\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5\u0dc4\u0ddc\u0dad\u0dca \u0dbb\u0da7\u0da7 \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8\u0dda \u0d85\u0dba\u0dd2\u0dad\u0dd2\u0dba \u0d85\u0dc4\u0dd2\u0db8\u0dd2 \u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d86\u0dba\u0ddd\u0da2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0d91\u0d9a\u0dad\u0dd4 \u0dc0\u0dd3 51%\u0d9a\u0da7 \u0dba\u0ddd\u0da2\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5\u0dc4\u0ddc\u0dad\u0dca \u0d91\u0dc0\u0dd0\u0db1\u0dd2 \u0d86\u0dba\u0ddd\u0da2\u0db1\u0dba\u0d9a\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0da2\u0dba \u0dc3\u0dbd\u0d9a\u0dcf \u0db6\u0dbd\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3\u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0db8\u0dd4\u0dc5\u0dd4 \u0dab\u0dba \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 1.126\u0d9a\u0dca \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0d9a\u0ddd\u0da7\u0dd2 1126\u0d9a\u0dca \u0dc0\u0db1 \u0db6\u0dc0\u0daf \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0d87\u0db8\u0dd0\u0dad\u0dd2 \u0db1\u0dd2\u0db8\u0dbd\u0dca \u0dc3\u0dd2\u0dbb\u0dd2\u0db4\u0dcf\u0dbd \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0d9a\u0dc5\u0dda\u0dba. \u0db6\u0dd2\u0dbd\u0dd2\u0dba\u0db1 401 \u0d9a\u0dd2.",
        "SriLankan Catering & Ground Handling \u0dc3\u0db3\u0dc4\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 EOI \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd3",
        "\u0db4\u0d9a\u0dd2\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0dda \u0db8\u0ddd\u0dc3\u0db8\u0dca \u0dc0\u0dd0\u0dc3\u0dd2 \u0dc3\u0dc4 \u0d9c\u0d82\u0dc0\u0dad\u0dd4\u0dbb \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca 1000\u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db8\u0dd2\u0dba \u0d9c\u0dd2\u0dba\u0dc4"
