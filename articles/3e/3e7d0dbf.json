    "si": {
      "title": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0dc0\u0da7 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf\u0dc0 \u0dad\u0dbb \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dad\u0ddd\u0dbb\u0dcf \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc4\u0dd9\u0da7 (20\u0daf\u0dcf) \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0dc0\u0da7 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0dcf\u0dc0\u0d9a\u0dca \u0d85\u0daf (19\u0daf\u0dcf) \u0dc3\u0dd2\u0da7 \u0dba\u0ddc\u0daf\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dc0\u0dbd \u0dc3\u0dc4 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0dc0\u0da7 \u0dba\u0dd4\u0daf\u00a0 \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db8\u0dd4\u0dbb\u0d9a\u0dcf\u0dc0\u0dbd\u0dca \u0dba\u0ddc\u0daf\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4\u0daf \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dda."
      ],
