          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dc1\u0dd2\u0dc0\u0da5\u0dcf\u0db1\u0db8\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3\u0daf\u0dbb\u0db1\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0db1\u0dca\u0db1\u0dd2\u0dba",
