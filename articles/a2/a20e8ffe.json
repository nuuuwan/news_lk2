          },
          {
            "text": "\u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb",
            "label": "LOC"
          }
        ],
        [
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0d9a\u0dc0\u0dd4\u0db1\u0dca\u0dc3\u0dd2\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba\u0dda",
            "label": "ORG"
          },
          {
            "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba",
            "label": "PERSON"
