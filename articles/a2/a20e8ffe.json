          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0da0\u0dcf\u0dbd\u0dca\u0dc3\u0dca \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dbd\u0db1\u0dcf\u0daf\u0db1\u0dca",
