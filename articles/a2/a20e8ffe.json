          "text": "\u0b9a\u0bbe\u0bb0\u0bcd\u0bb2\u0bb8\u0bcd \u0b8e\u0bae\u0bcd.\u0baa\u0bbf.\u0b95\u0bcd\u0b95\u0bb3\u0bcd",
          "label": "PERSON"
