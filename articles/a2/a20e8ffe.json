            "label": "GPE"
          },
          {
            "text": "\u0b95\u0bbf\u0bb4\u0b95\u0bcd\u0b95\u0bc1",
            "label": "LOC"
          }
        ],
        [
          {
            "text": "\u0b89\u0bb2\u0b95\u0ba4\u0bcd \u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0b85\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bc7\u0bb0\u0bb5\u0bc8",
            "label": "ORG"
          },
          {
            "text": "\u0ba4\u0bae\u0bbf\u0bb4\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b95\u0bc2\u0b9f\u0bcd\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1",
            "label": "ORG"
          },
          {
            "text": "\u0baf\u0bbe\u0bb4\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0bbe\u0bb0\u0bbe\u0bb3\u0bc1\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0b9a\u0bbf\u0bb5\u0b9e\u0bbe\u0ba9\u0bae\u0bcd \u0bb8\u0bcd\u0bb0\u0bc0\u0ba4\u0bb0\u0ba9\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0bb5\u0ba9\u0bcd\u0ba9\u0bbf",
            "label": "NORP"
