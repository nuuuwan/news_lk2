          },
          {
            "text": "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dd4\u0dab\u0dcf\u0db8\u0dbd \u0dbb\u0daf\u0d9c\u0dd4\u0dbb\u0dd4 \u0db4\u0daf\u0dc0\u0dd2\u0dba",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3\u0db0\u0dbb\u0db1\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0da0\u0dcf\u0dbd\u0dca\u0dc3\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\"\u0db8\u0db4\u0dd9\u0dbb\u0dd4\u0db8\u0dca \u0db4\u0dd9\u0dbb\u0dc0\u0ddb\u0dad\u0db8\u0dd2\u0dad\u0dca \u0d8b\u0dc5\u0dd9\u0dbd",
            "label": "EVENT"
          },
          {
            "text": "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0d9d \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "35 \u0dc0\u0db1 \u0dc0\u0dc3\u0dbb",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dbd\u0ddd\u0d9a \u0daf\u0dd9\u0db8\u0dc5 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0d9a\u0dc0\u0dd4\u0db1\u0dca\u0dc3\u0dd2\u0dbd\u0dba",
