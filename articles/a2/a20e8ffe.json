        {
          "text": "\u0da0\u0dcf\u0dbd\u0dca\u0dc3\u0dca \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dd4",
          "label": "PERSON"
        },
        {
          "text": "\u0da9\u0dba\u0dc3\u0dca\u0db4\u0ddd\u0dbb\u0dcf\u0dc0",
