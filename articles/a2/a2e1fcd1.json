    "si": {
      "title": "\u0d8c\u0dc0 \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dad\u0dcf\u0dc0\u0d9a\u0dcf\u0dbd\u0dd2\u0d9a\u0dc0 \u0db1\u0dc0\u0dad\u0dcf \u0d87\u0dad",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d8c\u0dc0 \u0dc0\u0dd9\u0dbd\u0dca\u0dbd\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd \u0d85\u0db0\u0dca\u200d\u0dba\u0dba\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0daf (\u0da2\u0dd4\u0db1\u0dd2 29) \u0dc3\u0dd2\u0da7 \u0db1\u0dd0\u0dc0\u0dad \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca \u0daf\u0dd9\u0db1 \u0dad\u0dd4\u0dbb\u0dd4 \u0dad\u0dcf\u0dc0\u0d9a\u0dcf\u0dbd\u0dd2\u0d9a\u0dc0 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9c\u0dad\u0dca \u0db6\u0dc0 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d8b\u0db4\u0d9a\u0dd4\u0dbd\u0db4\u0dad\u0dd2 \u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0da2\u0dba\u0db1\u0dca\u0dad \u0dbd\u0dcf\u0dbd\u0dca \u0dbb\u0dad\u0dca\u0db1\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba."
      ],
