          {
            "text": "\u0dc0\u0dbb\u0dca\u0dc2 \u0db6\u0ddc\u0dc4\u0ddd \u0d9c\u0dab\u0db1\u0d9a\u0dca",
            "label": "DATE"
          },
          {
            "text": "\u0db8\u0dda \u0d8b\u0daf\u0dd1\u0dc3\u0db1",
            "label": "TIME"
          }
        ],
        [
          {
            "text": "\u0db6\u0dbd\u0d82\u0d9c\u0ddc\u0da9 \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dad\u0dca\u0db1\u0db4\u0dd4\u0dbb \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dab \u0d92\u0d9a\u0d9a\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db6\u0dbd\u0d82\u0d9c\u0ddc\u0da9 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db6\u0dbd\u0d82\u0d9c\u0ddc\u0da9 \u0d8b\u0dc3\u0dcf\u0dc0\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u200d\u0dca\u200d\u0dbb\u0dcf\u0dad\u0dca \u0da9\u0dd3.\u0d91\u0db8\u0dca \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0dad\u0dca\u0db1\u0db4\u0dd4\u0dbb \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db1\u0dd2\u0dc0\u0dcf\u0dbb\u0dab \u0d92\u0d9a\u0d9a\u0dba",
