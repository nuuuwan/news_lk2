            "label": "CARDINAL"
          },
          {
            "text": "\u0d85\u0dc3\u0dca\u0d9c\u0dd2\u0dbb\u0dd2 \u0db8\u0dc4\u0dcf \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb \u0d85\u0db7\u0dd2\u0db1\u0db1\u0dca\u0daf\u0db1 \u0db8\u0d82\u0d9c\u0dbd\u0dca\u200d\u0dba\u0dba",
            "label": "FAC"
          },
          {
