    "ta": {
      "title": "\u0bb7\u0bb5\u0bc7\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 '\u0bae\u0bb9\u0bbe\u0bae\u0bbe\u0ba9\u0bcd\u0baf \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0baa\u0ba4\u0bbf\u0b95\u0bc7\u0bb7\u0bc7\u0bb5\u0bbe' \u0b8e\u0ba9\u0bcd\u0bb1 \u0baa\u0b9f\u0bcd\u0b9f\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1\u0baa\u0bcd \u0baa\u0b9f\u0bc8\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0ba9\u0bbf \u0b9c\u0bc6\u0ba9\u0bb0\u0bb2\u0bcd \u0b9a\u0bb5\u0bc7\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0 \u0b9a\u0bbf\u0bb2\u0bcd\u0bb5\u0bbe\u0bb5\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf\u0baf\u0baa\u0bcd \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0bae\u0b95\u0bbe \u0b9a\u0b99\u0bcd\u0b95 \u0b9a\u0baa\u0bc8\u0baf\u0bbf\u0ba9\u0bbe\u0bb2\u0bcd \u0bae\u0b95\u0bbe\u0bae\u0bbe\u0ba9\u0bcd\u0baf \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0baa\u0ba4\u0bbf\u0b95\u0bc7\u0bb8\u0bcd\u0bb5\u0bb0\u0bb0\u0bcd \u0b8e\u0ba9\u0bcd\u0bb1 \u0b95\u0bcc\u0bb0\u0bb5\u0baa\u0bcd \u0baa\u0b9f\u0bcd\u0b9f\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (28) \u0baa\u0bbf\u0bb1\u0bcd\u0baa\u0b95\u0bb2\u0bcd \u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf \u0bae\u0b95\u0bbe \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf \u0bae\u0b95\u0bbe \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8 \u0b85\u0baa\u0bbf\u0ba8\u0ba8\u0bcd\u0ba4\u0ba9 \u0bb5\u0bbf\u0bb4\u0bbe\u0bb5\u0bbf\u0bb2\u0bcd \u0b87\u0ba8\u0bcd\u0ba4 \u0b95\u0bcc\u0bb0\u0bb5\u0baa\u0bcd \u0baa\u0b9f\u0bcd\u0b9f\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bc1.",
        "\u0ba8\u0bbe\u0b9f\u0bc1, \u0bae\u0ba4\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0b95 \u0ba4\u0bbf\u0bb0\u0bc1.\u0b9c\u0bc6\u0ba9\u0bb0\u0bb2\u0bcd \u0b9a\u0bb5\u0bc7\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0 \u0b9a\u0bbf\u0bb2\u0bcd\u0bb5\u0bbe \u0b86\u0bb1\u0bcd\u0bb1\u0bbf\u0baf \u0b9a\u0bc7\u0bb5\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0b95 \u0b87\u0ba8\u0bcd\u0ba4 \u0b95\u0bcc\u0bb0\u0bb5\u0baa\u0bcd \u0baa\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95 \u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf \u0bae\u0b95\u0bbe \u0b9a\u0b99\u0bcd\u0b95 \u0b9a\u0baa\u0bc8 \u0ba4\u0bc0\u0bb0\u0bcd\u0bae\u0bbe\u0ba9\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1."
      ],
      "title_ents": [
        {
          "text": "\u0bae\u0bb9\u0bbe\u0bae\u0bbe\u0ba9\u0bcd\u0baf \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0baa\u0ba4\u0bbf\u0b95\u0bc7\u0bb7\u0bc7\u0bb5\u0bbe'",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0baa\u0bbe\u0ba4\u0bc1\u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bc1 \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0bb5\u0bc7\u0ba8\u0bcd\u0ba4\u0bbf\u0bb0 \u0b9a\u0bbf\u0bb2\u0bcd\u0bb5\u0bbe",
            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bb9\u0bbe\u0bae\u0bbe\u0ba9\u0bcd\u0baf \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0baa\u0bbe\u0ba4\u0bbf\u0b95\u0bc7\u0bb6\u0bcd\u0bb5\u0bb0",
            "label": "FAC"
          },
          {
            "text": "\u0b9a\u0b99\u0bcd\u0b95 \u0b9a\u0baa\u0bc8",
            "label": "PERSON"
          },
          {
            "text": "\u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "\u0b87\u0ba9\u0bcd\u0bb1\u0bc1",
            "label": "DATE"
          },
          {
            "text": "28",
            "label": "CARDINAL"
          },
          {
            "text": "\u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf \u0bae\u0b95\u0bbe \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8 \u0b85\u0baa\u0bbf\u0ba8\u0ba8\u0bcd\u0ba4\u0ba9 \u0bb5\u0bbf\u0bb4\u0bbe",
            "label": "FAC"
          },
          {
            "text": "\u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf \u0bae\u0b95\u0bbe \u0bb5\u0bbf\u0b95\u0bbe\u0bb0\u0bc8",
            "label": "FAC"
          }
        ],
        [
          {
            "text": "\u0b85\u0bb8\u0bcd\u0b95\u0bbf\u0bb0\u0bbf \u0bae\u0b95\u0bbe",
            "label": "NORP"
          },
          {
