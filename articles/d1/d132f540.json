        [
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4\u0d9c\u0dda",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd3\u0dad\u0dd2\u0da5 \u0dc6\u0dba\u0dd2\u0dc3\u0dbb\u0dca \u0db8\u0dd4\u0dc3\u0dca\u0dad\u0dcf\u0dc6\u0dcf",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 2 \u0dc0\u0dd9\u0db1\u0dd2\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
