        ]
      ]
    },
    "si": {
      "title": "\u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf \u0dc0\u0dd2\u0dbb\u0dc4\u0dd2\u0dad\u0dba\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0d9a\u0dca\u0d9a\u0dbb 20 \u0d9a \u0d89\u0da9\u0db8\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf \u0dc0\u0dd2\u0dbb\u0dc4\u0dd2\u0dad\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0d85\u0d9a\u0dca\u0d9a\u0dbb 20 \u0d9a \u0d89\u0da9\u0db8\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1\u0dc0\u0dcf. \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8\u0dba \u0dc3\u0dc4 \u0dc3\u0dad\u0dca\u0dc0 \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0d92 \u0dad\u0dd4\u0dc5 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0d9a\u0dd9\u0dbb\u0dda. \u0d92 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 50\u0d9a\u0dca \u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dbb\u0db1\u0dc0\u0dcf."
      ],
      "title_ents": [
        {
          "text": "\u0d85\u0d9a\u0dca\u0d9a\u0dbb 20\u0dba\u0dd2",
          "label": "QUANTITY"
        }
      ],
