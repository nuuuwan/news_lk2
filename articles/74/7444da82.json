    "si": {
      "title": "\u0da2\u0dd6\u0db1\u0dd2 27 \u0dc3\u0dd2\u0da7 \u0da2\u0dd6\u0dbd\u0dd2 03 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dba 3\u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4\u0da2\u0db1 \u0d8b\u0db4\u0dba\u0ddd\u0d9c\u0dd2\u0dad\u0dcf \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0 (PUCSL) \u0da2\u0dd4\u0db1\u0dd2 27 \u0dc3\u0dd2\u0da7 \u0da2\u0dd6\u0dbd\u0dd2 3 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dd0\u0dba 3 \u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca \u0d85\u0db1\u0dd4\u0db8\u0dad \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0, ABCDEFGHIJKLPQRSTUVW \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dd2\u0dc0\u0dcf \u0d9a\u0dcf\u0dbd\u0dba\u0dda \u0db4\u0dd0\u0dba 1 \u0dba\u0dd2 \u0db8\u0dd2\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dd4 40 \u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dc3\u0dc4 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0db4\u0dd0\u0dba 1 \u0dba\u0dd2 \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 20 \u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1\u0dd4 \u0d87\u0dad.",
        "CC \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 6.00 \u0dc3\u0dd2\u0da7 8.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf (\u0da2\u0dd6\u0dbd\u0dd2 2 \u0dc3\u0dc4 3 \u0dc4\u0dd0\u0dbb) \u0db4\u0dd0\u0dba \u0daf\u0dd9\u0d9a\u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0d85\u0dad\u0dbb MNOXYZ \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0d8b\u0daf\u0dd1\u0dc3\u0db1 5.00 \u0dc3\u0dd2\u0da7 8.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf (\u0da2\u0dd6\u0dbd\u0dd2 2 \u0dc3\u0dc4 3 \u0dc4\u0dd0\u0dbb) \u0db4\u0dd0\u0dba 3 \u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dd9\u0dbb\u0dda."
      ],
