  "original_title": "\u0db6\u0dc3\u0dca \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dc3\u0dd2\u0dba\u0dba\u0da7 22 \u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
  "text_idx": {
    "en": {
      "title": "Bus fares up by 22 percent",
      "author": "unknown",
      "body_lines": [
        "The director general of the National Transport Board, Thilan Miranda, says that bus fares will be increased by 22 percent from midnight today (30th).",
        "According to the Director General, the revision of bus fares will take effect on July 1."
      ],
      "title_ents": [
        {
          "text": "22 percent",
          "label": "PERCENT"
        }
      ],
