    "si": {
      "title": "COVID \u0dba\u0dc5\u0dd2\u0dad\u0dca \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dc4\u0dd4",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dad\u0dd4\u0dc5 \u0db1\u0dd0\u0dc0\u0dad\u0dad\u0dca COVID-19 \u0db4\u0dd0\u0dad\u0dd2\u0dbb \u0dba\u0dcf \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0da7 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0d85\u0d9f\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d89\u0dbb\u0dd2\u0daf\u0dcf (17) \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd6 COVID-19 \u0d86\u0dc3\u0dcf\u0daf\u0db1 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 34 \u0d9a\u0dca \u0dc0\u0dd4\u0dc0\u0daf, \u0db8\u0dbb\u0dab \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad.",
        "\u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0dad\u0dc4\u0dc0\u0dd4\u0dbb\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 COVID-19 \u0d86\u0dc3\u0dcf\u0daf\u0db1 \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 664,414 \u0d9a\u0dd2."
      ],
