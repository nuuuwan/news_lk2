    "si": {
      "title": "\u0dc4\u0dd2\u0dc3\u0dca \u0dad\u0dd0\u0db1\u0dca\u0dc0\u0dbd \u0dc3\u0dd4\u0dc5\u0d9f\u0dd2\u0db1\u0dca \u0d9c\u0dc3\u0dcf\u0d9c\u0dd9\u0db1 \u0dba\u0db1 \u0dc0\u0dc4\u0dbd\u0dc0\u0dbd\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0dc4 \u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0 \u0d85\u0dad\u0dbb \u0db4\u0dc5\u0db8\u0dd4 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dba \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0dc4\u0dd2\u0dc3\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0db1\u0dba\u0dda \u0daf\u0dd0\u0da9\u0dd2 \u0dc3\u0dd4\u0dc5\u0d9f\u0d9a\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dad\u0dcf\u0dc0\u0d9a\u0dcf\u0dbd\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dda\u0d9a\u0dca\u0dc2\u0d9a\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0dc0\u0dc4\u0dbd\u0dba \u0d9a\u0da9\u0dcf \u0dc0\u0dd0\u0da7\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf."
      ],
      "title_ents": [],
