            "label": "GPE"
          },
          {
            "text": "\u0b9a\u0bc0\u0ba9",
            "label": "NORP"
          }
        ],
        [
          {
            "text": "\u0b95\u0ba9\u0bcd\u0baa\u0bc2\u0b9a\u0bbf\u0baf\u0bb8\u0bcd \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9\u0bae\u0bcd",
            "label": "ORG"
