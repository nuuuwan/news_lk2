    "si": {
      "title": "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca\u0da7 \u0d86\u0dc1\u0dd2\u0dbb\u0dca\u0dc0\u0dcf\u0daf...",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
