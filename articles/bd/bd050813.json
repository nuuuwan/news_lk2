    "si": {
      "title": "Singapore Space Challenge \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba\u0d9a\u0dca \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0da7\u0dad\u0dca",
      "author": "unknown",
      "body_lines": [
        "Singapore Space Challenge 2021 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc4\u0ddc\u0db3\u0db8 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0dad\u0dd4\u0db1 \u0d85\u0dad\u0dbb\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda SEDS_LunarBot \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0db8\u0dd9\u0dc0\u0dbb Singapore Space Challenge 2021 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dbd\u0db6\u0dcf\u0daf\u0dd4\u0db1\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dba \u0dc0\u0dd4\u0dba\u0dda, \"\u0dc3\u0db3 \u0db8\u0dad \u0d9a\u0dd0\u0dab\u0dd3\u0db8\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0dcf \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dd3\u0dba \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dcf \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dbb\u0ddd\u0dc0\u0dbb\u0dca \u0dba\u0dcf\u0db1\u0dba\u0d9a\u0dca \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\" \u0dba\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc4\u0ddc\u0db3\u0db8 \u0db1\u0dd2\u0db4\u0dd0\u0dba\u0dd4\u0db8\u0dca 03 \u0d85\u0dad\u0dbb\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0da7 SEDS_LunarBot \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dda \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dab\u0dba \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba. \u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 \u0dc4\u0ddc\u0db3\u0db8 \u0db1\u0dd0\u0d9c\u0dd3 \u0d91\u0db1 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0daf\u0dd9\u0d9a \u0dc3\u0daf\u0dc4\u0dcf \u0dbd\u0db6\u0dcf\u0daf\u0dd4\u0db1\u0dca Distinction Award \u0dc3\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca\u0daf \u0db4\u0dd2\u0daf\u0dd4\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd6 \u0d85\u0dad\u0dbb \u0dc3\u0dd2\u0d82\u0d9c\u0db4\u0dca\u0db4\u0dd4\u0dbb\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca 1,000 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dad\u0dca\u200d\u0dba\u0dcf\u0d9c\u0dba\u0d9a\u0dca \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0daf SEDS_LunarBot \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba. \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0d85\u0db7\u0dca\u200d\u0dba\u0dc0\u0d9a\u0dcf\u0dc1 \u0d9c\u0dc0\u0dda\u0dc2\u0dab\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0d9a\u0dca\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0dab\u0dba\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0dd0\u0daf\u0dd4\u0db8\u0dca\u0dbd\u0dad\u0dca \u0db1\u0dc0\u0dc3\u0dd3\u0dbd\u0db1\u0dca\u0dad \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2 \u0d9a\u0dbb\u0d9c\u0dad\u0dca\u0dc4.",
        "Singapore Space Technologies LTD\u00a0 \u0d86\u0dba\u0dad\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0d82\u0d9c\u0db4\u0dca\u0db4\u0dd6\u0dbb\u0dd4\u0dc0\u0dda \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0dad\u0dcf\u0db1\u0dcf\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba, AWS Educate, Office for Space Technology and Industry - Singapore, Singapore Digital, \u0dc3\u0dc4 Shiseido Japan \u0dba\u0db1 \u0d86\u0dba\u0dad\u0db1 \u0dc0\u0dbd \u0d85\u0db1\u0dd4\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db8\u0dd9\u0db8 \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd9\u0dc0\u0dbb \u0d87\u0db8\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0, \u0d91\u0d82\u0d9c\u0dbd\u0db1\u0dca\u0dad\u0dba, \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0d85\u0dbb\u0dcf\u0db6\u0dd2\u0dba, \u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0, \u0d9a\u0dd0\u0db1\u0da9\u0dcf\u0dc0, \u0dc3\u0dc4 \u0db6\u0dd9\u0dbd\u0dca\u0da2\u0dd2\u0dba\u0db8 \u0d87\u0dad\u0dd4\u0dbd\u0dd4 \u0dbb\u0da7\u0dc0\u0dbd\u0dca 18 \u0d9a\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca 140 \u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0d9a\u0dca \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd2\u0dba. \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 15 \u2013 25 \u0dad\u0dca \u0d85\u0dad\u0dbb \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca 600 \u0d9a\u0dca \u0db4\u0db8\u0dab \u0db8\u0dd9\u0db8 \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca SEDS_LunarBot \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0daf \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "SEDS_LunarBot \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc3\u0db3\u0dc4\u0dcf 18 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dc0\u0dd2\u0dba\u0dda \u0db4\u0dc3\u0dd4\u0dc0\u0db1 \u0d8b\u0dc3\u0dc3\u0dca\u0db4\u0dd9\u0dc5 \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd \u0db4\u0dc5\u0db8\u0dd4 \u0dc0\u0dc3\u0dbb\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0dc0\u0dd9\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dbd\u0dad\u0dca \u0dc0\u0dd2\u0dba. \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0db1\u0db8\u0dca, \u0d9a\u0ddc\u0dc5\u0db9 \u0da9\u0dd3.\u0d91\u0dc3\u0dca. \u0dc3\u0dda\u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0db6\u0db1 \u0dc0\u0dd2\u0daf\u0dd4\u0dbb\u0d82\u0d9c \u0dbd\u0dd1\u0db1\u0dca\u0da9\u0dc3\u0dca, \u0d9a\u0ddc\u0dc5\u0db9 \u0dc1\u0dcf\u0db1\u0dca\u0dad \u0db6\u0dd9\u0db1\u0da9\u0dd2\u0d9a\u0dca \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0db6\u0db1 \u0da2\u0dd6\u0da9\u0dca \u0db4\u0dd3\u0dbb\u0dd2\u0dc3\u0dca \u0dc4\u0dcf \u0d95\u0dc2\u0db0 \u0db4\u0dad\u0dd2\u0dbb\u0dab \u0dc3\u0dc4 \u0d85\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db4\u0dbb\u0dca\u0da9\u0dd2\u0dba\u0dd4 \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d89\u0d9c\u0dd9\u0db1\u0dd4\u0db8 \u0dbd\u0db6\u0db1 \u0dc3\u0db8\u0dd2\u0dad \u0dbb\u0dab\u0dc3\u0dd2\u0d82\u0dc4 \u0dba\u0db1 \u0d85\u0dba\u0dba\u0dd2."
      ],
      "title_ents": [
        {
          "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
          "label": "GPE"
        },
        {
          "text": "\u0dc3\u0dd2\u0d82\u0d9c\u0db4\u0dca\u0db4\u0dd6\u0dbb\u0dd4 \u0d85\u0db7\u0dca\u200d\u0dba\u0dc0\u0d9a\u0dcf\u0dc1 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dba",
