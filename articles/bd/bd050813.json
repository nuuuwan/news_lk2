          {
            "text": "18 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dc5\u0db8\u0dd4 \u0dc0\u0dc3\u0dbb",
            "label": "DATE"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0da9\u0dd3.\u0d91\u0dc3\u0dca",
