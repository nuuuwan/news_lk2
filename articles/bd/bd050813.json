          },
          {
            "text": "\u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 15-25 \u0d85\u0dad\u0dbb",
            "label": "DATE"
          },
          {
