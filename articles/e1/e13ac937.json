          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0da9\u0dd4\u0db6\u0dcf\u0dba\u0dd2",
            "label": "GPE"
          },
          {
            "text": "\u0d8a\u0dba\u0dda",
            "label": "DATE"
          }
        ],
        [],
        [
          {
            "text": "\u0da9\u0dd0\u0db1\u0dd2\u0dc3\u0dca \u0d85\u0dbd\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d91.\u0da2\u0dcf",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0da7\u0dcf\u0db1\u0dd2\u0dc3\u0dca",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0da2\u0dd6\u0dbd\u0dd2 13",
            "label": "DATE"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0dbb\u0dd6\u0db4\u0dc0\u0dcf\u0dc4\u0dd2\u0db1\u0dd3 \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0",
