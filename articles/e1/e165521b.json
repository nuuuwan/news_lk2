    "si": {
      "title": "BRICS \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd\u0daf\u0dcf\u0dba\u0d9a \u0db6\u0dc0 \u0da0\u0dd3\u0db1 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d87\u0db8\u0dad\u0dd2 \u0d9a\u0dd2\u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "BRICS \u0dc4\u0dd2 \u0da0\u0dd3\u0db1 \u0dc3\u0dad\u0dca\u0d9a\u0dcf\u0dbb\u0d9a \u0dc0\u0dc3\u0dbb \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd\u0daf\u0dcf\u0dba\u0d9a \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0da0\u0dd3\u0db1 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0dc3\u0dc4 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd0\u0db1\u0dca\u0d9c\u0dca \u0dba\u0dd3 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "2022 \u0daf\u0dd3 \u0dba\u0dcf\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dab\u0dba\u0dda \u0db8\u0dd4\u0dbd\u0dc3\u0dd4\u0db1 \u0daf\u0dbb\u0db1 \u0da0\u0dd3\u0db1\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dad\u0dca\u0d9a\u0dcf\u0dbb\u0d9a\u0dad\u0dca\u0dc0\u0dba \u0daf\u0dbb\u0db1 BRICS \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0dca \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0d9a\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0 \u0dc0\u0dd0\u0db1\u0dca\u0d9c\u0dca \u0db8\u0dda \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u00a0\u0d9a\u0dc5\u0dda\u0dba.",
        "\u0da0\u0dd3\u0db1\u0dba,\u00a0\u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0,\u00a0\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0, \u0db6\u0dca\u200d\u0dbb\u0dc3\u0dd3\u0dbd\u0dba \u0dc3\u0dc4 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d85\u0db4\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0 \u0dba\u0db1 \u0dbb\u0da7\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d91\u0d9a\u0dad\u0dd4\u0dc0 \u0dc3\u0dd0\u0daf\u0dd3\u00a0\u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb,\u00a0\u0db8\u0dd9\u0dba \u0dbd\u0ddd\u0d9a \u0db6\u0dbd\u0dc0\u0dad\u0dd4\u0db1\u0dca\u0da7 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba\u0d9a\u0dd2.",
        "BRICS \u0dba\u0db1\u0dd4 \u0db6\u0dca\u200d\u0dbb\u0dc3\u0dd3\u0dbd\u0dba, \u0dbb\u0dd4\u0dc3\u0dd2\u0dba\u0dcf\u0dc0, \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0, \u0da0\u0dd3\u0db1\u0dba \u0dc3\u0dc4 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d85\u0db4\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf\u0dc0\u0dda \u0db1\u0dd0\u0d9c\u0dd3 \u0d91\u0db1 \u0dc0\u0dd9\u0dc5\u0db3\u0db4\u0dbd \u0dc3\u0db8\u0dd6\u0dc4\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0d9a\u0dd9\u0da7\u0dd2 \u0dba\u0dd9\u0daf\u0dd4\u0db8\u0dba\u0dd2."
      ],
