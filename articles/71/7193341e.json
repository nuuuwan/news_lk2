        [
          {
            "text": "\u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d87\u0db8\u0dad\u0dd2",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dbb\u0dcf\u0da2\u0dca\u0dba \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d91\u0db8\u0dca\u0db4\u0dd3 \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "19 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9/\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 29/2022",
            "label": "ORG"
