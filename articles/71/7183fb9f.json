          {
            "text": "\u0dbd\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2",
            "label": "NORP"
          },
          {
            "text": "\u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
