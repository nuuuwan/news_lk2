          },
          {
            "text": "\u0d85\u0da9\u0dd2 \u0d85\u0da7\u0d9a\u0dca",
            "label": "QUANTITY"
          },
          {
            "text": "\u0d91\u0dbd\u0dca\u0da7\u0dd3\u0da7\u0dd3\u0d8a\u0dba",
