          },
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0da2\u0dd2\u0dad\u0dca \u0dc0\u0dd2\u0dad\u0dcf\u0db1\u0dcf\u0da0\u0dca\u0da0\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dba\u0dd4\u0db0\u0ddd\u0db4\u0d9a\u0dbb\u0dab \u0dc3\u0dda\u0dc0\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0d82\u0da2\u0dd4\u0dbd \u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dc0\u0dc3\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dcf\u0dbd\u0dad\u0dd4\u0dc0\u0d9a\u0dca\u0d9a\u0dd4 \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0",
            "label": "LOC"
          },
          {
            "text": "\u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd2 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0dab\u0daf\u0dd9\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3",
            "label": "PERSON"
          },
          {
            "text": "57",
            "label": "CARDINAL"
          },
          {
            "text": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db6\u0dbd\u0d9a\u0dcf\u0dba\u0dda \u0db1\u0dd2\u0dc1\u0dca\u0dc1\u0d82\u0d9a \u0d8a\u0dbb\u0dd2\u0dba\u0d9c\u0db8",
            "label": "PERSON"
