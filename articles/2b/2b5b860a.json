  "time_ut": 1616140846,
  "original_lang": "si",
  "original_title": "\u0d85\u0db4\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dca\u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d85\u0dc3\u0dd3\u0db8\u0dd2\u0dad \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0da2\u0dcf\u0dbd \u0dc3\u0db6\u0db3\u0dad\u0dcf",
  "text_idx": {
    "en": {
      "title": "Unlimited internet connection as of April",
      "author": "unknown",
      "body_lines": [
        "According to Sri Lanka Telecommunication Regulatory Commission, customers will be able to get approved unlimited internet plans by next month.",
        "\"ISPs have been ordered to provide information on the unlimited internet packages available to the public by March 1, 2021 to the Telecommunications Regulatory Commission of Sri Lanka, and we are currently in the process of approving the packages submitted by the operators. Customers can expect approved unlimited internet plans by April 2021.\u201d"
      ],
      "title_ents": [
        {
          "text": "April",
          "label": "DATE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "Sri Lanka Telecommunication Regulatory Commission",
            "label": "ORG"
          },
          {
            "text": "next month",
