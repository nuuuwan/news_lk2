    "si": {
      "title": "\u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 8,000 \u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad",
      "body_lines": [
        "COLOMBO (News 1st); \u0d9c\u0dad \u0dc0\u0dd6 \u0db8\u0dcf\u0dc3\u0dba \u0dad\u0dd4\u0dc5 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 8,179\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0d92\u0d9a\u0d9a\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0d92\u0d9a\u0d9a\u0dba\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0dd4\u0daf\u0dad\u0dca \u0dc3\u0db8\u0dbb\u0dc0\u0dd3\u0db8 \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0db8\u0dcf\u0dc3\u0dba\u0d9a \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0db8\u0dd9\u0dba \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0dc0\u0dc3\u0dbb \u0dad\u0dd4\u0dc5 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 32,385 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0dd4\u0daf\u0dad\u0dca \u0dc3\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dc4\u0dd2\u0dbb \u0db4\u0dc5\u0dcf\u0dad \u0dad\u0dd4\u0dc5 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0db8\u0dbb\u0dca\u0daf\u0db1 \u0dc0\u0dd0\u0da9\u0dc3\u0da7\u0dc4\u0db1\u0d9a\u0dca \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5 \u0db6\u0dc0\u0daf \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dad\u0dc0\u0daf, \u0da2\u0dd4\u0db1\u0dd2 \u0db8\u0dcf\u0dc3\u0dba \u0dad\u0dd4\u0dc5 \u0da9\u0dd9\u0d82\u0d9c\u0dd4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 8,179\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0dc3\u0db8\u0dbb\u0dc0\u0dd3\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0d85\u0d82\u0dc1\u0dba\u0dda \u0dc0\u0dd0\u0da9 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d85\u0d82\u0dc1\u0dba\u0da7 \u0dc0\u0dc3\u0dbb 5\u0d9a \u0dc0\u0dd0\u0da7\u0dd4\u0db4\u0dca \u0dbb\u0dc4\u0dd2\u0dad \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dd4 \u0daf?",
        "\u0db1\u0dd3\u0dad\u0dd2\u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dd3 \u0dbd\u0dd9\u0dc3 \u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0dc3\u0d82\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dab\u0dba \u0dc0\u0dd3\u0db8\u0da7 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dc5 \u0dad\u0dc0\u0dad\u0dca 35 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0d9c\u0dd9\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda"
