    "si": {
      "title": "\u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad \u0dc4\u0dcf \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0d85\u0dba\u0dc0\u0dd0\u0dba\u0d9a\u0dca \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0daf\u0dd3",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0daf\u0dd2\u0dbb\u0dd2 \u0db8\u0dcf\u0dc3 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0dd2\u0dad \u0dc4\u0dcf \u0d85\u0db1\u0dca\u0dad\u0dbb\u0dca\u0d9a\u0dcf\u0dbd\u0dd3\u0db1 \u0d85\u0dba\u0dc0\u0dd0\u0dba\u0d9a\u0dca \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 \u0db8\u0dcf\u0dc3\u0dba\u0dda \u0daf\u0dd3 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a, \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1, \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0dc4 \u0da2\u0db1\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (26\u0daf\u0dcf) \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0dad\u0dd3\u0dbb\u0dab \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0daf\u0dd3\u0db8\u0dda \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc4\u0db8\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4",
          "label": "DATE"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a",
            "label": "PERSON"
