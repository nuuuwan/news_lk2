    "si": {
      "title": "\u0daf\u0dca\u0dc0\u0dd2 \u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0db7\u0dcf\u0dc0\u0dd2\u0dad\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd9\u0db1\u0db8 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0db1\u0dba\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dda \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0ddc\u0dc5\u0db9 \u0db8\u0dc4\u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0\u0da7 \u0d85\u0dba\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dbb\u0db1\u0dca\u0db1\u0db1\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0dd9\u0db1\u0db8 \u0db1\u0dd3\u0dad\u0dd2 \u0dbb\u0dd3\u0dad\u0dd2 \u0db4\u0db1\u0dc0\u0dcf \u0d87\u0dad.",
        "\u0db8\u0dd9\u0db8 \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dd4\u0db8\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0d85\u0daf\u0dd2\u0dba\u0dbb \u0dbd\u0db6\u0db1 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0daf\u0dd3 \u0db8\u0dbb\u0dd4\u0d82\u0d9c\u0dcf \u0db6\u0dba\u0dd2\u0dc3\u0dd2\u0d9a\u0dbd\u0dba \u0d87\u0db8\u0dbb\u0dca \u0db4\u0dcf\u0dbb, \u0dc4\u0dd9\u0da7\u0dd2\u0dba\u0dcf\u0dc0\u0dad\u0dca \u0dc3\u0dc4 \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd4\u0db8 \u0dc4\u0dbb\u0dc4\u0dcf \u0db7\u0dcf\u0dc0\u0dd2\u0dad \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca \u0d9a\u0dbb \u0d87\u0dad. (\u0d92)"
      ],
