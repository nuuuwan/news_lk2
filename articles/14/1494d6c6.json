    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: \u0db1\u0dcf\u0db3\u0dd4\u0db1\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0d9f \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dda \u0db1\u0dde\u0d9a\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0\u0dd2\u0dba",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0dda \u0db1\u0dd0\u0d82\u0d9c\u0dd4\u0dbb\u0db8\u0dca \u0dbd\u0dcf \u0d87\u0dad\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0db1\u0dde\u0d9a\u0dcf \u0d9c\u0da2\u0db6\u0dcf\u0dc4\u0dd4 \u0db1\u0dde\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dd2\u0db1\u0dca \u0d9c\u0db8\u0db1\u0dca \u0db8\u0dbd\u0dd4 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0da7 \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dc0\u0dcf.",
        "\u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0dda \u0dc0\u0dbb\u0dcf\u0dba \u0db8\u0dcf\u0dc3\u0dca\u0da7\u0dbb\u0dca \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0d9a\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0db1\u0dde\u0d9a\u0dcf \u0dc3\u0dd2\u0db3\u0dd4\u0dbb\u0dc5, \u0dc3\u0dc4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0db1\u0dde\u0d9a\u0dcf \u0d9c\u0da2\u0db6\u0dcf\u0dc4\u0dd4 \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0dbd\u0da7 \u0d9c\u0ddc\u0da9\u0dc0\u0dd3 \u0dc0\u0dbb\u0dcf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dc0 \u0d9c\u0dd2\u0dba \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d91\u0db8 \u0db8\u0dd0\u0db1\u0dd2\u0dc6\u0dd9\u0dc3\u0dca\u0da7\u0dba\u0dda \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dc4\u0ddd \u0dba\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dcf\u0dc0\u0dbd\u0da7 \u0d9c\u0ddc\u0da9 \u0dc0\u0dd6 \u0d85\u0dba \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0dc0\u0dd2\u0dc3\u0dca\u0dad\u0dbb \u0dad\u0db8\u0dcf\u0da7 \u0dbd\u0db6\u0dcf \u0daf\u0dd2\u0dba \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "<iframe src=\u201dhttps://www.facebook.com/plugins/video.php?height=476&href=https%3A%2F%2Fwww.facebook.com%2FNewsfirstSL%2Fvideos%2F725646241991892%2F=al&show_06 \u2033 width=\u201d476\u2033 height=\u201d476\u2033 style=\u201dborder:none;overflow:hidden\u201d scrolling=\u201dno\u201d frameborder=\u201d0\u2033 allowfullscreen=\u201dtrue\u201d allow=\u201dautoplay; \u0d9a\u0dca\u0dbd\u0dd2\u0db4\u0dca\u0db6\u0ddd\u0da9\u0dca-\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0db1; \u0dc3\u0d82\u0d9a\u0dda\u0dad\u0dcf\u0dad\u0dca\u0db8\u0d9a-\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba; \u0db4\u0dd2\u0db1\u0dca\u0dad\u0dd6\u0dbb\u0dba\u0dda \u0db4\u0dd2\u0db1\u0dca\u0dad\u0dd6\u0dbb\u0dba; web-share\u201d allowFullScreen=\u201dtrue\u201d></iframe>",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: \u0db1\u0dcf\u0db3\u0dd4\u0db1\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0d9f \u0db1\u0dcf\u0dc0\u0dd2\u0d9a \u0dc4\u0db8\u0dd4\u0daf\u0dcf\u0dc0\u0dda \u0db1\u0dde\u0d9a\u0dcf \u0d9a\u0ddc\u0dc5\u0db9 \u0dc0\u0dbb\u0dcf\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0\u0dd2\u0dba"
      ],
