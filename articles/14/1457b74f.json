          },
          {
            "text": "\u0da2\u0ddd\u0dbb\u0dca\u0da2\u0dca \u0dbd\u0dd0\u0dbb\u0dd2\u0dba\u0dcf-\u0d87\u0da9\u0dca\u0da2\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dca\u0dbb\u0dd2\u0dc3\u0dca\u0da7\u0dd2\u0dba\u0db1\u0dca \u0dc3\u0dca\u0d9a\u0dd6\u0d9c\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0ddc\u0da7\u0dbb\u0dd2 \u0da2\u0dcf\u0dad\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d92 \u0d91\u0dc3\u0dca \u0dc0\u0dd9\u0db1\u0dca\u0d9a\u0da7\u0dda\u0dc2\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
