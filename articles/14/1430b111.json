    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 15 \u0dc3\u0dc4 16 \u0dba\u0db1 \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0db4\u0dd0\u0dba 1 \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 20 \u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0daf\u0dd4\u0dbd\u0dca\u0dba\u0dcf \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
      "body_lines": [
        "ECONOMYNEXT - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0db3\u0dd4\u0daf\u0dcf (15) \u0dc3\u0dc4 \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf (16) \u0db4\u0dd0\u0dba \u0d91\u0d9a\u0dba\u0dd2 \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 20 \u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca \u0db4\u0db1\u0dc0\u0db1 \u0db6\u0dc0 \u0db8\u0dc4\u0da2\u0db1 \u0d8b\u0db4\u0dba\u0ddd\u0d9c\u0dd2\u0dad\u0dcf \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0\u0dda (PUCSL) \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0da2\u0db1\u0d9a \u0dbb\u0dad\u0dca\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 (A, B, C, D, E, F, G, H, I, J, K, L, P, Q, R, S, T, U, V and W) \u0db4\u0dd0\u0dba\u0d9a \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0dc0\u0dda. \u0dc3\u0dc4 \u0dc3\u0dc0\u0dc3 5.00 \u0dc3\u0dd2\u0da7 9.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd2\u0db1\u0dcf\u0da9\u0dd2 20 \u0dba\u0dd2.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0da2\u0dbd \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dad\u0dd2\u0db6\u0dd3\u0db8 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0db1\u0dca\u0db0\u0dd2 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d9a\u0dcf\u0dbd\u0dc3\u0dd3\u0db8\u0dcf\u0dc0 \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba. \u0d9a\u0dd9\u0da7\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf \u0d9c\u0dd9\u0db1 \u0dba\u0dcf\u0db8\u0da7\u0dad\u0dca \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dd4 \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0d85\u0d9b\u0dab\u0dca\u0da9 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0dba \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8\u0da7\u0dad\u0dca \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0db8\u0dc4\u0da2\u0db1 \u0d8b\u0db4\u0dba\u0ddd\u0d9c\u0dd2\u0dad\u0dcf \u0d9a\u0ddc\u0db8\u0dd2\u0dc3\u0db8 \u0db4\u0dc0\u0dc3\u0dcf \u0d87\u0dad.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dc3\u0dbb 9\u0d9a\u0da7 \u0db4\u0dc3\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc0\u0dad\u0dcf\u0dc0\u0da7 \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2 \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0d89\u0dc4\u0dc5 \u0db1\u0dd0\u0d82\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb, \u0dc3\u0db8\u0dc3\u0dca\u0dad 75%\u0d9a \u0dc0\u0dd0\u0da9\u0dd2\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0db8\u0d9f\u0dd2\u0db1\u0dca, \u0dad\u0dc0\u0db8\u0dad\u0dca \u0d85\u0da9\u0dd4 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dc4\u0db1\u0dcf\u0db0\u0dcf\u0dbb \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0d87\u0dad."
      ],
