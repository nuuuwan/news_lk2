    "si": {
      "title": "\u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf\u0db1\u0dd4 \u0db8\u0db1\u0dca\u0d9a\u0dd2\u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dad\u0dd2\u0dba\u0dd4\u0dab\u0dd4 \u0dbd\u0dd9\u0dc3 \u0d89\u0dc4\u0dc5\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db8\u0db1\u0dca\u0d9a\u0dd2\u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0db1\u0dca \u0dad\u0dd2\u0dba\u0dd4\u0dab\u0dd4 \u0dbd\u0dd9\u0dc3 \u0d89\u0dc4\u0dc5 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7, \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 11,000\u0d9a\u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0d91\u0dbb\u0da7 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc3\u0dc4 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5\u0dba\u0db1\u0dca \u0db4\u0dd0\u0dad\u0dd2\u0dbb \u0dba\u0dcf\u0db8 \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db6\u0dba\u0dd2\u0da9\u0db1\u0dca \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0dbd\u0db1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0da0\u0dcf\u0dbb\u0dba\u0da7 \u0daf\u0ddc\u0dc3\u0dca \u0db4\u0dc0\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0dbb\u0ddd\u0d9c \u0db4\u0dcf\u0dbd\u0db1 \u0dc4\u0dcf \u0dc0\u0dd0\u0dc5\u0dd0\u0d9a\u0dca\u0dc0\u0dd3\u0db8\u0dda \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1 (CDC) \u0dc4\u0dd2 \u0db1\u0dc0\u0dad\u0db8 \u0daf\u0dad\u0dca\u0dad\u0dc0\u0dbd\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dbb\u0da7 \u0db4\u0dd4\u0dbb\u0dcf \u0db8\u0db1\u0dca\u0d9a\u0dd2\u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca 11,177 \u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0db1\u0dd2\u0dc0\u0dca\u0dba\u0ddd\u0d9a\u0dca \u0dc4\u0dd2 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0dba 2,295\u0d9a\u0dd2. \u0d9a\u0dd0\u0dbd\u0dd2\u0dc6\u0ddd\u0db1\u0dd2\u0dba\u0dcf\u0dc0\u0dd9\u0db1\u0dca 1,945\u0d9a\u0dca \u0dc3\u0dc4 \u0dc6\u0dca\u0dbd\u0ddc\u0dbb\u0dd2\u0da9\u0dcf\u0dc0\u0dd9\u0db1\u0dca 1,085\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0dbd\u0ddc\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0db8\u0db1\u0dca\u0d9a\u0dd2\u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0dca \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0db1\u0dca\u0db1\u0dda \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dd9\u0db1\u0dd2."
      ],
