    "si": {
      "title": "\u0d85\u0daf (30) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 35,000\u0d9a\u0dca \u0d9c\u0ddc\u0da9\u0db6\u0dcf\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dc0\u0dd2\u0daf\u0dd4\u0dbd\u0dd2\u0db6\u0dbd \u0dc4\u0dcf \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d9a\u0dcf\u0d82\u0da0\u0db1 \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dc0\u0dc3\u0db1\u0dca\u0db1\u0dda \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0daf\u0dd2\u0db1 4 \u0dad\u0dd4\u0dc5 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0da9\u0dd4\u0db4\u0dcf\u0da9\u0dd4 \u0db1\u0dd2\u0dc0\u0dd0\u0dbb\u0daf\u0dd2 \u0d9a\u0dbb \u0dad\u0dc0\u0dad\u0dca \u0dad\u0ddc\u0d9c \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0db4\u0dd2\u0da7\u0dad\u0dca \u0d9a\u0dbb \u0dc4\u0dd0\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0dc3\u0dd2\u0dbd\u0ddd\u0db1\u0dca \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0ddd\u0dbd\u0dd2\u0dba\u0db8\u0dca \u0dc3\u0dca\u0da7\u0ddd\u0dbb\u0dda\u0da2\u0dca \u0da7\u0dbb\u0dca\u0db8\u0dd2\u0db1\u0dbd\u0dca\u0dc3\u0dca \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca (\u0dc3\u0dd3\u0db4\u0dd3\u0d91\u0dc3\u0dca\u0da7\u0dd3\u0d91\u0dbd\u0dca) \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0daf\u0ddb\u0db1\u0dd2\u0d9a\u0dc0 \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 4000\u0d9a\u0dca \u0dc3\u0dc4 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 3000\u0d9a\u0dca \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dbb\u0dd2\u0db1 \u0db6\u0dc0 \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\"\u0db6\u0dc3\u0dca \u0dc3\u0dc4 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db3\u0dc4\u0dcf \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dad\u0dcf \u0dc3\u0db8\u0dca\u0db4\u0dd4\u0dbb\u0dca\u0dab \u0d9a\u0dbb \u0d87\u0dad,\" \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc0\u0dd2\u0da2\u0dda\u0dc3\u0dda\u0d9a\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d85\u0daf (30) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dda \u0dad\u0dc0\u0dad\u0dca \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca 92 \u0dc0\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db8\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0da7\u0ddc\u0db1\u0dca 35,000\u0d9a\u0dca \u0d9c\u0ddc\u0da9\u0db6\u0dd1\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0\u0daf \u0d94\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "APG \u0d9a\u0dc5 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0db1\u0db8\u0dca, \u0d8a\u0dc5\u0d9f \u0dc0\u0dd2\u0d9a\u0dbd\u0dca\u0db4\u0dba \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dbb\u0dab\u0dba\u0d9a\u0dd2: \u0db8\u0ddb\u0dad\u0dca\u200d\u0dbb\u0dd3"
      ],
