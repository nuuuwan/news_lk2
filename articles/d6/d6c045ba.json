    "si": {
      "title": "\u0dc3\u0dad\u0ddc\u0dc3 \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db7\u0dcf\u0dab\u0dca\u0da9 5\u0d9a \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dbd\u0d82\u0d9a\u0dcf \u0dc3\u0dad\u0ddc\u0dc3 \u0dc3\u0dd2\u0dba \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0dc3\u0dd0\u0dbd\u0dca\u0dc0\u0dbd \u0d85\u0daf \u0dc3\u0dd2\u0da7 \u0dc3\u0dd3\u0db1\u0dd2 \u0dc3\u0dc4 \u0dc3\u0dc4\u0dbd\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0d86\u0dc4\u0dcf\u0dbb \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0db4\u0dc4\u0d9a \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dc3\u0dad\u0ddc\u0dc3 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db4\u0dc3\u0db1\u0dca\u0daf \u0dba\u0dcf\u0db4\u0dcf \u0d85\u0db6\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dcf\u0dc3 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba \u0dad\u0dd4\u0dc5 \u0d85\u0dad\u0dca\u200d\u0dba\u0dcf\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0dbb\u0dd0\u0dc3\u0d9a \u0db8\u0dd2\u0dbd \u0db4\u0dc4\u0dc5 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0dd4\u0db4\u0dd2\u0dbb\u0dd2 \u0dc0\u0dd9\u0dc5\u0dd9\u0db3\u0dc3\u0dd0\u0dbd\u0dca \u0da2\u0dcf\u0dbd\u0dba\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd6 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0dc3\u0dc4 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dbd\u0ddc\u0d9a\u0dd4 \u0dc5\u0dd6\u0dab\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca (\u0dbb\u0dd4. 220) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 40\u0d9a\u0dd2\u0db1\u0dca \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba. \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0db4\u0ddc\u0db1\u0dca\u0db1\u0dd2 \u0dc3\u0db8\u0dca\u0db6\u0dcf (\u0dbb\u0dd4. 225) \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 31 \u0d9a\u0dd2\u0db1\u0dca \u0daf, \u0d9a\u0dd9\u0da7\u0dd2 \u0db0\u0dcf\u0db1\u0dca\u200d\u0dba \u0dc3\u0db8\u0dca\u0db6\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca (\u0dbb\u0dd4. 225) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 31 \u0d9a\u0dd2\u0db1\u0dca \u0daf, \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0db1\u0dcf\u0da9\u0dd4 (\u0dbb\u0dd4. 218) \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 20 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0d85\u0da9\u0dd4 \u0d9a\u0dbb \u0d87\u0dad. , \u0dbb\u0dad\u0dd4 \u0db4\u0dbb\u0dd2\u0db4\u0dca\u0db4\u0dd4 (\u0dbb\u0dd4. 580) \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 120 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0d9a\u0da9\u0dbd \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca (\u0dbb\u0dd4. 595) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0dc3\u0dd4\u0daf\u0dd4 \u0d9a\u0dd0\u0d9a\u0dd4\u0dc5\u0dd4 \u0dc3\u0dc4\u0dbd\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca (\u0dbb\u0dd4. 210) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 15 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba. , \u0dc3\u0dd4\u0daf\u0dd4 \u0dc3\u0dd3\u0db1\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca (\u0dbb\u0dd4. 305) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 7 \u0d9a\u0dd2\u0db1\u0dca \u0daf, \u0dc3\u0dd4\u0daf\u0dd4\u0dc5\u0dd4\u0dab\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca (\u0dbb\u0dd4. 750) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 100 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba. \u0dc4\u0dcf\u0dbd\u0dca\u0db8\u0dd0\u0dc3\u0dca\u0dc3\u0db1\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca (\u0dbb\u0dd4. 1,400) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 25 \u0d9a\u0dd2\u0db1\u0dca \u0daf, \u0dc0\u0dd2\u0dba\u0dc5\u0dd2 \u0db8\u0dd2\u0dbb\u0dd2\u0dc3\u0dca (\u0dbb\u0dd4. 1,950) \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 260 \u0d9a\u0dd2\u0db1\u0dca \u0daf, \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0dad\u0dcf\u0db4\u0dbd\u0dca (\u0dbb\u0dd4. 320) \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 40 \u0d9a\u0dd2\u0db1\u0dca \u0daf \u0d85\u0da9\u0dd4 \u0dc0\u0dd2\u0dba.",
        "\u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0dbb\u0dd0\u0dc3\u0d9a \u0db8\u0dd2\u0dbd \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d85\u0da9\u0dd4 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0dad\u0dca, \u0d91\u0db8\u0d9f\u0dd2\u0db1\u0dca \u0dc3\u0dd1\u0db8 \u0db4\u0dc0\u0dd4\u0dbd\u0d9a\u0da7\u0db8 \u0daf\u0dd2\u0db1\u0d9a\u0da7 \u0dad\u0dd4\u0db1\u0dca\u0dc0\u0dda\u0dbd \u0dc0\u0dda\u0dbd\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc4\u0dd0\u0d9a\u0dd2\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0dc0\u0dd2\u0dba. (\u0da0\u0dad\u0dd4\u0dbb\u0d82\u0d9c \u0dc3\u0db8\u0dbb\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8)"
      ],
