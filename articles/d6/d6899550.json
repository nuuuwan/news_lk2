          {
            "text": "\u0dc0\u0dc3\u0dcf\u0dba\u0dd2\u0da0\u0dda\u0db1 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8\u0dda",
