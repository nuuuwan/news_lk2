            "label": "GPE"
          },
          {
            "text": "\u0db8\u0dd3\u0da7\u0dbb\u0dca 50 \u0dba\u0dd2",
            "label": "QUANTITY"
          },
          {
            "text": "\u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb\u0db1\u0dcf\u0dba\u0d9a",
            "label": "ORG"
          },
          {
