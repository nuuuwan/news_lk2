    "si": {
      "title": "\u0db8\u0dc0 \u0daf\u0dbb\u0dd4 \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dc3\u0db8\u0d9c \u0dc0\u0dd0\u0dc0\u0da7 \u0db4\u0db1\u0dd3",
      "author": "unknown",
      "body_lines": [
        "\u0d87\u0db9\u0dd2\u0dbd\u0dd2\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf \u0dc0\u0dd0\u0dc0\u0dda \u0dc3\u0ddc\u0dbb\u0ddc\u0dc0\u0dca\u0dc0 \u0d85\u0dc3\u0dbd\u0dd2\u0db1\u0dca \u0db8\u0dc0\u0d9a \u0dc3\u0dd2\u0dba \u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dc3\u0db8\u0d9c \u0dc0\u0dd0\u0dc0\u0da7 \u0db4\u0dd0\u0db1 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2.",
        "\u0d91\u0d9a\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca \u0db6\u0dc0\u0dad\u0dca \u0db8\u0dc0 \u0dc3\u0dc4 \u0dad\u0dc0\u0dad\u0dca \u0daf\u0dbb\u0dd4\u0dc0\u0d9a\u0dd4 \u0db6\u0dda\u0dbb\u0dcf\u0d9c\u0dd9\u0db1 \u0dbb\u0ddd\u0dc4\u0dbd\u0dad\u0dca \u0d9c\u0dad\u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0daf \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2."
      ],
