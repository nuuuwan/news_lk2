    "si": {
      "title": "\u0d85\u0dba\u0dd2.\u0d95.\u0dc3\u0dd3. \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc3\u0dd3\u0db8\u0dcf\u0dc0 \u0dad\u0dc0\u0dad\u0dca \u0d85\u0da9\u0dd4\u0d9a\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0db1\u0dca \u0d94\u0dba\u0dd2\u0dbd\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda (\u0d85\u0dba\u0dd2.\u0d95.\u0dc3\u0dd3.) \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0dd3\u0db8\u0dcf\u0dc0 \u0db4\u0dc4\u0dc5 \u0daf\u0db8\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0dba\u0dd2.\u0d95.\u0dc3\u0dd3. \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc0\u0dbb\u0d9a\u0da7 \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1,500 \u0d9a, \u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 2,500 \u0d9a \u0dc3\u0dc4 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0dc0\u0dcf\u0dc4\u0db1\u0dc0\u0dbd\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 7,000 \u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0d85\u0dba\u0dd2.\u0d95.\u0dc3\u0dd3. \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dca\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dc0\u0dbb\u0d9a\u0da7 \u0dba\u0dad\u0dd4\u0dbb\u0dd4\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0d9a\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 2,500 \u0d9a, \u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae\u0dba\u0d9a\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 3,000 \u0d9a \u0dc3\u0dc4 \u0dc0\u0dd9\u0db1\u0dad\u0dca \u0dc0\u0dcf\u0dc4\u0db1\u0dc0\u0dbd\u0da7 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,000 \u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
