          },
          {
            "text": "\u0bae\u0bb9\u0bb0\u0b95\u0bae \u0baa\u0bc1\u0bb1\u0bcd\u0bb1\u0bc1\u0ba8\u0bcb\u0baf\u0bcd \u0bb5\u0bc8\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b9a\u0bbe\u0bb2\u0bc8",
            "label": "ORG"
          }
        ]
      ]
    }
