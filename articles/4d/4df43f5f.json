        [
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 40 \u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "PERCENT"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dc4\u0dbb\u0d9c\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0d9a\u0dcf \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dcf\u0dbd\u0dd2\u0d9c\u0dcf\u0dc0\u0dad\u0dca\u0dad \u0dc0\u0d9a\u0dd4\u0d9c\u0da9\u0dd4 \u0dbb\u0ddd\u0dc4\u0dbd",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dbb\u0dc0\u0dd3 \u0d9a\u0dd4\u0db8\u0dd4\u0daf\u0dda\u0dc1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc0\u0dd2\u0daf\u0dca\u0dc0\u0dad\u0dca \u0dc3\u0d82\u0d9c\u0db8\u0dba",
            "label": "ORG"
          }
        ],
        [],
        [
          {
            "text": "\u0dc3\u0dd2\u0dba\u0dba\u0da7 50 \u0d9a\u0dca \u0db4\u0db8\u0dab",
            "label": "PERCENT"
          },
          {
            "text": "\u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "\u0daf\u0dc0\u0dc3",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dbb\u0dc0\u0dd3 \u0d9a\u0dd4\u0db8\u0dd4\u0daf\u0dda\u0dc1\u0dca",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd4\u0db8\u0dd4\u0daf\u0dda\u0dc1\u0dca",
