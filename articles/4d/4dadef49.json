          }
        ]
      ]
    },
    "si": {
      "title": "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4 \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0dba\u0da7 \u0db6\u0dc3\u0dd3",
      "author": "unknown",
      "body_lines": [
        "\u0db6\u0daf\u0dd4\u0dbd\u0dca\u0dbd \u0db8\u0dc4 \u0dbb\u0ddd\u0dc4\u0dbd\u0dda \u0dc5\u0db8\u0dcf, \u0dc1\u0dbd\u0dca\u200d\u0dba, \u0db4\u0dd2\u0dc5\u0dd2\u0d9a\u0dcf, .\u0db1\u0dcf\u0dbb\u0dd2 \u0dc4\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dc3\u0dc0 ,\u0dc3\u0dca\u0db1\u0dcf\u0dba\u0dd4, \u0dc4\u0dd8\u0daf , \u0dc0\u0dd2\u0d9a\u0dbd\u0dcf\u0d82\u0d9c \u0dba\u0db1 \u0dbb\u0ddd\u0d9c \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0daf \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0da5 \u0dc0\u0ddb\u0daf\u0dc0\u0dbb\u0dd4 \u0dc4\u0dcf \u0dad\u0dc0\u0dad\u0dca \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db8\u0dda \u0daf\u0dd2\u0db1\u0dc0\u0dbd \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dd2\u0d9c\u0dba\u0da7 \u0db4\u0dd2\u0dc5\u0dd2\u0dba\u0db8\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0dcf\u0db4\u0dd0\u0daf\u0dd2\u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0dbb\u0dcf\u0da2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0dad\u0dd2."
      ],
