            "label": "PERSON"
          },
          {
            "text": "\u0dc4\u0dbb\u0dca\u0dc2 \u0dc0\u0dd2\u0da2\u0dda\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
