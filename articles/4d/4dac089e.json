          },
          {
            "text": "\u0d85\u0dbb\u0dd4\u0db1\u0dca\u0daf\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd4\u0dbb\u0dda\u0db1\u0dca \u0dbb\u0dcf\u0d9d\u0dc0\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0dba\u0daf\u0dcf\u0db8\u0dd2\u0dab\u0dd2 \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
