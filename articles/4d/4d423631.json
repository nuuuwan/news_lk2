    "si": {
      "title": "\u0db8\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0daf \u0db8\u0ddc\u0dbb\u0d9c\u0ddc\u0da9 \u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba \u0dad\u0dd9\u0dbd\u0dca \u0d87\u0db8\u0dd0\u0dad\u0dd2 \u0dc4\u0db8\u0dd4 \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4 \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0daf \u0db8\u0ddc\u0dbb\u0d9c\u0ddc\u0da9 \u0db8\u0dc4\u0dad\u0dcf \u0dc3\u0dc4 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0\u0dda \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca,\u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0d9a \u0dc0\u0dcf\u0dba\u0dd4,\u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc4\u0dcf \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dc4\u0dbb\u0dca\u0daf\u0dd3\u0db4\u0dca \u0dc3\u0dd2\u0d82 \u0db4\u0dd6\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0dc3\u0db8\u0d9c \u0dc4\u0db8\u0dd4\u0dc0\u0d9a\u0dca \u0db1\u0dc0\u0daf\u0dd2\u0dbd\u0dca\u0dbd\u0dd2 \u0db1\u0dd4\u0dc0\u0dbb \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc4\u0dcf \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd2\u0dab.",
        "\u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0daf\u0dca\u0dc0\u0dd2\u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dca\u0dc0\u0dd2\u0d9a \u0db6\u0dbd\u0dc1\u0d9a\u0dca\u0dad\u0dd2 \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dd3\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0dc4\u0daf\u0dd2\u0dc3\u0dd2 \u0d9a\u0dbb\u0dd4\u0dab\u0dd4 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dc3\u0dcf\u0d9a\u0da0\u0dca\u0da1\u0dcf \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd9\u0dba\u0dd2.\u0d91\u0db8 \u0dc4\u0db8\u0dd4\u0dc0\u0dda\u0daf\u0dd3 \u0db8\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0daf \u0db8\u0ddc\u0dbb\u0d9c\u0ddc\u0da9 \u0db8\u0dc4\u0dad\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0db8\u0dd4\u0dc4\u0dd4\u0dab\u0daf\u0dd3\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0daf\u0dd4\u0dc2\u0dca\u0d9a\u0dbb\u0dad\u0dcf \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0dc3\u0dc4 \u0db6\u0dd9\u0daf\u0dcf \u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c \u0dc3\u0db8\u0dca\u0db6\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dd6\u0dbb\u0dd2 \u0db8\u0dc4\u0dad\u0dcf \u0daf\u0dd0\u0db1\u0dd4\u0dc0\u0dad\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba",
          "label": "NORP"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a",
            "label": "NORP"
          },
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dd2\u0dba\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0d89\u0db1\u0dca\u0daf\u0dd3\u0dba",
            "label": "NORP"
          },
          {
            "text": "\u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca, \u0dc3\u0dca\u0dc0\u0db7\u0dcf\u0dc0\u0dd2\u0d9a \u0dc0\u0dcf\u0dba\u0dd4,",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc4\u0dcf \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dc4\u0dbb\u0dca\u0daf\u0dd3\u0db4\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dd2\u0d82 \u0db4\u0dd6\u0dbb\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0dc4\u0dcf \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dc0 \u0daf\u0dd2\u0dbd\u0dca\u0dbd\u0dd2",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0db8\u0ddc\u0dbb\u0d9c\u0ddc\u0da9",
            "label": "PERSON"
          },
          {
            "text": "\u0db4\u0dd6\u0dbb\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          },
          {
            "text": "\u0dc1\u0dca\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0",
            "label": "GPE"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0bae\u0bbf\u0bb2\u0bbf\u0ba8\u0bcd\u0ba4 \u0bae\u0bca\u0bb0\u0b95\u0bca\u0b9f \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf \u0b8e\u0ba3\u0bcd\u0ba3\u0bc6\u0baf\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bb0\u0bc8 \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb5\u0bc1\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b89\u0baf\u0bb0\u0bcd\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0b95\u0bb0\u0bcd \u0bae\u0bbf\u0bb2\u0bbf\u0ba8\u0bcd\u0ba4 \u0bae\u0bca\u0bb0\u0b95\u0bca\u0b9f \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf \u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0bcb\u0bb2\u0bbf\u0baf\u0bae\u0bcd, \u0b87\u0baf\u0bb1\u0bcd\u0b95\u0bc8 \u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1, \u0bb5\u0bc0\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0b95\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bc1\u0bb1 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bb0\u0bcd \u0bb8\u0bcd\u0bb0\u0bc0 \u0bb9\u0bb0\u0bcd\u0ba4\u0bc0\u0baa\u0bcd \u0b9a\u0bbf\u0b99\u0bcd \u0baa\u0bc2\u0bb0\u0bbf \u0b86\u0b95\u0bbf\u0baf\u0bcb\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b87\u0b9f\u0bc8\u0baf\u0bbf\u0bb2\u0bbe\u0ba9 \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0baa\u0bc1\u0ba4\u0bc1 \u0ba4\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb3\u0bcd\u0bb3 \u0bb5\u0bc0\u0b9f\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0b95\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bc1\u0bb1 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0bb2\u0bcd \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0ba4\u0bc1.",
        "\u0b87\u0b9a\u0bcd\u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bbf\u0ba9\u0bcd \u0baa\u0bcb\u0ba4\u0bc1, \u200b\u200b\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0ba8\u0bcb\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b9a\u0bbf\u0bb0\u0bae\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b8e\u0bb0\u0bbf\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bcd\u0bb1\u0bc1 \u0bb5\u0bbf\u0ba8\u0bbf\u0baf\u0bcb\u0b95\u0bae\u0bcd \u0b9a\u0bc6\u0baf\u0bcd\u0bb5\u0ba4\u0bbf\u0bb2\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b8e\u0ba4\u0bbf\u0bb0\u0bcd\u0b95\u0bca\u0bb3\u0bcd\u0bb3\u0bc1\u0bae\u0bcd \u0b9a\u0bb5\u0bbe\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bc1\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bbf\u0bb0\u0bc1.\u0bae\u0bca\u0bb0\u0b95\u0bca\u0b9f, \u0ba4\u0bbf\u0bb0\u0bc1.\u0baa\u0bc2\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0bb5\u0bbf\u0bb3\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bbe\u0bb0\u0bcd."
      ],
      "title_ents": [
        {
          "text": "\u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0ba9\u0bcd",
          "label": "NORP"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
            "label": "NORP"
          },
          {
            "text": "\u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0bbe",
            "label": "GPE"
          },
          {
            "text": "\u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0baf\u0ba9\u0bcd",
            "label": "NORP"
          },
          {
            "text": "\u0baa\u0bc6\u0b9f\u0bcd\u0bb0\u0bcb\u0bb2\u0bbf\u0baf\u0bae\u0bcd, \u0b87\u0baf\u0bb1\u0bcd\u0b95\u0bc8 \u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1,",
            "label": "ORG"
          },
          {
            "text": "\u0bb5\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0b9a\u0ba4\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0b95\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bc1\u0bb1 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bb8\u0bcd\u0bb0\u0bc0 \u0bb9\u0bb0\u0bcd\u0ba4\u0bc0\u0baa\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0b9a\u0bbf\u0b99\u0bcd \u0baa\u0bc2\u0bb0\u0bbf",
            "label": "PERSON"
          },
          {
            "text": "\u0bb5\u0bc0\u0b9f\u0bcd\u0b9f\u0bc1\u0bb5\u0b9a\u0ba4\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0b95\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bc1\u0bb1 \u0bb5\u0bbf\u0bb5\u0b95\u0bbe\u0bb0\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0b95\u0bae\u0bcd",
            "label": "ORG"
          },
          {
            "text": "\u0baa\u0bc1\u0ba4\u0bc1 \u0ba4\u0bbf\u0bb2\u0bcd\u0bb2\u0bbf",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0bae\u0bca\u0bb0\u0b95\u0bca\u0b9f",
            "label": "PERSON"
          },
          {
            "text": "\u0baa\u0bc2\u0bb0\u0bbf",
            "label": "PERSON"
          },
          {
            "text": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
            "label": "GPE"
          },
