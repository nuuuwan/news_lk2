            "label": "DATE"
          },
          {
            "text": "\u0dbd\u0db6\u0db1 \u0dc3\u0db3\u0dd4\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "4",
            "label": "CARDINAL"
          },
          {
            "text": "\u0db4\u0dd9\u0dbb \u0daf\u0dd2\u0db1",
            "label": "DATE"
          },
          {
            "text": "\u0dc3\u0dd1\u0db8 \u0daf\u0dd2\u0db1\u0db8",
            "label": "DATE"
          },
          {
            "text": "\u0dbd\u0db6\u0db1 \u0dc3\u0db3\u0dd4\u0daf\u0dcf",
            "label": "DATE"
          },
          {
            "text": "9.00",
            "label": "CARDINAL"
          },
          {
            "text": "\u0da7\u0dca\u0dc0\u0dd2\u0da7\u0dbb\u0dca",
            "label": "PRODUCT"
          },
          {
            "text": "\u0d86\u0d9c\u0db8\u0db1 \u0dc4\u0dcf \u0dc0\u0dd2\u0d9c\u0db8\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db0\u0db8\u0dca\u0db8\u0dd2\u0d9a \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0",
