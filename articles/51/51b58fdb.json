          }
        ],
        [
          {
            "text": "\u0db4\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca\u0d9a\u0dd4\u0dbd\u0db8\u0dda\u0daf\u0dd3 \u0dba\u0dcf\u0db4\u0db1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0dc0\u0dc0\u0dd4\u0db1\u0dd2\u0dba\u0dcf\u0dc0 \u0daf\u0d9a\u0dca\u0dc0\u0dcf",
