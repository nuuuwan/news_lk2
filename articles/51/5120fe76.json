  "text_idx": {
    "en": {
      "title": "Three wheeler fare Rs. 10 up",
      "author": "unknown",
      "body_lines": [
        "The three wheeler associations have decided to increase the three wheeler fares by 10 rupees as compared to the increase in fuel prices. Accordingly, they have decided to increase the current fare of Rs. 100 for the first kilometer to Rs. 90 from the second kilometer to Rs. 90."
      ],
