    "si": {
      "title": "\u0dad\u0dca\u200d\u0dbb\u0dd2\u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dbb\u0dd4. 10\u0d9a\u0dd2\u0db1\u0dca \u0d89\u0dc4\u0dc5\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0dc0\u0dd0\u0da9\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dc3\u0dcf\u0db4\u0dd9\u0d9a\u0dca\u0dc2\u0dc0 \u0dad\u0dca\u200d\u0dbb\u0dd2 \u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10\u0d9a\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dad\u0dca\u200d\u0dbb\u0dd2 \u0dbb\u0ddd\u0daf \u0dbb\u0dae \u0dc3\u0d82\u0d9c\u0db8\u0dca \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda. \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb\u0dba\u0da7 \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d85\u0dba\u0d9a\u0dbb\u0db1 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 100\u0d9a \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dbb\u0dc0 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0dcf\u0d9c\u0dd9\u0db1 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd \u0db8\u0dd3\u0da7\u0dbb\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d85\u0dba\u0d9a\u0dc5 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 80\u0d9a \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 90\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dbb\u0dd3\u0db8\u0da7 \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
