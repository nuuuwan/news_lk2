          "text": "\u0db4\u0dd1\u0db1\u0dca \u0d92\u0dc2\u0dd2\u0dba\u0dcf \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0\u0dda MD \u0db1\u0dd2\u0db8\u0dbd\u0dca \u0dad\u0dd2\u0dbd\u0d9a\u0dbb\u0dad\u0dca\u0db1 \u2018\u0db6\u0dd0\u0d82\u0d9a\u0dd4 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3",
