    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0db8\u0d9c \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db4\u0dc5\u0db8\u0dd4 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc3\u0db8\u0d9c \u0d9c\u0dcf\u0dbd\u0dca\u0dbd\u0dda\u0daf\u0dd3 \u0d8a\u0dba\u0dda \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dd6 \u0dad\u0dbb\u0d9c \u0daf\u0dd9\u0d9a\u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0d85\u0daf \u0daf\u0dd9\u0dc0\u0dd0\u0db1\u0dd2 \u0daf\u0dd2\u0db1\u0dba \u0db1\u0dd2\u0db8\u0dcf \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0d94\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0 \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd3.",
        "\u0dad\u0dbb\u0d9c\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0da7 \u0db4\u0dc4\u0dbb\u0daf\u0dd4\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0dc3\u0dd2\u0dba \u0db4\u0dc5\u0db8\u0dd4 \u0d89\u0db1\u0dd2\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0daf\u0dd9\u0db1\u0dcf \u0daf\u0dd0\u0dc0\u0dd3 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 212\u0d9a\u0dca \u0dbb\u0dd0\u0dc3\u0dca \u0d9a\u0dc5\u0dcf.",
        "\u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db1\u0dcf\u0dba\u0d9a \u0db4\u0dbb\u0dca \u0d9a\u0db8\u0dd2\u0db1\u0dca\u0dc3\u0dca \u0db1\u0ddc\u0daf\u0dd0\u0dc0\u0dd3 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 26\u0d9a\u0dca \u0dc3\u0dc4 \u0db1\u0dda\u0dad\u0db1\u0dca \u0dbd\u0dba\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 8\u0d9a\u0dca \u0dbd\u0db6\u0dcf \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2. \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0d9a\u0dd0\u0db8\u0dbb\u0db1\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dd3\u0db1\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 77\u0d9a\u0dca, \u0d8b\u0dc3\u0dca\u0db8\u0dcf\u0db1\u0dca \u0d9a\u0dc0\u0dcf\u0da2\u0dcf \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 71\u0d9a\u0dca, \u0d87\u0dbd\u0dd9\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dda\u0dbb\u0dd2 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 45\u0d9a\u0dca \u0dc3\u0dc4 \u0da9\u0dda\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0ddd\u0db1\u0dbb\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 25\u0d9a\u0dca \u0dbb\u0dd0\u0dc3\u0dca \u0d9a\u0dc5\u0dc4. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8\u0dda\u0daf\u0dd3 \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca 4, \u0da2\u0dd9\u0dc6\u0dca\u0dbb\u0dd2 \u0dc0\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0dda 2, \u0dad\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0d91\u0d9a\u0dca \u0d9a\u0da9\u0dd4\u0dbd\u0dca\u0dbd\u0d9a\u0dca \u0daf\u0dc0\u0dcf \u0d9c\u0dad\u0dca\u0dc4.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: 212/10 (\u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0db1\u0dd2\u0dbb\u0ddd\u0dc2\u0db1\u0dca \u0daf\u0dd2\u0d9a\u0dca\u0dc0\u0dd0\u0dbd\u0dca\u0dbd 58, \u0d85\u0d82\u0da2\u0dbd\u0ddd \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dca\u0dc3\u0dca 39, \u0dad\u0dd2\u0db8\u0dad\u0dd2 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 28, \u0db4\u0daf\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dc3\u0d82\u0d9c 23, \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca 22, \u0dad\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf 14. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0db1\u0dda\u0dad\u0db1\u0dca \u0dbd\u0dba\u0db1\u0dca 5/90, \u0dc3\u0dd3\u0dc3\u0dd3\u0db8\u0dca/\u0db8\u0dd2\u0da0\u0dd9\u0dbd\u0dca\u0dc3\u0dca 5 . 1/25, \u0db8\u0dd2\u0dc2\u0dd9\u0dbd\u0dca \u0dc3\u0dca\u0da7\u0dcf\u0d9a\u0dca 1/31)",
        "\u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0: 313/8 (\u0db4\u0dd2\u0dad\u0dd2\u0d9a\u0dbb\u0dd4: \u0d9a\u0dd0\u0db8\u0dbb\u0db1\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dd3\u0db1\u0dca 77, \u0d8b\u0dc3\u0dca\u0db8\u0dcf\u0db1\u0dca \u0d9a\u0dc0\u0dcf\u0da2\u0dcf 71, \u0d87\u0dbd\u0dd9\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dda\u0dbb\u0dd2 45, \u0db4\u0dd0\u0da7\u0dca \u0d9a\u0db8\u0dd2\u0db1\u0dca\u0dc3\u0dca \u0d92\u0d92 26, \u0da9\u0dda\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0ddd\u0db1\u0dbb\u0dca \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 25. \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8: \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca 4/107, \u0da2\u0dd9\u0dc6\u0dca\u0dbb\u0dd2 \u0dc0\u0ddc\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0dda 2/68, \u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf 1/8 )"
      ],
