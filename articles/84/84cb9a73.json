            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0da2\u0dd2\u0dad\u0dca \u0db8\u0dbd\u0dbd\u0dca\u0d9a\u0ddc\u0da9",
