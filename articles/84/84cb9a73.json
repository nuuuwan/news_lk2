            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0bb5\u0bbf\u0b9c\u0bbf\u0ba4\u0bcd \u0bae\u0bb2\u0bb2\u0bcd\u0b95\u0bca\u0b9f",
            "label": "PERSON"
          },
          {
            "text": "\u0bae\u0bb9\u0bbf\u0ba8\u0bcd\u0ba4 \u0b9a\u0bae\u0baf\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9",
            "label": "PERSON"
          },
          {
            "text": "\u0b85\u0bb0\u0bcd\u0b9c\u0bc1\u0ba9 \u0b92\u0baa\u0bc7\u0b9a\u0bc7\u0b95\u0bb0",
