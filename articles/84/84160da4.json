        [
          {
            "text": "\u0d85\u0d9c\u0ddd\u0dc3\u0dca\u0dad\u0dd4 01 \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0d8b\u0daf\u0dd1\u0dc3\u0db1",
            "label": "DATE"
