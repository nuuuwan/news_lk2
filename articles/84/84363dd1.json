    "si": {
      "title": "\u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0daf\u0db8\u0dcf \u0db4\u0dd9\u0dbb\u0dc5\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db8\u0dd3\u0dbb\u0dd2\u0d9c\u0db8 \u0dad\u0d82\u0d9c\u0ddd\u0dc0\u0dd2\u0da7 \u0db4\u0dcf\u0dbb\u0dda \u0dc4\u0dc5\u0dd4\u0d9a\u0dcf\u0db8 \u0d9a\u0db1\u0dca\u0daf\u0dda\u0daf\u0dd3 \u0d85\u0daf (23) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0d9a\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db8\u0dd3\u0dbb\u0dd2\u0d9c\u0db8 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0db8\u0dd4\u0dad\u0dd4\u0dbb\u0dcf\u0da2\u0dc0\u0dd9\u0dbd \u0dc3\u0dd2\u0da7 \u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dcf\u0db1 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1\u0dba \u0d9a\u0dc5 \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca \u0dbd\u0dd3\u0da7\u0dbb\u0dca 33,600\u0d9a\u0dca \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba\u0dda \u0dad\u0dd2\u0db6\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc4\u0dc5\u0dd4\u0d9a\u0db8 \u0d9a\u0db1\u0dca\u0daf \u0dad\u0dbb\u0dab\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0db6\u0dc0\u0dd4\u0dc3\u0dbb\u0dba \u0dc4\u0daf\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0db4\u0dc3\u0dd4\u0db4\u0dc3\u0da7 \u0dba\u0dcf\u0db8\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d85\u0db1\u0dad\u0dd4\u0dbb \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab\u0dc0\u0dbd\u0daf\u0dd3 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf."
      ],
