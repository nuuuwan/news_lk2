    "si": {
      "title": "\u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0dad\u0dad\u0dca\u0db4\u0dbb 10 \u0da7 \u0d85\u0da9\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dbb \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba \u0d9a\u0dc5 \u0db4\u0dc5\u0db8\u0dd4 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dcf \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd9\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0db8\u0dd3\u0da7\u0dbb 100 \u0d89\u0dc3\u0dc0\u0dca\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc0\u0dbb\u0da7 \u0dad\u0dad\u0dca\u0db4\u0dbb 10 \u0dc3\u0dd3\u0db8\u0dcf\u0dc0 \u0db6\u0dd2\u0db3 \u0daf\u0dd0\u0db8\u0dd6 \u0db4\u0dc5\u0db8\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a\u0dba\u0dcf \u0dc3\u0dc4 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dcf \u0dc0\u0dd3\u0db8\u0da7 \u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0d85\u0db6\u0dda\u0d9a\u0ddd\u0db1\u0dca \u0dc3\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dba.",
        "\u0d85\u0db6\u0dda\u0d9a\u0ddd\u0db1\u0dca \u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0dc3\u0dca\u0dc0\u0dd2\u0da7\u0dca\u0dc3\u0dbb\u0dca\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dad\u0dd2 Resisprint International Chaux-de-Fonds 2022 \u0dad\u0dbb\u0d9f\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 A \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba\u0dda \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0db8\u0dc4\u0dcf \u0dad\u0dbb\u0d9f\u0dba\u0da7 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd2 \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0d89\u0dc3\u0dc0\u0dca\u0dc0 \u0dad\u0dad\u0dca\u0db4\u0dbb 9.96\u0d9a\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0db8 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d85\u0daf \u0d94\u0dc4\u0dd4 \u0db6\u0dd2\u0db3 \u0daf\u0dd0\u0db8\u0dd4\u0dc0\u0dda \u0dad\u0dad\u0dca\u0db4\u0dbb 10.6\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0db8\u0dd0\u0dba\u0dd2 \u0db8\u0dcf\u0dc3\u0dba\u0dda\u0daf\u0dd3 \u0d94\u0dc4\u0dd4 \u0dad\u0dd0\u0db6\u0dd6 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf\u0dc0\u0dba\u0dd2.",
        "\u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0dad\u0dad\u0dca\u0db4\u0dbb 10 \u0da7 \u0d85\u0da9\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0d9a\u0dbb \u0da2\u0dba\u0d9c\u0dca\u200d\u0dbb\u0dc4\u0dab\u0dba \u0d9a\u0dc5 \u0db4\u0dc5\u0db8\u0dd4 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0d86\u0dc3\u0dd2\u0dba\u0dcf\u0db1\u0dd4 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dcf \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca \u0dc0\u0dd9\u0dba\u0dd2"
      ],
