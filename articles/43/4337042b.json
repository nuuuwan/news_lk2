    "si": {
      "title": "\u0dad\u0dbd\u0dd9\u0dba\u0dd2\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dda \u0db8\u0dc3\u0dd4\u0db1\u0dca \u0d87\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0da7 \u0d9c\u0dd2\u0dba \u0db0\u0dd3\u0dc0\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca",
      "author": "\u0dc0\u0dd2\u0dc2\u0dca\u0dab\u0dd4",
      "body_lines": [
        "\u0dad\u0dbd\u0dd9\u0dba\u0dd2\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8 \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5\u0dda \u0dc3\u0dd2\u0da7 \u0db6\u0ddd\u0da7\u0dca\u0da7\u0dd4\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0da7 \u0d9c\u0dd2\u0dba \u0db0\u0dd3\u0dc0\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0d85\u0dad\u0dd4\u0dbb\u0dd4\u0daf\u0db1\u0dca\u0dc0 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd6 \u0db1\u0db8\u0dd4\u0dad\u0dca \u0d91\u0db8 \u0db0\u0dd3\u0dc0\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dcf \u0dc3\u0dd9\u0dc0\u0dd3\u0db8\u0dda \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dd2\u0dc3\u0dd2\u0db3\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0dca \u0dbd\u0dd0\u0db6\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad.",
        "\u0dad\u0dbd\u0dd9\u0dba\u0dd2\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8 \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dc5\u0da7 \u0d85\u0dba\u0dad\u0dca \u0dbb\u0dcf\u0dc3\u0dad\u0dd4\u0dbb\u0dd9\u0dba\u0dd2 \u0dbb\u0dcf\u0dc3\u0dc3\u0dda\u0d9a\u0dbb\u0dca (\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 52), \u0dbb\u0dcf\u0da2\u0db8\u0dd6\u0dbb\u0dca\u0dad\u0dd2 \u0db8\u0ddc\u0dc4\u0dcf\u0db1\u0dca\u0dbb\u0dcf\u0da2\u0dca (\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 50) \u0dc3\u0dc4 \u0dbb\u0dcf\u0da2\u0dd2 \u0da2\u0db1\u0dad\u0dca (\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 27) \u0dba\u0db1 \u0db0\u0dd3\u0dc0\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dcf \u0dc3\u0dd4\u0db4\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dad\u0dbd\u0dd9\u0dba\u0dd2\u0db8\u0db1\u0dca\u0db1\u0dcf\u0dbb\u0db8 \u0db4\u0dd2\u0dba\u0dbb\u0dca \u0d85\u0d82\u0dc1\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db8\u0dd4\u0dc4\u0dd4\u0daf\u0dda \u0daf\u0dd0\u0dbd\u0dca \u0db8\u0dc3\u0dd4\u0db1\u0dca \u0d87\u0dbd\u0dca\u0dbd\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf 14 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d91\u0db1\u0dca\u0da2\u0dd2\u0db1\u0dca \u0d94\u0dbb\u0dd4\u0dc0\u0d9a\u0dd2\u0db1\u0dca (\u0db6\u0ddd\u0da7\u0dca\u0da7\u0dd4\u0dc0) .OVRB-A-4138 MNRI) \u0db4\u0dd2\u0da7\u0dad\u0dca \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc3\u0dd4\u0db4\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0d9c\u0ddc\u0da9\u0db6\u0dd2\u0db8\u0da7 \u0db1\u0ddc\u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd2 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca 15 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d85\u0daf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db8\u0dd9\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db0\u0dd3\u0dc0\u0dbb\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0dc4 \u0db1\u0dcf\u0dc0\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0ddd\u0daf\u0dd2\u0dc3\u0dd2 \u0d9a\u0dbb\u0dad\u0dd2.",
        "\u0d91\u0dc4\u0dd9\u0dad\u0dca 16 \u0dc0\u0dd0\u0db1\u0dd2 \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0dc0\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dad\u0dca \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc4\u0ddd \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0d9c\u0dd2\u0dba \u0db6\u0ddd\u0da7\u0dca\u0da7\u0dd4\u0dc0 \u0dc4\u0db8\u0dd4 \u0dc0\u0dd3 \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda. \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0daf\u0dd2\u0db1 \u0daf\u0dd9\u0d9a\u0dda \u0dc3\u0dd2\u0da7 \u0db8\u0dd9\u0db8 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0da7 \u0dad\u0daf \u0dc3\u0dd4\u0dc5\u0d82 \u0dc4\u0db8\u0dcf \u0d9c\u0dd2\u0dba \u0db6\u0dc0\u0daf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda."
      ],
