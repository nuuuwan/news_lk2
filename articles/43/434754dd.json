    "ta": {
      "title": "\u0bae\u0bc1\u0ba4\u0bb2\u0bbf\u0bb2\u0bcd \u0ba4\u0bc1\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc6\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0b9f\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8",
      "author": "unknown",
      "body_lines": [
        "\u0b85\u0bb5\u0bc1\u0bb8\u0bcd\u0ba4\u0bbf\u0bb0\u0bc7\u0bb2\u0bbf\u0baf\u0bbe\u0bb5\u0bc1\u0b95\u0bcd\u0b95\u0bc6\u0ba4\u0bbf\u0bb0\u0bbe\u0ba9 \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f \u0b9f\u0bc6\u0bb8\u0bcd\u0b9f\u0bcd \u0ba4\u0bca\u0b9f\u0bb0\u0bbf\u0bb2\u0bcd, \u0b95\u0bbe\u0bb2\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bae\u0bbe\u0b95\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3 \u0bae\u0bc1\u0ba4\u0bb2\u0bbe\u0bb5\u0ba4\u0bc1 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0bae\u0bc1\u0ba4\u0bb2\u0bbf\u0bb2\u0bcd \u0ba4\u0bc1\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc6\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0b9f\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0ba8\u0bbe\u0ba3\u0baf\u0b9a\u0bcd \u0b9a\u0bc1\u0bb4\u0bb1\u0bcd\u0b9a\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0ba9\u0bcd\u0bb1 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0ba3\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd \u0ba4\u0bbf\u0bae\u0bc1\u0ba4\u0bcd \u0b95\u0bb0\u0bc1\u0ba3\u0bbe\u0bb0\u0ba4\u0bcd\u0ba9, \u0ba4\u0bae\u0ba4\u0ba3\u0bbf \u0bae\u0bc1\u0ba4\u0bb2\u0bbf\u0bb2\u0bcd \u0ba4\u0bc1\u0b9f\u0bc1\u0baa\u0bcd\u0baa\u0bc6\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbe\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0ba9 \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8: 1. \u0baa\u0ba4\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb8\u0b99\u0bcd\u0b95, 2. \u0ba4\u0bbf\u0bae\u0bc1\u0ba4\u0bcd \u0b95\u0bb0\u0bc1\u0ba3\u0bbe\u0bb0\u0ba4\u0bcd\u0ba9 (\u0b85\u0ba3\u0bbf\u0ba4\u0bcd\u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd), 3. \u0b95\u0bc1\u0b9a\u0bb2\u0bcd \u0bae\u0bc6\u0ba9\u0bcd\u0b9f\u0bbf\u0bb8\u0bcd, 4. \u0b85\u0b9e\u0bcd\u0b9a\u0bb2\u0bcb \u0bae\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bc2\u0bb8\u0bcd, 5. \u0ba4\u0ba9\u0b9e\u0bcd\u0b9a\u0baf \u0b9f\u0bbf \u0b9a\u0bbf\u0bb2\u0bcd\u0bb5\u0bbe, 6. \u0ba4\u0bbf\u0ba9\u0bc7\u0bb7\u0bcd \u0b9a\u0ba8\u0bcd\u0ba4\u0bbf\u0bae\u0bbe\u0bb2\u0bcd, 7. \u0ba8\u0bbf\u0bb0\u0bcb\u0bb7\u0ba9\u0bcd \u0b9f\u0bbf\u0b95\u0bcd\u0bb5\u0bc6\u0bb2\u0bcd\u0bb2 (\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bbe\u0bb3\u0bb0\u0bcd), 8. \u0bb0\u0bae\u0bc7\u0bb7\u0bcd \u0bae\u0bc6\u0ba9\u0bcd\u0b9f\u0bbf\u0bb8\u0bcd, 9. \u0b9c\u0bc6\u0b83\u0baa\u0bcd\u0bb0\u0bbf \u0bb5\u0ba9\u0bcd\u0b9f\u0bb0\u0bcd\u0b9a\u0bc7, 10. \u0bb2\u0b9a\u0bbf\u0ba4\u0bcd \u0b8e\u0bae\u0bcd\u0baa\u0bc1\u0bb2\u0bcd\u0ba4\u0bc6\u0ba9\u0bbf\u0baf, 11. \u0b85\u0b9a\u0bbf\u0ba4 \u0baa\u0bc6\u0bb0\u0bcd\u0ba3\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb.",
        "\u0b85\u0bb5\u0bc1\u0bb8\u0bcd\u0ba4\u0bbf\u0bb0\u0bc7\u0bb2\u0bbf\u0baf\u0bbe: 1. \u0b9f\u0bc7\u0bb5\u0bbf\u0b9f\u0bcd \u0bb5\u0bcb\u0bb0\u0bcd\u0ba9\u0bb0\u0bcd, 2. \u0b89\u0bb8\u0bcd\u0bae\u0bbe\u0ba9\u0bcd \u0b95\u0bb5\u0bbe\u0b9c\u0bbe, 3. \u0bae\u0bb0\u0bcd\u0ba9\u0bc1\u0bb8\u0bcd \u0bb2\u0baa\u0bc1\u0bb7\u0bc8\u0ba9\u0bcd, 4. \u0bb8\u0bcd\u0b9f\u0bc0\u0bb5\u0bcd \u0bb8\u0bcd\u0bae\u0bbf\u0ba4\u0bcd, 5. \u0b9f\u0bcd\u0bb0\u0bc6\u0bb5\u0bbf\u0bb8\u0bcd \u0bb9\u0bc6\u0b9f\u0bcd, 6. \u0b95\u0bae\u0bb0\u0bca\u0ba9\u0bcd \u0b95\u0bbf\u0bb1\u0bc0\u0ba9\u0bcd, 7. \u0b85\u0bb2\u0bc6\u0b95\u0bcd\u0bb8\u0bcd \u0b95\u0bbe\u0bb0\u0bbf (\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bc6\u0b9f\u0bcd \u0b95\u0bbe\u0baa\u0bcd\u0baa\u0bbe\u0bb3\u0bb0\u0bcd), 8. \u0baa\u0bb1\u0bcd \u0b95\u0bae\u0bbf\u0ba9\u0bcd\u0bb8\u0bcd (\u0b85\u0ba3\u0bbf\u0ba4\u0bcd\u0ba4\u0bb2\u0bc8\u0bb5\u0bb0\u0bcd), 9. \u0bae\u0bbf\u0bb1\u0bcd\u0b9a\u0bc6\u0bb2\u0bcd \u0bb8\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd\u0b95\u0bcd, 10. \u0ba8\u0bc7\u0ba4\u0ba9\u0bcd \u0bb2\u0bc8\u0baf\u0ba9\u0bcd, 11. \u0bae\u0bbf\u0bb1\u0bcd\u0b9a\u0bc6\u0bb2\u0bcd \u0bb8\u0bcd\u0bb5\u0baa\u0bcd\u0bb8\u0ba9\u0bcd."
      ],
