    "si": {
      "title": "\u0db4\u0dca\u200d\u0dbb\u0dae\u0db8\u0dba\u0dd9\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0db4\u0dd0\u0daf\u0dc0\u0dd3\u0db8\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d95\u0dc3\u0dca\u0da7\u0dda\u200d\u0dca\u200d\u0dbb\u0dbd\u0dd2\u0dba\u0dcf\u0dc0 \u0dc3\u0db8\u0d9c \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0dad\u0dbb\u0d9c \u0daf\u0dd9\u0d9a\u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0db1\u0dca\u0dc0\u0dd2\u0dad \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0d9a\u200d\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0dad\u0dbb\u0d9c\u0dba\u0dda\u0daf\u0dd3 \u0dc1\u200d\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8 \u0db4\u0dc5\u0db8\u0dd4\u0dc0 \u0db4\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0da7 \u0db4\u0dc4\u0dbb\u0daf\u0dd9\u0db1\u0dd4 \u0d87\u0dad.",
        "\u0d9a\u0dcf\u0dc3\u0dd2\u0dba\u0dda \u0dc0\u0dcf\u0dc3\u0dd2\u0dba \u0daf\u0dd2\u0db1\u0dd6 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dda \u0db1\u0dcf\u0dba\u0d9a \u0dad\u0dd2\u0db8\u0dad\u0dd2 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda \u0dad\u0db8\u0daf\u0db1\u0dd3 \u0db4\u0dc5\u0db8\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0dad\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0da7 \u0db4\u0dd2\u0dc0\u0dd2\u0dc3\u0dd9\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0: 1. \u0db4\u0daf\u0dd4\u0db8\u0dca \u0db1\u0dd2\u0dc3\u0d82\u0d9c, 2. \u200b\u200b\u0dad\u0dd2\u0db8\u0dad\u0dd2 \u0d9a\u0dbb\u0dd4\u0dab\u0dcf\u0dbb\u0dad\u0dca\u0db1 (\u0db1\u0dcf\u0dba\u0d9a), 3. \u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca, 4. \u0d85\u0d82\u0da2\u0dbd\u0ddd \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dca\u0dc3\u0dca, 5. \u0dad\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf, 6. \u0daf\u0dd2\u0db1\u0dda\u0dc2\u0dca \u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8\u0dcf\u0dbd\u0dca, 7. \u0db1\u0dd2\u0dbb\u0ddd\u0dc2\u0db1\u0dca \u0daf\u0dd2\u0d9a\u0dca\u0dc0\u0dd0\u0dbd\u0dca\u0dbd (\u0d9a\u0da9\u0dd4\u0dbd\u0dd4 \u0dbb\u0d9a\u0dd2\u0db1\u0dca\u0db1\u0dcf), 8. \u0dbb\u0db8\u0dda\u0dc2\u0dca \u0db8\u0dd9\u0db1\u0dca\u0da9\u0dd2\u0dc3\u0dca. , 9. \u0da2\u0dd9\u0dc6\u0dca\u0dbb\u0dd2 \u0dc0\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0dda, 10. \u0dbd\u0dc3\u0dd2\u0dad\u0dca \u0d87\u0db9\u0dd4\u0dbd\u0dca\u0daf\u0dd9\u0dab\u0dd2\u0dba, 11. \u0d85\u0dc3\u0dd2\u0dad \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4.",
        "\u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0: 1. \u0da9\u0dda\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0ddd\u0db1\u0dbb\u0dca, 2. \u0d8b\u0dc3\u0dca\u0db8\u0dcf\u0db1\u0dca \u0d9a\u0dc0\u0dcf\u0da2\u0dcf, 3. \u0db8\u0dcf\u0dbb\u0dca\u0db1\u0dc3\u0dca \u0dbd\u0dd0\u0db4\u0dca\u0dc2\u0dba\u0dd2\u0db1\u0dca, 4. \u0dc3\u0dca\u0da7\u0dd3\u0dc0\u0dca \u0dc3\u0dca\u0db8\u0dd2\u0dad\u0dca, 5. \u0da7\u0dca\u200d\u0dbb\u0dd0\u0dc0\u0dd2\u0dc3\u0dca \u0dc4\u0dd9\u0da9\u0dca, 6. \u0d9a\u0dd0\u0db8\u0dbb\u0db1\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dd3\u0db1\u0dca, 7. \u0d87\u0dbd\u0dd9\u0d9a\u0dca\u0dc3\u0dca \u0d9a\u0dda\u0dbb\u0dd2 (\u0d9a\u0da9\u0dd4\u0dbd\u0dd4 \u0dbb\u0d9a\u0dd2\u0db1\u0dca\u0db1\u0dcf), 8. \u0db4\u0dbb\u0dca \u0d9a\u0db8\u0dd2\u0db1\u0dca\u0dc3\u0dca (\u0db1\u0dcf\u0dba\u0d9a), 9 .\u0db8\u0dd2\u0dc2\u0dd9\u0dbd\u0dca \u0dc3\u0dca\u0da7\u0dcf\u0dbb\u0dca\u0d9a\u0dca, 10. \u0db1\u0dda\u0dad\u0db1\u0dca \u0dbd\u0dba\u0db1\u0dca, 11. \u0db8\u0dd2\u0da0\u0dd9\u0dbd\u0dca \u0dc3\u0dca\u0dc0\u0db6\u0dca\u0dc3\u0db1\u0dca."
      ],
