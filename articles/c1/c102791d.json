          }
        ]
      ]
    },
    "si": {
      "title": "\u0d85\u0dbb\u0d9c\u0dbd \u0db6\u0dd2\u0db8\u0dda \u0dad\u0dc0\u0db8\u0dad\u0dca \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0da2\u0db1\u0d9a\u0dcf\u0dba\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d85\u0dbb\u0d9c\u0dbd\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca \u0daf\u0dd2\u0db1 93 \u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0d85\u0dbb\u0d9c\u0dbd \u0dba\u0dd9\u0daf\u0dd4\u0dab\u0dd4 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dd2\u0da7 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0dbb\u0dd0\u0db3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2.",
        "\u0d91\u0db8 \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0db4\u0dd2\u0dba\u0d9c\u0dd0\u0da7 \u0db4\u0dd9\u0dc5 \u0dad\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0db1\u0dd0\u0dbb\u0db9\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0daf \u0db8\u0dda \u0dc0\u0dd9\u0db1\u0dc0\u0dd2\u0da7 \u0d91\u0dba\u0dcf \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
