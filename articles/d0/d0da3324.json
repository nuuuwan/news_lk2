          {
            "text": "\u0baa\u0bc6\u0b9f\u0bcd\u0bb0\u0bc7\u0bbe\u0bb2\u0bcd",
            "label": "PERSON"
          },
          {
            "text": "\u0b9f\u0bc0\u0b9a\u0bb2\u0bcd",
