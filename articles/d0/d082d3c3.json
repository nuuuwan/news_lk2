    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0da7\u0ddd\u0d9a\u0db1 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dbb\u0db1 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d85\u0daf \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dd2\u0dbb\u0dc0\u0dd4\u0db8\u0dca\u0dc4\u0dbd\u0d9a\u0daf\u0dd3 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0db4\u0dd9\u0dbb \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd9\u0d9a\u0dd4\u0d9c\u0dda \u0d89\u0db1\u0dca\u0db0\u0db1 \u0da7\u0ddd\u0d9a\u0db1\u0dba \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dcf \u0d9a\u0dbb\u0db1 \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc4\u0db8\u0dd4\u0daf\u0dcf \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca, \u0db8\u0dda \u0dc0\u0dc3\u0dbb\u0dda \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dd0\u0daf \u0dc3\u0dd2\u0da7 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dad\u0ddc\u0d9c \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1 \u0db6\u0dc0\u0da7 \u0dbb\u0da2\u0dba \u0d8a\u0dba\u0dda \u0dc3\u0dc4\u0dad\u0dd2\u0d9a \u0dc0\u0dd2\u0dba. \u0db4\u0dd2\u0d9a\u0dca\u0dc3\u0dca - \u0db4\u0dca\u200d\u0dbb\u0daf\u0dd3\u0db4\u0dca \u0db4\u0dad\u0dd2\u0dbb\u0dab"
      ],
