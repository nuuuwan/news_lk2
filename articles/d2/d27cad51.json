  "text_idx": {
    "en": {
      "title": "Inflow of foreign labor remittances down",
      "author": "unknown",
      "body_lines": [
        "Foreign labor remittances fell 51.6 percent to $1.6 billion in the first six months of this year, reversing a sharp decline in June and reversing May's rise.",
        "Foreign labor remittances in June were US$ 274.3 million, a 42.6% drop compared to US$ 478.4 million recorded in 2021.",
        "Remittances increased from $249 million in April to $304 million in May but fell again in June."
      ],
