    "si": {
      "title": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0dc4\u0dcf PUCSL \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0dc4\u0db8\u0dd4\u0dc0\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db4\u0ddc\u0daf\u0dd4 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0 \u0dc4\u0dd9\u0dc0\u0dad\u0dca \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0, \u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0 \u0dc4\u0dd9\u0dc0\u0dad\u0dca \u0d9a\u0ddd\u0db4\u0dcf \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf \u0dbb\u0dd0\u0dc3\u0d9a\u0dca \u0db8\u0dda \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0dc4\u0dd9\u0da7 (05) \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0dc4\u0db8\u0dd4\u0dc0\u0da7 \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddc \u0d9c\u0dd1\u0dc3\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca \u0dc3\u0dc4 \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddc \u0d9c\u0dd1\u0dc3\u0dca \u0da7\u0dbb\u0dca\u0db8\u0dd2\u0db1\u0dbd\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca \u0dba\u0db1 \u0d86\u0dba\u0dad\u0db1 \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda. \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 (\u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba) \u0d9c\u0dbb\u0dd4 \u0da0\u0dbb\u0dd2\u0dad \u0dc4\u0dda\u0dbb\u0dad\u0dca \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dda.",
        "\u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8, \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3(\u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba) \u0d9c\u0dbb\u0dd4 \u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0dab \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0d91\u0daf\u0dd2\u0db1\u0db8 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0db1 \u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0d87\u0dad\u0dca\u0dad\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0dc4\u0dcf \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dba\u0dd2.",
        "\u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dc4\u0dcf \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dd3\u0dba \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0\u0daf \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1 \u0dbb\u0dab\u0dad\u0dd4\u0d82\u0d9c \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dc4\u0dd9\u0da7 \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d91\u0dba\u0da7 \u0d85\u0db8\u0dad\u0dbb\u0dc0, \u0d91\u0daf\u0dd2\u0db1 \u0dbb\u0da2\u0dba\u0dda \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0\u0daf \u0d91\u0dc4\u0dd2 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4 \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0d85\u0db1\u0dd4\u0dbb \u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba\u0daf\u0dbb\u0dca\u0dc1\u0db1 \u0dba\u0dcf\u0db4\u0dcf \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0db1 \u0d85\u0dad\u0dbb, \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d91\u0db8 \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0dc4\u0db8\u0dd4\u0dc0\u0da7 \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb, \u0d91\u0dc5\u0db9\u0dd9\u0db1 06 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0 \u0dc4\u0db8\u0dd4\u0dc0\u0da7 \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0d87\u0dad\u0dca\u0dad\u0dda \u0db8\u0dc4\u0da2\u0db1 \u0d8b\u0db4\u0dba\u0ddd\u0d9c\u0dd2\u0dad\u0dcf \u0d9a\u0ddc\u0db8\u0dd2\u0dc2\u0db1\u0dca \u0dc3\u0db7\u0dcf\u0dc0\u0dba\u0dd2."
      ],
      "title_ents": [
        {
          "text": "PUCSL \u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
          "label": "ORG"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0db8\u0dc4\u0da2\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db8\u0dd9\u0db8 \u0dc3\u0dad\u0dd2\u0dba",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0da7\u0dbb\u0dca\u0db8\u0dd2\u0db1\u0dbd\u0dca \u0dbd\u0d82\u0d9a\u0dcf \u0dbd\u0dd2\u0db8\u0dd2\u0da7\u0da9\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc4\u0dd9\u0da7",
            "label": "DATE"
          },
          {
            "text": "05",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d9a\u0ddd\u0db4\u0dca \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0da0\u0dbb\u0dd2\u0dad \u0dc4\u0dda\u0dbb\u0dad\u0dca",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0dc4\u0dcf \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0da2\u0dba\u0dda \u0d9c\u0dd2\u0dab\u0dd4\u0db8\u0dca \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0daf\u0dd2\u0db1\u0db8",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0dc4\u0dcf \u0db1\u0dd2\u0dc0\u0dcf\u0dc3 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba\u0dda \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a \u0d9a\u0db8\u0dd2\u0da7\u0dd4\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0dc4\u0dd9\u0da7",
            "label": "DATE"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0dc3\u0db1\u0dca\u0db1 \u0dbb\u0dab\u0dad\u0dd4\u0d82\u0d9c",
            "label": "PERSON"
          }
        ],
        [
          {
