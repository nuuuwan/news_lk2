    "si": {
      "title": "\u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0db1 \u0dbd\u0daf \u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0db1 \u0db6\u0dc0 SJB \u0db4\u0dc0\u0dc3\u0dba\u0dd2",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2\u0dba \u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda \u0dad\u0db8\u0db1\u0dca \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0db1\u0dca\u0db1\u0dda \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0db1 \u0dbd\u0daf \u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0db8\u0dd2\u0dc3 \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0db1 \u0dbd\u0daf \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a\u0da7 \u0db1\u0ddc\u0dc0\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\"\u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0d9a\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0db1\u0dd4 \u0dbd\u0db6\u0db1\u0dca\u0db1\u0dda \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db8\u0dd2\u0dc3 \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0ddc\u0dc0\u0dda. \u0d9a\u0dae\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0db3\u0dc0\u0db1 \u0dbd\u0daf \u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dbb\u0dd0\u0dc3\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0db4\u0dd2 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd3 \u0dc0\u0dd9\u0db8\u0dd4\" \u0dba\u0db1\u0dd4\u0dc0\u0dd9\u0db1\u0dca SJB \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a\u0dba\u0dd9\u0d9a\u0dd4 Daily FT \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
