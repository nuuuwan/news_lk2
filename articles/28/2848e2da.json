            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbd\u0db1 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
