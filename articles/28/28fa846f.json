  "time_ut": 1661915354,
  "original_lang": "si",
  "original_title": "\u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db0\u0dd2\u0d9a\u0dcf\u0dbb\u0dd2\u0dba\u0dd9\u0db1\u0dca  \u0d85\u0dad\u0dd2\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9c\u0dd0\u0dc3\u0da7\u0dca \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a\u0dca",
  "text_idx": {
    "en": {
      "title": "An extraordinary gazette notification from the Consumer Affairs Authority",
      "author": "unknown",
      "body_lines": [
        "The Consumer Affairs Authority has issued a special gazette notice publishing the conditions related to the production, import, marketing, storage, sale and collection of several types of goods.",
        "Animal feed, bottled drinking water, tinned fish, cement, lentils, baby nappies and sanitary napkins, milk powder, eggs, rice, fertilizers, wheat flour, car spare parts, onions, chicken, dry chillies, halibut etc. These terms apply."
      ],
      "title_ents": [
        {
          "text": "the Consumer Affairs Authority",
          "label": "ORG"
        }
      ],
