    "si": {
      "title": "\u0d91\u0dc5\u0dd2\u0dba\u0da7 \u0d91\u0db1\u0dca\u0db1\u0dad\u0dca \u0d9a\u0dbd\u0dd2\u0db1\u0dca \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca\u0da7 \u0dad\u0db1\u0dad\u0dd4\u0dbb\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0db1\u0dd2\u0daf\u0dc4\u0dc3 \u0dbd\u0db6\u0db1 \u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca \u0dbb\u0dcf\u0db8\u0db1\u0dcf\u0dba\u0d9a \u0db8\u0dc4\u0dad\u0dcf\u0da7 \u0db1\u0dc0 \u0dad\u0db1\u0dad\u0dd4\u0dbb \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0 \u0d9a\u0db8\u0dca\u0d9a\u0dbb\u0dd4 \u0dc4\u0dcf \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0db8\u0db1\u0dd6\u0dc2 \u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dca\u0d9a\u0dcf\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d85\u0daf \u0dc3\u0dc0\u0dc3\u0dca \u0dc0\u0dbb\u0dd4\u0dc0\u0dd9\u0dd2 \u0d92 \u0dad\u0db1\u0dad\u0dd4\u0dbb\u00a0 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0db1\u0dd2\u0dc0\u0dd9\u0dd2\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0daf \u0db1\u0dcf\u0db1\u0dcf\u0dba\u0d9a\u0dca\u0d9a\u0dcf\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0d9a\u0dd3\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0dbb\u0db1\u0dca\u0da2\u0db1\u0dca",
