          {
            "text": "\u0db8\u0dc4\u0dbb\u0d9c\u0db8 \u0dad\u0dbb\u0dd4\u0dab \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0db7\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dc0\u0dab\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda\u0daf\u0dd3",
