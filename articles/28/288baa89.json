          {
            "text": "\u0db8\u0dc4\u0dcf\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0dad\u0dd2\u0dc3\u0dca\u0dc3 \u0dc0\u0dd2\u0dad\u0dcf\u0dbb\u0dab",
