  "text_idx": {
    "en": {
      "title": "Calling for the presidency today at 10.00 am",
      "author": "unknown",
      "body_lines": [
        "Calling for nominations to elect the next president will be done in Parliament today.",
        "Parliamentary sources say that four candidates, including the Acting President, are going to present themselves for the post of President.",
        "Parliament is scheduled to meet today at 10.00 am under the chairmanship of Speaker Mahinda Yapa Abeywardena."
      ],
