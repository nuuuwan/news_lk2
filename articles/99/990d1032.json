    "si": {
      "title": "\u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba\u0dda \u0daf\u0dd3\u0dbb\u0dca\u0d9c \u0daf\u0dd2\u0db1\u0d9a\u0da7 \u0db4\u0dc3\u0dd4 \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8",
      "author": "T. Saranya",
      "body_lines": [
        "\u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0daf\u0dd0\u0da9\u0dd2 \u0dc4\u0dd2\u0d9f\u0dba\u0d9a\u0da7 \u0dbd\u0d9a\u0dca\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0dbd\u0dd2\u0da7\u0dca\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d85\u0daf (14) \u0dbd\u0db6\u0dcf \u0daf\u0dd4\u0db1\u0dca\u0db1\u0dcf.",
        "\u0db1\u0dd4\u0dc0\u0dbb\u0d91\u0dc5\u0dd2\u0dba \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0db1\u0d9c\u0dbb\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dda \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1 \u0db8\u0d9c\u0dd2\u0db1\u0dca \u0db8\u0dcf\u0dc3\u0dba\u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca \u0d91\u0dba \u0dbd\u0db6\u0dcf\u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0d8b\u0daf\u0dda \u0dc3\u0dd2\u0da7\u0db8 \u0daf\u0dd2\u0d9c\u0dd4 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbd \u0dbb\u0dd0\u0db3\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2.",
        "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0daf \u0daf\u0dd2\u0db1 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dbb\u0dd2\u0db1 \u0dbd\u0daf \u0dbd\u0dd3\u0da7\u0dbb\u0dca 120 \u0d9c\u0dd1\u0dc3\u0dca \u0d9a\u0db1\u0dca\u0da7\u0dda\u0db1\u0dbb\u0dca \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca \u0dc0\u0dd9\u0dad \u0dbd\u0db6\u0dcf \u0daf\u0dd4\u0db1\u0dca \u0d85\u0dad\u0dbb \u0d92\u0dc0\u0dcf \u0d91\u0db1\u0dad\u0dd4\u0dbb\u0dd4 \u0db6\u0dbd\u0dcf \u0dc3\u0dd2\u0da7\u0dd2 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0d89\u0dc0\u0dd4\u0db8\u0dca \u0db4\u0dd2\u0dc4\u0dd4\u0db8\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0da7 \u0dc3\u0dbb\u0dd2\u0dbd\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0da2\u0dd3\u0dc0\u0dad\u0dca \u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba."
      ],
