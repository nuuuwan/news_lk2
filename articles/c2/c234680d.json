    "si": {
      "title": "\u0db4\u0dcf\u0db1\u0dca \u0d9c\u0dd9\u0da9\u0dd2\u0dba\u0d9a \u0db8\u0dd2\u0dbd\u0dad\u0dca \u0d89\u0dc4\u0dc5 \u0d9c\u0dd2\u0dba\u0dcf",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d8a\u0dba\u0dda (03) \u0dc3\u0dd2\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0dc0\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dbb\u0ddc\u0da7\u0dd2 \u0db8\u0dd2\u0da7\u0dd2\u0dba\u0d9a \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 100\u0d9a\u0dd2\u0db1\u0dca \u0dc3\u0dc4 \u0db4\u0dbb\u0dcf\u0da7\u0dcf, \u0dbb\u0ddc\u0da7\u0dd3 \u0dc3\u0dc4 \u0dbb\u0ddd\u0dbd\u0dca\u0dc3\u0dca \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10 \u0dc3\u0dd2\u0da7 15 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d86\u0db4\u0db1\u0dc1\u0dcf\u0dbd\u0dcf \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0d82\u0d9c\u0db8\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d91\u0db8 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0d85\u0dc3\u0dda\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dad\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dad\u0dd2\u0dbb\u0dd2\u0d9f\u0dd4 \u0db4\u0dd2\u0da7\u0dd2 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8 \u0dc3\u0dc4 \u0d91\u0dc4\u0dd2 \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0dbd\u0dd9\u0dc3 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0daf\u0db8\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2."
      ],
      "title_ents": [],
      "body_line_ents_list": [
