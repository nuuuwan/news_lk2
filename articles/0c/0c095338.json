      "body_line_ents_list": [
        [
          {
            "text": "\u0db8\u0dc4\u0db1\u0dd4\u0dc0\u0dbb \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbb\u0dca\u0dae \u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0dc3\u0dbb",
            "label": "DATE"
          },
          {
            "text": "\u0db1\u0dd2\u0dad\u0dca\u0dad\u0dc0\u0dd9\u0dbd \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0dab\u0dba\u0dda\u0daf\u0dd3",
            "label": "FAC"
          },
