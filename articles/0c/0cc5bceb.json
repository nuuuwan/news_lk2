  "original_title": "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d9c\u0dcf\u0dc3\u0dca\u0dad\u0dd4\u0dc0 \u0d85\u0d9f\u0dc4\u0dbb\u0dd4\u0dc0\u0dcf\u0daf\u0dcf \u0dc3\u0dd2\u0da7 \u0d89\u0dc4\u0dc5\u0da7",
  "text_idx": {
    "en": {
      "title": "Train fares up from Tuesday",
      "author": "unknown",
      "body_lines": [
        "A senior official of the Railway Department said that it has been decided to increase the train fares from next Tuesday (12) and the minimum fare is likely to increase to 20 rupees.",
        "The official said that the legal procedure for that is currently in progress and will be completed by next Sunday.",
        "Accordingly, the official further said that the train fare will increase to half of the bus fare in the relevant area."
      ],
      "title_ents": [
        {
          "text": "Tuesday",
          "label": "DATE"
        }
      ],
