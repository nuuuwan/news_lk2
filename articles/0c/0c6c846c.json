    "si": {
      "title": "\u0db4\u0dc0\u0dd4\u0dbd\u0dca \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca \u0d85\u0daf (29) \u0dc0\u0dd0\u0da9 \u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0d9a",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0daf\u0dd3\u0db8\u0db1\u0dcf \u0d87\u0dad\u0dd4\u0dc5\u0dd4 \u0d89\u0dbd\u0dca\u0dbd\u0dd3\u0db8\u0dca \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0db8\u0dd4\u0dbd\u0dca \u0d9a\u0dbb \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dd4\u0dbd\u0dca \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca \u0daf\u0dd3\u0db4 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dca\u0dad \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0d9a\u0dca \u0daf\u0dd2\u0dba\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0dad\u0dd3\u0dbb\u0dab\u0dba \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dd6\u0dad\u0dd2\u0d9a\u0dcf \u0dc3\u0dda\u0dc0\u0dcf \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0db1\u0dd2 \u0daf\u0dda\u0dc0\u0dd2\u0d9a\u0dcf \u0d9a\u0ddc\u0da9\u0dd2\u0dad\u0dd4\u0dc0\u0d9a\u0dca\u0d9a\u0dd4 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba \u0d9a\u0dca\u0dc2\u0dda\u0dad\u0dca\u200d\u0dbb\u0dba\u0da7 \u0db4\u0dbb\u0dd2\u0db4\u0dd6\u0dbb\u0d9a \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0db1\u0dca 8\u0d9a\u0dca \u0db8\u0dd9\u0db8 \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0dba\u0da7 \u0dc3\u0dc4\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0db1 \u0db6\u0dc0\u0dba\u0dd2."
      ],
