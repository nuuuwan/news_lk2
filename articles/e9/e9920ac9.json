    "si": {
      "title": "\u0d9a\u0db3\u0dc3\u0dd4\u0dbb\u0dd2\u0db3\u0dd4 \u0db4\u0dd2\u0dc4\u0dd2\u0da7 \u0db4\u0dad\u0dcf 5000\u0d9a\u0dca \u0d94\u0d9a\u0db3 \u0dc4\u0dbb\u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0d93\u0dad\u0dd2\u0dc4\u0dcf\u0dc3\u0dd2\u0d9a \u0dbb\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db8\u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba\u0dda \u0dc0\u0dcf\u0dbb\u0dca\u0dc2\u0dd2\u0d9a \u0d87\u0dc3\u0dc5 \u0db8\u0d82\u0d9c\u0dbd\u0dca\u200d\u0dba \u0dc3\u0daf\u0dc4\u0dcf \u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb \u0dc3\u0dd2\u0da7 \u0db4\u0dcf \u0d9c\u0db8\u0db1\u0dd2\u0db1\u0dca \u0d91\u0db1\u00a0 \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0d9c\u0dd0\u0db1\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf\u00a0\u0dbb\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0db8\u0dc4\u0dcf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba\u0dda \u0db6\u0dc3\u0dca\u0db1\u0dcf\u0dba\u0d9a \u0db1\u0dd2\u0dbd\u0db8\u0dda \u0dad\u0dd0\u0db1\u0dca\u0db4\u0dad\u0dca \u0da9\u0dd2\u0dc2\u0dcf\u0db1\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dbb\u0dad\u0dca\u0db1 \u0d9c\u0dd4\u0dab\u0dc3\u0dda\u0d9a\u0dbb \u0dc3\u0dc4 \u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd \u0daf\u0dd2\u0dc3\u0dcf\u0db4\u0dad\u0dd2 \u0d9c\u0dd4\u0dab\u0daf\u0dcf\u0dc3 \u0dc3\u0db8\u0dbb\u0dc3\u0dd2\u0d82\u0dc4 \u0daf\u0dc5\u0daf\u0dcf \u0db8\u0dcf\u0dbd\u0dd2\u0d9c\u0dcf\u0dc0\u0dda \u0daf\u0dd2\u0dba\u0dc0\u0da9\u0db1 \u0db1\u0dd2\u0dbd\u0db8\u0dda \u0db1\u0dd2\u0dbd\u0db1\u0dca\u0d9c \u0daf\u0dd1\u0dbd \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4 \u0d94\u0d9a\u0db3 \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba \u0d85\u0dc3\u0dbd\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dc4.",
        "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb \u0dc3\u0dd2\u0da7 \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0dc4\u0dd4 5000 \u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dba\u0dcf\u0dbd \u0dc0\u0db1 \u0d8b\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0d93\u0dad\u0dd2\u0dc4\u0dcf\u0dc3\u0dd2\u0d9a \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0db4\u0dd4\u0daf\u0db6\u0dd2\u0db8 \u0dc0\u0dd9\u0dad \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2.",
        "\u0d94\u0d9a\u0daf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba \u0d85\u0dc3\u0dbd\u0dd2\u0db1\u0dca \u0dba\u0dcf\u0dbd \u0dc0\u0db1\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0da7 \u0d87\u0dad\u0dd4\u0dc5\u0dd4\u0dc0\u0db1 \u0db6\u0dd0\u0dad\u0dd2\u0db8\u0dad\u0dd4\u0db1\u0dca \u0daf\u0dd2\u0db1 \u0d9c\u0dab\u0db1\u0dcf\u0dc0\u0d9a\u0dca \u0d9c\u0dd9\u0dc0\u0dcf \u0d93\u0dad\u0dd2\u0dc4\u0dcf\u0dc3\u0dd2\u0d9a \u0d9a\u0db3\u0dc3\u0dd4\u0dbb\u0dd2\u0db1\u0dca\u0daf\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7 \u0db4\u0dad\u0dcf \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0dad\u0dd2.",
        "\u0db8\u0dd9\u0db8 \u0dc0\u0db1\u0dca\u0daf\u0db1\u0dcf\u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db8\u0dd6\u0dbd\u0dd2\u0d9a \u0db4\u0dc4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dc0\u0db1 \u0da2\u0dbd\u0dba \u0d86\u0dc4\u0dcf\u0dbb \u0db4\u0dcf\u0db1 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0db1\u0da2\u0dd3\u0dc0\u0dd2 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0dbb\u0da2\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0daf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dba\u0ddc\u0daf\u0dcf \u0d87\u0dad."
      ],
      "title_ents": [
        {
          "text": "\u0d9a\u0dad\u0dbb\u0d9c\u0db8",
          "label": "GPE"
        },
        {
          "text": "\u0d95\u0d9a\u0db1\u0dca\u0daf",
          "label": "PERSON"
        }
      ],
      "body_line_ents_list": [
        [
          {
            "text": "\u0da9\u0dd2\u0dc2\u0dcf\u0db1\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dbb\u0dad\u0dca\u0db1 \u0d9c\u0dd4\u0dab\u0dc3\u0dda\u0d9a\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0db8\u0dc4\u0dcf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0daf\u0dd2\u0dba\u0dc0\u0da9\u0db1 \u0db1\u0dd2\u0dbd\u0db8\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0dbd\u0d82\u0d9c \u0daf\u0dd1\u0dbd",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0ddc\u0db1\u0dbb\u0dcf\u0d9c\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0dc3\u0db8\u0dbb\u0dc3\u0dd2\u0d82\u0dc4 \u0daf\u0dc5\u0daf\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0d94\u0d9a\u0db3 \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb",
            "label": "LOC"
          },
          {
            "text": "\u0dbb\u0dd4\u0dc4\u0dd4\u0dab\u0dd4 \u0db8\u0dc4\u0dcf \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "5000\u0d9a\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1\u0dba\u0dd2",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db1\u0dd0\u0d9c\u0dd9\u0db1\u0dc4\u0dd2\u0dbb",
            "label": "LOC"
          }
        ],
        [
          {
            "text": "\u0dba\u0dcf\u0dbd \u0d8b\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba",
