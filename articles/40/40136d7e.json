    "si": {
      "title": "\u0d8a\u0daf\u0dca \u0d85\u0dbd\u0dca-\u0d85\u0daf\u0dcf \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd4\u0dc3\u0dca\u0dbd\u0dd2\u0db8\u0dca\u0dc0\u0dbb\u0dd4 \u0dbb\u0dd0\u0dc3\u0dca \u0dc0\u0dd9\u0dad\u0dd2",
