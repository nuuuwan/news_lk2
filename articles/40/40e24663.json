    "si": {
      "title": "\u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dcf \u0d87\u0dc5\u0dda \u0d9c\u0dd4\u0dab\u0dcf\u0d9c\u0dda \u0d9c\u0ddd\u0dbd\u0dba\u0ddd \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0daf\u0dd0\u0dbd\u0dda",
      "author": "unknown",
      "body_lines": [
        "\u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0d9a\u0dbd\u0dca\u0dbd\u0dd2 \u0db1\u0dcf\u0dba\u0d9a\u0dba\u0d9a\u0dd4 \u0dc0\u0db1 \u0d9a\u0dd2\u0db9\u0dd4\u0dbd\u0dcf \u0d87\u0dbd\u0dda \u0d9c\u0dd4\u0dab\u0dcf\u0d9c\u0dda \u0db8\u0dad\u0dca\u0daf\u0dca\u200d\u0dbb\u0dc0\u0dca\u200d\u0dba \u0da2\u0dcf\u0dbd\u0dba \u0db8\u0dd9\u0dc4\u0dd9\u0dba\u0dc0\u0db1 \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0d9a\u0dd4 \u0da2\u0dd3\u0dc0 \u0d85\u0dad\u0dca\u0db6\u0ddd\u0db8\u0dca\u0db6\u0dba\u0d9a\u0dca, \u0d9a\u0dda\u0dbb\u0dc5 \u0d9c\u0d82\u0da2 \u0dc3\u0dc4 \u0dc4\u0dd9\u0dbb\u0ddc\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0db8\u0d9f \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0db8\u0ddc\u0dc0\u0dd4\u0db1\u0dca \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0dbd\u0daf \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0d9a\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0dc0\u0dad\u0dca\u0dad\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dc3\u0db8\u0dda \u0db4\u0dbd\u0dca\u0dbd\u0dd2\u0dba\u0dc0\u0dad\u0dca\u0dad, \u0d9a\u0dcf\u0db8\u0dda\u0dbd\u0dca \u0db4\u0da7\u0dd4\u0db8\u0d9c \u0db8\u0d82\u0dc3\u0db1\u0dca\u0daf\u0dd2\u0dba \u0d85\u0dc3\u0dbd \u0daf\u0dd3 \u0d8a\u0dba\u0dda (28)\u0db8\u0dd9\u0db8 \u0dc0\u0dd0\u0da7\u0dbd\u0dd3\u0db8\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0d87\u0dad.",
        "\u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca \u0dbd\u0d9a\u0dca\u0dc2 15 \u0d9a\u0da7 \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0da7\u0dd2\u0db1\u0dcf\u0d9a\u0db8\u0dd2\u0db1\u0dca \u0dba\u0dd4\u0dad\u0dca \u0d9a\u0dda\u0dbb\u0dc5 \u0d9c\u0d82\u0da2\u0dcf \u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 06 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 440 \u0d9a\u0dca, \u0dc4\u0dd9\u0dbb\u0ddc\u0dba\u0dd2\u0db1\u0dca \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 05 \u0db8\u0dd2\u0dbd\u0dd2 \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 300 \u0d9a\u0dca \u0dc3\u0dc4 \u0dc0\u0dd2\u0daf\u0dda\u0dc1\u0dd3\u0dba \u0dbb\u0da7\u0d9a \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0dd2\u0dad M67 \u0dc0\u0dbb\u0dca\u0d9c\u0dba\u0dda \u0da2\u0dd3\u0dc0 \u0d85\u0dad\u0dca\u0db6\u0ddd\u0db8\u0dca\u0db6\u0dba\u0d9a\u0dca \u0dc3\u0db8\u0d9f \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1."
      ],
