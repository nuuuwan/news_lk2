    "si": {
      "title": "\u0dc3\u0da2\u0dd2\u0dad\u0dca\u0d9c\u0dda \u0dc3\u0dc4\u0ddd\u0daf\u0dbb\u0dd2\u0dba \u0dbb\u0da7\u0dd2\u0db1\u0dca \u0dba\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0dc0\u0dd2\u0db4\u0d9a\u0dca\u0dc2 \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0dc3\u0dc4\u0ddd\u0daf\u0dbb\u0dd2\u0dba \u0dc0\u0db1 \u0daf\u0dd4\u0dbd\u0dcf\u0d82\u0da2\u0dbd\u0dd3 \u0da2\u0dba\u0d9a\u0ddc\u0da9\u0dd2 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0d8a\u0dba\u0dda (26\u0daf\u0dcf) \u0d8b\u0daf\u0dd1\u0dc3\u0db1 \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dc0 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u0d87\u0dba \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0db1\u0dca\u0d9a\u0db1\u0dca \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba\u0dda \u0dba\u0dd6.\u0d91\u0dbd\u0dca 505 \u0daf\u0dbb\u0dab \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dba\u0dcf\u0db1\u0dba\u0dd9\u0db1\u0dca \u0d91\u0d82\u0d9c\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0dbd\u0db1\u0dca\u0da9\u0db1\u0dca \u0db1\u0dd4\u0dc0\u0dbb \u0db6\u0dbd\u0dcf \u0db4\u0dd2\u0da7\u0dad\u0dca\u0dc0 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dd9\u0dba\u0dd2.\u0d87\u0dba \u0dad\u0db8 \u0daf\u0dbb\u0dd4 \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dc0\u0db1 \u0dc3\u0db1\u0dca\u0da2\u0dda \u0da2\u0dba\u0d9a\u0ddc\u0da9\u0dd2 \u0dc3\u0dc4 \u0d85\u0db8\u0dcf\u0dba\u0dcf \u0da2\u0dba\u0d9a\u0ddc\u0da9\u0dd2 \u0dba\u0db1 \u0daf\u0dbb\u0dd4 \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dc3\u0db8\u0d9c \u0db8\u0dd9\u0dc3\u0dda \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1\u0dd9\u0db1\u0dca \u0db4\u0dd2\u0da7\u0dad\u0dca\u0dc0 \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf\u0d9c\u0dda \u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0dd4\u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0dc3\u0dd2\u0dba \u0db4\u0dde\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db1\u0dd2\u0dc0\u0dd9\u0dc3\u0da7\u00a0 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0db6\u0dcf \u0dc0\u0dd2\u0db1\u0dcf\u0dc1 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd2\u0dba \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0daf\u0dd4\u0dbd\u0dcf\u0d82\u0da2\u0dbd\u0dd3 \u0da2\u0dba\u0d9a\u0ddc\u0da9\u0dd2 \u0db8\u0dc4\u0dad\u0dca\u0db8\u0dd2\u0dba \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0da7 \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0dba\u0d9a\u0dca\u0daf \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba 20\u0daf\u0dcf \u0dc3\u0da7\u0dc4\u0db1\u0dca \u0d9a\u0dbb \u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba."
      ],
