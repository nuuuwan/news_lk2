          {
            "text": "\u0da2\u0dd4\u0dbd\u0dd2\u0dba\u0db1\u0dca \u0db4\u0db1\u0dca\u0daf\u0dd4 \u0dba\u0dd0\u0dc0\u0dd3\u0db8 \u0da2\u0dd9\u0dc4\u0dcf\u0db1\u0dca \u0d9a\u0db1\u0d9c\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0da7\u0dca\u200d\u0dbb\u0dcf\u0db1\u0dca\u0dc3\u0dca\u0db4\u0dda\u0dbb\u0db1\u0dca\u0dc3\u0dd2 \u0d89\u0db1\u0dca\u0da7\u0dbb\u0dca\u0db1\u0dd0\u0dc2\u0db1\u0dbd\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u0d86\u0dba\u0dad\u0db1\u0dba",
