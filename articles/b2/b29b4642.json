          {
            "text": "\u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u0dbb\u0dd1\u0db8\u0dca 530 \u0d9a\u0dd2",
            "label": "QUANTITY"
          },
          {
            "text": "25%",
