            "text": "\u0da0\u0db1\u0dca\u0daf\u0dca\u200d\u0dbb\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dc2\u0dca\u0dab\u0db1\u0dca",
