    "si": {
      "title": "\u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba\u0dda \u0dc3\u0dbb\u0dc3\u0dc0\u0dd2 \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0dd2\u0d9a\u0dcf\u0dc0 \u0dc3\u0dbb\u0daf\u0dd2\u0dba\u0dbd\u0dca \u0d9c\u0dbd\u0dd9\u0db1\u0dca \u0dc0\u0dd0\u0da7\u0dd3 \u0db8\u0dbb\u0dd4\u0da7",
      "author": "unknown",
      "body_lines": [
        "\u0db4\u0dd9\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dc3\u0dbb\u0dc3\u0dc0\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0db8\u0d9c \u0db8\u0dcf\u0dc0\u0db1\u0dd0\u0dbd\u0dca\u0dbd \u0d8b\u0dad\u0dd4\u0dc0\u0db8\u0dca \u0d9a\u0db1\u0dca\u0daf \u0dc3\u0dd6\u0dbb\u0dc3\u0dbb\u0daf\u0dd2\u0dba\u0dbd\u0dca \u0d9c\u0dbd \u0dad\u0dbb\u0dab\u0dba \u0d9a\u0dc5 \u0db4\u0dd9\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dc3\u0dbb\u0dc3\u0dc0\u0dd2\u0dba\u0dda \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0db4\u0dd3\u0da8\u0dba\u0dda \u0dc3\u0dc4\u0dcf\u0dba \u0d8b\u0db4\u0daf\u0dda\u0dc1\u0dd2\u0d9a\u0dcf\u0dc0\u0d9a \u0d91\u0db8 \u0d9c\u0dbd\u0dd9\u0db1\u0dca \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0d85\u0da9\u0dd2 300\u0d9a\u0dca \u0db4\u0db8\u0dab \u0db4\u0dca\u200d\u0dbb\u0db4\u0dcf\u0dad\u0dba\u0d9a\u0da7 \u0dc0\u0dd0\u0da7\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2",
        "\u0db8\u0dd9\u0dc3\u0dda \u0db8\u0dd2\u0dba\u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dca\u0dad\u0dda \u0d87\u0dbd\u0dca\u0db4\u0dd2\u0da7\u0dd2\u0dba\u0dda \u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd2\u0dbb\u0dc3\u0dca\u0db8\u0dd2 \u0d9a\u0ddc\u0da9\u0dd2\u0dad\u0dd4\u0dc0\u0d9a\u0dca\u0d9a\u0dd4 \u0db1\u0db8\u0dd0\u0dad\u0dd2 27 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0dad\u0dbb\u0dd4\u0dab\u0dd2\u0dba\u0d9a\u0dd2.",
        "\u0db4\u0dda\u0dbb\u0dcf\u0daf\u0dd9\u0dab\u0dd2\u0dba \u0dc3\u0dbb\u0dc3\u0dc0\u0dd2\u0dba\u0dda \u0d9a\u0dd8\u0dc2\u0dd2 \u0db4\u0dd3\u0da8\u0dba\u0dda \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0dc3\u0db8 \u0d85\u0daf \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0d8b\u0dad\u0dd4\u0dc0\u0db8\u0dca\u0d9a\u0db1\u0dca\u0daf \u0dc3\u0dd6\u0dbb\u0dc3\u0dbb\u0daf\u0dd2\u0dba\u0db1\u0dca \u0d9c\u0dbd \u0dad\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0daf\u0dd3 \u0d87\u0dba \u0db4\u0dba \u0dbd\u0dd2\u0dc3\u0dca\u0dc3\u0dcf \u0db8\u0dda \u0d85\u0dba\u0dd4\u0dbb\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dc5\u0da7 \u0dc0\u0dd0\u0da7\u0dd2 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dd2\u0dba\u0dba\u0dd2."
      ],
