    "si": {
      "title": "\u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0dc5\u0db8\u0dd4\u0db1\u0dca 21 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4\u0da7 \u0dc3\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0dad\u0dbb\u0dca\u0da2\u0db1: \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dc0\u0dda\u0daf\u0dd2\u0dba\u0dd9\u0d9a\u0dd4\u0da7 \u0dc0\u0dc3\u0dbb 13\u0d9a \u0dc3\u0dd2\u0dbb \u0daf\u0dac\u0dd4\u0dc0\u0db8\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0db6\u0dd2\u0dba \u0d9c\u0dd0\u0db1\u0dca\u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0dc3\u0dda\u0dc0\u0db1\u0dba \u0dba\u0db1 \u0dc3\u0dd2\u0daf\u0dca\u0db0\u0dd3\u0db1\u0dca \u0daf\u0dd9\u0d9a\u0d9a\u0da7 \u0dc0\u0dbb\u0daf\u0d9a\u0dbb\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dc0\u0dda\u0daf\u0dd2\u0dba\u0dd9\u0d9a\u0dd4\u0da7 POCSO \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0d9a\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc0\u0dc3\u0dbb 13 \u0d9a \u0dc3\u0dd2\u0dbb\u0daf\u0dac\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc5\u0db8\u0dd4\u0db1\u0dca \u0d86\u0dc3\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0d9a\u0dd2\u0dba\u0db8\u0dd2\u0db1\u0dca \u0d9a\u0dd0\u0dbd\u0dd1\u0db6\u0daf \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0ddc\u0dc3\u0dca \u0dc3\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0dc3\u0dda\u0dc0\u0db1\u0dba\u0dda \u0dba\u0dd9\u0daf\u0dd4\u0dab\u0dda\u0dba. \u0d91\u0db8\u0dd9\u0db1\u0dca\u0db8 \u0d91\u0dba \u0dc3\u0dd2\u0dba \u0da2\u0d82\u0d9c\u0db8 \u0daf\u0dd4\u0dbb\u0d9a\u0dae\u0db1\u0dba\u0dda \u0dc0\u0dd3\u0da9\u0dd2\u0dba\u0ddd\u0dc0\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0db4\u0da7\u0dd2\u0d9c\u0dad \u0d9a\u0dbb\u0db1 \u0db6\u0dc0\u0da7 \u0dad\u0dbb\u0dca\u0da2\u0db1\u0dba \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0d94\u0dc4\u0dd4 \u0d91\u0db8 \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0dc5\u0db8\u0dd4\u0db1\u0dca \u0dc3\u0db8\u0d9f \u0db1\u0dd0\u0dc0\u0dad \u0db1\u0dd0\u0dc0\u0dad\u0dad\u0dca \u0dc3\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0dc3\u0dda\u0dc0\u0db1\u0dba\u0dda \u0db1\u0dd2\u0dbb\u0dad \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf.",
        "\u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0 \u0d87\u0dad\u0dca\u0dad\u0dda 2018 \u0dc0\u0dc3\u0dbb\u0dda 28 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf\u0dba. \u0db8\u0dd9\u0db8 \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba\u0dc0\u0dda\u0daf\u0dd2\u0dba\u0dcf \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0dc5\u0db8\u0dd4\u0db1\u0dca 21 \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0db8\u0dbd\u0dd2\u0d82\u0d9c\u0dd2\u0d9a \u0dc3\u0dda\u0dc0\u0db1\u0dba\u0da7 \u0db6\u0dbd\u0d9a\u0dbb \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0dd2\u0dba. \u0db8\u0dda \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0\u0dba\u0dd9\u0db1\u0dca \u0db6\u0dd2\u0db1\u0dca\u0daf\u0dd6\u0dbb\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0db1\u0da9\u0dd4 16\u0d9a\u0dca, \u0d9c\u0d82\u0d9c\u0ddc\u0dbd\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0db1\u0da9\u0dd4 3\u0d9a\u0dca, \u0d9c\u0dd4\u0db1\u0dca\u0dad\u0db6\u0dd4\u0dbb\u0dcf \u0dad\u0daf\u0dcf\u0dc3\u0db1\u0dca\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0dc3\u0dc4 \u0d9a\u0ddc\u0dbd\u0dca\u0dbd\u0dd6\u0dbb\u0dca \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0dda \u0d91\u0d9a\u0dca \u0db1\u0da9\u0dd4\u0dc0 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0d9a\u0dbb \u0d87\u0dad.",
        "\u0db8\u0dd3\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0db1\u0da9\u0dd4 \u0d8b\u0da9\u0dd4\u0db4\u0dd2 \u0daf\u0dd2\u0dc3\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dca \u0d85\u0dad\u0dd2\u0dbb\u0dda\u0d9a \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0dda \u0dc3\u0dc4 \u0db4\u0ddc\u0d9a\u0dca\u0dc3\u0ddd \u0d9a\u0da9\u0dd2\u0db1\u0db8\u0dca \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0db1\u0da9\u0dd4 11\u0d9a \u0dad\u0dd3\u0db1\u0dca\u0daf\u0dd4\u0dc0 \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0d87\u0dad. \u0d89\u0db1\u0dca \u0db1\u0da9\u0dd4 8 \u0d9a\u0daf\u0dd3 \u0d94\u0dc4\u0dd4 \u0db1\u0dd2\u0daf\u0ddc\u0dc3\u0dca \u0d9a\u0ddc\u0da7 \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dbb\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dd4\u0dc0\u0dda \u0d94\u0dc4\u0dd4\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2 \u0da0\u0ddd\u0daf\u0db1\u0dcf \u0d94\u0db4\u0dca\u0db4\u0dd4 \u0db1\u0ddc\u0dc0\u0dd6 \u0db6\u0dc0 \u0db4\u0dc0\u0dc3\u0db8\u0dd2\u0db1\u0dd2.",
        "\u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0\u0dda\u0daf\u0dd3 \u0d94\u0dc4\u0dd4\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2 \u0db1\u0da9\u0dd4 2\u0d9a\u0daf\u0dd3 \u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dba \u0dc3\u0d82\u0dc0\u0dda\u0daf\u0dd3 \u0dad\u0dd3\u0db1\u0dca\u0daf\u0dd4\u0dc0\u0d9a\u0dca \u0dbd\u0db6\u0dcf\u0daf\u0dd3 \u0d87\u0dad. \u0d91\u0db1\u0db8\u0dca \u0d91\u0d9a\u0dca \u0db1\u0da9\u0dd4\u0dc0\u0d9a\u0daf\u0dd3 \u0dc0\u0dc3\u0dbb 10\u0d9a \u0dc3\u0dd2\u0dbb\u0daf\u0dac\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0dc3\u0dc4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1000\u0d9a \u0daf\u0da9\u0dba\u0d9a\u0dca\u0daf \u0dad\u0dc0\u0dad\u0dca \u0db1\u0da9\u0dd4\u0dc0\u0d9a\u0daf\u0dd3 \u0dc0\u0dc3\u0dbb 3\u0d9a \u0db6\u0dbb\u0db4\u0dad\u0dc5 \u0dc0\u0dd0\u0da9 \u0dc3\u0dc4\u0dd2\u0dad \u0dc3\u0dd2\u0dbb\u0daf\u0dac\u0dd4\u0dc0\u0db8\u0d9a\u0dca \u0dc3\u0dc4 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1000\u0d9a \u0daf\u0da9\u0dba\u0d9a\u0dca\u0daf \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda."
      ],
