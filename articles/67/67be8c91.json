          }
        ],
        [
          {
            "text": "\u0daf\u0dc4\u0dc3\u0dca",
            "label": "CARDINAL"
          },
          {
            "text": "\u0d9a\u0ddc\u0dc5\u0db9",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "39 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "ORDINAL"
          },
          {
            "text": "\u0d9a\u0dc5\u0dd4 \u0da2\u0dd6\u0dbd\u0dd2\u0dba",
            "label": "EVENT"
          }
        ],
        [
          {
            "text": "\u0d9a\u0ddc\u0dad\u0dbd\u0db8\u0dca\u0db4\u0db4\u0dd4 \u0d85\u0dbd\u0dd4\u0dc0\u0dba\u0dd2\u0d9a\u0dd2\u0dad\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0dc0\u0da9\u0db8\u0dcf\u0dbb\u0da7\u0dca\u0dc3\u0dd2-\u0db8\u0dad\u0dca\u0dad\u0dcf\u0da9\u0dd2",
            "label": "GPE"
          },
          {
            "text": "\u0d8b\u0dad\u0dd4\u0dbb\u0dd4 \u0db8\u0dbb\u0dcf\u0da7\u0dca\u0dc2\u0dd2",
            "label": "GPE"
          },
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0db8\u0dca\u0db8\u0dda\u0dbd\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0db4\u0dcf\u0dbb\u0dca\u0dbd\u0dd2\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0d91\u0db8\u0dca \u0d92 \u0dc3\u0dd4\u0db8\u0db1\u0dca\u0dad\u200d\u0dca\u200d\u0dbb\u0db1\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dc5\u0dcf\u0dad\u0dca \u0dc3\u0db7\u0dcf \u0db8\u0dc4 \u0db1\u0d9c\u0dbb \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "ORG"
          },
          {
            "text": "\u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0daf\u0dcf\u0dc3 \u0dc3\u0db7\u0dcf\u0dc0",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0da9\u0db8\u0dcf\u0dbb\u0da7\u0dca\u0dc3\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dc5\u0dd4 \u0da2\u0dd6\u0dbd\u0dd2\u0dba",
            "label": "EVENT"
          },
          {
            "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0dba\u0dcf\u0db4\u0db1\u0dba \u0dc0\u0dd2\u0dc1\u0dca\u0dc0\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf\u0dbd\u0dba",
            "label": "ORG"
          }
