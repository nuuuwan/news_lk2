      "body_line_ents_list": [
        [
          {
            "text": "\u0d85\u0da2\u0dd2\u0dad\u0dca \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
