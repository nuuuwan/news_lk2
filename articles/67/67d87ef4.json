  "original_title": "\u0db8\u0dc4\u0da2\u0db1 \u0db4\u0dd9\u0dad\u0dca\u0dc3\u0db8\u0dca \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0d9a\u0dcf\u0dbb\u0d9a \u0dc3\u0db7\u0dcf\u0dc0 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dc0\u0dbb\u0dba\u0db1\u0dca \u0db1\u0db8\u0dca \u0d9a\u0dd9\u0dbb\u0dda",
