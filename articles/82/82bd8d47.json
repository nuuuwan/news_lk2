    "si": {
      "title": "\u0dbb\u0d82\u0d9c\u0db1 \u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0dc3\u0db8\u0dcf\u0da2\u0dc0\u0dcf\u0daf\u0dd3 \u0dc1\u0dd2\u0dc2\u0dca\u200d\u0dba \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0dba\u0d9a \u0dbb\u0d82\u0d9c\u0db1 \u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca \u0daf\u0dda\u0dc0\u0db4\u0dca\u200d\u0dbb\u0dd2\u0dba \u0d9a\u0ddc\u0db8\u0dca\u0db4\u0db1\u0dd2\u0dad\u0dd9\u0dbb\u0dd4 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0d9c\u0dd9\u0db1 \u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba\u0da7 \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0d9c\u0dd2\u0dba\u0dda\u0dba."
      ],
      "title_ents": [
        {
          "text": "\u0dbb\u0d82\u0d9c\u0db1 \u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca",
