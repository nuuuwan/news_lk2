    "ta": {
      "title": "\u0bb0\u0b99\u0bcd\u0b95\u0ba9 \u0bb2\u0b95\u0bcd\u0bae\u0bbe\u0bb2\u0bcd \u0b95\u0bc8\u0ba4\u0bc1",
      "author": "unknown",
      "body_lines": [
        "\u0b9a\u0bcb\u0bb7\u0bb2\u0bbf\u0b9a \u0bae\u0bbe\u0ba3\u0bb5\u0bb0\u0bcd \u0b92\u0ba9\u0bcd\u0bb1\u0bbf\u0baf\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b85\u0bae\u0bc8\u0baa\u0bcd\u0baa\u0bbe\u0bb3\u0bb0\u0bcd \u0bb0\u0b99\u0bcd\u0b95\u0ba9 \u0bb2\u0b95\u0bcd\u0bae\u0bbe\u0bb2\u0bcd \u0ba4\u0bc7\u0bb5\u0baa\u0bcd\u0baa\u0bbf\u0bb0\u0bbf\u0baf \u0b95\u0bca\u0bae\u0bcd\u0baa\u0ba9\u0bbf\u0ba4\u0bcd\u0ba4\u0bc6\u0bb0\u0bc1 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bbe\u0bb0\u0bbe\u0bb2\u0bcd \u0b95\u0bc8\u0ba4\u0bc1 \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1 \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bbe\u0bb0\u0bbf\u0b9f\u0bae\u0bcd \u0b85\u0bb4\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1\u0b9a\u0bcd \u0b9a\u0bc6\u0bb2\u0bcd\u0bb2\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbe\u0bb0\u0bcd."
      ],
