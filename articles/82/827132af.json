    "si": {
      "title": "\u0d8b\u0da9\u0dbb\u0da7 \u0db8\u0dc4\u0dcf \u0db8\u0d82\u0d9c\u0dbd\u0dca\u200d\u0dba\u0dba\u0da7 \u0db8\u0dd4\u0dbd \u0db4\u0dd4\u0dbb\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d8b\u0da9\u0dbb\u0da7 \u0d87\u0dc3\u0dc5 \u0db4\u0dd9\u0dbb\u0dc4\u0dbb \u0db8\u0d82\u0d9c\u0dbd\u0dca\u200d\u0dba\u0dba\u0dda \u0d86\u0dbb\u0db8\u0dca\u0db7\u0dba \u0dc3\u0db1\u0dd2\u0da7\u0dd4\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0db8\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dc0\u0dca\u0db8\u0dc4\u0dcf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0d9a\u0db4\u0dca \u0dc3\u0dd2\u0da7\u0dc0\u0dd3\u0db8 \u0d85\u0daf (29) \u0d85\u0dc5\u0dd4\u0dba\u0db8 03.03 \u0da7 \u0dba\u0ddc\u0daf\u0dd4\u0db1 \u0dc3\u0dd4\u0db7 \u0db8\u0dd4\u0dc4\u0dd4\u0dbb\u0dca\u0dad\u0dd2\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd2\u0dba .",
        "\u0db1\u0dcf\u0dae, \u0dc0\u0dd2\u0dc2\u0dca\u0dab\u0dd4, \u0d9a\u0dad\u0dbb\u0d9c\u0db8 \u0dc3\u0dc4 \u0db4\u0dad\u0dca\u0dad\u0dd2\u0db1\u0dd2 \u0dba\u0db1 \u0dc3\u0dd2\u0dc0\u0dca\u0db8\u0dc4\u0dcf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0d92 \u0d85\u0dba\u0dd4\u0dbb\u0dd2\u0db1\u0dca \u0d9a\u0db4\u0dca \u0dc3\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dd9\u0dbb\u0dd4\u0dab\u0dd4 \u0d85\u0dad\u0dbb \u0d91\u0dad\u0dd0\u0db1\u0dca \u0db4\u0da7\u0db1\u0dca \u0daf\u0dd2\u0db1 \u0db4\u0dc4\u0d9a\u0dca \u0dc3\u0dd2\u0dc0\u0dca\u0db8\u0dc4\u0dcf \u0daf\u0dda\u0dc0\u0dcf\u0dbd\u0dba\u0db1\u0dca\u0dc4\u0dd2 \u0d85\u0db7\u0dca\u200d\u0dba\u0db1\u0dca\u0dad\u0dbb \u0db4\u0dd9\u0dbb\u0dc4\u0dd0\u0dbb \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d85\u0db1\u0dad\u0dd4\u0dbb\u0dd4\u0dc0 \u0d87\u0dc3\u0dc5 \u0db4\u0dd9\u0dbb\u0dc4\u0dbb \u0dc0\u0dd3\u0daf\u0dd2 \u0dc3\u0d82\u0da0\u0dcf\u0dbb\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba ."
      ],
