      "body_line_ents_list": [
        [
          {
            "text": "\u0d9c\u0dbd\u0dda\u0dc0\u0dd9\u0dbd \u0db6\u0db9\u0dbb\u0d9c\u0dc3\u0dca\u0dc0 \u0dc0\u0dd0\u0dc0",
            "label": "PERSON"
          },
          {
