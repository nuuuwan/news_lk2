    "si": {
      "title": "\u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0dad\u0dcf\u0dba\u0dd2\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0db4\u0dd2\u0db4\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0dc3\u0dc4 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0d9a\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0dad\u0dcf\u0dba\u0dd2\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0d85\u0dc0\u0db8 \u0dc0\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1 17\u0d9a \u0db4\u0dd2\u0db4\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0dc3\u0dc4 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0db8\u0dcf\u0dbd\u0dcf\u0dc0\u0d9a\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0dbb\u0ddc\u0dba\u0dd2\u0da7\u0dbb\u0dca \u0db4\u0dd4\u0dc0\u0dad\u0dca \u0dc3\u0dda\u0dc0\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.\u0d91\u0d9a\u0dd2\u0db1\u0dd9\u0d9a\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dca \u0db8\u0dcf\u0dbd\u0dcf\u0dc0 \u0dc4\u0ddc\u0db3\u0dd2\u0db1\u0dca \u0dc3\u0dd0\u0dbd\u0dc3\u0dd4\u0db8\u0dca \u0d9a\u0dbb \u0dc3\u0dd2\u0daf\u0dd4\u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dad\u0dcf\u0dba\u0dd2\u0dbd\u0db1\u0dca\u0dad \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0d82\u0dc1 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0d85\u0daf(17) \u0d85\u0dbd\u0dd4\u0dba\u0db8 \u0daf\u0d9a\u0dd4\u0dab\u0dd4 \u0dad\u0dcf\u0dba\u0dd2\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0db4\u0dc5\u0dcf\u0dad\u0dca 3 \u0d9a \u0d89\u0db1\u0dca\u0db0\u0db1 \u0dc4\u0dbd\u0dca \u0dc3\u0dc4 \u0dc0\u0dd9\u0dc5\u0db3\u0dc3\u0dd0\u0dbd\u0dca \u0d89\u0dbd\u0d9a\u0dca\u0d9a \u0d9a\u0dbb \u0d9c\u0db1\u0dd2\u0db8\u0dd2\u0db1\u0dca \u0db8\u0dd9\u0db8 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0dca \u0dc3\u0dc4 \u0db4\u0dd2\u0db4\u0dd2\u0dbb\u0dd3\u0db8\u0dca \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd3 \u0d87\u0dad.\u0db8\u0dd9\u0db8 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0dd3\u0db8\u0dca \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc4\u0dad\u0dca \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc3\u0dd4\u0dc5\u0dd4 \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0dad\u0dcf\u0dba\u0dd2\u0dbd\u0db1\u0dca\u0dad \u0d86\u0dbb\u0d9a\u0dca\u0dc2\u0d9a \u0d85\u0d82\u0dc1 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.\u0db8\u0dd9\u0db8 \u0db4\u0dca\u200d\u0dbb\u0dc4\u0dcf\u0dbb \u0dc0\u0dbd \u0dc0\u0d9c\u0d9a\u0dd3\u0db8 \u0dad\u0dc0\u0db8 \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0dd9\u0d9a\u0dd4 \u0db7\u0dcf\u0dbb \u0d9c\u0dd9\u0db1 \u0db1\u0dd0\u0dad\u0dd0\u0dba\u0dd2 \u0dbb\u0ddc\u0dba\u0dd2\u0da7\u0dbb\u0dca \u0db4\u0dd4\u0dc0\u0dad\u0dca \u0dc3\u0dda\u0dc0\u0dba \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dc5\u0dda\u0dba."
      ],
