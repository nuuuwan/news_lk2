    "si": {
      "title": "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0da7 \u0db1\u0dc0 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0d86\u0dba\u0dad\u0db1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0db1\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd3\u0db1\u0dca \u0db4\u0dad\u0dca \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1, \u0db8\u0dc4\u0dcf\u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0dc4 \u0da2\u0db1\u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba \u0d86\u0da0\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf (26) \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0daf\u0dda\u0dc1\u0dd3\u0dba \u0d86\u0daf\u0dcf\u0dba\u0db8\u0dca \u0d9a\u0ddc\u0db8\u0dc3\u0dcf\u0dbb\u0dd2\u0dc3\u0dca \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0da9\u0dd3.\u0d86\u0dbb\u0dca .\u0d91\u0dc3\u0dca \u0dc4\u0db4\u0dd4\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2, \u0dbb\u0dda\u0d9c\u0dd4 \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u200d\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0db4\u0dd3.\u0db6\u0dd3.\u0d91\u0dc3\u0dca.\u0dc3\u0dd3 \u0db1\u0ddc\u0db1\u0dd2\u0dc3\u0dca, \u0db8\u0dc4\u0dcf \u0db7\u0dcf\u0dab\u0dca\u0da9\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0db1\u0dd2\u0dba\u0ddd\u0da2\u0dca\u200d\u0dba \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0dbd\u0dd9\u0dc3 \u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca.\u0d92 \u0dc3\u0dad\u0dca\u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0dc3\u0dc4 \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u200d\u0dc2\u0dab \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u200d\u0dc2 \u0da2\u0db1\u0dbb\u0dcf\u0dbd\u0dca \u0dbd\u0dd9\u0dc3 \u0da2\u0dd6\u0da9\u0dca \u0db1\u0dd2\u0dbd\u0dd4\u0d9a\u0dca\u0dc2\u0dcf\u0db1\u0dca \u0dba\u0db1 \u0db8\u0dc4\u0dad\u0dca\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db8\u0dd9\u0db8 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc0\u0db1 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db4\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca \u0d9a\u0dc5 \u0db6\u0dc0 \u0daf \u0d87\u0db8\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0d9a\u0dd3\u0dc0\u0dda\u0dba.",
        "\u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0db8\u0dda \u0db6\u0dc0 \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0\u0dda \u0daf\u0dd3 \u0d85\u0daf (26) \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0dad\u0dd3\u0dbb\u0dab \u0daf\u0dd0\u0db1\u0dd4\u0db8\u0dca\u0daf\u0dd3\u0db8\u0dda \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0dc4\u0db8\u0dd4\u0dc0 \u0d85\u0db8\u0dad\u0db8\u0dd2\u0db1\u0dd2."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0d9c\u0dd4\u0dab\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
          },
          {
            "text": "26",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "DRS \u0dc4\u0db4\u0dd4\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2",
            "label": "ORG"
          },
          {
            "text": "\u0dc3\u0dad\u0dca\u0d9a\u0dd4\u0db8\u0dcf\u0dbb",
            "label": "PERSON"
          },
          {
            "text": "\u0db7\u0dcf\u0dab\u0dca\u0da9\u0dcf\u0d9c\u0dcf\u0dbb",
            "label": "ORG"
          },
          {
            "text": "\u0da2\u0dd6\u0da9\u0dca \u0db1\u0dd2\u0dbd\u0dd4\u0d9a\u0dca\u0dc2\u0dcf\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd0\u0db6\u0dd2\u0db1\u0da7\u0dca \u0db4\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9a\u0dcf",
            "label": "PRODUCT"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0db8\u0dab\u0dca\u0da9\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0daf",
            "label": "DATE"
