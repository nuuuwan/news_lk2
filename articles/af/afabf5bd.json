          {
            "text": "\u0dc3\u0db8\u0d9c\u0dd2 \u0da2\u0db1 \u0db6\u0dbd\u0dc0\u0dda\u0d9c\u0dba\u0dd9\u0db1\u0dca \u0dc4\u0dd4\u0dc3\u0dca\u0db8\u0d9a\u0dca",
