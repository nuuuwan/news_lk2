    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0daf\u0dd2\u0db1 \u0dad\u0dd4\u0db1\u0d9a\u0da7 \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT \u2013 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0dc0\u0dc3\u0dcf \u0daf\u0dd0\u0db8\u0dd4\u0dab\u0dd4 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0da2\u0dd6\u0db1\u0dd2 28, \u0db6\u0daf\u0dcf\u0daf\u0dcf \u0dc3\u0dc4 30 \u0db6\u0dca\u200d\u0dbb\u0dc4\u0dc3\u0dca\u0db4\u0dad\u0dd2\u0db1\u0dca\u0daf\u0dcf \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 7.30 \u0dc3\u0dd2\u0da7 \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4 1.30 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0db4\u0db8\u0dab\u0d9a\u0dca \u0dc0\u0dd2\u0dc0\u0dd8\u0dad \u0d9a\u0dd9\u0dbb\u0dd9\u0db1 \u0d85\u0dad\u0dbb, \u0db8\u0dcf\u0dbb\u0dca\u0d9c\u0d9c\u0dad \u0db4\u0db1\u0dca\u0dad\u0dd2 27 \u0dc3\u0db3\u0dd4\u0daf\u0dcf \u0dc3\u0dc4 \u0da2\u0dd6\u0dbd\u0dd2 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dda. 01.",
        "\u0da2\u0dd4\u0db1\u0dd2 25 \u0dc3\u0dd9\u0db1\u0dc3\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0d85\u0db0\u0dca\u200d\u0dba\u0dcf\u0db4\u0db1 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0d9a \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd9\u0db1\u0dca\u0db1\u0dda \u0db8\u0dd9\u0db8 \u0db1\u0dcf\u0d9c\u0dbb\u0dd2\u0d9a \u0db4\u0dcf\u0dc3\u0dbd\u0dca\u0dc0\u0dbd \u0db4\u0dca\u200d\u0dbb\u0dcf\u0dae\u0db8\u0dd2\u0d9a (1 \u0dc3\u0dd2\u0da7 5 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0dcf) \u0dc0\u0dd2\u0dc0\u0dd8\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0daf\u0dd2\u0db1 \u0d9c\u0dab\u0db1 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3\u0dc0 \u0dc0\u0dd2\u0daf\u0dd4\u0dc4\u0dbd\u0dca\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dd4\u0db1\u0dca\u0da7 \u0d85\u0db7\u0dd2\u0db8\u0dad\u0dba \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0db4\u0dca\u200d\u0dbb\u0dc0\u0dcf\u0dc4\u0db1 \u0d9c\u0dd0\u0da7\u0dc5\u0dd4 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0daf\u0dd2\u0db1\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0db1 \u0d9c\u0dd4\u0dbb\u0dd4\u0dc0\u0dbb\u0dd4\u0db1\u0dca \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dd2\u0d9a \u0db1\u0dd2\u0dc0\u0dcf\u0da9\u0dd4 \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca \u0d85\u0dba \u0dbd\u0dd9\u0dc3 \u0db1\u0ddc\u0dc3\u0dbd\u0d9a\u0db1 \u0db6\u0dc0 \u0d91\u0db8 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba\u0dda \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0dc0\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0dc0\u0dd2\u0db1\u0dd2\u0db8\u0dba \u0dc4\u0dd2\u0d9f\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db4\u0dd9\u0da7\u0dca\u200d\u0dbb\u0dbd\u0dca, \u0da9\u0dd3\u0dc3\u0dbd\u0dca \u0dc3\u0dc4 \u0db7\u0dd6\u0db8\u0dd2\u0dad\u0dd9\u0dbd\u0dca \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd0\u0dad\u0db4\u0dd4\u0db8\u0dca \u0d9c\u0dab\u0db1\u0dca \u0daf\u0dd2\u0d9c\u0dd4 \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0d87\u0dad\u0dd2 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda. \u0dc4\u0dd2\u0d9f\u0dba \u0dc3\u0dc4 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0dcf\u0db8 \u0db4\u0dd2\u0dc5\u0dd2\u0db6\u0db3 \u0db6\u0dd2\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0daf\u0dd2\u0dc0\u0dba\u0dd2\u0db1 \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda. \u0da2\u0dd4\u0db1\u0dd2 24 \u0dc3\u0dd2\u0d9a\u0dd4\u0dbb\u0dcf\u0daf\u0dcf \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dad\u0dd2\u0db6\u0dd6 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0dde\u0d9a\u0dcf\u0dc0\u0d9a\u0dca \u0daf\u0dd2\u0db1 \u0db1\u0dd2\u0dba\u0db8\u0dba\u0d9a\u0dca \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda. (\u0d9a\u0ddc\u0dc5\u0db9/\u0da2\u0dd4\u0db1\u0dd225/2022)"
      ],
