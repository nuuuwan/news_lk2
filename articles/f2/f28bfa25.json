    "si": {
      "title": "\u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1 \u0d9a\u0dd2\u0dc4\u0dd2\u0db4\u0dba\u0d9a\u0da7 \u0db4\u0dd0\u0dba \u0dc4\u0dad\u0d9a \u0da2\u0dbd \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0\u0d9a\u0dca",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0da2\u0dcf\u0dbd\u0dba\u0da7 \u0d85\u0dad\u0dca\u200d\u0dba\u0dc0\u0dc1\u0dca\u200d\u0dba \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0daf\u0dd2\u0dba\u0dd4\u0dab\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0dda \u0d85\u0dbd\u0dd4\u0dad\u0dca\u0dc0\u0dd0\u0da9\u0dd2\u0dba\u0dcf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dd2\u0daf\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db4\u0dd0\u0dba \u0dc4\u0dad\u0d9a \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dcf \u0d87\u0dad\u0dd2 \u0db6\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0da2\u0dbd \u0dc3\u0db8\u0dca\u0db4\u0dcf\u0daf\u0db1 \u0dc4\u0dcf \u0da2\u0dbd\u0dcf\u0db4\u0dc0\u0dc4\u0db1 \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba (NWSDB) \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dc4\u0dd9\u0da7 (23) \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 11.00 \u0dc3\u0dd2\u0da7 \u0d89\u0dbb\u0dd2\u0daf\u0dcf (24) \u0db4\u0dd9\u0dbb\u0dc0\u0dbb\u0dd4 6.00 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0da2\u0dbd \u0d9a\u0db4\u0dca\u0db4\u0dcf\u0daf\u0dd4\u0dc0 \u0db4\u0db1\u0dc0\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dda.",
        "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d9a\u0ddc\u0dc5\u0db9 7, 8, 9 \u0dc3\u0dc4 10 \u0dba\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dc0\u0dbd\u0da7 \u0da2\u0dbd \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0db1\u0dd4 \u0d87\u0dad. (CS)"
      ],
