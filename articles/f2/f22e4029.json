    "si": {
      "title": "\u0da9\u0dbd\u0dc3\u0dca \u0da2\u0db1\u0db4\u0dad\u0dd2 \u0dc0\u0dd4\u0dc0\u0dc4\u0ddc\u0dad\u0dca \u0dc3\u0da2\u0dd2\u0da9\u0dca \u0d85\u0d9c\u0db8\u0dd0\u0dad\u0dd2 - \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf \u0db6\u0dbd\u0dba",
      "author": "T. Saranya",
      "body_lines": [
        "\u0d91\u0db8 \u0d92\u0d9a\u0d9a\u0dba\u0dda \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0da9\u0dbd\u0dc3\u0dca \u0dad\u0dda\u0dbb\u0dd3 \u0db4\u0dad\u0dca \u0dc0\u0dd4\u0dc0\u0dc4\u0ddc\u0dad\u0dca \u0d85\u0d9c\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dba\u0dcf \u0dbd\u0dd9\u0dc3 \u0dc3\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0dda\u0db8\u0daf\u0dcf\u0dc3 \u0db8\u0dc4\u0dad\u0dcf \u0dad\u0ddd\u0dbb\u0dcf \u0d9c\u0db1\u0dca\u0db1\u0dcf \u0db6\u0dc0 \u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca\u0db8\u0dad\u0dd4\u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0db4\u0dc0\u0dc3\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0db8\u0dad\u0dd4\u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0db4\u0dd0\u0dc0\u0dc3\u0dd4\u0dc0\u0dda \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0d85\u0dad\u0dbb \u0d87\u0dad\u0dd2\u0d9a\u0dbb\u0d9c\u0dad\u0dca \u0d91\u0d9a\u0d9f\u0dad\u0dcf\u0dc0 \u0db8\u0dad \u0d91\u0dba \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1 \u0db6\u0dc0\u0dba\u0dd2.",
        "\u0da9\u0dbd\u0dc3\u0dca \u0d92\u0d9a\u0d9a\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1\u0dd2\u0dba\u0dcf\u0da7 \u0dc3\u0db7\u0dcf\u0db4\u0dad\u0dd2 \u0db0\u0dd6\u0dbb\u0dba\u0da7 \u0db4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dad\u0dbb\u0db8\u0dca \u0dc3\u0dc4\u0dba\u0ddd\u0d9c\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0db6\u0dc0\u0daf \u0dbb\u0d82\u0da2\u0dd2\u0dad\u0dca \u0db8\u0dad\u0dd4\u0db6\u0dab\u0dca\u0da9\u0dcf\u0dbb \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
