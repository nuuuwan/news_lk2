          {
            "text": "84 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2\u0dba",
            "label": "DATE"
          },
          {
            "text": "\u0dba\u0dc2\u0dca\u0dc0\u0db1\u0dca\u0dad\u0dca \u0dc3\u0dd2\u0d82\u0dc4",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0d9c\u0dad\u0dd2\u0dc1\u0dd3\u0dbd\u0dd3 \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba",
