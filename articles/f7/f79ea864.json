  "original_title": "\u0b95\u0b9f\u0bcd\u0b9a\u0bbf\u0ba4\u0bcd \u0ba4\u0bbe\u0bb5\u0baa\u0bcd\u0baa\u0bcb\u0bb5\u0ba4\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
  "text_idx": {
    "en": {
      "title": "The party will not jump",
      "author": "unknown",
      "body_lines": [
        "United People's Shakti General Secretary Ranjith Mathuma Bandara has denied reports that he will join the government with the majority of the party's MPs."
      ],
