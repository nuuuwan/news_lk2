            "label": "ORG"
          },
          {
            "text": "www.agrarian.lk",
            "label": "GPE"
          },
          {
            "text": "the high season",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "The Ministry of Agriculture",
            "label": "ORG"
          },
          {
            "text": "50 kg",
            "label": "QUANTITY"
          },
          {
            "text": "10,000",
            "label": "CARDINAL"
          }
        ]
      ]
    },
    "si": {
      "title": "\u0dba\u0dd4\u0dbb\u0dd2\u0dba\u0dcf \u0d9c\u0db1\u0dca\u0db1 \u0db6\u0da9 \u0d89\u0dbb\u0dd2\u0d9f\u0dd4 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0db1\u0dca\u0db1",
      "author": "unknown",
      "body_lines": [
        "\u0db8\u0dc4 \u0d9a\u0db1\u0dca\u0db1\u0dba\u0dda\u0daf\u0dd3 \u00a0\u0db6\u0da9 \u0d89\u0dbb\u0dd2\u0d9f\u0dd4 \u0dc0\u0d9c\u0dcf\u0dc0\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba\u0dba \u0dba\u0dd4\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca\u0da7\u00a0\u00a0www.agrarian.lk \u0dc0\u0dd9\u0db6\u0dca \u0d85\u0da9\u0dc0\u0dd2\u0dba \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0dbd\u0dd2\u0dba\u0dcf\u0db4\u0daf\u0dd2\u0d82\u0da0\u0dd2 \u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0dc3\u0dbd\u0dc3\u0dcf \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u00a0\u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,000\u0d9a \u0db8\u0dd2\u0dbd\u0da7 \u0dc0\u0dd3 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca\u0da7 \u0dbd\u0db6\u0dcf \u0daf\u0dd4\u0db1\u0dca \u0dba\u0dd4\u0dbb\u0dd2\u0dba\u0dcf \u0db4\u0ddc\u0dc4\u0ddc\u0dbb \u0d9a\u0dd2\u0dbd\u0ddd \u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca 50\u0d9a \u0db8\u0dd2\u0da7\u0dd2\u0dba, \u0db6\u0da9\u0d89\u0dbb\u0dd2\u0d9f\u0dd4 \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca\u0da7 \u0daf \u0d91\u0db8 \u0db8\u0dd2\u0dbd\u0da7\u0db8 \u0dbd\u0db6\u0dcf \u0daf\u0dd3\u0db8\u0da7 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dba\u0ddc\u0daf\u0dcf \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d9a\u0dd8\u0dc2\u0dd2\u0d9a\u0dbb\u0dca\u0db8 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1\u0dba \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba."
      ],
      "title_ents": [],
      "body_line_ents_list": [
