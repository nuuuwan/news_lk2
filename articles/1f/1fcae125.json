    "si": {
      "title": "\u0db0\u0db1\u0d82\u0da2\u0dba\u0da7 \u0dc3\u0dc4 \u0dc0\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0dda\u0da7 \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca",
      "author": "unknown",
      "body_lines": [
        "\u0d95\u0dc3\u0dca\u0da7\u0dca\u200d\u0dbb\u0dda\u0dbd\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0d91\u0dbb\u0dd9\u0dc4\u0dd2\u0dc0 \u0da7\u0dd9\u0dc3\u0dca\u0da7\u0dca \u0dad\u0dbb\u0d9c\u0dba\u0da7 \u0dc3\u0dc4\u0db7\u0dcf\u0d9c\u0dd2 \u0dc0\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf \u00a0\u0d9a\u0dab\u0dca\u0da9\u0dcf\u0dba\u0db8\u0dda \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dd2\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0dc0\u0db1 \u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf \u0dc3\u0dc4 \u0da2\u0dd9\u0dc6\u0dca\u0dbb\u0dd2 \u0dc0\u0dd0\u0db1\u0dca\u0da9\u0dbb\u0dca\u0dc3\u0dda\u0da7 \u00a0\u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0ddb\u0dbb\u0dc3\u0dba \u0d86\u0dc3\u0dcf\u0daf\u0db1\u0dba \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d91\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0db1\u0dca \u0daf\u0dd9\u0daf\u0dd9\u0db1\u0dcf \u0dc0\u0dd9\u0db1\u0dd4\u0dc0\u0da7 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dcf\u0dad\u0dca \u0da2\u0dba\u0dc3\u0dd6\u0dbb\u0dd2\u0dba \u0dc3\u0dc4 \u0dbd\u0d9a\u0dca\u200d\u0dc2\u0dcf\u0db1\u0dca \u0dc3\u0db3\u0d9a\u0dd0\u0db1\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba\u0da7 \u0d9a\u0dd0\u0db3\u0dc0\u0dcf \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd3\u0da7 \u0db4\u0dd9\u0dbb \u0d87\u0db1\u0dca\u0da2\u0dbd\u0ddd \u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dca\u0dc3\u0dca \u0dc3\u0dc4 \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd3\u0db1\u0dca \u0da2\u0dba\u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0da7 \u0daf \u0d9a\u0ddc\u0dc0\u0dd2\u0da9\u0dca \u0dc0\u0ddb\u0dbb\u0dc3\u0dba \u0d86\u0dc3\u0dcf\u0daf\u0db1\u0dba \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd2\u0dab\u0dd2."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "\u0db0\u0db1\u0d82\u0da2\u0dba \u0daf \u0dc3\u0dd2\u0dbd\u0dca\u0dc0\u0dcf",
