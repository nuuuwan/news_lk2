    "si": {
      "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0dc3\u0d82\u0dc1\u0ddd\u0db0\u0db1\u0dba \u0d9a\u0dd9\u0dbb\u0dda",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "COLOMBO (News 1st); \u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dd3\u0dad\u0dd2\u0d9c\u0dad \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0d89\u0db1\u0dca\u0db0\u0db1 \u0db8\u0dd2\u0dbd \u0d85\u0da9\u0dd4 \u0d9a\u0dbb \u0d87\u0dad;",
        "\u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4 \u0d9a\u0dbb\u0db1 \u0dbd\u0daf \u0db1\u0dcf\u0dba\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7 \u0db4\u0dcf\u0dbd\u0db1\u0dba \u0db7\u0dcf\u0dbb \u0db1\u0ddc\u0daf\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4\u0dba: \u0d9a\u0dad\u0ddd\u0dbd\u0dd2\u0d9a \u0dbb\u0daf\u0d9c\u0dd4\u0dbb\u0dd4 \u0dc3\u0db8\u0dd4\u0dc5\u0dd4\u0dc0"
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
            "text": "News 1st",
            "label": "DATE"
          },
          {
            "text": "\u0dbd\u0d82\u0d9a\u0dcf \u0d9b\u0db1\u0dd2\u0da2 \u0dad\u0dd9\u0dbd\u0dca \u0db1\u0dd3\u0dad\u0dd2\u0d9c\u0dad \u0dc3\u0d82\u0dc3\u0dca\u0dae\u0dcf\u0dc0",
