    "si": {
      "title": "\u0da2\u0db1\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dc0\u0dd0\u0da9 \u0d85\u0dbb\u0db9\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba \u0d85\u0dbb\u0d9c\u0dbd \u0d9a\u0dbb\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0db8\u0dd4\u0daf\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d85\u0daf \u0dc0\u0dd0\u0da9 \u0d85\u0dbb\u0db9\u0db1\u0dca\u0db1\u0dda \u0daf\u0dd2\u0db1 11\u0d9a\u0da7 \u0db4\u0dc3\u0dd4\u0dc0\u0dba\u0dd2.",
        "\u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3 \u0db8\u0da7\u0dca\u0da7\u0db8\u0dda \u0dc0\u0dd0\u0da9 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0daf \u2063\u0d87\u0dbb\u0dd0\u0db9\u0dd3\u0db8\u2063\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dba.\u0d9a\u0dd9\u0da7\u0dd2 \u0d9a\u0dcf\u0dbd\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd4\u0dc5\u0dad \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2\u0dc0\u0dbb\u0dba\u0dcf \u0daf \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0dc0\u0dd0\u0da9 \u0d87\u0dbb\u0db9\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad\u0dc0 \u0d87\u0dad.",
        "\u0db8\u0dd9\u0dd2 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7\u0dad\u0dca \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd\u0dba\u0dda \u0d85\u0dbd\u0dd4\u0dad\u0dca\u0dc0\u0dd0\u0da9\u0dd2\u0dba\u0dcf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0dc3\u0dd2\u0daf\u0dd4 \u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0db6\u0dc0 \u0da2\u0db1\u0dcf\u0db0\u0dd2\u0db4\u0dad\u0dd2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba\u0dcf\u0dbd \u0d86\u0dbb\u0d82\u0da0\u0dd2 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dba\u0dd2."
      ],
      "title_ents": [],
