{
  "newspaper_id": "ada-lk",
  "url": "https://www.ada.lk/technology/\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda--\u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8-Hyper-Casual-\u2013-eSports-Championship--\u0d85\u0daf-\u0d87\u0dbb\u0db9\u0dd9\u0dba\u0dd2/5-378499",
  "time_ut": 1621063675,
  "original_lang": "si",
  "original_title": "\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda  \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports Championship  \u0d85\u0daf \u0d87\u0dbb\u0db9\u0dd9\u0dba\u0dd2",
  "text_idx": {
    "si": {
      "title": "\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda  \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports Championship  \u0d85\u0daf \u0d87\u0dbb\u0db9\u0dd9\u0dba\u0dd2",
      "body_lines": [
        "\u0dad\u0dbb\u0dd4\u0dab \u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1\u0dba IMI Games \u0dc3\u0dc4 SLT \u0db8\u0ddc\u0db6\u0dd2\u0da7\u0dd9\u0dbd\u0dca \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0d85\u0daf (15) \u0dc3\u0dc0\u0dc3 5\u0da7 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dda\u0dba \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0d9a\u0dd4\u0dc3\u0dbd\u0dad\u0dcf \u0d94\u0db4\u0dca\u0db1\u0dd0\u0d82\u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0db4\u0dc3\u0dd4\u0db6\u0dd2\u0db8 \u0dc4\u0dcf \u0daf\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dba\u0dd2.",
        "\u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0da2\u0dba\u0d9c\u0db1\u0dca\u0db1\u0dcf 300 \u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dad\u0dd1\u0d9c\u0dd2 \u0dc3\u0dc4 Data \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 SLT \u0db8\u0ddc\u0db6\u0dd2\u0da7\u0dd9\u0dbd\u0dca \u0d86\u0dba\u0dad\u0db1\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca\u0dc0\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db8\u0dd9\u0db8 Hyper Casual \u2013 eSports \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0d85\u0daf \u0dc3\u0dd2\u0da7 \u0daf\u0dd2\u0db1 02 \u0d9a\u0dca \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c 06 \u0d9a\u0dca \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dba\u0dcf\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1\u0dd4 \u0d87\u0dad.",
        "\u0d85\u0daf\u0dcf\u0dc5 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c 06 \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dba\u0db1 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dd4\u0dc0\u0dbb\u0dd4\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0d8b\u0daf\u0dcf\u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dcf \u0dc4\u0ddd \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0d8b\u0dbb\u0dd4\u0db8\u0d9a\u0db8\u0dca \u0d9a\u0dd3\u0db8\u0dda \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0d8b\u0daf\u0dcf\u0dc0\u0db1\u0dd4 \u0d87\u0dad.",
        "Hyper Casual \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0dc0 \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf\u0daf\u0dd4\u0db1\u0dca IMI Games \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0dc3\u0dc4 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d89\u0da7\u0dd4 \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0db8\u0dd9\u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dda\u0dba \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dda \u0db1\u0dc0\u0db8\u0dd4 \u0d85\u0dad\u0dca\u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0db1\u0dd4 \u0d87\u0dad."
      ]
    },
    "ta": {
      "title": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bbf\u0b95\u0baa\u0bcd\u0baa\u0bc6\u0bb0\u0bbf\u0baf \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0b9a\u0bc1\u0bb5\u0bb2\u0bcd - \u0b88\u0bb8\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0b9a\u0bbe\u0bae\u0bcd\u0baa\u0bbf\u0baf\u0ba9\u0bcd\u0bb7\u0bbf\u0baa\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0ba4\u0bca\u0b9f\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1",
      "body_lines": [
        "\u0b87\u0bb3\u0bc8\u0b9e\u0bb0\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1, IMI \u0b95\u0bc7\u0bae\u0bcd\u0bb8\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd SLT \u0bae\u0bca\u0baa\u0bbf\u0b9f\u0bc6\u0bb2\u0bcd \u0b87\u0ba3\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bbf\u0b95\u0baa\u0bcd\u0baa\u0bc6\u0bb0\u0bbf\u0baf \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0b9a\u0bc1\u0bb5\u0bb2\u0bcd - \u0b88\u0bb8\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (15) \u0bae\u0bbe\u0bb2\u0bc8 5 \u0bae\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bae\u0bbe\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bcb\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b87\u0ba3\u0bc8\u0baf \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0ba4\u0bbf\u0bb1\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0bae\u0bc7\u0bae\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bc8\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0bae\u0bcd\u0b95\u0bb3\u0bc8 \u0b89\u0bb0\u0bc1\u0bb5\u0bbe\u0b95\u0bcd\u0b95 \u0ba4\u0bc7\u0bb5\u0bc8\u0baf\u0bbe\u0ba9 \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bc1\u0b9f\u0bcd\u0baa \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0baa\u0bcd\u0baa\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bb5\u0ba4\u0bbe\u0b95\u0bc1\u0bae\u0bcd.",
        "SLT Mobitel 300\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bae\u0bc7\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf \u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0bb0\u0bbf\u0b9a\u0bc1\u0b95\u0bb3\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0ba4\u0bb0\u0bb5\u0bc1\u0b95\u0bb3\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0bae\u0b9f\u0bcd\u0b9f \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0bb7\u0bc1\u0bb5\u0bb2\u0bcd - \u0b88\u0bb8\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8\u0bbe\u0b9f\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd 06 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b8a\u0b9f\u0bbe\u0b95 \u0b87\u0ba8\u0bcd\u0ba4\u0baa\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b8a\u0b9f\u0bbe\u0b95 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7\u0bb1 \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd.",
        "\u0b86\u0bb1\u0bc1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0b9a\u0bb5\u0bbe\u0bb2\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7\u0bb1\u0bc1\u0bae\u0bcd \u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0b87\u0bb1\u0bc1\u0ba4\u0bbf\u0baf\u0bbe\u0b95 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0bb8\u0bcd\u0b95\u0bcb\u0bb0\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bc8 \u0b85\u0b9f\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bbe\u0baf\u0bcd\u0baa\u0bcd\u0baa\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bc1\u0bb5\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bcd, \u0b85\u0b99\u0bcd\u0b95\u0bc1 \u0b85\u0ba4\u0bbf\u0b95 \u0bae\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc6\u0ba3\u0bcd \u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0ba4\u0b9f\u0b95\u0bb3 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b9a\u0bbe\u0bae\u0bcd\u0baa\u0bbf\u0baf\u0ba9\u0bcd\u0bb7\u0bbf\u0baa\u0bcd\u0baa\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0bb5\u0bbe\u0baf\u0bcd\u0baa\u0bcd\u0baa\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bc1\u0bb5\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bcd.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0bb7\u0bc1\u0bb5\u0bb2\u0bcd \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc8 \u0b85\u0bb1\u0bbf\u0bae\u0bc1\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf, IMI \u0b95\u0bc7\u0bae\u0bcd\u0bb8\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bc1\u0b9f\u0bcd\u0baa \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9 \u0b86\u0ba4\u0bb0\u0bb5\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd, \u0b87\u0ba4\u0bc1 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b9a\u0bc8\u0baa\u0bb0\u0bcd \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0bc1\u0ba4\u0bbf\u0baf \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b85\u0ba9\u0bc1\u0baa\u0bb5\u0ba4\u0bcd\u0ba4\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd."
      ]
    },
    "en": {
      "title": "Sri Lanka's largest Hyper Casual - eSports Championship begins today",
      "body_lines": [
        "Sri Lanka's first and largest Hyper Casual - eSports tournament jointly organized by the Ministry of Youth and Sports, IMI Games and SLT Mobitel, kicks off today (15) at 5 pm.",
        "The main objective of this competition is to hone the skills of Sri Lankan cyber players and to provide the technical background and contribution required to create cyber games.",
        "SLT Mobitel is offering all prizes and data to over 300 winning athletes.",
        "This national level Hyper Casual - eSports tournament will be held for two days from today and the athletes will have to advance through this tournament through 06 sports.",
        "All athletes who advance through the six sports challenges will eventually have the opportunity to reach the national scoreboard, where the highest scoring player or athlete will have the opportunity to inherit the national title.",
        "Introducing the Hyper Casual game to Sri Lanka, IMI Games will provide all the technical and organizational support for the tournament, which will bring a new level of national experience to Sri Lankan cyber players."
      ]
    }
  },
  "title": "\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda  \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports Championship  \u0d85\u0daf \u0d87\u0dbb\u0db9\u0dd9\u0dba\u0dd2",
  "body_lines": [
    "\u0dad\u0dbb\u0dd4\u0dab \u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1\u0dba IMI Games \u0dc3\u0dc4 SLT \u0db8\u0ddc\u0db6\u0dd2\u0da7\u0dd9\u0dbd\u0dca \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0d85\u0daf (15) \u0dc3\u0dc0\u0dc3 5\u0da7 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dda.",
    "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dda\u0dba \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0d9a\u0dd4\u0dc3\u0dbd\u0dad\u0dcf \u0d94\u0db4\u0dca\u0db1\u0dd0\u0d82\u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0db4\u0dc3\u0dd4\u0db6\u0dd2\u0db8 \u0dc4\u0dcf \u0daf\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dba\u0dd2.",
    "\u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0da2\u0dba\u0d9c\u0db1\u0dca\u0db1\u0dcf 300 \u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dad\u0dd1\u0d9c\u0dd2 \u0dc3\u0dc4 Data \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 SLT \u0db8\u0ddc\u0db6\u0dd2\u0da7\u0dd9\u0dbd\u0dca \u0d86\u0dba\u0dad\u0db1\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca\u0dc0\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2.",
    "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db8\u0dd9\u0db8 Hyper Casual \u2013 eSports \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0d85\u0daf \u0dc3\u0dd2\u0da7 \u0daf\u0dd2\u0db1 02 \u0d9a\u0dca \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c 06 \u0d9a\u0dca \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dba\u0dcf\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1\u0dd4 \u0d87\u0dad.",
    "\u0d85\u0daf\u0dcf\u0dc5 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c 06 \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dba\u0db1 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dd4\u0dc0\u0dbb\u0dd4\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0d8b\u0daf\u0dcf\u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dcf \u0dc4\u0ddd \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0d8b\u0dbb\u0dd4\u0db8\u0d9a\u0db8\u0dca \u0d9a\u0dd3\u0db8\u0dda \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0d8b\u0daf\u0dcf\u0dc0\u0db1\u0dd4 \u0d87\u0dad.",
    "Hyper Casual \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0dc0 \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf\u0daf\u0dd4\u0db1\u0dca IMI Games \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0dc3\u0dc4 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d89\u0da7\u0dd4 \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0db8\u0dd9\u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dda\u0dba \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dda \u0db1\u0dc0\u0db8\u0dd4 \u0d85\u0dad\u0dca\u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0db1\u0dd4 \u0d87\u0dad."
  ],
  "translate": {
    "si": {
      "title": "\u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda  \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports Championship  \u0d85\u0daf \u0d87\u0dbb\u0db9\u0dd9\u0dba\u0dd2",
      "body_lines": [
        "\u0dad\u0dbb\u0dd4\u0dab \u0dc4\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0d82\u0dc1\u0dba IMI Games \u0dc3\u0dc4 SLT \u0db8\u0ddc\u0db6\u0dd2\u0da7\u0dd9\u0dbd\u0dca \u0d91\u0d9a\u0dca\u0dc0 \u0db4\u0dc0\u0dad\u0dca\u0dc0\u0db1 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0dae\u0db8 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd\u0dad\u0db8 Hyper Casual \u2013 eSports \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0d85\u0daf (15) \u0dc3\u0dc0\u0dc3 5\u0da7 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0dc0\u0dda.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dda\u0dba \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0d9a\u0dd4\u0dc3\u0dbd\u0dad\u0dcf \u0d94\u0db4\u0dca\u0db1\u0dd0\u0d82\u0dc0\u0dd3\u0db8 \u0dc3\u0dc4 \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0db1\u0dd2\u0dbb\u0dca\u0db8\u0dcf\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0d85\u0dc0\u0dc1\u0dca\u200d\u0dba \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0db4\u0dc3\u0dd4\u0db6\u0dd2\u0db8 \u0dc4\u0dcf \u0daf\u0dcf\u0dba\u0d9a\u0dad\u0dca\u0dc0\u0dba \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8 \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db0\u0dcf\u0db1 \u0d85\u0dbb\u0db8\u0dd4\u0dab\u0dba\u0dd2.",
        "\u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0da2\u0dba\u0d9c\u0db1\u0dca\u0db1\u0dcf 300 \u0d9a\u0da7 \u0d85\u0db0\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dad\u0dd1\u0d9c\u0dd2 \u0dc3\u0dc4 Data \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 SLT \u0db8\u0ddc\u0db6\u0dd2\u0da7\u0dd9\u0dbd\u0dca \u0d86\u0dba\u0dad\u0db1\u0dba \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0db4\u0dad\u0dca\u0dc0\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0dba\u0dd2.",
        "\u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dd9\u0db1\u0dca \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db8\u0dd9\u0db8 Hyper Casual \u2013 eSports \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba \u0d85\u0daf \u0dc3\u0dd2\u0da7 \u0daf\u0dd2\u0db1 02 \u0d9a\u0dca \u0db4\u0dd4\u0dbb\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c 06 \u0d9a\u0dca \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dba\u0dcf\u0db8\u0da7 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u0db1\u0dd4 \u0d87\u0dad.",
        "\u0d85\u0daf\u0dcf\u0dc5 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf \u0dad\u0dbb\u0d9c \u0d85\u0db7\u0dd2\u0dba\u0ddd\u0d9c 06 \u0d94\u0dc3\u0dca\u0dc3\u0dda \u0d89\u0daf\u0dd2\u0dbb\u0dd2\u0dba\u0da7 \u0dba\u0db1 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0d85\u0dc0\u0dc3\u0dcf\u0db1\u0dba\u0dda \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 \u0db4\u0dd4\u0dc0\u0dbb\u0dd4\u0dc0\u0da7 \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd3\u0db8\u0dda \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0d8b\u0daf\u0dcf\u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0dc4\u0dd2\u0daf\u0dd3 \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0dbd\u0d9a\u0dd4\u0dab\u0dd4 \u0dbd\u0db6\u0dcf\u0d9c\u0db1\u0dca\u0db1\u0dcf \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a\u0dba\u0dcf \u0dc4\u0ddd \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dd2\u0d9a\u0dcf\u0dc0 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc1\u0dd6\u0dbb\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0d8b\u0dbb\u0dd4\u0db8\u0d9a\u0db8\u0dca \u0d9a\u0dd3\u0db8\u0dda \u0dc4\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0 \u0d8b\u0daf\u0dcf\u0dc0\u0db1\u0dd4 \u0d87\u0dad.",
        "Hyper Casual \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0dc0 \u0db8\u0dd9\u0dbb\u0da7\u0da7 \u0dc4\u0db3\u0dd4\u0db1\u0dca\u0dc0\u0dcf\u0daf\u0dd4\u0db1\u0dca IMI Games \u0db8\u0dd9\u0db8 \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dad\u0dcf\u0d9a\u0dca\u0dc2\u0dab\u0dd2\u0d9a \u0dc3\u0dc4 \u0dc3\u0d82\u0dc0\u0dd2\u0db0\u0dcf\u0db1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d89\u0da7\u0dd4 \u0d9a\u0dbb\u0db1 \u0d85\u0dad\u0dbb \u0db8\u0dd9\u0db8\u0d9c\u0dd2\u0db1\u0dca \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dda\u0dba \u0dc3\u0dba\u0dd2\u0db6\u0dbb\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0d9a \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0da9\u0dd2\u0d9a\u0dcf\u0dc0\u0db1\u0dca\u0da7 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0db8\u0da7\u0dca\u0da7\u0db8\u0dda \u0db1\u0dc0\u0db8\u0dd4 \u0d85\u0dad\u0dca\u0daf\u0dd0\u0d9a\u0dd3\u0db8\u0d9a\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dc0\u0db1\u0dd4 \u0d87\u0dad."
      ]
    },
    "ta": {
      "title": "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bbf\u0b95\u0baa\u0bcd\u0baa\u0bc6\u0bb0\u0bbf\u0baf \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0b9a\u0bc1\u0bb5\u0bb2\u0bcd - \u0b88\u0bb8\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0b9a\u0bbe\u0bae\u0bcd\u0baa\u0bbf\u0baf\u0ba9\u0bcd\u0bb7\u0bbf\u0baa\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0ba4\u0bca\u0b9f\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1",
      "body_lines": [
        "\u0b87\u0bb3\u0bc8\u0b9e\u0bb0\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bc1, IMI \u0b95\u0bc7\u0bae\u0bcd\u0bb8\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd SLT \u0bae\u0bca\u0baa\u0bbf\u0b9f\u0bc6\u0bb2\u0bcd \u0b87\u0ba3\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1 \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bbf\u0b95\u0baa\u0bcd\u0baa\u0bc6\u0bb0\u0bbf\u0baf \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0b9a\u0bc1\u0bb5\u0bb2\u0bcd - \u0b88\u0bb8\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 (15) \u0bae\u0bbe\u0bb2\u0bc8 5 \u0bae\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc1 \u0b86\u0bb0\u0bae\u0bcd\u0baa\u0bae\u0bbe\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0bae\u0bc1\u0b95\u0bcd\u0b95\u0bbf\u0baf \u0ba8\u0bcb\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b87\u0ba3\u0bc8\u0baf \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0ba4\u0bbf\u0bb1\u0ba9\u0bcd\u0b95\u0bb3\u0bc8 \u0bae\u0bc7\u0bae\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b9a\u0bc8\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0bae\u0bcd\u0b95\u0bb3\u0bc8 \u0b89\u0bb0\u0bc1\u0bb5\u0bbe\u0b95\u0bcd\u0b95 \u0ba4\u0bc7\u0bb5\u0bc8\u0baf\u0bbe\u0ba9 \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bc1\u0b9f\u0bcd\u0baa \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0ba3\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0baa\u0b99\u0bcd\u0b95\u0bb3\u0bbf\u0baa\u0bcd\u0baa\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bb5\u0ba4\u0bbe\u0b95\u0bc1\u0bae\u0bcd.",
        "SLT Mobitel 300\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0bae\u0bc7\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0bb5\u0bc6\u0bb1\u0bcd\u0bb1\u0bbf \u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0bb0\u0bbf\u0b9a\u0bc1\u0b95\u0bb3\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0ba4\u0bb0\u0bb5\u0bc1\u0b95\u0bb3\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0bae\u0b9f\u0bcd\u0b9f \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0bb7\u0bc1\u0bb5\u0bb2\u0bcd - \u0b88\u0bb8\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bcd\u0bb8\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0bae\u0bc1\u0ba4\u0bb2\u0bcd \u0b87\u0bb0\u0ba3\u0bcd\u0b9f\u0bc1 \u0ba8\u0bbe\u0b9f\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0b9f\u0bc8\u0baa\u0bc6\u0bb1\u0bb5\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd 06 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0baa\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b8a\u0b9f\u0bbe\u0b95 \u0b87\u0ba8\u0bcd\u0ba4\u0baa\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0b8a\u0b9f\u0bbe\u0b95 \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7\u0bb1 \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd.",
        "\u0b86\u0bb1\u0bc1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0b9a\u0bb5\u0bbe\u0bb2\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bae\u0bc2\u0bb2\u0bae\u0bcd \u0bae\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7\u0bb1\u0bc1\u0bae\u0bcd \u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0b87\u0bb1\u0bc1\u0ba4\u0bbf\u0baf\u0bbe\u0b95 \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0bb8\u0bcd\u0b95\u0bcb\u0bb0\u0bcd\u0baa\u0bcb\u0bb0\u0bcd\u0b9f\u0bc8 \u0b85\u0b9f\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bbe\u0baf\u0bcd\u0baa\u0bcd\u0baa\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bc1\u0bb5\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bcd, \u0b85\u0b99\u0bcd\u0b95\u0bc1 \u0b85\u0ba4\u0bbf\u0b95 \u0bae\u0ba4\u0bbf\u0baa\u0bcd\u0baa\u0bc6\u0ba3\u0bcd \u0baa\u0bc6\u0bb1\u0bcd\u0bb1 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0b85\u0bb2\u0bcd\u0bb2\u0ba4\u0bc1 \u0ba4\u0b9f\u0b95\u0bb3 \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b9a\u0bbe\u0bae\u0bcd\u0baa\u0bbf\u0baf\u0ba9\u0bcd\u0bb7\u0bbf\u0baa\u0bcd\u0baa\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0bb5\u0bbe\u0baf\u0bcd\u0baa\u0bcd\u0baa\u0bc8\u0baa\u0bcd \u0baa\u0bc6\u0bb1\u0bc1\u0bb5\u0bbe\u0bb0\u0bcd\u0b95\u0bb3\u0bcd.",
        "\u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb9\u0bc8\u0baa\u0bcd\u0baa\u0bb0\u0bcd \u0b95\u0bc7\u0bb7\u0bc1\u0bb5\u0bb2\u0bcd \u0bb5\u0bbf\u0bb3\u0bc8\u0baf\u0bbe\u0b9f\u0bcd\u0b9f\u0bc8 \u0b85\u0bb1\u0bbf\u0bae\u0bc1\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bc1\u0ba4\u0bcd\u0ba4\u0bbf, IMI \u0b95\u0bc7\u0bae\u0bcd\u0bb8\u0bcd \u0baa\u0bcb\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0b85\u0ba9\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1 \u0ba4\u0bca\u0bb4\u0bbf\u0bb2\u0bcd\u0ba8\u0bc1\u0b9f\u0bcd\u0baa \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba8\u0bbf\u0bb1\u0bc1\u0bb5\u0ba9 \u0b86\u0ba4\u0bb0\u0bb5\u0bc8\u0baf\u0bc1\u0bae\u0bcd \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd, \u0b87\u0ba4\u0bc1 \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8 \u0b9a\u0bc8\u0baa\u0bb0\u0bcd \u0bb5\u0bc0\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0baa\u0bc1\u0ba4\u0bbf\u0baf \u0ba4\u0bc7\u0b9a\u0bbf\u0baf \u0b85\u0ba9\u0bc1\u0baa\u0bb5\u0ba4\u0bcd\u0ba4\u0bc8 \u0bb5\u0bb4\u0b99\u0bcd\u0b95\u0bc1\u0bae\u0bcd."
      ]
    },
    "en": {
      "title": "Sri Lanka's largest Hyper Casual - eSports Championship begins today",
      "body_lines": [
        "Sri Lanka's first and largest Hyper Casual - eSports tournament jointly organized by the Ministry of Youth and Sports, IMI Games and SLT Mobitel, kicks off today (15) at 5 pm.",
        "The main objective of this competition is to hone the skills of Sri Lankan cyber players and to provide the technical background and contribution required to create cyber games.",
        "SLT Mobitel is offering all prizes and data to over 300 winning athletes.",
        "This national level Hyper Casual - eSports tournament will be held for two days from today and the athletes will have to advance through this tournament through 06 sports.",
        "All athletes who advance through the six sports challenges will eventually have the opportunity to reach the national scoreboard, where the highest scoring player or athlete will have the opportunity to inherit the national title.",
        "Introducing the Hyper Casual game to Sri Lanka, IMI Games will provide all the technical and organizational support for the tournament, which will bring a new level of national experience to Sri Lankan cyber players."
      ]
    }
  }
}