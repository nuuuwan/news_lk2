    "si": {
      "title": "\u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca\u0d9c\u0dda \u0db4\u0dc5\u0db8\u0dd4 \u0d9a\u0da9\u0dba\u0dd2\u0db8 \u0dc3\u0dcf\u0dbb\u0dca\u0dae\u0d9a\u0dba\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0d91\u0d82\u0d9c\u0dbd\u0db1\u0dca\u0dad\u0dba\u0dda \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd9\u0db1 \u0db4\u0ddc\u0daf\u0dd4\u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db8\u0dab\u0dca\u0da9\u0dbd\u0dba\u0dd3\u0dba \u0dad\u0dbb\u0d9c\u0dcf\u0dc0\u0dbd\u0dd2\u0dba\u0dda \u0db8\u0dd3\u0da7\u0dbb\u0dca 100 \u0db4\u0dd2\u0dbb\u0dd2\u0db8\u0dd2 \u0dad\u0dbb\u0d9c\u0dba\u0dda \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0dd0\u0db6\u0dd3\u0db8\u0dda \u0dad\u0dbb\u0d9c\u0dba\u0d9a\u0da7 \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0da9\u0dcf \u0d9a\u0dc5 \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dba\u0dda \u0dc3\u0dd4\u0db4\u0dd4\u0dbb\u0dd2 \u0d9a\u0dd9\u0da7\u0dd2\u0daf\u0dd4\u0dbb \u0db0\u0dcf\u0dc0\u0db1 \u0dc1\u0dd6\u0dbb \u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0d85\u0db6\u0dda\u0d9a\u0ddd\u0db1\u0dca \u0d91\u0dc4\u0dd2 \u0db4\u0dc5\u0db8\u0dd4 \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba \u0daf\u0dd2\u0db1\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc3\u0db8\u0dad\u0dca\u0dc0\u0dd2\u0dba.",
        "\u0dba\u0dd4\u0db4\u0dd4\u0db1\u0dca \u0d91\u0db8 \u0dad\u0dbb\u0d9c\u0dba \u0dad\u0dad\u0dca\u0db4\u0dbb 10.06\u0d9a\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0db8 \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0d94\u0dc4\u0dd4 \u0d85\u0dc0\u0dc3\u0db1\u0dca \u0db4\u0dd6\u0dbb\u0dca\u0dc0 \u0dad\u0dbb\u0d9c\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0dc3\u0dd4\u0daf\u0dd4\u0dc3\u0dd4\u0d9a\u0db8\u0dca \u0dbd\u0db6\u0dcf\u0d9c\u0dad\u0dca\u0dad\u0dda\u0dba."
      ],
