    "si": {
      "title": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d85\u0da9\u0dd4 \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc0\u0dd6 \u0dad\u0dda \u0db8\u0dd2\u0dbd \u0da2\u0dd4\u0db1\u0dd2 \u0dad\u0dd4\u0db1\u0dca\u0dc0\u0db1 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2",
      "author": "",
      "body_lines": [
        "ECONOMYNEXT - \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0d85\u0da9\u0dd4 \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc0\u0dd6 \u0dbd\u0d82\u0d9a\u0dcf \u0dad\u0dda \u0db8\u0dd2\u0dbd \u0da2\u0dd6\u0db1\u0dd2 \u0dad\u0dd4\u0db1\u0dca\u0dc0\u0db1 \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1,447.39 \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd2 \u0d85\u0dad\u0dbb, \u0db4\u0dd9\u0dbb \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 1,455 \u0dc3\u0dd2\u0da7, \u0dc0\u0dca\u200d\u0dba\u0dc0\u0dc4\u0dcf\u0dbb \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0d9b\u0dab\u0dca\u0da9\u0dc0 \u0d85\u0dc0\u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0db6\u0dd0\u0dc0\u0dd2\u0db1\u0dca, \u0d9a\u0dbb\u0dca\u0db8\u0dcf\u0db1\u0dca\u0dad \u0daf\u0dad\u0dca\u0dad \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dba\u0dd2.",
        "\u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0da2\u0dd4\u0db1\u0dd2 22 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda \u0d85\u0dbd\u0dd9\u0dc0\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0d85\u0da9\u0dd4 \u0dc0\u0dbb\u0dca\u0db0\u0db1\u0dba \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba\u0dba\u0dd9\u0db1\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0da7 \u0da9\u0ddc\u0dbd\u0dbb\u0dca 4.05 \u0d9a\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0d91\u0dba \u0dc0\u0dc3\u0dbb\u0d9a\u0da7 \u0db4\u0dd9\u0dbb \u0da9\u0ddc\u0dbd\u0dbb\u0dca 2.92 \u0da7 \u0dc0\u0da9\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd2\u0dba. \u0da9\u0ddc\u0dbd\u0dbb\u0dba \u0daf\u0dd4\u0dbb\u0dca\u0dc0\u0dbd \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db1\u0dd0\u0db9\u0dd4\u0dbb\u0dd4 \u0dc0\u0db1 \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb\u0dab\u0dba \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad.",
        "\u0da2\u0dd4\u0db1\u0dd2 22 \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda\u0daf\u0dd3 \u0db4\u0ddc\u0dad\u0dd4\u0da7\u0dd4\u0dc0 \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba\u0dda Low Grown BOP1 \u0dc1\u0dca\u200d\u0dbb\u0dda\u0dab\u0dd2\u0dba \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 4,300\u0d9a\u0dca \u0dc3\u0dc4 \u0db4\u0ddc\u0dad\u0dd4\u0da7\u0dd4\u0dc0 OP1 \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 4,250\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0dbd\u0db6\u0dcf \u0d9c\u0dad\u0dca \u0db6\u0dc0 Ceylon Tea Brokers \u0daf\u0dad\u0dca\u0dad \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dba\u0dd2.",
        "\u0d85\u0dbd\u0dca\u0dc4\u0dda\u0dc0\u0dcf\u0db1 \u0dc3\u0dd4\u0db4\u0dbb\u0dca \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba\u0dda FBOPFSp \u0db4\u0dca\u200d\u0dbb\u0dd2\u0db8\u0dd2\u0dba\u0db8\u0dca \u0db8\u0dbd\u0dca \u0dc0\u0dbb\u0dca\u0d9c \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,500 \u0d9a\u0dca \u0daf \u0d9a\u0dcf\u0db8\u0dbb\u0d82\u0d9c\u0db4\u0dd2\u0da7\u0dd2\u0dba \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba\u0dda FBOPFExSP1 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 10,000 \u0d9a\u0dca \u0daf \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d87\u0dad.",
        "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0\u0dda \u0dc0\u0dd9\u0dc5\u0dd9\u0db1\u0dca\u0daf\u0db1\u0dca\u0da7 \u0dc3\u0dc4 \u0dc3\u0ddc\u0dc6\u0dca\u0da7\u0dca-\u0db4\u0dd9\u0d9c\u0dbb\u0dca \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba\u0dba\u0dd9\u0db1\u0dca \u0d8b\u0daf\u0dca\u0db0\u0db8\u0db1\u0dba \u0db4\u0dd0\u0db8\u0dd2\u0dab\u0dd9\u0db1\u0dca\u0db1\u0dda \u0d86\u0db1\u0dba\u0db1\u0dd2\u0d9a \u0db8\u0dd2\u0dbd \u0d9c\u0dab\u0db1\u0dca \u0dc0\u0dbd\u0dd2\u0db1\u0dca \u0db6\u0dc0 \u0db4\u0dca\u200d\u0dbb\u0d9a\u0dcf\u0dc1 \u0d9a\u0dbb\u0dba\u0dd2. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0d85\u0dc0\u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dc4 \u0db6\u0dd0\u0d82\u0d9a\u0dd4\u0dc0 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0db1 \u0dc0\u0dd2\u0da7 \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dc5 \u0dc4\u0ddd \u0d85\u0db4\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dc5 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4\u0db8 \u0dc0\u0dd9\u0dc5\u0db3\u0dcf\u0db8\u0dca \u0d9a\u0dbb\u0db1 \u0db7\u0dcf\u0dab\u0dca\u0da9\u0dc0\u0dbd \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0dc6\u0dd9\u0da9\u0dbb\u0dbd\u0dca \u0dc3\u0d82\u0da0\u0dd2\u0dad\u0dba \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0db8\u0dd4\u0daf\u0dca\u200d\u0dbb\u0dab\u0dba \u0d9a\u0dbb\u0db1 \u0dc0\u0dd2\u0da7 \u0d9c\u0ddd\u0dbd\u0dd3\u0dba \u0db8\u0dd2\u0dbd \u0daf \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0d85\u0db1\u0dd4\u0dc0 (\u0db7\u0dcf\u0dab\u0dca\u0da9 \u0d8b\u0dad\u0dca\u0db4\u0dcf\u0dad\u0dba) \u0d89\u0dc4\u0dc5 \u0dba\u0dba\u0dd2. 2008/2009 \u0daf\u0dd3 \u0db6\u0dd2\u0db3\u0dd3 \u0d9c\u0dd2\u0dba Greenspan-Bernanke \u0db6\u0dd4\u0db6\u0dd4\u0dbd\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0db1\u0dbb\u0d9a\u0db8 \u0dc0\u0dd6 \u0d8a\u0db1\u0dd2\u0dba\u0dcf \u2018Powell Bubble\u2019 \u0dc4\u0dda\u0dad\u0dd4\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dda \u0db8\u0ddc\u0dc4\u0ddc\u0dad\u0dda \u0db7\u0dcf\u0dab\u0dca\u0da9 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dc5 \u0dba\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd3.",
        "\u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0da9\u0ddc\u0dbd\u0dbb\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0da2\u0dd4\u0db1\u0dd2 22 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc0\u0dd2\u0d9a\u0dd4\u0dab\u0dd4\u0db8\u0dca \u0dc3\u0dcf\u0db8\u0dcf\u0db1\u0dca\u200d\u0dba\u0dba \u0db4\u0dc3\u0dd4\u0d9c\u0dd2\u0dba \u0dc0\u0dc3\u0dbb\u0dda 2.92 \u0da7 \u0dc3\u0dcf\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dc0 \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dba\u0d9a\u0dca \u0da9\u0ddc\u0dbd\u0dbb\u0dca 3.52 \u0d9a\u0dd2.",
        "\u0da2\u0dd6\u0db1\u0dd2 22 \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd9\u0db1\u0dca\u0daf\u0dda\u0dc3\u0dd2\u0dba\u0dda\u0daf\u0dd3, Low Grown \u0dc3\u0db3\u0dc4\u0dcf \u0dc4\u0ddc\u0db3 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd6 \u0d85\u0dad\u0dbb Ex-Estate \u0dc3\u0db3\u0dc4\u0dcf \u0daf\u0dd0\u0da9\u0dd2 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0d9a\u0dca \u0dad\u0dd2\u0db6\u0dd6 \u0db6\u0dc0 Ceylon Tea Brokers, \u0d9a\u0ddc\u0dc5\u0db9 \u0db4\u0daf\u0db1\u0db8\u0dca \u0d9a\u0dbb\u0d9c\u0dad\u0dca \u0dad\u0dda \u0dad\u0dd0\u0dbb\u0dd0\u0dc0\u0dca\u0d9a\u0dcf\u0dbb \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0db4\u0dc0\u0dc3\u0dba\u0dd2.",
        "\u0d85\u0da9\u0dd4 \u0dc0\u0dd0\u0da9\u0dd4\u0dab\u0dd4 \u0d9a\u0ddc\u0dc5 / \u0da7\u0dd2\u0db4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0db7\u0dda\u0daf\u0dba \u0db4\u0dd9\u0dbb \u0dc3\u0dad\u0dd2\u0dba\u0dda \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 2.4 \u0da7 \u0dc3\u0dcf\u0db4\u0dda\u0d9a\u0dca\u0dc2\u0dc0 \u0dc0\u0dd0\u0da9\u0dd2 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u0d9a\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0d9c\u0dca\u200d\u0dbb\u0dd1\u0db8\u0dca \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 2.26 \u0d9a\u0dca \u0d85\u0dbd\u0dd9\u0dc0\u0dd2 \u0dc0\u0dd3 \u0d87\u0dad.",
