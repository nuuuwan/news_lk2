    "si": {
      "title": "Covid \u0db8\u0dbb\u0dab \u0dc3\u0dc4 \u0dbb\u0ddd\u0d9c\u0dd3\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0dd9\u0db8\u0dd2\u0db1\u0dca \u0db4\u0dc0\u0dad\u0dd3",
      "author": "\u0db1\u0ddc\u0daf\u0db1\u0dca\u0db1\u0dcf",
      "body_lines": [
        "\u0d9a\u0ddc\u0dbb\u0ddd\u0db1\u0dcf \u0dc0\u0ddb\u0dbb\u0dc3\u0dba \u0d86\u0dc3\u0dcf\u0daf\u0db1\u0dba \u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 \u0d89\u0dc4\u0dc5 \u0d9c\u0ddc\u0dc3\u0dca \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf. \u0d91\u0dc4\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0db5\u0dbd\u0dba\u0d9a\u0dca \u0dbd\u0dd9\u0dc3 \u0da2\u0dd4\u0dbd\u0dd2 25 \u0dc0\u0db1 \u0daf\u0dd2\u0db1 \u0db4\u0dc3\u0dca \u0daf\u0dd9\u0db1\u0dd9\u0d9a\u0dd4 \u0db8\u0dd2\u0dba \u0d9c\u0dd2\u0dba\u0dc4.",
        "\u0db8\u0dda \u0d85\u0dad\u0dbb, \u0d8a\u0dba\u0dda (26) \u0dc4\u0db3\u0dd4\u0db1\u0dcf\u0d9c\u0dad\u0dca \u0d86\u0dc3\u0dcf\u0daf\u0dd2\u0dad\u0dba\u0dd2\u0db1\u0dca \u0dc3\u0d82\u0d9b\u0dca\u200d\u0dba\u0dcf\u0dc0 119\u0d9a\u0dca \u0db6\u0dc0 \u0dbb\u0da2\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd2 \u0daf\u0dd9\u0db4\u0dcf\u0dbb\u0dca\u0dad\u0db8\u0dda\u0db1\u0dca\u0dad\u0dd4\u0dc0 \u0db1\u0dd2\u0dc0\u0dda\u0daf\u0db1\u0dba \u0d9a\u0dbb\u0dba\u0dd2."
      ],
      "title_ents": [],
      "body_line_ents_list": [
        [
          {
