    "si": {
      "title": "\u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0db6\u0dc5\u0d9a\u0dcf \u0dc3\u0dd9\u0db6\u0dc5\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0dba\u0daf\u0dd2\u0dc0\u0dd2 \u0db1\u0dc3\u0dcf \u0d9c\u0db1\u0dd3",
      "author": "T. Saranya",
      "body_lines": [
        "\u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf\u0dba\u0dda \u0d8b\u0db4 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a\u0dc0\u0dbb\u0dba\u0d9a\u0dd4 \u0d9a\u0ddd\u0db1\u0dcf\u0dc4\u0dda\u0db1 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb\u0dda\u0daf\u0dd3 \u0dc0\u0dd9\u0da9\u0dd2 \u0dad\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0dba\u0daf\u0dd2\u0dc0\u0dd2 \u0dc4\u0dcf\u0db1\u0dd2\u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d9a\u0da9\u0dc0\u0dad - \u0d9a\u0ddd\u0db1\u0dc4\u0dda\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0dcf\u0dbb\u0dca\u0dba \u0db6\u0dc5\u0d9a\u0dcf \u0d9a\u0db3\u0dc0\u0dd4\u0dbb\u0dda \u0d85\u0dc0\u0dd2 \u0d9c\u0db6\u0da9\u0dcf\u0dc0\u0d9a\u0dca \u0db7\u0dcf\u0dbb\u0dc0 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dc5 59 \u0dc4\u0dd0\u0dc0\u0dd2\u0dbb\u0dd2\u0daf\u0dd2 \u0d8b\u0db4 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0db4\u0dbb\u0dd3\u0d9a\u0dca\u0dc2\u0d9a\u0dc0\u0dbb\u0dba\u0dd9\u0d9a\u0dd4 \u0daf\u0dd9\u0daf\u0dbb\u0dd4 \u0db4\u0dd2\u0dba\u0dd9\u0d9a\u0dd4 \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0dc3\u0dd2\u0dba\u0daf\u0dd2\u0dc0\u0dd2 \u0dc4\u0dcf\u0db1\u0dd2\u0d9a\u0dbb\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u0dc0\u0dcf."
      ],
