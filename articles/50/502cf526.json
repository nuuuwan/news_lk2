          },
          {
            "text": "\u0d9a\u0dd4\u0dc3\u0dbd\u0dca \u0dc3\u0daf\u0dbb\u0dd4\u0dc0\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d85\u0db6\u0dca\u0daf\u0dd4\u0dbd\u0dca \u0d9a\u0dcf\u0daf\u0dbb\u0dca \u0d85\u0db6\u0dca\u0daf\u0dd4\u0dbd\u0dca \u0d9a\u0dbd\u0dd3\u0dbd\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd9\u0dba\u0dbb\u0dcf\u0db8\u0dca \u0da2\u0dba\u0d9a\u0dd4\u0db8\u0dcf\u0dbb\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dd9\u0dba\u0dbb\u0dcf\u0db8\u0dca \u0da2\u0dd9\u0dba\u0dbb\u0dcf\u0da2\u0dca",
            "label": "PERSON"
          }
        ]
