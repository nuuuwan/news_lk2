          }
        ],
        [
          {
            "text": "\u0db8\u0dc4\u0dda\u0dc3\u0dca\u0dad\u0dca\u0dbb\u0dcf\u0dad\u0dca\u0dc0\u0dbb\u0dba\u0dcf",
            "label": "ORG"
          },
          {
            "text": "\u0d8b\u0db4\u0daf\u0dda\u0dc1\u0d9a",
