          {
            "text": "\u0dc3\u0dcf\u0d9c\u0dbb \u0dbd\u0dd2\u0dba\u0db1\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0ddc\u0da7\u0dd4\u0dc0 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
