      "body_line_ents_list": [
        [
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a \u0daf\u0dd9\u0db8\u0dc5",
            "label": "GPE"
          },
          {
            "text": "\u0da7\u0dca\u200d\u0dbb\u0dd2\u0da0\u0dd2 \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0db6\u0db1\u0dca\u0db0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb\u0dba\u0dda \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb",
