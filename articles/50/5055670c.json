          },
          {
            "text": "\u0d85\u0dba\u0dd2\u0da9\u0dd2\u0dba\u0dbd\u0dca \u0db4\u0dc5\u0db8\u0dd4 \u0dad\u0dda\u0dbb\u0dd3\u0db8",
            "label": "ORG"
          },
          {
            "text": "\u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0dcf\u0d82\u0d9a\u0dd2\u0d9a",
            "label": "LOC"
          },
          {
            "text": "\u0db8\u0db0\u0dca\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dd4\u0dbb\u0dd4\u0dab\u0dd1\u0d9c\u0dbd \u0dc3\u0dda\u0dc0\u0dcf \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0dd4\u0dbb\u0dd4\u0dab\u0dd1\u0d9c\u0dbd",
            "label": "GPE"
          },
          {
            "text": "\u0d85\u0dba\u0dd2\u0da9\u0dd2\u0dba\u0dbd\u0dca \u0db4\u0dc5\u0db8\u0dd4 \u0dad\u0dda\u0dbb\u0dd3\u0db8",
            "label": "ORG"
