          {
            "text": "\u0dad\u0dd4\u0db1\u0dca",
            "label": "CARDINAL"
          }
        ],
        [
          {
            "text": "\u0dc3\u0dda\u0dc0\u0dcf \u0db8\u0db0\u0dca\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba",
            "label": "FAC"
