            "label": "ORG"
          }
        ],
        [
          {
            "text": "\u0d9a\u0da7\u0dd4\u0db1\u0dcf\u0dba\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0db8\u0dad\u0dca\u0dad\u0dbd \u0d9c\u0dd4\u0dc0\u0db1\u0dca \u0dad\u0ddc\u0da7\u0dd4\u0db4\u0dbd",
            "label": "PERSON"
          }
        ],
        [
          {
            "text": "\u0dc4\u0dcf\u0db8\u0dd4\u0daf\u0dd4\u0dbb\u0dd4\u0dc0\u0ddd",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd2\u0d9c\u0ddc\u0da9 \u0dc0\u0dad\u0dca\u0dad",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0dcf\u0dc1\u0dca\u200d\u0dba\u0db4 \u0dc4\u0dd2\u0db8\u0dd2\u0dba",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db8\u0dca.\u0da2\u0dd3. \u0dad\u0dd2\u0dc3\u0dbb \u0d85\u0db1\u0dd4\u0dbb\u0dcf\u0db0",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0dbd\u0dca.\u0d91\u0db1\u0dca.\u0da9\u0dd3. \u0db4\u0dd9\u0dbb\u0dda\u0dbb\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dbb\u0db8\u0dda\u0dc2\u0dca \u0d89\u0db1\u0dca\u0daf\u0dd2\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0d86\u0dbb\u0dca.\u0d92. \u0dbb\u0dcf\u0da2\u0db4\u0d9a\u0dca\u0dc2",
            "label": "PERSON"
          },
          {
            "text": "\u0d92.\u0d92. \u0dc3\u0dd2\u0dbb\u0dd2\u0dbd\u0dca \u0db8\u0db1\u0dad\u0dd4\u0d82\u0d9c",
            "label": "ORG"
          },
          {
            "text": "\u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca.\u0db4\u0dd3. \u0d89\u0dc3\u0dd4\u0dbb\u0dd4 \u0dc0\u0dbb\u0dca\u0dab\u0d9a\u0dd4\u0dbd",
            "label": "ORG"
          },
          {
            "text": "\u0dbb\u0ddc\u0dc2\u0dcf\u0db1\u0dca \u0d85\u0dbd\u0dd2 \u0da9\u0dd0\u0db1\u0dd2\u0dc3\u0dca \u0d85\u0dbd\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0da7\u0dd3.\u0dc3\u0dd3. \u0da0\u0db1\u0dca\u0daf\u0dd2\u0db8\u0dcf\u0dbd\u0dca \u0d9c\u0db8\u0d9c\u0dda",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dd3.\u0d86\u0dbb\u0dca.\u0d91\u0dc3\u0dca.",
            "label": "GPE"
          },
          {
            "text": "\u0db6\u0dd9\u0db1\u0dca\u0dad\u0dbb \u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db1\u0dca.\u0d91\u0db8\u0dca.\u0dad\u0dc0\u0dd4\u0dc6\u0dd2\u0d9a\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db8\u0dca. \u0d9a\u0dcf\u0dc3\u0dd2\u0db8\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0db1\u0dd2\u0dbd\u0db1\u0dca\u0dad \u0dc3\u0db8\u0dd2\u0dad\u0dca \u0db4\u0dca\u200d\u0dbb\u0db1\u0dcf\u0db1\u0dca\u0daf\u0dd4",
            "label": "PERSON"
          },
          {
            "text": "\u0d9a\u0ddd\u0dbb\u0dc5\u0d9c\u0dda \u0db6\u0db1\u0dca\u0daf\u0dd4\u0dbd \u0db4\u0dca\u200d\u0dbb\u0db7\u0dcf\u0dad\u0dca",
            "label": "ORG"
          },
          {
            "text": "\u0d91\u0da0\u0dca.\u0d91\u0db8\u0dca.\u0da7\u0dd3.\u0da2\u0dd3. \u0db8\u0dd0\u0dab\u0dd2\u0d9a\u0dcf",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0db8\u0dd3\u0dbb \u0db8\u0db0\u0dd4\u0dc1\u0d82\u0d9a \u0dc3\u0dd2\u0dbb\u0dd2\u0dc0\u0dbb\u0dca\u0db0\u0db1",
            "label": "PERSON"
          },
          {
            "text": "\u0dc3\u0dd4\u0daf\u0dad\u0dca \u0dbd\u0d9a\u0dca\u0dc2\u0dca\u0db8\u0db1\u0dca",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db8\u0dca.\u0d86\u0dbb\u0dca \u0da0\u0dcf\u0dbb\u0dd4\u0d9a",
            "label": "PERSON"
          },
          {
            "text": "\u0da9\u0dd3.\u0db4\u0dd3. \u0da0\u0dad\u0dd4\u0dbb\u0dd2\u0d9a\u0dcf \u0dc3\u0dbb\u0ddd\u0da2\u0db1\u0dd3",
            "label": "PERSON"
          },
          {
            "text": "\u0da2\u0dda \u0db1\u0dd2\u0dbd\u0db1\u0dca\u0dad",
            "label": "PERSON"
          },
          {
            "text": "\u0d91\u0db8\u0dca \u0db1\u0dd2\u0dc1\u0dcf\u0db1\u0dca\u0dad\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dbd\u0d9a\u0dca\u0db8\u0dcf\u0dbd\u0dca \u0dc3\u0dd6\u0dbb\u0dd2\u0dba\u0d9c\u0ddc\u0da9",
            "label": "PERSON"
          }
        ]
      ]
    },
    "ta": {
      "title": "\u0b95\u0bbe\u0bb2\u0bbf \u0bae\u0bc1\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0b9f\u0bb2\u0bbf\u0bb2\u0bcd \u0baa\u0bcb\u0bb0\u0bbe\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f 21 \u0baa\u0bc7\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0baa\u0baf\u0ba3\u0ba4\u0bcd\u0ba4\u0b9f\u0bc8 \u0bb5\u0bbf\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1",
      "author": "\u0ba4\u0bc6\u0bb0\u0bbf\u0baf\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8",
      "body_lines": [
        "\u0b95\u0bbe\u0bb2\u0bbf \u0bae\u0bc1\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0b9f\u0bb2\u0bbf\u0bb2\u0bcd \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b88\u0b9f\u0bc1\u0baa\u0b9f\u0bcd\u0b9f 21 \u0baa\u0bc7\u0bb0\u0bcd \u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bc8 \u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc7\u0bb1\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bc1 \u0ba4\u0b9f\u0bc8 \u0bb5\u0bbf\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0ba8\u0bc0\u0ba4\u0bb5\u0bbe\u0ba9\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bae\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bc1 \u0baa\u0bbf\u0bb1\u0baa\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0b9c\u0ba9\u0bbe\u0ba4\u0bbf\u0baa\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bb2\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0ba9\u0bcd \u0baa\u0bbf\u0bb0\u0ba4\u0bbe\u0ba9 \u0ba8\u0bc1\u0bb4\u0bc8\u0bb5\u0bbe\u0baf\u0bbf\u0bb2\u0bcd\u0b95\u0bb3\u0bc8 \u0bae\u0bb1\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1 \u0baa\u0bca\u0ba4\u0bc1\u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1 \u0b87\u0b9f\u0bc8\u0baf\u0bc2\u0bb1\u0bc1 \u0bb5\u0bbf\u0bb3\u0bc8\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4 \u0b95\u0bc1\u0bb1\u0bcd\u0bb1\u0b9a\u0bcd\u0b9a\u0bbe\u0b9f\u0bcd\u0b9f\u0bbf\u0ba9\u0bcd \u0baa\u0bc7\u0bb0\u0bbf\u0bb2\u0bcd \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0b95\u0bcd\u0b95\u0bbe\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bc0\u0ba4\u0bc1 \u0bb5\u0bbf\u0b9a\u0bbe\u0bb0\u0ba3\u0bc8 \u0ba8\u0b9f\u0ba4\u0bcd\u0ba4\u0bc1\u0bae\u0bbe\u0bb1\u0bc1 \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bbe\u0bb0\u0bbe\u0bb2\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b95\u0bcb\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bae\u0bc8\u0baf \u0b95\u0bca\u0bb4\u0bc1\u0bae\u0bcd\u0baa\u0bc1 \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0ba8\u0bc0\u0ba4\u0bb5\u0bbe\u0ba9\u0bcd \u0ba4\u0bbf\u0bb2\u0bbf\u0ba9 \u0b95\u0bae\u0b95\u0bc7 \u0b87\u0ba8\u0bcd\u0ba4 \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bc8 \u0baa\u0bbf\u0bb1\u0baa\u0bcd\u0baa\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd.",
        "\u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0b95\u0bcd\u0b95\u0bbe\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bc8 \u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc7\u0bb1\u0bc1\u0bb5\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0ba9 \u0b9a\u0bbe\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0b95\u0bcd\u0b95\u0bc2\u0bb1\u0bc1\u0b95\u0bb3\u0bcd \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbf\u0bb2\u0bcd \u0baa\u0bc1\u0bb2\u0ba9\u0bbe\u0baf\u0bcd\u0bb5\u0bc1 \u0b85\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0b95\u0bb3\u0bcd \u0b95\u0bbf\u0b9f\u0bc8\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0b95 \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0baa\u0bca\u0bb2\u0bbf\u0bb8\u0bbe\u0bb0\u0bcd \u0ba8\u0bc0\u0ba4\u0bbf\u0bae\u0ba9\u0bcd\u0bb1\u0bbf\u0bb2\u0bcd \u0b85\u0bb1\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd. \u0b86\u0bb0\u0bcd\u0baa\u0bcd\u0baa\u0bbe\u0b9f\u0bcd\u0b9f\u0b95\u0bcd\u0b95\u0bbe\u0bb0\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0b9f\u0bcd\u0b9f\u0bc1\u0ba8\u0bbe\u0baf\u0b95\u0bcd\u0b95 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0ba4\u0bcd\u0ba4\u0bb3 \u0bb5\u0bbf\u0bae\u0bbe\u0ba9 \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0bb4\u0bbf\u0baf\u0bbe\u0b95 \u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bc8 \u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc7\u0bb1\u0bc1\u0bb5\u0ba4\u0bc8\u0ba4\u0bcd \u0ba4\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b89\u0ba4\u0bcd\u0ba4\u0bb0\u0bb5\u0bc8 \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b95\u0bcb\u0bb0\u0bbf\u0ba9\u0bb0\u0bcd.",
        "\u0b87\u0ba4\u0ba9\u0bcd\u0baa\u0b9f\u0bbf, \u0b95\u0bcb\u0b9f\u0bcd\u0b9f\u0bc8 \u0ba8\u0bc0\u0ba4\u0bb5\u0bbe\u0ba9\u0bcd \u0bb5\u0ba3\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb1\u0bcd\u0b95\u0bc1 \u0baa\u0baf\u0ba3\u0ba4\u0bcd \u0ba4\u0b9f\u0bc8 \u0bb5\u0bbf\u0ba4\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd. \u0bb5\u0bbf\u0b95\u0bca\u0b9f \u0bb5\u0ba4\u0bcd\u0ba4\u0bc7 \u0b95\u0bbe\u0bb7\u0bcd\u0baf\u0baa \u0ba4\u0bc7\u0bb0\u0bb0\u0bcd, \u0b8e\u0bae\u0bcd.\u0b9c\u0bbf. \u0ba4\u0bbf\u0b9a\u0bb0 \u0b85\u0ba9\u0bc1\u0bb0\u0bbe\u0ba4\u0bbe, \u0b8e\u0bb2\u0bcd.\u0b8e\u0ba9\u0bcd.\u0b9f\u0bbf. \u0baa\u0bc6\u0bb0\u0bc7\u0bb0\u0bbe, \u0baa\u0bbf.\u0baa\u0bbf.\u0b8e\u0bae\u0bcd. \u0bb0\u0bae\u0bc7\u0bb7\u0bcd \u0b87\u0ba8\u0bcd\u0ba4\u0bbf\u0b95\u0bcd\u0b95, \u0b86\u0bb0\u0bcd.\u0b8f. \u0bb0\u0bbe\u0b9c\u0baa\u0b95\u0bcd\u0b9a\u0bc7, \u0b8f.\u0b8f. \u0b9a\u0bbf\u0bb1\u0bbf\u0bb2\u0bcd \u0bae\u0ba9\u0ba4\u0bc1\u0b99\u0bcd\u0b95, \u0b9f\u0baa\u0bbf\u0bb3\u0bcd\u0baf\u0bc2.\u0baa\u0bbf. \u0b87\u0b9a\u0bc1\u0bb0\u0bc1 \u0bb5\u0bb0\u0bcd\u0ba3\u0b95\u0bc1\u0bb2, \u0bb0\u0bca\u0bb7\u0bbe\u0ba9\u0bcd \u0b85\u0bb2\u0bbf \u0b9f\u0bbe\u0ba9\u0bbf\u0bb8\u0bcd \u0b85\u0bb2\u0bbf, \u0b9f\u0bbf.\u0b9a\u0bbf. \u0b9a\u0ba3\u0bcd\u0b9f\u0bbf\u0bae\u0bbe\u0bb2\u0bcd \u0b95\u0bae\u0b95\u0bc7, \u0b9f\u0bbf.\u0b86\u0bb0\u0bcd.\u0b8e\u0bb8\u0bcd. \u0baa\u0bc6\u0ba8\u0bcd\u0ba4\u0bb0 \u0b86\u0bb0\u0bbe\u0b9a\u0bcd\u0b9a\u0bbf, \u0b8e\u0ba9\u0bcd.\u0b8e\u0bae\u0bcd.\u0ba4\u0bcc\u0baa\u0bc0\u0b95\u0bcd, \u0b8e\u0bae\u0bcd.\u0b95\u0bbe\u0b9a\u0bbf\u0bae\u0bcd, \u0ba8\u0bbf\u0bb2\u0ba8\u0bcd\u0ba4 \u0b9a\u0bae\u0bbf\u0ba4\u0bcd \u0baa\u0bc6\u0bb0\u0bcd\u0ba9\u0bbe\u0ba3\u0bcd\u0b9f\u0bcb, \u0b95\u0bcb\u0bb0\u0bb2\u0b95\u0bc7 \u0baa\u0ba8\u0bcd\u0ba4\u0bc1\u0bb2 \u0baa\u0bbf\u0bb0\u0baa\u0bbe\u0ba4\u0bcd, \u0b8e\u0b9a\u0bcd.\u0b8e\u0bae\u0bcd.\u0b9f\u0bbf.\u0b9c\u0bbf. \u0bae\u0bc6\u0ba9\u0bbf\u0b95\u0bbe, \u0b9a\u0bae\u0bc0\u0bb0 \u0bae\u0ba4\u0bc1\u0bb7\u0b99\u0bcd\u0b95 \u0b9a\u0bbf\u0bb1\u0bbf\u0bb5\u0bb0\u0bcd\u0ba4\u0ba9, \u0b9a\u0bc1\u0ba4\u0ba4\u0bcd \u0bb2\u0b95\u0bcd\u0bb7\u0bcd\u0bae\u0ba9\u0bcd, \u0b8e\u0bae\u0bcd.\u0b86\u0bb0\u0bcd.\u0b9a\u0bbe\u0bb0\u0bc1\u0b95, \u0b9f\u0bbf.\u0baa\u0bbf. \u0b9a\u0ba4\u0bc1\u0bb0\u0bbf\u0b95\u0bbe \u0b9a\u0bb0\u0bcb\u0b9c\u0ba9\u0bbf, \u0b9c\u0bc7.\u0ba8\u0bbf\u0bb2\u0ba8\u0bcd\u0ba4 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b8e\u0bae\u0bcd.\u0ba8\u0bbf\u0bb7\u0bbe\u0ba8\u0bcd\u0ba4\u0bbf. (\u0bb2\u0b95\u0bcd\u0bae\u0bbe\u0bb2\u0bcd \u0b9a\u0bc2\u0bb0\u0bbf\u0baf\u0b95\u0bca\u0b9f)"
      ],
