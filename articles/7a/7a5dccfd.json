          {
            "text": "\u0d85\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dda\u0daf\u0dd4\u0dbb\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2",
            "label": "PERSON"
          },
          {
            "text": "\u0dc0\u0dd9\u0dbd\u0dca\u0dbd \u0dc0\u0dbb\u0dca\u0dc3\u0dd2 \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba",
            "label": "ORG"
          },
          {
            "text": "\u0d9a\u0dc5\u0dd4\u0dad\u0db1\u0dca\u0dad\u0dca\u200d\u0dbb\u0dd2\u0d9c\u0dda \u0d8b\u0daf\u0dda\u0db1\u0dd2 \u0da2\u0dba\u0dbb\u0dad\u0dca\u0db1",
            "label": "PERSON"
          },
          {
