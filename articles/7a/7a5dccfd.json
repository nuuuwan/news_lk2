          },
          {
            "text": "29 \u0dc0\u0dd0\u0db1\u0dd2",
            "label": "DATE"
          }
        ],
        [
          {
            "text": "\u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 \u0db4\u0db1\u0dc3\u0dca \u0dc4\u0dad\u0dbb\u0dba\u0dd2",
            "label": "DATE"
          },
          {
            "text": "\u0db8\u0dcf\u0dbd\u0db9\u0dda",
            "label": "GPE"
          }
        ],
        [
          {
            "text": "\u0d85\u0da2\u0dd2\u0dad\u0dca \u0db4\u0dda\u0daf\u0dd4\u0dbb\u0d86\u0dbb\u0da0\u0dca\u0da0\u0dd2",
