            "label": "ORG"
          },
          {
            "text": "\u0db1\u0dbd\u0dca\u0dbd\u0dd4\u0dbb\u0dca",
            "label": "LOC"
          }
        ],
        [
          {
            "text": "\u0dc0\u0dd2\u0d9c\u0dca\u0db1\u0dda\u0dc2\u0dca\u0dc0\u0dbb\u0db1\u0dca",
            "label": "GPE"
          },
          {
            "text": "\u0dbb\u0db1\u0dd2\u0dbd\u0dca \u0dc0\u0dd2\u0d9a\u0dca\u200d\u0dbb\u0db8\u0dc3\u0dd2\u0d82\u0dc4",
