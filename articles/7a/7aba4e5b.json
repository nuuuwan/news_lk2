    "si": {
      "title": "\u0d91\u0db1\u0dca\u0da2\u0dd2\u0db1\u0dca \u0dbb\u0dd2\u0dba\u0dd0\u0daf\u0dd4\u0dbb\u0ddd \u0d9a\u0ddc\u0da7\u0dc3\u0d9a\u0dd4\u0dad\u0dca \u0dc0\u0dd0\u0da9\u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0dd9\u0dad\u0dd2",
      "author": "unknown",
      "body_lines": [
        "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db0\u0dcf\u0dc0\u0db1\u0dcf\u0d9c\u0dcf\u0dbb \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0dc3\u0dc4 \u0db1\u0dd2\u0dba\u0dcf\u0db8\u0d9a\u0dba\u0db1\u0dca \u0d9a\u0dca\u200d\u0dbb\u0dd2\u0dba\u0dcf\u0dad\u0dca\u0db8\u0d9a \u0d9a\u0dbb\u0db1 \u0dc0\u0dd0\u0da9\u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0da7 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d91\u0db1\u0dca\u0da2\u0dd2\u0db1\u0dca \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0d9a\u0ddc\u0da7\u0dc3\u0d9a\u0dca \u0d85\u0daf (5) \u0db8\u0db0\u0dca\u200d\u0dba\u0db8 \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3\u0dba\u0dda \u0dc3\u0dd2\u0da7 \u0d91\u0d9a\u0dad\u0dd4 \u0dc0\u0db1 \u0db6\u0dc0 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db1\u0d9f\u0dcf\u0dc3\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0dda \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2\u0dba\u0dda \u0d9a\u0dd0\u0db3\u0dc0\u0dd4\u0d9a\u0dbb\u0dd4 \u0d89\u0db1\u0dca\u0daf\u0dd2\u0d9a \u0daf\u0ddc\u0da9\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0db8\u0dc4\u0dad\u0dcf \u0d85\u0daf \u0dbb\u0dcf\u0dad\u0dca\u200d\u0dbb\u0dd3 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0db1\u0d9f\u0dcf\u0dc3\u0dd2\u0da7\u0dd4\u0dc0\u0dd3\u0db8\u0dda \u0dc0\u0dd8\u0dad\u0dca\u0dad\u0dd3\u0dba \u0dc3\u0db8\u0dd2\u0dad\u0dd2\u0dba\u0da7 \u0dc3\u0dc4\u0dba \u0daf\u0d9a\u0dca\u0dc0\u0db1 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0d91\u0db1\u0dca\u0da2\u0dd2\u0db1\u0dca \u0dbb\u0dd2\u0dba\u0daf\u0dd4\u0dbb\u0dd4 \u0dc3\u0d82\u0d9c\u0db8\u0dba\u0dda \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0db8\u0dd9\u0db8 \u0dc0\u0dd0\u0da9\u0dc0\u0dbb\u0dca\u0da2\u0db1\u0dba\u0da7 \u0d91\u0d9a\u0dca\u0dc0\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0d89\u0db1\u0dca\u0db0\u0db1 \u0d9c\u0dd0\u0da7\u0dbd\u0dd4\u0dc0\u0da7 \u0daf\u0dd4\u0db8\u0dca\u0dbb\u0dd2\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0daf\u0dd0\u0da9\u0dd2\u0dc0 \u0db8\u0dd4\u0dc4\u0dd4\u0dab \u0daf\u0dd3 \u0dc3\u0dd2\u0da7\u0dd2\u0db1 \u0db6\u0dc0\u0dad\u0dca \u0daf\u0ddc\u0da9\u0db1\u0dca\u0d9c\u0ddc\u0da9 \u0db8\u0dc4\u0dad\u0dcf \u0dc0\u0dd0\u0da9\u0dd2 \u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0d9a\u0dd3\u0dba."
      ],
      "title_ents": [],
