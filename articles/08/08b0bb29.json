          }
        ],
        [
          {
            "text": "\u0daf\u0dd9\u0db8\u0dc5 \u0da2\u0dcf\u0dad\u0dd2\u0d9a \u0dc3\u0db1\u0dca\u0db0\u0dcf\u0db1\u0dba",
