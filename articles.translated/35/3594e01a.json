{
  "newspaper_id": "lankadeepa-lk",
  "url": "https://www.lankadeepa.lk/news/\u0db8\u0dcf\u0dc3-\u0dc4\u0dba\u0d9a\u0da7-\u0db4\u0dc3\u0dd4-\u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd\u0da7-\u0dbd\u0dcf\u0dc6\u0dca-\u0d9c\u0dd1\u0dc3\u0dca/101-615226",
  "time_ut": 1655900045,
  "title": "\u0db8\u0dcf\u0dc3 \u0dc4\u0dba\u0d9a\u0da7 \u0db4\u0dc3\u0dd4 \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd\u0da7 \u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca",
  "body_lines": [
    "\u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db1\u0d9c\u0dbb\u0dba\u0da7\u00a0\u0db8\u0dcf\u0dc3 \u0dc4\u0dba\u0d9a\u0da7 \u0db4\u0dc3\u0dd4\u00a0 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca \u0dc0\u0dd3 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u00a0 \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dc5\u0dda\u0dba.",
    "\u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0dc0\u0dd9\u0dbb\u0dc5 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0db1\u0dba\u0dda \u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0d9c\u0dd1\u0dc3\u0dca\u00a0 \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dad\u0dbb \u0d9a\u0dd2\u0dbd\u0ddd 12.5 \u0d9c\u0dd1\u0dc3\u0dca \u0da7\u0dd0\u0d82\u0d9a\u0dd2 700 \u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0dd2\u0dbd\u0ddc 5 \u0d9c\u0dd1\u0dc3\u0dca \u0da7\u0dd0\u0d82\u0d9a\u0dd2 390 \u0d9a\u0dca \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0dc3\u0dca\u0dc0\u0dcf\u0db8\u0dd3\u0db1\u0dca \u0dc0\u0dc4\u0db1\u0dca\u0dc3\u0dda\u0dbd\u0dcf \u0d9a\u0dd2\u0dc4\u0dd2\u0db4 \u0db1\u0db8\u0d9a\u0dca\u0daf \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0daf \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db1\u0d9c\u0dbb\u0dba\u0da7 \u0dc0\u0dd0\u0da9\u0db8 \u0d9a\u0dbb \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf\u0dd0\u0d9a\u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba."
  ],
  "original_lang": "si",
  "translate": {
    "si": {
      "title": "\u0db8\u0dcf\u0dc3 \u0dc4\u0dba\u0d9a\u0da7 \u0db4\u0dc3\u0dd4 \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd\u0da7 \u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca",
      "body_lines": [
        "\u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db1\u0d9c\u0dbb\u0dba\u0da7\u00a0\u0db8\u0dcf\u0dc3 \u0dc4\u0dba\u0d9a\u0da7 \u0db4\u0dc3\u0dd4\u00a0 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd4 \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0dbd\u0dcf\u0dc6\u0dca \u0d9c\u0dd1\u0dc3\u0dca \u0dad\u0ddc\u0d9c\u0dba\u0d9a\u0dca \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca \u0dc0\u0dd3 \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8\u00a0 \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db4\u0ddc\u0dbd\u0dd2\u0dc3\u0dd2\u0dba \u0d9a\u0dc5\u0dda\u0dba.",
        "\u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0dc0\u0dd9\u0dbb\u0dc5 \u0d9a\u0dca\u200d\u0dbb\u0dd3\u0da9\u0dcf\u0d82\u0d9c\u0db1\u0dba\u0dda \u0daf\u0dd3 \u0db8\u0dd9\u0db8 \u0d9c\u0dd1\u0dc3\u0dca\u00a0 \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb\u0dca \u0dbd\u0db6\u0dcf \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0dc0\u0dd2\u0dc1\u0dcf\u0dbd \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0d9a\u0dca \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dad\u0dbb \u0d9a\u0dd2\u0dbd\u0ddd 12.5 \u0d9c\u0dd1\u0dc3\u0dca \u0da7\u0dd0\u0d82\u0d9a\u0dd2 700 \u0d9a\u0dca \u0dc3\u0dc4 \u0d9a\u0dd2\u0dbd\u0ddc 5 \u0d9c\u0dd1\u0dc3\u0dca \u0da7\u0dd0\u0d82\u0d9a\u0dd2 390 \u0d9a\u0dca \u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dc5 \u0d85\u0dad\u0dbb \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0dc0\u0dd2\u0dc4\u0dcf\u0dbb\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dc0\u0dbd \u0dc3\u0dca\u0dc0\u0dcf\u0db8\u0dd3\u0db1\u0dca \u0dc0\u0dc4\u0db1\u0dca\u0dc3\u0dda\u0dbd\u0dcf \u0d9a\u0dd2\u0dc4\u0dd2\u0db4 \u0db1\u0db8\u0d9a\u0dca\u0daf \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd2\u0dbd\u0daf\u0dd3 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0daf \u0db6\u0dda\u0dbb\u0dd4\u0dc0\u0dbd \u0db1\u0d9c\u0dbb\u0dba\u0da7 \u0dc0\u0dd0\u0da9\u0db8 \u0d9a\u0dbb \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf\u0dd0\u0d9a\u0d9c\u0dad \u0dc4\u0dd0\u0d9a\u0dd2 \u0dc0\u0dd2\u0dba."
      ]
    },
    "ta": {
      "title": "\u0b86\u0bb1\u0bc1 \u0bae\u0bbe\u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0bb1\u0b95\u0bc1 \u0baa\u0bc7\u0bb0\u0bc1\u0bb5\u0bb3\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b9a\u0bbf\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bc1 \u0bb5\u0bbe\u0baf\u0bc1",
      "body_lines": [
        "\u0baa\u0bc7\u0bb0\u0bc1\u0bb5\u0bb3\u0bc8 \u0baa\u0bca\u0bb2\u0bbf\u0b9a\u0bbe\u0bb0\u0bcd \u0ba4\u0bb2\u0bc8\u0baf\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1 \u0b86\u0bb1\u0bc1 \u0bae\u0bbe\u0ba4\u0b99\u0bcd\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0baa\u0bcd \u0baa\u0bbf\u0ba9\u0bcd\u0ba9\u0bb0\u0bcd \u0baa\u0bc6\u0bb1\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0b89\u0bb3\u0bcd\u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1 Laughfs \u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1\u0bb5\u0bc8 \u0baa\u0bc7\u0bb0\u0bc1\u0bb5\u0bb3\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bbf\u0ba8\u0bbf\u0baf\u0bcb\u0b95\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd.",
        "\u0baa\u0bc7\u0bb0\u0bc1\u0bb5\u0bb3\u0bc8 \u0b95\u0b9f\u0bb1\u0bcd\u0b95\u0bb0\u0bc8 \u0bae\u0bc8\u0ba4\u0bbe\u0ba9\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b95\u0bbe\u0bb8\u0bcd \u0b9a\u0bbf\u0bb2\u0bbf\u0ba3\u0bcd\u0b9f\u0bb0\u0bcd\u0b95\u0bb3\u0bc8 \u0b9a\u0bc7\u0b95\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0ba4\u0bb1\u0bcd\u0b95\u0bbe\u0b95 \u0baa\u0bc6\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bca\u0b95\u0bc8\u0baf\u0bbe\u0ba9 \u0bae\u0b95\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0bbf\u0bb0\u0ba3\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd, 700 12.5 \u0b95\u0bbf\u0bb2\u0bcb \u0b8e\u0bb0\u0bbf\u0bb5\u0bbe\u0baf\u0bc1 \u0ba4\u0bbe\u0b99\u0bcd\u0b95\u0bbf\u0b95\u0bb3\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd 390 \u0b95\u0bbf\u0bb2\u0bcb 5 \u0ba4\u0bbe\u0b99\u0bcd\u0b95\u0bbf\u0b95\u0bb3\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0ba9."
      ]
    },
    "en": {
      "title": "Laugh gas to Beruwala after six months",
      "body_lines": [
        "The Beruwala Police intervened and distributed a stock of domestic Laugfs gas received six months later in Beruwala.",
        "A large number of people had gathered at the Beruwala Beach Stadium to collect the gas cylinders, 700 12.5 kg gas tanks and 390 kg 5 tanks were released."
      ]
    }
  }
}