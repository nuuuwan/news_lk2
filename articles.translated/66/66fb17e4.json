  "title": "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca 6 \u0daf\u0dcf \u0dad\u0dd9\u0d9a\u0dca \u0db1\u0dd1",
  "body_lines": [
    "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0da7 \u0dbd\u0db6\u0db1 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dc3 6 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd0\u0db4\u0dba\u0dd3\u0db8\u0da7 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0 \u0d91\u0db8 \u0dc3\u0db8\u0dcf\u0d9c\u0db8\u0dda \u0d8b\u0dc3\u0dc3\u0dca \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd2\u0dba\u0dd9\u0d9a\u0dca \u2018\u0dbd\u0d82\u0d9a\u0dcf\u0daf\u0dd3\u0db4\u2019\u0dba\u0da7 \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
    "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0d86\u0db1\u0dba\u0db1\u0dba \u0d9a\u0dc5 \u0d9c\u0dd1\u0dc3\u0dca \u0db8\u0dd9\u0da7\u0dd2\u0dca\u200d\u0dbb\u0d9a\u0dca\u0da7\u0ddc\u0db1\u0dca 3,500 \u0db6\u0dd0\u0d9c\u0dd2\u0db1\u0dca \u0dc0\u0db1 \u0db1\u0dde\u0d9a\u0dcf \u0daf\u0dd9\u0d9a\u0d9a\u0dca \u0dbd\u0db6\u0db1 \u0da2\u0dd6\u0dbd\u0dd2 \u0db8\u0dc3 5 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0dc3\u0dd2\u0da7 12 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0daf\u0d9a\u0dca\u0dc0\u0dcf \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5 \u0dbd\u0dd0\u0db6\u0dd3\u0db8\u0da7 \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db6\u0dc0\u0dad\u0dca \u0d91\u0db8 \u0d9c\u0dd1\u0dc3\u0dca \u0db1\u0dde\u0d9a\u0dcf \u0db1\u0dd2\u0dba\u0db8\u0dd2\u0dad \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dbd\u0dd0\u0db6\u0dd4\u0dab \u0dc4\u0ddc\u0dad\u0dca 6 \u0dc0\u0dd0\u0db1\u0dd2 \u0db1\u0dd0\u0dc0\u0dad \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0d86\u0dbb\u0db8\u0dca\u0db7 \u0d9a\u0dc5 \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d94\u0dc4\u0dd4 \u0d9a\u0dd3\u0dba.",
    "\u0dbd\u0dd2\u0da7\u0dca\u200d\u0dbb\u0ddd \u0dc3\u0db8\u0dcf\u0d9c\u0db8 \u0dc3\u0dad\u0dd4\u0dc0 \u0d9c\u0dd1\u0dc3\u0dca \u0dad\u0ddc\u0d9c \u0db1\u0ddc\u0db8\u0dd0\u0dad\u0dd2\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd0\u0db4\u0dba\u0dd4\u0db8 \u0db8\u0dda \u0db8\u0dc3 4 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0d85\u0dad\u0dca\u0dc4\u0dd2\u0da7\u0dd4\u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0db8\u0dda \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 \u0daf\u0dd2\u0db1 22 \u0d9a\u0dca \u0d9c\u0dd8\u0dc4\u0dc3\u0dca\u0dae \u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb \u0db1\u0ddc\u0db8\u0dd0\u0dad.",
    "\u0d9c\u0dd1\u0dc3\u0dca \u0db6\u0dd9\u0daf\u0dcf\u0dc4\u0dd0\u0dbb\u0dd3\u0db8 \u0db1\u0dad\u0dbb \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd4\u0dab \u0daf \u0d91\u0db8 \u0daf\u0dd2\u0db1 22 \u0dad\u0dd4\u0dc5 \u0d9c\u0dd1\u0dc3\u0dca \u0d85\u0dc5\u0dd9\u0dc0\u0dd2\u0dc3\u0dbd\u0dca \u0d85\u0dc3\u0dc5 \u0daf\u0dd2\u0d9c\u0dd4 \u0d9c\u0dd1\u0dc3\u0dca \u0dc3\u0dd2\u0dbd\u0dd2\u0db1\u0dca\u0da9\u0dbb \u0db4\u0ddd\u0dbd\u0dd2\u0db8\u0dca \u0daf\u0dd0\u0d9a\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2\u0dba."
