  "title": "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0db4\u0d82\u0da0\u0dd2\u0d9a\u0dcf\u0dc0\u0dad\u0dca\u0dad\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0dbb \u0dc0\u0dc4\u0dba\u0dd2",
  "body_lines": [
    "\u0d89\u0db1\u0dca\u0db0\u0db1 \u0db1\u0ddc\u0dbd\u0dd0\u0db6\u0dd3\u0db8\u0da7 \u0d9a\u0ddd\u0db4\u0dba\u0da7 \u0db4\u0dad\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db4\u0d82\u0da0\u0dd2\u0d9a\u0dcf\u0dc0\u0dad\u0dca\u0dad \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dd9\u0db1\u0dca \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dc0\u0dc3\u0dcf \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dba \u0daf\u0dd0\u0d9a\u0dca\u0dc0\u0dd6\u0dc4.",
    "\u0db4\u0d82\u0daf\u0dd2\u0d9a\u0dcf\u0dc0\u0dad\u0dca\u0dad\u0dd9\u0db1\u0dca \u0db4\u0dcf\u0dbb \u0dc0\u0dc3\u0dcf \u0daf\u0dd0\u0db8\u0dd3\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0d85\u0dc0\u0da7 \u0db8\u0dcf\u0dbb\u0dca\u0d9c \u0dbb\u0dd0\u0dc3\u0d9a \u0daf\u0dd0\u0da9\u0dd2 \u0dc0\u0dcf\u0dc4\u0db1 \u0dad\u0daf\u0db6\u0daf\u0dba\u0d9a\u0dca \u0d87\u0dad\u0dd2 \u0dc0\u0dd2\u0dba."
  ],
  "original_lang": "si",
