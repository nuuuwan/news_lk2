    "si": {
      "title": "\u0dc3\u0dc4\u0dbd\u0dca \u0db8\u0dcf\u0dc6\u0dd2\u0dba\u0dcf\u0dc0 \u0db1\u0dad\u0dbb \u0d9a\u0dbb\u0db1\u0dca\u0db1",
      "body_lines": [
        "\u0dbb\u0da7 \u0dad\u0dd4\u0dc5 \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0dc3\u0dc4\u0dbd\u0dca \u0db4\u0dd2\u0da7\u0dd2 \u0db8\u0dcf\u0dc6\u0dd2\u0dba\u0dcf\u0dc0 \u0db1\u0dad\u0dbb \u0d9a\u0dd2\u0dbb\u0dd3\u0db8\u0da7 \u0db6\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0dc4\u0dbd\u0dca \u0db4\u0dd2\u0da7\u0dd2\u0dc0\u0dbd\u0da7 \u0daf \u0db4\u0dcf\u0dbd\u0db1 \u0db8\u0dd2\u0dbd\u0d9a\u0dca \u0db4\u0dd0\u0db1\u0dc0\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0dc3\u0dc4\u0dbd\u0dca \u0dc0\u0dca\u200d\u0dba\u0dcf\u0db4\u0dcf\u0dbb\u0dd2\u0d9a \u0d91\u0db8\u0dca. \u0d91\u0dc3\u0dca. \u0d91\u0db8\u0dca. \u0dc3\u0db1\u0dd6\u0dbb\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dc3\u0dd3\u0dba.",
        "\u0dad\u0dd4\u0db1\u0dca\u0dc0\u0dd0\u0db1\u0dd2 \u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dc0\u0dba\u0d9a\u0dca \u0d9c\u0ddc\u0dc0\u0dd3\u0db1\u0dca\u0d9c\u0dd9\u0db1\u0dca \u0d85\u0da9\u0dd4 \u0db8\u0dd2\u0dbd\u0da7 \u0dad\u0dd9\u0dad \u0dc0\u0dd3 \u0dbd\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0d92\u0dc0\u0dcf \u0dc3\u0dc4\u0dbd\u0dca \u0db4\u0dd2\u0da7\u0dd2 \u0db6\u0dc0\u0da7 \u0db4\u0dad\u0dca\u0d9a\u0dbb \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u0dca \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca 325 \u0dc3\u0dd2\u0da7 \u0d89\u0dc4\u0dc5 \u0db8\u0dd2\u0dbd\u0da7 \u0d85\u0dc5\u0dd9\u0dc0\u0dd2 \u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0d9a\u0dd3 \u0dc3\u0db1\u0dd6\u0dbb\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0d91\u0db8 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3 \u0dbd\u0db6\u0db1 \u0db8\u0dd2\u0dbd\u0dd2\u0dba\u0db1 \u0d9c\u0dab\u0db1\u0dd2\u0db1\u0dca \u0dc0\u0db1 \u0dbd\u0dcf\u0db7\u0dba \u0db4\u0dd2\u0dbd\u0dd2\u0db6\u0db3\u0dc0 \u0d9a\u0dd2\u0dc3\u0dd2\u0dc0\u0d9a\u0dd4 \u0d9a\u0dae\u0dcf \u0db1\u0ddc\u0d9a\u0dbb\u0db1 \u0db6\u0dc0 \u0daf \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda\u0dba."
      ],
