{
  "newspaper_id": "ada-lk",
  "url": "https://www.ada.lk/breaking_news/\u0dbb\u0da2\u0dba\u0dda-\u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca-\u0dc0\u0dd2\u0daf\u0dda\u0dc1-\u0d9c\u0dad\u0dc0\u0dd3\u0db8\u0da7-\u0d85\u0daf\u0dcf\u0dc5-\u0da0\u0d9a\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9b\u0dba-\u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca-\u0d9a\u0dbb\u0dba\u0dd2/11-394704",
  "time_ut": 1655883771,
  "title": "\u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0da0\u0d9a\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9b\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
  "body_lines": [
    "\u0da2\u0dca\u200d\u0dba\u0dd9\u0dc2\u0dca\u0da8\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dc0\u0dd0\u0da7\u0dd4\u0db4\u0da7 \u0db6\u0dbd \u0db1\u0ddc\u0db4\u0dcf\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca\u0da7 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0dba\u0dcf\u0db8\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0da0\u0d9a\u0dca\u200d\u0dbb \u0dbd\u0dda\u0d9b\u0dca\u200d\u0dba \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0dbd\u0db1 \u0dc4\u0dcf \u0dc3\u0dca\u0dc0\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1 \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
    "\u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0d92 \u0d92 \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba \u0dba\u0da7\u0dad\u0dda \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0d9c\u0dad\u0dc0\u0db1 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0db8\u0dcf\u0dc3\u0dca\u0db4\u0dad\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dca\u200d\u0dbb\u0dda\u0dc2\u0dab\u0dba \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0db1\u0dca\u0daf \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
    "\u0db8\u0dcf\u0dab\u0dca\u0da9\u0dbd\u0dd2\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad\u0dc0\u0db1\u0dc0\u0dcf\u0db1\u0db8\u0dca \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba\u0dda \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0db8\u0dcf\u0dab\u0dca\u0da9\u0dbd\u0dd2\u0d9a \u0db1\u0ddc\u0dc0\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0db4\u0dbb\u0dd2\u0dc0\u0dcf\u0dc3 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5\u0daf\u0dd3\u0daf \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d91\u0db8\u0dca.\u0d91\u0db8\u0dca.\u0db4\u0dd3.\u0d9a\u0dda. \u0db8\u0dcf\u0dba\u0dcf\u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
  ],
  "original_lang": "si",
  "translate": {
    "si": {
      "title": "\u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad\u0dc0\u0dd3\u0db8\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0da0\u0d9a\u0dca\u200d\u0dbb\u0dbd\u0dda\u0d9b\u0dba \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb\u0dba\u0dd2",
      "body_lines": [
        "\u0da2\u0dca\u200d\u0dba\u0dd9\u0dc2\u0dca\u0da8\u0dad\u0dca\u0dc0\u0dba\u0da7 \u0dc4\u0dcf \u0dc0\u0dd2\u0dc1\u0dca\u200d\u0dbb\u0dcf\u0db8\u0dc0\u0dd0\u0da7\u0dd4\u0db4\u0da7 \u0db6\u0dbd \u0db1\u0ddc\u0db4\u0dcf\u0db1 \u0db4\u0dbb\u0dd2\u0daf\u0dd2 \u0dbb\u0da2\u0dba\u0dda \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca\u0da7 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0dbb\u0dd0\u0d9a\u0dd2\u0dba\u0dcf\u0dc0\u0da7 \u0dba\u0dcf\u0db8\u0da7 \u0d85\u0daf\u0dcf\u0dc5 \u0da0\u0d9a\u0dca\u200d\u0dbb \u0dbd\u0dda\u0d9b\u0dca\u200d\u0dba \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0db4\u0dbb\u0dd2\u0db4\u0dcf\u0dbd\u0db1 \u0dc4\u0dcf \u0dc3\u0dca\u0dc0\u0daf\u0dda\u0dc1 \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1 \u0dbd\u0dda\u0d9a\u0db8\u0dca\u0dc0\u0dbb\u0dba\u0dcf \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db1\u0dd2\u0d9a\u0dd4\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dd9\u0dc4\u0dd2\u0daf\u0dd3 \u0d92 \u0d92 \u0d9a\u0dcf\u0dab\u0dca\u0da9\u0dba \u0dba\u0da7\u0dad\u0dda \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0d9c\u0dad\u0dc0\u0db1 \u0dbb\u0dcf\u0da2\u0dca\u200d\u0dba \u0dc3\u0dda\u0dc0\u0d9a\u0dba\u0db1\u0dca \u0db8\u0dcf\u0dc3\u0dca\u0db4\u0dad\u0dcf \u0dc1\u0dca\u200d\u0dbb\u0dd3 \u0dbd\u0d82\u0d9a\u0dcf\u0dc0 \u0dc0\u0dd9\u0dad \u0db4\u0dca\u200d\u0dbb\u0dda\u0dc2\u0dab\u0dba \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0da9\u0ddc\u0dbd\u0dbb\u0dca \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0dab\u0dba\u0db1\u0dca\u0daf \u0d87\u0dad\u0dd4\u0dc5\u0dad\u0dca \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0db8\u0dcf\u0dab\u0dca\u0da9\u0dbd\u0dd2\u0d9a \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad\u0dc0\u0db1\u0dc0\u0dcf\u0db1\u0db8\u0dca \u0d94\u0dc0\u0dd4\u0db1\u0dca \u0dc3\u0dda\u0dc0\u0dba\u0dda \u0dc3\u0dca\u0dae\u0dd2\u0dbb \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd2\u0dba \u0dba\u0dd4\u0dad\u0dd4 \u0db6\u0dc0\u0dad\u0dca \u0db8\u0dcf\u0dab\u0dca\u0da9\u0dbd\u0dd2\u0d9a \u0db1\u0ddc\u0dc0\u0db1 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0db1\u0dca\u0da7 \u0db4\u0dbb\u0dd2\u0dc0\u0dcf\u0dc3 \u0d9a\u0dcf\u0dbd\u0dba \u0dad\u0dd4\u0dc5\u0daf\u0dd3\u0daf \u0dc0\u0dd2\u0daf\u0dda\u0dc1 \u0d9c\u0dad \u0dc0\u0dd2\u0dba \u0dc4\u0dd0\u0d9a\u0dd2 \u0db6\u0dc0\u0dad\u0dca \u0d85\u0db8\u0dcf\u0dad\u0dca\u200d\u0dba\u0dcf\u0d82\u0dc1 \u0dbd\u0dda\u0d9a\u0db8\u0dca \u0d91\u0db8\u0dca.\u0d91\u0db8\u0dca.\u0db4\u0dd3.\u0d9a\u0dda. \u0db8\u0dcf\u0dba\u0dcf\u0daf\u0dd4\u0db1\u0dca\u0db1\u0dda \u0db8\u0dc4\u0dad\u0dcf \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd3\u0dba."
      ]
    },
    "ta": {
      "title": "\u0b85\u0bb0\u0b9a \u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bc7\u0bb1\u0bc1\u0bb5\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbe\u0b95 \u0b9a\u0bc1\u0bb1\u0bcd\u0bb1\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0bc8 \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bbf\u0b9f\u0bb5\u0bc1\u0bae\u0bcd",
      "body_lines": [
        "\u0b85\u0bb0\u0b9a \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bcb\u0b95\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0baa\u0ba3\u0bbf\u0bae\u0bc2\u0baa\u0bcd\u0baa\u0bc1 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b93\u0baf\u0bcd\u0bb5\u0bc2\u0ba4\u0bbf\u0baf\u0bae\u0bcd \u0baa\u0bbe\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bbe\u0ba4 \u0bb5\u0b95\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bbf\u0bb2\u0bcd \u0baa\u0ba3\u0bbf\u0baf\u0bae\u0bb0\u0bcd\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0ba4\u0bc1 \u0ba4\u0bca\u0b9f\u0bb0\u0bcd\u0baa\u0bbe\u0ba9 \u0b9a\u0bc1\u0bb1\u0bcd\u0bb1\u0bb1\u0bbf\u0b95\u0bcd\u0b95\u0bc8\u0baf\u0bc8 \u0baa\u0bca\u0ba4\u0bc1\u0ba8\u0bbf\u0bb0\u0bcd\u0bb5\u0bbe\u0b95 \u0b89\u0bb3\u0bcd\u0ba8\u0bbe\u0b9f\u0bcd\u0b9f\u0bb2\u0bc1\u0bb5\u0bb2\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b9a\u0bc6\u0baf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0baf\u0bbf\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0bbe\u0bb0\u0bcd.",
        "\u0b92\u0bb5\u0bcd\u0bb5\u0bca\u0bb0\u0bc1 \u0baa\u0bbf\u0bb0\u0bbf\u0bb5\u0bbf\u0ba9\u0bcd \u0b95\u0bc0\u0bb4\u0bc1\u0bae\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1\u0b95\u0bb3\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0b9a\u0bcd \u0b9a\u0bc6\u0bb2\u0bcd\u0bb2\u0bc1\u0bae\u0bcd \u0b85\u0bb0\u0b9a \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bcb\u0b95\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bae\u0bbe\u0ba4\u0bbe\u0ba8\u0bcd\u0ba4\u0bae\u0bcd \u0b87\u0bb2\u0b99\u0bcd\u0b95\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0ba9\u0bc1\u0baa\u0bcd\u0baa \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bbf\u0baf \u0b9f\u0bca\u0bb2\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0b89\u0bb3\u0bcd\u0bb3\u0b9f\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9.",
        "\u0b8a\u0bb4\u0bbf\u0baf\u0bb0\u0bcd \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bcb\u0b95\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0bb2\u0bcd\u0bb5\u0ba4\u0bbe\u0baf\u0bbf\u0ba9\u0bcd \u0b85\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0bc7\u0bb5\u0bc8\u0baf\u0bbf\u0bb2\u0bcd \u0b89\u0bb1\u0bc1\u0ba4\u0bbf \u0b9a\u0bc6\u0baf\u0bcd\u0baf\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0b95\u0bcd\u0b95 \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bc1\u0bae\u0bcd \u0b8e\u0ba9\u0bb5\u0bc1\u0bae\u0bcd, \u0baa\u0ba3\u0bbf\u0baf\u0bbe\u0b9f\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0bb2\u0bcd\u0bb2\u0bbe\u0ba4 \u0b89\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bcb\u0b95\u0ba4\u0bcd\u0ba4\u0bb0\u0bcd\u0b95\u0bb3\u0bc1\u0bae\u0bcd \u0ba8\u0ba9\u0bcd\u0ba9\u0b9f\u0ba4\u0bcd\u0ba4\u0bc8 \u0b95\u0bbe\u0bb2\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0bb5\u0bc6\u0bb3\u0bbf\u0ba8\u0bbe\u0b9f\u0bc1 \u0b9a\u0bc6\u0bb2\u0bcd\u0bb2 \u0bae\u0bc1\u0b9f\u0bbf\u0baf\u0bc1\u0bae\u0bcd \u0b8e\u0ba9\u0bb5\u0bc1\u0bae\u0bcd \u0b85\u0bae\u0bc8\u0b9a\u0bcd\u0b9a\u0bbf\u0ba9\u0bcd \u0b9a\u0bc6\u0baf\u0bb2\u0bbe\u0bb3\u0bb0\u0bcd \u0b8e\u0bae\u0bcd.\u0b8e\u0bae\u0bcd.\u0baa\u0bbf.\u0b95\u0bc7 \u0b9c\u0baf\u0b9a\u0bbf\u0b99\u0bcd\u0b95 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd. \u0bae\u0bbe\u0baf\u0bbe\u0ba4\u0bc1\u0ba9\u0bcd\u0ba9\u0bc7 \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bbe\u0bb0\u0bcd."
      ]
    },
    "en": {
      "title": "Issue circular regarding the departure of public servants",
      "body_lines": [
        "The Secretary to the Ministry of Public Administration and Home Affairs has issued a circular regarding the employment of public servants abroad without affecting their seniority and pension.",
        "The dollars to be remitted to Sri Lanka on a monthly basis by public servants going abroad under each category are also included.",
        "Secretary to the Ministry MMPK Jayasinghe said that if the staff officers go abroad, they should have been confirmed in the service and non-staff officers could also go abroad during the probation period. Mr. Mayadunne said."
      ]
    }
  }
}