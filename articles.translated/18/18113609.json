  "title": "''#GOTAGOHOME'' ; \u0d9a\u0ddc\u0dc4\u0dd4\u0dc0\u0dbd\u0daf\u0dd3 \u0d87\u0dc3\u0dd4\u0dab\u0dd4 '\u0d9a\u0dd4\u0dc3\u0dca\u0dc3\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0dbd\u0dcf\u0db4\u0dba'",
  "body_lines": [
    "\u0dbb\u0da7\u0dda \u0db4\u0dc0\u0dad\u0dd2\u0db1 \u0d86\u0dbb\u0dca\u0dae\u0dd2\u0d9a \u0d85\u0dbb\u0dca\u0db6\u0dd4\u0daf\u0dba\u0da7 \u0dc0\u0dd2\u0dc3\u0db3\u0dd4\u0db8\u0dca \u0dbd\u0db6\u0dcf \u0daf\u0dd9\u0db1 \u0dbd\u0dd9\u0dc3 \u0d89\u0dbd\u0dca\u0dbd\u0dcf '\u0d9a\u0dd4\u0dc3\u0dca\u0dc3\u0dd2\u0dba\u0dda \u0dc0\u0dd2\u0dbd\u0dcf\u0db4\u0dba' \u0dbd\u0dd9\u0dc3 \u0db1\u0db8\u0dca \u0d9a\u0dc5 \u0db8\u0dda \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba \u0d9a\u0ddc\u0dc5\u0db9, \u0d9a\u0ddc\u0dc4\u0dd4\u0dc0\u0dbd\u0daf\u0dd3 \u0db4\u0dd0\u0dc0\u0dd0\u0dad\u0dca\u0dc0\u0dd4\u0dab\u0dcf.",
    "\u0da2\u0dd4\u0db1\u0dd2 11 \u0dc0\u0dd0\u0db1\u0dd2\u0daf\u0dcf \u0db4\u0dd0\u0dc0\u0dad\u0dd2 \u0d91\u0db8 \u0dc0\u0dd2\u0dbb\u0ddd\u0db0\u0dad\u0dcf\u0dc0\u0dba\u0da7 \u0db8\u0dd4\u0dc5\u0dd4\u0dad\u0dd0\u0db1\u0dca\u0d9c\u0dd9\u0dba\u0dd2 \u0d8b\u0db4\u0d9a\u0dbb\u0dab \u0daf \u0dbb\u0dd0\u0d9c\u0dd9\u0db1 \u0da2\u0db1\u0dad\u0dcf\u0dc0 \u0db4\u0dd0\u0db8\u0dd2\u0dab \u0dc3\u0dd2\u0da7\u0dd2 \u0d85\u0dba\u0dd4\u0dbb\u0dd4 \u0daf\u0d9a\u0dca\u0db1\u0da7 \u0dbd\u0dd0\u0db6\u0dd4\u0dab\u0dd2."
  ],
