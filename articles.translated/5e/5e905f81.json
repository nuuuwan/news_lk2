  "title": "\u0db4\u0dbb\u0dd2\u0dc3\u0dbb\u0dba ; \u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd '\u0dc0\u0dca\u200d\u0dba\u0dcf\u0d9d\u0dca\u200d\u0dbb \u0db6\u0db6\u0dcf\u0dbd\u0dcf\u0d9c\u0dda' \u0daf\u0dc0\u0dc3 \u0d9c\u0dd9\u0dc0\u0dd9\u0db1 \u0d85\u0dba\u0dd4\u0dbb\u0dd4",
  "body_lines": [
    "\u0daf\u0dd9\u0dc4\u0dd2\u0dc0\u0dbd \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u0ddd\u0daf\u0dca\u200d\u0dba\u0dcf\u0db1\u0dba\u0dda \u0d8b\u0db4\u0dad \u0dbd\u0daf \u0db6\u0dd9\u0d82\u0d9c\u0dcf\u0dbd\u0dd2 \u0dc0\u0dca\u200d\u0dba\u0dcf\u0d9d\u0dca\u200d\u0dbb \u0db4\u0dd0\u0da7\u0dc0\u0dd4\u0db1\u0dca \u0dad\u0dd2\u0daf\u0dd9\u0db1\u0dcf \u0dc4\u0ddc\u0db3 \u0dc3\u0dde\u0d9b\u0dca\u200d\u0dba \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4\u0dc0\u0dd9\u0db1 \u0db6\u0dc0 \u0db4\u0dc1\u0dd4 \u0dc0\u0ddb\u0daf\u0dca\u200d\u0dba\u0dc0\u0dbb\u0dd4 \u0db4\u0dc0\u0dc3\u0dad\u0dd2.",
    "\u0d91\u0db8 \u0dc3\u0dad\u0dd4\u0db1\u0dca \u0db8\u0dc4\u0da2\u0db1 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dbb\u0dca\u0dc1\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0dcf \u0d91\u0d9a\u0dca\u0d9a\u0dbb \u0d85\u0dad\u0dd4 \u0d85\u0dad\u0dbb \u0db1\u0db8\u0dca \u0dad\u0dd0\u0db6\u0dd3\u0db8 \u0dc3\u0db3\u0dc4\u0dcf \u0db8\u0dd9\u0dbb\u0da7 \u0db4\u0dcf\u0dc3\u0dbd\u0dca \u0dc3\u0dd2\u0dc3\u0dd4\u0db1\u0dca\u0da7 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0dc0 \u0dbd\u0db6\u0dcf \u0daf\u0dd3 \u0d87\u0dad."
