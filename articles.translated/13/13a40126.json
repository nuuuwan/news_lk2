    "si": {
      "title": "\u0dc3\u0dd9\u0db1\u0dca\u0dad\u0dd2\u0dbd\u0dca \u0dad\u0ddc\u0dab\u0dca\u0da9\u0db8\u0db1\u0dca\u0d9c\u0dda \u0db8\u0dd0\u0daf\u0dd2\u0dc4\u0dad\u0dca\u0dc0\u0dd3\u0db8\u0dd9\u0db1\u0dca \u0da7\u0dd9\u0db8\u0dda\u0dbb\u0dd2\u0dba\u0dcf \u0dc0\u0dad\u0dca\u0dad\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0dc0\u0dd2\u0dc3\u0db3\u0dd4\u0db8\u0d9a\u0dca!- \u0d91\u0d9a\u0dad\u0dd4 \u0d9a\u0dc5 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8",
      "body_lines": [
        "\u0dc3\u0dd3\u0da9\u0db6\u0dca\u0dbd\u0dd2\u0dc0\u0dca\u0dc3\u0dd3 \u0db1\u0dcf\u0dba\u0d9a \u0dc3\u0dd9\u0db1\u0dca\u0dad\u0dd2\u0dbd\u0dca \u0dad\u0ddc\u0db1\u0dca\u0da9\u0db1\u0dca \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd3 \u0d87\u0dad\u0dca\u0dad\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0d9c\u0dd9\u0db1\u0dca \u0dbb\u0dd4.",
        "\u0dc3\u0dd9\u0db1\u0dca\u0dad\u0dd2\u0dbd\u0dca \u0dad\u0ddc\u0dab\u0dca\u0da9\u0db8\u0db1\u0dca \u0db8\u0dc4\u0dad\u0dcf \u0d91\u0db8 \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba\u0dda \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dcf\u0dbb \u0d85\u0db0\u0dca\u200d\u0dba\u0d9a\u0dca\u0dc2\u0dc0\u0dbb\u0dba\u0dcf \u0d85\u0db8\u0dad\u0dcf \u0d91\u0d9a\u0dad\u0dd4 \u0dc0\u0dd6 \u0db8\u0dd4\u0daf\u0dbd\u0dca \u0dc0\u0dad\u0dd4\u0dba\u0dcf\u0dba\u0dda \u0da2\u0db1\u0dad\u0dcf\u0dc0\u0da7 \u0d86\u0db4\u0dc3\u0dd4 \u0dbd\u0db6\u0dcf\u0daf\u0dd3\u0db8\u0da7 \u0dc0\u0dc4\u0dcf \u0d9a\u0da7\u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2\u0dad\u0dca\u0dc0\u0dba\u0d9a\u0dd2."
      ],
      "title_ents": [
        {
