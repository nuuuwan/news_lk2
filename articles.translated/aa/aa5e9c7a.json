  "newspaper_id": "lankadeepa-lk",
  "url": "https://www.lankadeepa.lk/latest_news/\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0dda-\u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd-\u0db7\u0dd6-\u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a\u0dca/1-615230",
  "time_ut": 1655907981,
  "title": "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a\u0dca",
  "body_lines": [
    "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0da7 \u0d85\u0daf (22) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db6\u0dbd\u0db4\u0dd1 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d9c\u0dab\u0db1 1,000\u0d9a \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dcf \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d91\u0dbb\u0da7 \u0d86\u0db4\u0daf\u0dcf \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd6\u0dc4.",
    "\u0db7\u0dd6\u0db8\u0dca\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0d87\u0dad\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0dca 600\u0d9a\u0dca \u0dba\u0dd0\u0dba\u0dd2 \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0d9c\u0dab\u0db1\u0dca \u0db6\u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0dd0\u0db6\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4 \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d85\u0dba\u0d9c\u0dda \u0d9c\u0dab\u0db1 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dc4\u0dd4 \u0db6\u0dd2\u0dba \u0db4\u0dc5 \u0d9a\u0dc5\u0dc4.",
    "\u0d9c\u0dd2\u0db1\u0dd2\u0d9a\u0ddc\u0db1 \u0daf\u0dd2\u0d9c \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0da7 \u0db6\u0dbd\u0db4\u0dd1 \u0d87\u0dad\u0dd2 \u0db8\u0dd9\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd\u0dad\u0dca\u0dc0\u0dba \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dcf\u0d82\u0d9a 5.9\u0d9a\u0dca \u0dba\u0dd0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
    "\u0d9a\u0db3\u0dd4\u0d9a\u0dbb \u0dc3\u0dc4 \u0daf\u0dd4\u0dc2\u0dca\u0d9a\u0dbb \u0d9c\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dc0\u0dbd\u0da7 \u0db8\u0dd9\u0dba\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0d9a\u0dca \u0d91\u0dbd\u0dca\u0dbd \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0db8 \u0daf \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0dd3 \u0d87\u0dad.",
    "\u0db8\u0dd9\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 2002 \u0dc0\u0dc3\u0dbb\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0da7 \u0db6\u0dbd\u0db4\u0dd1 \u0daf\u0dbb\u0dd4\u0dab\u0dd4\u0dad\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0db6\u0dc0 \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0daf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
    "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0dda \u0d9c\u0dd2\u0db1\u0dd2\u0d9a\u0ddc\u0db1 \u0daf\u0dd2\u0d9c \u0db1\u0d9c\u0dbb\u0dba\u0d9a\u0dca \u0dc0\u0db1 \u0d9a\u0ddd\u0dc3\u0dca\u0da7\u0dca \u0dc4\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb 44\u0d9a\u0dca \u0d88\u0dad\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0d9a\u0daf\u0dd3 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dc4\u0da7\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda. \u0d91\u0dba \u0db4\u0dcf\u0d9a\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0daf\u0dda\u0dc1\u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0dba\u0dd0\u0dba\u0dd2 \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db7\u0dd6\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc3\u0db8\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0d86\u0dba\u0dad\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda \u0dba.",
    "\u0dba\u0dd4\u0dbb\u0ddd\u0db4\u0dd3\u0dba - \u0db8\u0db0\u0dca\u200d\u0dba\u0db0\u0dbb\u0dab\u0dd3 \u0db7\u0dd6\u0d9a\u0db8\u0dca\u0db4\u0db1 \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd\u0dad\u0dca\u0dc0\u0dba \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dcf\u0d82\u0d9a 6.9\u0d9a\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0db7\u0dd6\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc3\u0db8\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0d91\u0dc4\u0dd2 \u0d9c\u0dab\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dcf\u0d82\u0d9a 5.9\u0d9a\u0dd2."
  ],
  "original_lang": "si",
  "translate": {
    "si": {
      "title": "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd \u0db7\u0dd6 \u0d9a\u0db8\u0dca\u0db4\u0db1\u0dba\u0d9a\u0dca",
      "body_lines": [
        "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0da7 \u0d85\u0daf (22) \u0db4\u0dc3\u0dca\u0dc0\u0dbb\u0dd4\u0dc0\u0dda \u0db6\u0dbd\u0db4\u0dd1 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d9c\u0dab\u0db1 1,000\u0d9a \u0d89\u0d9a\u0dca\u0db8\u0dc0\u0dcf \u0d9c\u0ddc\u0dc3\u0dca \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d91\u0dbb\u0da7 \u0d86\u0db4\u0daf\u0dcf \u0d9a\u0dc5\u0db8\u0db1\u0dcf\u0d9a\u0dbb\u0dab \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dc4\u0dd4 \u0db4\u0dd0\u0dc0\u0dd0\u0dc3\u0dd6\u0dc4.",
        "\u0db7\u0dd6\u0db8\u0dca\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dd9\u0db1\u0dca \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0db6\u0dcf \u0d87\u0dad\u0dd2 \u0db4\u0dd2\u0dbb\u0dd2\u0dc3\u0dca 600\u0d9a\u0dca \u0dba\u0dd0\u0dba\u0dd2 \u0db8\u0dda \u0dc0\u0db1\u0dc0\u0dd2\u0da7 \u0d9c\u0dab\u0db1\u0dca \u0db6\u0dbd\u0dcf \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0dad\u0dd4\u0dc0\u0dcf\u0dbd \u0dbd\u0dd0\u0db6\u0dd4\u0dc0\u0db1\u0dca\u0d9c\u0dda \u0dc3\u0dc4 \u0db8\u0dd2\u0dba\u0d9c\u0dd2\u0dba \u0d85\u0dba\u0d9c\u0dda \u0d9c\u0dab\u0db1 \u0dad\u0dc0\u0daf\u0dd4\u0dbb\u0da7\u0dad\u0dca \u0dc0\u0dd0\u0da9\u0dd2 \u0dc0\u0db1\u0dd4 \u0d87\u0dad\u0dd0\u0dba\u0dd2 \u0d91\u0db8 \u0db1\u0dd2\u0dbd\u0db0\u0dcf\u0dbb\u0dd3\u0dc4\u0dd4 \u0db6\u0dd2\u0dba \u0db4\u0dc5 \u0d9a\u0dc5\u0dc4.",
        "\u0d9c\u0dd2\u0db1\u0dd2\u0d9a\u0ddc\u0db1 \u0daf\u0dd2\u0d9c \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0da7 \u0db6\u0dbd\u0db4\u0dd1 \u0d87\u0dad\u0dd2 \u0db8\u0dd9\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd\u0dad\u0dca\u0dc0\u0dba \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dcf\u0d82\u0d9a 5.9\u0d9a\u0dca \u0dba\u0dd0\u0dba\u0dd2 \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0dc0\u0dda.",
        "\u0d9a\u0db3\u0dd4\u0d9a\u0dbb \u0dc3\u0dc4 \u0daf\u0dd4\u0dc2\u0dca\u0d9a\u0dbb \u0d9c\u0db8\u0dca\u0db8\u0dcf\u0db1\u0dc0\u0dbd\u0da7 \u0db8\u0dd9\u0dba\u0dd2\u0db1\u0dca \u0dc0\u0dd0\u0da9\u0dd2\u0db8 \u0db6\u0dbd\u0db4\u0dd1\u0db8\u0d9a\u0dca \u0d91\u0dbd\u0dca\u0dbd \u0dc0\u0dd3 \u0dad\u0dd2\u0db6\u0dd9\u0db1 \u0d85\u0dad\u0dbb \u0d91\u0db8 \u0db1\u0dd2\u0dc3\u0dcf \u0dad\u0ddc\u0dbb\u0dad\u0dd4\u0dbb\u0dd4 \u0dbd\u0dd0\u0db6\u0dd3\u0db8 \u0daf \u0db4\u0dca\u200d\u0dbb\u0db8\u0dcf\u0daf \u0dc0\u0dd3 \u0d87\u0dad.",
        "\u0db8\u0dd9\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 2002 \u0dc0\u0dc3\u0dbb\u0dd9\u0db1\u0dca \u0db4\u0dc3\u0dd4 \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0da7 \u0db6\u0dbd\u0db4\u0dd1 \u0daf\u0dbb\u0dd4\u0dab\u0dd4\u0dad\u0db8 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0db6\u0dc0 \u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0db8\u0dd9\u0db1\u0dca\u0db8 \u0dc0\u0dd2\u0daf\u0dd9\u0dc3\u0dca \u0db8\u0dcf\u0db0\u0dca\u200d\u0dba \u0daf \u0dc0\u0dcf\u0dbb\u0dca\u0dad\u0dcf \u0d9a\u0dbb \u0dad\u0dd2\u0db6\u0dda.",
        "\u0d87\u0dc6\u0dca\u0d9c\u0db1\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1\u0dba\u0dda \u0d9c\u0dd2\u0db1\u0dd2\u0d9a\u0ddc\u0db1 \u0daf\u0dd2\u0d9c \u0db1\u0d9c\u0dbb\u0dba\u0d9a\u0dca \u0dc0\u0db1 \u0d9a\u0ddd\u0dc3\u0dca\u0da7\u0dca \u0dc4\u0dd2 \u0d9a\u0dd2\u0dbd\u0ddd\u0db8\u0dd3\u0da7\u0dbb 44\u0d9a\u0dca \u0d88\u0dad\u0dd2\u0db1\u0dca \u0db4\u0dd2\u0dc4\u0dd2\u0da7\u0dd2 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0d9a\u0daf\u0dd3 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0 \u0dc4\u0da7\u0d9c\u0dd9\u0db1 \u0dad\u0dd2\u0db6\u0dda. \u0d91\u0dba \u0db4\u0dcf\u0d9a\u0dd2\u0dc3\u0dca\u0dad\u0dcf\u0db1 \u0daf\u0dda\u0dc1\u0dc3\u0dd3\u0db8\u0dcf\u0dc0\u0da7 \u0d86\u0dc3\u0db1\u0dca\u0db1 \u0dba\u0dd0\u0dba\u0dd2 \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf\u0dba\u0dda \u0db7\u0dd6\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc3\u0db8\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0d86\u0dba\u0dad\u0db1\u0dba \u0dc3\u0db3\u0dc4\u0db1\u0dca \u0d9a\u0dc5\u0dda \u0dba.",
        "\u0dba\u0dd4\u0dbb\u0ddd\u0db4\u0dd3\u0dba - \u0db8\u0db0\u0dca\u200d\u0dba\u0db0\u0dbb\u0dab\u0dd3 \u0db7\u0dd6\u0d9a\u0db8\u0dca\u0db4\u0db1 \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0db7\u0dd6\u0db8\u0dd2\u0d9a\u0db8\u0dca\u0db4\u0dcf\u0dc0\u0dda \u0db4\u0dca\u200d\u0dbb\u0db6\u0dbd\u0dad\u0dca\u0dc0\u0dba \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dcf\u0d82\u0d9a 6.9\u0d9a\u0dca \u0dc0\u0dd6 \u0d85\u0dad\u0dbb \u0d87\u0db8\u0dd9\u0dbb\u0dd2\u0d9a\u0dcf \u0d91\u0d9a\u0dca\u0dc3\u0dad\u0dca \u0da2\u0db1\u0db4\u0daf \u0db7\u0dd6\u0dc0\u0dd2\u0daf\u0dca\u200d\u0dba\u0dcf \u0dc3\u0db8\u0dd3\u0d9a\u0dca\u0dc2\u0dab \u0db8\u0db0\u0dca\u200d\u0dba\u0dc3\u0dca\u0dae\u0dcf\u0db1\u0dba\u0da7 \u0d85\u0db1\u0dd4\u0dc0 \u0d91\u0dc4\u0dd2 \u0d9c\u0dab\u0db1\u0dba \u0d9a\u0dd2\u0dbb\u0dd3\u0db8 \u0dbb\u0dd2\u0d9a\u0dca\u0da7\u0dbb\u0dca \u0db8\u0dcf\u0db4\u0d9a\u0dcf\u0d82\u0d9a 5.9\u0d9a\u0dd2."
      ]
    },
    "ta": {
      "title": "\u0b86\u0baa\u0bcd\u0b95\u0bbe\u0ba9\u0bbf\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0bb2\u0bcd \u0b9a\u0b95\u0bcd\u0ba4\u0bbf\u0bb5\u0bbe\u0baf\u0bcd\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bae\u0bcd",
      "body_lines": [
        "\u0b86\u0baa\u0bcd\u0b95\u0bbe\u0ba9\u0bbf\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0bb2\u0bcd \u0b87\u0ba9\u0bcd\u0bb1\u0bc1 \u0baa\u0bbf\u0bb1\u0bcd\u0baa\u0b95\u0bb2\u0bcd \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b89\u0baf\u0bbf\u0bb0\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b8e\u0ba3\u0bcd\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc8 1000-\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bae\u0bbe\u0b95 \u0b89\u0baf\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0b95 \u0baa\u0bc7\u0bb0\u0bbf\u0b9f\u0bb0\u0bcd \u0bae\u0bc7\u0bb2\u0bbe\u0ba3\u0bcd\u0bae\u0bc8 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba9\u0bb0\u0bcd.",
        "\u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b9a\u0bbf\u0b95\u0bcd\u0b95\u0bbf \u0b89\u0baf\u0bbf\u0bb0\u0bbf\u0bb4\u0ba8\u0bcd\u0ba4\u0bb5\u0bb0\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b8e\u0ba3\u0bcd\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc8 600 \u0b86\u0b95 \u0b87\u0bb0\u0bc1\u0b95\u0bcd\u0b95\u0bc1\u0bae\u0bcd \u0b8e\u0ba9 \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0b95\u0bc2\u0bb1\u0bbf\u0baf\u0ba4\u0bc1\u0b9f\u0ba9\u0bcd, \u0baa\u0bb2\u0bbf \u0b8e\u0ba3\u0bcd\u0ba3\u0bbf\u0b95\u0bcd\u0b95\u0bc8 \u0bae\u0bc7\u0bb2\u0bc1\u0bae\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bb2\u0bbe\u0bae\u0bcd \u0b8e\u0ba9\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bbe\u0bb0\u0bbf\u0b95\u0bb3\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0ba9\u0bb0\u0bcd.",
        "\u0ba4\u0bc6\u0ba9\u0bcd\u0b95\u0bbf\u0bb4\u0b95\u0bcd\u0b95\u0bc1 \u0b86\u0baa\u0bcd\u0b95\u0bbe\u0ba9\u0bbf\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0bb2\u0bcd \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f \u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0bb0\u0bbf\u0b95\u0bcd\u0b9f\u0bb0\u0bcd \u0b85\u0bb3\u0bb5\u0bc1\u0b95\u0bcb\u0bb2\u0bbf\u0bb2\u0bcd 5.9 \u0b86\u0b95 \u0baa\u0ba4\u0bbf\u0bb5\u0bbe\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0bae\u0bb2\u0bc8 \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0ba4\u0bca\u0bb2\u0bc8\u0ba4\u0bc2\u0bb0 \u0b95\u0bbf\u0bb0\u0bbe\u0bae\u0b99\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0ba4\u0bbf\u0b95\u0bb3\u0bb5\u0bbf\u0bb2\u0bcd \u0baa\u0bbe\u0ba4\u0bbf\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0bb2\u0bcd, \u0ba4\u0b95\u0bb5\u0bb2\u0bcd \u0ba4\u0bbe\u0bae\u0ba4\u0bae\u0bbe\u0b95\u0bbf \u0bb5\u0bb0\u0bc1\u0b95\u0bbf\u0bb1\u0ba4\u0bc1.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0baa\u0b9a\u0bbf\u0baa\u0bbf\u0b95\u0bcd \u0baa\u0bc6\u0bb0\u0bc1\u0b99\u0bcd\u0b95\u0b9f\u0bb2\u0bbf\u0ba9\u0bcd \u0b85\u0b9f\u0bbf\u0baa\u0bcd\u0baa\u0b95\u0bc1\u0ba4\u0bbf\u0baf\u0bbf\u0bb2\u0bcd \u0baa\u0ba4\u0bbf\u0bb5\u0bbe\u0b95\u0bbf\u0baf\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd, \u0b9a\u0bc1\u0ba9\u0bbe\u0bae\u0bbf \u0b8e\u0b9a\u0bcd\u0b9a\u0bb0\u0bbf\u0b95\u0bcd\u0b95\u0bc8 \u0b8e\u0ba4\u0bc1\u0bb5\u0bc1\u0bae\u0bcd \u0bb5\u0bbf\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0baa\u0bcd\u0baa\u0b9f\u0bb5\u0bbf\u0bb2\u0bcd\u0bb2\u0bc8.",
        "\u0ba4\u0bc6\u0ba9\u0bcd\u0b95\u0bbf\u0bb4\u0b95\u0bcd\u0b95\u0bc1 \u0b86\u0baa\u0bcd\u0b95\u0bbe\u0ba9\u0bbf\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bbf\u0ba9\u0bcd \u0b95\u0bcb\u0bb8\u0bcd\u0b9f\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0bc1 44 \u0b95\u0bbf\u0bb2\u0bcb\u0bae\u0bc0\u0b9f\u0bcd\u0b9f\u0bb0\u0bcd \u0ba4\u0bca\u0bb2\u0bc8\u0bb5\u0bbf\u0bb2\u0bcd \u0b87\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0bae\u0bc8\u0baf\u0bae\u0bcd \u0b95\u0bca\u0ba3\u0bcd\u0b9f\u0bbf\u0bb0\u0bc1\u0ba8\u0bcd\u0ba4\u0ba4\u0bc1. \u0b87\u0ba4\u0bc1 \u0baa\u0bbe\u0b95\u0bbf\u0bb8\u0bcd\u0ba4\u0bbe\u0ba9\u0bcd \u0b8e\u0bb2\u0bcd\u0bb2\u0bc8\u0b95\u0bcd\u0b95\u0bc1 \u0b85\u0bb0\u0bc1\u0b95\u0bbf\u0bb2\u0bcd \u0b87\u0bb0\u0bc1\u0baa\u0bcd\u0baa\u0ba4\u0bbe\u0b95 \u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc1\u0bb5\u0bbf\u0baf\u0bbf\u0baf\u0bb2\u0bcd \u0b86\u0baf\u0bcd\u0bb5\u0bc1 \u0bae\u0bc8\u0baf\u0bae\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0ba4\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1.",
        "\u0b87\u0ba8\u0bcd\u0ba4 \u0ba8\u0bbf\u0bb2\u0ba8\u0b9f\u0bc1\u0b95\u0bcd\u0b95\u0bae\u0bcd \u0bb0\u0bbf\u0b95\u0bcd\u0b9f\u0bb0\u0bcd \u0b85\u0bb3\u0bb5\u0bc1\u0b95\u0bcb\u0bb2\u0bbf\u0bb2\u0bcd 6.9 \u0b86\u0b95\u0bb5\u0bc1\u0bae\u0bcd, \u0b85\u0bae\u0bc6\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0baa\u0bc1\u0bb5\u0bbf\u0baf\u0bbf\u0baf\u0bb2\u0bcd \u0b86\u0baf\u0bcd\u0bb5\u0bc1 \u0bae\u0bc8\u0baf\u0bae\u0bcd \u0bb0\u0bbf\u0b95\u0bcd\u0b9f\u0bb0\u0bcd \u0b85\u0bb3\u0bb5\u0bc1\u0b95\u0bcb\u0bb2\u0bbf\u0bb2\u0bcd 5.9 \u0b86\u0b95\u0bb5\u0bc1\u0bae\u0bcd \u0baa\u0ba4\u0bbf\u0bb5\u0bbe\u0b95\u0bbf\u0baf\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1."
      ]
    },
    "en": {
      "title": "A strong earthquake in Afghanistan",
      "body_lines": [
        "The death toll from an earthquake that struck Afghanistan this afternoon has risen to more than 1,000, disaster management officials said.",
        "The death toll from the quake is estimated at 600, officials said, adding that the death toll could rise further.",
        "The quake, which struck southeastern Afghanistan, had a magnitude of 5.9 on the Richter scale.",
        "The hilly and remote villages have been most affected and as a result information has been delayed.",
        "The epicenter was reported below the Pacific Ocean floor, however; no tsunami alert was issued.",
        "The epicenter was reported 44 kilometers south of the southeastern Afghan city of Kost. The US Geological Survey said it was close to the Pakistan border.",
        "The epicenter was reported below the epicenter, at 6.9 on the Richter scale, while the US Geological Survey measured 5.9 on the Richter scale."
      ]
    }
  }
}