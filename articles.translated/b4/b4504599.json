{
  "newspaper_id": "ada-lk",
  "url": "https://www.ada.lk/breaking_news/\u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca-\u0db8\u0dc3\u0dca-\u0dc4\u0dcf-\u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb-\u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8-\u0dc3\u0dd2\u0dba\u0dba\u0da7-\u0dc4\u0dd0\u0dad\u0dca\u0dad\u0dd1\u0dc0\u0d9a\u0dd2\u0db1\u0dca-\u0db4\u0dc4\u0dc5\u0da7/11-394693",
  "time_ut": 1655879129,
  "title": "\u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca \u0db8\u0dc3\u0dca \u0dc4\u0dcf \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8 \u0dc3\u0dd2\u0dba\u0dba\u0da7 \u0dc4\u0dd0\u0dad\u0dca\u0dad\u0dd1\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dc5\u0da7",
  "body_lines": [
    "\u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca\u00a0 \u0db8\u0dc3\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u00a0 \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca\u00a0 1300\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca\u00a0 \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd\u00a0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca\u00a0 50 \u0d9a\u0dca\u00a0 \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca\u00a0 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dbd\u00a0 \u0dba\u0dd1\u0db8\u0dad\u0dca\u00a0 \u0dc3\u0db8\u0d9c\u00a0 \u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9\u00a0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u00a0\u00a0 \u0d92\u0dc0\u0dcf\u00a0 \u0dc3\u0db3\u0dc4\u0dcf\u00a0 \u0d87\u0dad\u0dd2 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u00a0 \u0dc3\u0dd2\u0dba\u0dba\u0da7\u00a0\u00a0 \u0dc4\u0dd0\u0dad\u0dca\u0dad\u0dd1\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab\u00a0\u00a0 \u0db4\u0dc4\u0dad\u00a0 \u0db6\u0dd0\u0dc3\u00a0 \u0d87\u0dad\u0dd0\u0dba\u0dd2\u00a0\u00a0 \u0dc0\u0dd9\u0dbd\u0dd9\u0db3\u0dc3\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0dc3\u0daf\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dad\u0dd2.",
    "\u0d9a\u0dd4\u0d9a\u0dd4\u0dc5\u0dd4 \u0db8\u0dc3\u0dca\u00a0 \u0dc3\u0dc4 \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb\u0dba\u0d9a\u00a0 \u0db8\u0dd2\u0dbd\u00a0 \u0daf\u0dbb\u0dcf\u0d9c\u0dad\u00a0 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2\u00a0\u00a0 \u0dbd\u0dd9\u0dc3 \u0d89\u0dc4\u0dbd\u00a0 \u0dba\u0dd1\u0db8\u0dad\u0dca\u00a0 \u0dc3\u0db8\u0d9c\u00a0 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0da2\u0db1\u0dad\u0dcf\u0dc0\u00a0 \u0d92\u0dc0\u0dcf \u0db8\u0dd2\u0dbd\u0daf\u0dd2\u00a0 \u0d9c\u0dd0\u0db1\u0dd2\u0db8\u00a0\u00a0 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4\u00a0\u00a0 \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2\u00a0 \u0d94\u0dc0\u0dd4\u0dc4\u0dd4\u00a0 \u0d9a\u0dd2\u0dba\u0dad\u0dd2.",
    "\u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u00a0 \u0d86\u0dc4\u0dcf\u0dbb\u00a0\u00a0\u0db8\u0dd2\u0dbd \u0dc3\u0dc4 \u0d89\u0db1\u0dca\u0db0\u0db1\u00a0 \u0db8\u0dd2\u0dbd\u00a0\u00a0 \u0d85\u0db0\u0dd2\u0d9a\u00a0 \u0dbd\u0dd9\u0dc3\u00a0 \u0d89\u0dc4\u0dbd\u00a0 \u0dba\u0dd1\u0db8\u00a0 \u0dc3\u0db8\u0d9c\u00a0 \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u00a0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7\u00a0\u00a0\u0d91\u0db8\u00a0 \u0db7\u0dcf\u0dab\u0dca\u0da9\u00a0 \u0dc0\u0dbd \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dbd\u00a0 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7\u00a0 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u00a0 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u00a0 \u0db6\u0dc0\u0daf\u00a0\u00a0 \u0dc0\u0dd9\u0dbd\u0dd9\u0daf\u0dc3\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dad\u0dd2."
  ],
  "original_lang": "si",
  "translate": {
    "si": {
      "title": "\u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca \u0db8\u0dc3\u0dca \u0dc4\u0dcf \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8 \u0dc3\u0dd2\u0dba\u0dba\u0da7 \u0dc4\u0dd0\u0dad\u0dca\u0dad\u0dd1\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0dc4\u0dc5\u0da7",
      "body_lines": [
        "\u0d9a\u0dd4\u0d9a\u0dd4\u0dbd\u0dca\u00a0 \u0db8\u0dc3\u0dca \u0d9a\u0dd2\u0dbd\u0ddd\u0dc0\u0d9a\u00a0 \u0db8\u0dd2\u0dbd \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca\u00a0 1300\u0d9a\u0dca \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca\u00a0 \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb\u0dba\u0d9a \u0db8\u0dd2\u0dbd\u00a0 \u0dbb\u0dd4\u0db4\u0dd2\u0dba\u0dbd\u0dca\u00a0 50 \u0d9a\u0dca\u00a0 \u0daf\u0d9a\u0dca\u0dc0\u0dcf\u0dad\u0dca\u00a0 \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dbd\u00a0 \u0dba\u0dd1\u0db8\u0dad\u0dca\u00a0 \u0dc3\u0db8\u0d9c\u00a0 \u0db6\u0dbd\u0db1\u0dca\u0d9c\u0ddc\u0da9\u00a0 \u0db4\u0dca\u200d\u0dbb\u0daf\u0dda\u0dc1\u0dba\u0dda\u00a0\u00a0 \u0d92\u0dc0\u0dcf\u00a0 \u0dc3\u0db3\u0dc4\u0dcf\u00a0 \u0d87\u0dad\u0dd2 \u0d89\u0dbd\u0dca\u0dbd\u0dd4\u0db8\u00a0 \u0dc3\u0dd2\u0dba\u0dba\u0da7\u00a0\u00a0 \u0dc4\u0dd0\u0dad\u0dca\u0dad\u0dd1\u0dc0\u0d9a\u0dd2\u0db1\u0dca \u0db4\u0db8\u0dab\u00a0\u00a0 \u0db4\u0dc4\u0dad\u00a0 \u0db6\u0dd0\u0dc3\u00a0 \u0d87\u0dad\u0dd0\u0dba\u0dd2\u00a0\u00a0 \u0dc0\u0dd9\u0dbd\u0dd9\u0db3\u0dc3\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0dc3\u0daf\u0dc4\u0db1\u0dca \u0d9a\u0dbb\u0dad\u0dd2.",
        "\u0d9a\u0dd4\u0d9a\u0dd4\u0dc5\u0dd4 \u0db8\u0dc3\u0dca\u00a0 \u0dc3\u0dc4 \u0db6\u0dd2\u0dad\u0dca\u0dad\u0dbb\u0dba\u0d9a\u00a0 \u0db8\u0dd2\u0dbd\u00a0 \u0daf\u0dbb\u0dcf\u0d9c\u0dad\u00a0 \u0db1\u0ddc\u0dc4\u0dd0\u0d9a\u0dd2\u00a0\u00a0 \u0dbd\u0dd9\u0dc3 \u0d89\u0dc4\u0dbd\u00a0 \u0dba\u0dd1\u0db8\u0dad\u0dca\u00a0 \u0dc3\u0db8\u0d9c\u00a0 \u0db4\u0dcf\u0dbb\u0dd2\u0db7\u0ddd\u0d9c\u0dd2\u0d9a \u0da2\u0db1\u0dad\u0dcf\u0dc0\u00a0 \u0d92\u0dc0\u0dcf \u0db8\u0dd2\u0dbd\u0daf\u0dd2\u00a0 \u0d9c\u0dd0\u0db1\u0dd2\u0db8\u00a0\u00a0 \u0db4\u0dca\u200d\u0dbb\u0dad\u0dd2\u0d9a\u0dca\u0dc2\u0dda\u0db4\u00a0\u00a0 \u0d9a\u0dbb \u0d87\u0dad\u0dd0\u0dba\u0dd2\u00a0 \u0d94\u0dc0\u0dd4\u0dc4\u0dd4\u00a0 \u0d9a\u0dd2\u0dba\u0dad\u0dd2.",
        "\u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u00a0 \u0d86\u0dc4\u0dcf\u0dbb\u00a0\u00a0\u0db8\u0dd2\u0dbd \u0dc3\u0dc4 \u0d89\u0db1\u0dca\u0db0\u0db1\u00a0 \u0db8\u0dd2\u0dbd\u00a0\u00a0 \u0d85\u0db0\u0dd2\u0d9a\u00a0 \u0dbd\u0dd9\u0dc3\u00a0 \u0d89\u0dc4\u0dbd\u00a0 \u0dba\u0dd1\u0db8\u00a0 \u0dc3\u0db8\u0d9c\u00a0 \u0dc3\u0dad\u0dca\u0dad\u0dca\u0dc0\u00a0 \u0db1\u0dd2\u0dc2\u0dca\u0db4\u0dcf\u0daf\u0d9a\u0dba\u0dd2\u0db1\u0dca\u0da7\u00a0\u00a0\u0d91\u0db8\u00a0 \u0db7\u0dcf\u0dab\u0dca\u0da9\u00a0 \u0dc0\u0dbd \u0db8\u0dd2\u0dbd \u0d89\u0dc4\u0dbd\u00a0 \u0daf\u0dd0\u0db8\u0dd3\u0db8\u0da7\u00a0 \u0dc3\u0dd2\u0daf\u0dd4\u0dc0\u00a0 \u0dad\u0dd2\u0db6\u0dd9\u0db1\u00a0 \u0db6\u0dc0\u0daf\u00a0\u00a0 \u0dc0\u0dd9\u0dbd\u0dd9\u0daf\u0dc3\u0dbd\u0dca \u0dc4\u0dd2\u0db8\u0dd2\u0dba\u0ddd \u0db4\u0dd9\u0db1\u0dca\u0dc0\u0dcf \u0daf\u0dd9\u0dad\u0dd2."
      ]
    },
    "ta": {
      "title": "\u0b95\u0bcb\u0bb4\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0b9f\u0bcd\u0b9f\u0bc8\u0b95\u0bcd\u0b95\u0bbe\u0ba9 \u0ba4\u0bc7\u0bb5\u0bc8 70 \u0b9a\u0ba4\u0bb5\u0bc0\u0ba4\u0bae\u0bcd \u0b95\u0bc1\u0bb1\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bc1",
      "body_lines": [
        "\u0b92\u0bb0\u0bc1 \u0b95\u0bbf\u0bb2\u0bcb \u0b95\u0bcb\u0bb4\u0bbf\u0b95\u0bcd\u0b95\u0bb1\u0bbf\u0baf\u0bbf\u0ba9\u0bcd \u0bb5\u0bbf\u0bb2\u0bc8 1300 \u0bb0\u0bc2\u0baa\u0bbe\u0bb5\u0bbe\u0b95\u0bb5\u0bc1\u0bae\u0bcd, \u0bae\u0bc1\u0b9f\u0bcd\u0b9f\u0bc8\u0baf\u0bbf\u0ba9\u0bcd \u0bb5\u0bbf\u0bb2\u0bc8 50 \u0bb0\u0bc2\u0baa\u0bbe\u0bb5\u0bbe\u0b95\u0bb5\u0bc1\u0bae\u0bcd \u0b89\u0baf\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3 \u0ba8\u0bbf\u0bb2\u0bc8\u0baf\u0bbf\u0bb2\u0bcd, \u0baa\u0bb2\u0bbe\u0b99\u0bcd\u0b95\u0bca\u0b9f\u0bc8 \u0baa\u0bbf\u0bb0\u0ba4\u0bc7\u0b9a\u0ba4\u0bcd\u0ba4\u0bbf\u0bb2\u0bcd \u0b87\u0bb5\u0bb1\u0bcd\u0bb1\u0bbf\u0ba9\u0bcd \u0ba4\u0bc7\u0bb5\u0bc8 \u0b9a\u0bc1\u0bae\u0bbe\u0bb0\u0bcd 70 \u0bb5\u0bc0\u0ba4\u0ba4\u0bcd\u0ba4\u0bbe\u0bb2\u0bcd \u0b95\u0bc1\u0bb1\u0bc8\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0b95 \u0b95\u0b9f\u0bc8 \u0b89\u0bb0\u0bbf\u0bae\u0bc8\u0baf\u0bbe\u0bb3\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0ba4\u0bc6\u0bb0\u0bbf\u0bb5\u0bbf\u0b95\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd.",
        "\u0b95\u0bcb\u0bb4\u0bbf\u0b95\u0bcd\u0b95\u0bb1\u0bbf \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0bae\u0bc1\u0b9f\u0bcd\u0b9f\u0bc8 \u0bb5\u0bbf\u0bb2\u0bc8 \u0b95\u0bbf\u0b9f\u0bc1\u0b95\u0bbf\u0b9f\u0bc1\u0bb5\u0bc6\u0ba9 \u0b89\u0baf\u0bb0\u0bcd\u0ba8\u0bcd\u0ba4\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0bb2\u0bcd, \u0ba8\u0bc1\u0b95\u0bb0\u0bcd\u0bb5\u0bcb\u0bb0\u0bcd \u0bb5\u0bbe\u0b99\u0bcd\u0b95 \u0bae\u0bb1\u0bc1\u0ba4\u0bcd\u0ba4\u0bc1\u0bb5\u0bbf\u0b9f\u0bcd\u0b9f\u0ba9\u0bb0\u0bcd \u0b8e\u0ba9\u0bcd\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd.",
        "\u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8\u0ba4\u0bcd \u0ba4\u0bc0\u0bb5\u0ba9\u0bae\u0bcd \u0bae\u0bb1\u0bcd\u0bb1\u0bc1\u0bae\u0bcd \u0b8e\u0bb0\u0bbf\u0baa\u0bca\u0bb0\u0bc1\u0bb3\u0bbf\u0ba9\u0bcd \u0bb5\u0bbf\u0bb2\u0bc8 \u0b85\u0ba4\u0bbf\u0b95\u0bb0\u0bbf\u0baa\u0bcd\u0baa\u0bc1\u0b9f\u0ba9\u0bcd, \u0b95\u0bbe\u0bb2\u0bcd\u0ba8\u0b9f\u0bc8\u0baa\u0bcd \u0baa\u0bca\u0bb0\u0bc1\u0b9f\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0b89\u0bb1\u0bcd\u0baa\u0ba4\u0bcd\u0ba4\u0bbf\u0baf\u0bbe\u0bb3\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b85\u0ba8\u0bcd\u0ba4\u0baa\u0bcd \u0baa\u0bca\u0bb0\u0bc1\u0b9f\u0bcd\u0b95\u0bb3\u0bbf\u0ba9\u0bcd \u0bb5\u0bbf\u0bb2\u0bc8\u0baf\u0bc8 \u0b85\u0ba4\u0bbf\u0b95\u0bb0\u0bbf\u0b95\u0bcd\u0b95 \u0bb5\u0bc7\u0ba3\u0bcd\u0b9f\u0bbf\u0baf \u0ba8\u0bbf\u0bb2\u0bc8 \u0b8f\u0bb1\u0bcd\u0baa\u0b9f\u0bcd\u0b9f\u0bc1\u0bb3\u0bcd\u0bb3\u0ba4\u0bbe\u0b95\u0bb5\u0bc1\u0bae\u0bcd \u0b95\u0b9f\u0bc8 \u0b89\u0bb0\u0bbf\u0bae\u0bc8\u0baf\u0bbe\u0bb3\u0bb0\u0bcd\u0b95\u0bb3\u0bcd \u0b9a\u0bc1\u0b9f\u0bcd\u0b9f\u0bbf\u0b95\u0bcd\u0b95\u0bbe\u0b9f\u0bcd\u0b9f\u0bc1\u0b95\u0bbf\u0ba9\u0bcd\u0bb1\u0ba9\u0bb0\u0bcd."
      ]
    },
    "en": {
      "title": "Demand for chicken and eggs fell by 70 percent",
      "body_lines": [
        "With the price of a kilo of chicken going up to Rs. 1300 and the price of an egg going up to Rs. 50, the demand for them in the Balangoda area has dropped by about 70 percent, say shop owners.",
        "They say consumers have refused to buy chicken and eggs as prices have skyrocketed.",
        "The shop owners also point out that with the increase in the prices of animal feed and fuel, the producers of animal products have had to increase the prices of those products."
      ]
    }
  }
}