    "si": {
      "title": "\u0d8a\u0dc5\u0dcf\u0db8\u0dca \u0dc3\u0dbb\u0dab\u0dcf\u0d9c\u0dad\u0dba\u0dd9\u0d9a\u0dd4\u0da7 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0dd0\u0db6\u0dd3\u0db8\u0da7 \u0dad\u0dd0\u0dad\u0dca \u0d9a\u0dd2\u0dbb\u0dd3\u0db8",
      "author": "",
      "body_lines": [
        "\u0d8a\u0dc5\u0dcf\u0db8\u0dca \u0dc3\u0dbb\u0dab\u0dcf\u0d9c\u0dad\u0dba\u0dd2\u0db1\u0dca \u0dad\u0db8\u0db1\u0dca \u0db1\u0dd2\u0daf\u0dc4\u0dc3\u0dca \u0d9a\u0dbb\u0db1 \u0dbd\u0dd9\u0dc3 \u0d89\u0dbd\u0dca\u0dbd\u0dcf \u0da7\u0dd2\u200d\u0dca\u200d\u0dbb\u0da0\u0dd2 \u0dc4\u0dd2 \u0dc0\u0dd2\u0dc1\u0dda\u0dc2 \u0d9a\u0db3\u0dc0\u0dd4\u0dbb\u0d9a \u0daf\u0dd2\u0db1 34\u0d9a\u0dca \u0dad\u0dd2\u0dc3\u0dca\u0dc3\u0dda \u0d8b\u0db4\u0dc0\u0dcf\u0dc3\u0dba\u0d9a \u0db1\u0dd2\u0dbb\u0dad\u0dc0 \u0dc3\u0dd2\u0da7\u0dd2\u0dad\u0dd2.",
        "\u0db8\u0dda \u0dad\u0dad\u0dca\u0dad\u0dca\u0dc0\u0dba \u0dad\u0dd4\u0dc5 \u0d8b\u0db8\u0dcf \u0dbb\u0db8\u0db1\u0db1\u0dca \u0db1\u0db8\u0dd0\u0dad\u0dd2 \u0dc3\u0dbb\u0dab\u0dcf\u0d9c\u0dad\u0dba\u0dcf \u0d8a\u0dba\u0dda (24) \u0dc3\u0dd2\u0dbb\u0dd4\u0dbb\u0da7 \u0d9c\u0dd2\u0db1\u0dd2 \u0dad\u0db6\u0dcf\u0d9c\u0dd9\u0db1 \u0dc3\u0dd2\u0dba\u0daf\u0dd2\u0dc0\u0dd2 \u0dc4\u0dcf\u0db1\u0dd2\u0d9a\u0dbb \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0da7 \u0d8b\u0dad\u0dca\u0dc3\u0dcf\u0dc4 \u0d9a\u0dbb \u0d87\u0dad. \u0d9a\u0dd9\u0dc3\u0dda \u0dc0\u0dd9\u0dad\u0dad\u0dca, \u0d94\u0dc4\u0dd4 \u0dc3\u0dd2\u0dba\u0dbd\u0dd4 \u0dc3\u0dbb\u0dab\u0dcf\u0d9c\u0dad\u0dba\u0dd2\u0db1\u0dca \u0dc0\u0dd2\u0dc3\u0dd2\u0db1\u0dca \u0db6\u0dda\u0dbb\u0dcf \u0d9c\u0db1\u0dd4 \u0dbd\u0dd0\u0db6\u0dda."
