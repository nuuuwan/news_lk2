          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb \u0da2\u0db1 \u0db6\u0dbd\u0db8\u0dd4\u0d9b",
            "label": "ORG"
          },
          {
            "text": "\u0d85\u0db1\u0dd4\u0dbb \u0d9a\u0dd4\u0db8\u0dcf\u0dbb \u0daf\u0dd2\u0dc3\u0dcf\u0db1\u0dcf\u0dba\u0d9a",
